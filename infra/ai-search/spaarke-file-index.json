    { "// searchable=true": "text-content field (file name) used for full-text query", "name": "fileName",            "type": "Edm.String",                "key": false, "retrievable": true,  "filterable": true,  "searchable": true,  "sortable": true,  "facetable": true,  "analyzer": "standard.lucene" },
