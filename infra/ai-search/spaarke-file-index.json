    { "// override-facetable": "datetime faceting is rarely useful (per catalog policy table)", "name": "updatedAt",           "type": "Edm.DateTimeOffset",        "key": false, "retrievable": true,  "filterable": true,  "searchable": false, "sortable": true,  "facetable": false },
    { "// searchable=true": "parent entity type may be queried by name in semantic/full-text scenarios", "name": "parentEntityType",    "type": "Edm.String",                "key": false, "retrievable": true,  "filterable": true,  "searchable": true,  "sortable": true,  "facetable": true  },
    { "name": "parentEntityId",      "type": "Edm.String",                "key": false, "retrievable": true,  "filterable": true,  "searchable": false, "sortable": true,  "facetable": true  },
    { "// searchable=true": "parent entity display name acceptable for full-text query", "name": "parentEntityname",    "type": "Edm.String",                "key": false, "retrievable": true,  "filterable": true,  "searchable": true,  "sortable": true,  "facetable": true  },
    { "// override-sortable": "Collection(Edm.String): Azure forbids sortable on collections", "name": "privilege_group_ids", "type": "Collection(Edm.String)",    "key": false, "retrievable": true,  "filterable": true,  "searchable": false, "sortable": false, "facetable": true  },
    { "name": "containerId",         "type": "Edm.String",                "key": false, "retrievable": true,  "filterable": true,  "searchable": false, "sortable": true,  "facetable": true  },
    { "// override-facetable": "datetime faceting is rarely useful (per catalog policy table)", "name": "lastModified",        "type": "Edm.DateTimeOffset",        "key": false, "retrievable": true,  "filterable": true,  "searchable": false, "sortable": true,  "facetable": false },
    { "name": "sourceSystem",        "type": "Edm.String",                "key": false, "retrievable": true,  "filterable": true,  "searchable": false, "sortable": true,  "facetable": true  }
