    { "// searchable=true": "long-form content text used for full-text query; sortable/facetable=false: long-text fields cannot be sort/facet keys", "name": "content",             "type": "Edm.String",                "key": false, "retrievable": true,  "filterable": false, "searchable": true,  "sortable": false, "facetable": false, "analyzer": "standard.lucene" },
    { "// vector-field": "3072-dim HNSW cosine; retrievable=false (vector payload is heavy, excluded from $select); stored=true retains for reranking; searchable=true enables vector search", "name": "contentVector3072",   "type": "Collection(Edm.Single)",    "key": false, "retrievable": false, "stored": true,  "filterable": false, "searchable": true,  "sortable": false, "facetable": false, "dimensions": 3072, "vectorSearchProfile": "knowledge-vector-profile-3072" },
    { "// vector-field": "3072-dim HNSW cosine; retrievable=false (vector payload is heavy, excluded from $select); stored=true retains for reranking; searchable=true enables vector search", "name": "documentVector3072",  "type": "Collection(Edm.Single)",    "key": false, "retrievable": false, "stored": true,  "filterable": false, "searchable": true,  "sortable": false, "facetable": false, "dimensions": 3072, "vectorSearchProfile": "knowledge-vector-profile-3072" },
    { "// override-filter-sort-facet": "opaque JSON metadata blob — not meaningful to filter/sort/facet; retrievable for client-side parsing", "name": "metadata",            "type": "Edm.String",                "key": false, "retrievable": true,  "filterable": false, "searchable": false, "sortable": false, "facetable": false },
