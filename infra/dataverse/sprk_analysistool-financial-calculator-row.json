  "_comment_consumption": "Read by scripts/Seed-TypedHandlers.ps1. Idempotent — script queries by sprk_toolcode first; UPSERTs.",
  "sprk_name": "SYS-Financial Calculator",
  "sprk_toolcode": "FIN-CALC@v1",
  "sprk_description": "Pure deterministic financial math: sum, tax, discount, FX conversion (configured rate table), weighted average, and aggregation by category. All money math uses decimal; mixed-currency operations are rejected. NO LLM call.",
  "sprk_handlerclass": "FinancialCalculatorHandler",
  "sprk_availableincontexts_value": 100000000,
  "_comment_availableincontexts": "100000000 = Playbook (this handler is invoked from Playbook nodes after upstream extraction; no chat-direct invocation in R6).",
  "sprk_jsonschema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "FinancialCalculatorHandler Request",
    "type": "object",
    "required": ["operation"],
    "properties": {
      "operation": {
        "type": "string",
        "enum": ["Sum", "Tax", "Discount", "FxConvert", "WeightedAvg", "AggregateByCategory"]
      },
      "operands": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["amount", "currency"],
          "properties": {
            "amount":   { "type": "number" },
            "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
            "category": { "type": "string" },
            "weight":   { "type": "number", "minimum": 0 }
          }
        }
      },
      "rate":   { "type": "number" },
      "amount": {
        "type": "object",
        "required": ["amount", "currency"],
        "properties": {
          "amount":   { "type": "number" },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3 }
        }
      },
      "targetCurrency": { "type": "string", "minLength": 3, "maxLength": 3 },
      "config": {
        "type": "object",
        "properties": {
          "supportedCurrencies":  { "type": "array", "items": { "type": "string" } },
          "fxRateTable":          { "type": "object", "additionalProperties": { "type": "number" } },
          "defaultRoundingMode":  { "type": "string", "enum": ["BankersRounding", "MidpointAwayFromZero"] },
          "decimalPrecision":     { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "sprk_configuration": {
    "operation": "Sum",
    "operands": [],
    "config": {
      "supportedCurrencies": ["USD", "EUR", "GBP", "JPY", "CAD"],
      "fxRateTable": {
