# Access Level Enforcement Tests (Task 072)
# Used by: tests/e2e/specs/secure-project/access-level-enforcement.spec.ts
#
# Three test Contact records must exist in Dataverse with active
# sprk_externalrecordaccess rows for TEST_PROJECT_ID at each access level.
# Portal JWT tokens can be obtained via:
#   - Power Pages portal login flow (manual browser extraction)
#   - Entra External ID token endpoint (for test accounts with known credentials)
#
# AccessLevel option set values:
#   ViewOnly    = 100000000
#   Collaborate = 100000001
#   FullAccess  = 100000002

# View Only test user (sprk_accesslevel = 100000000)
VIEW_ONLY_USER_EMAIL=viewonly@external-test.example.com
VIEW_ONLY_TOKEN=

# Collaborate test user (sprk_accesslevel = 100000001)
COLLABORATE_USER_EMAIL=collaborate@external-test.example.com
COLLABORATE_TOKEN=

# Full Access test user (sprk_accesslevel = 100000002)
FULL_ACCESS_USER_EMAIL=fullaccess@external-test.example.com
FULL_ACCESS_TOKEN=

# A document ID linked to TEST_PROJECT_ID (for server-side download tests)
# Use any sprk_document record GUID from the project
TEST_DOCUMENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
