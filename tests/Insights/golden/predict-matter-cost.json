{
  "$schema": "./predict-matter-cost.schema.json",
  "$comment": "Phase 1 golden dataset for the predict-matter-cost synthesis playbook (D-P14). Drives both the in-process eval harness (tests/unit/Sprk.Bff.Api.Tests/Eval/PredictMatterCostEvalHarnessTests.cs) and the live-environment runbook (notes/phase-1-live-smoke-runbook.md). Permissive Phase 1 thresholds: groundedness >= 95% (not 100%), no insufficient miscalls beyond 1/15 (~7% tolerance), LLM-as-judge true Relevance deferred to Phase 1.5 (Phase 1 uses mechanical band-overlap proxy).",
  "version": "1.0.0",
  "playbook": "predict-matter-cost",
  "phase": "Phase 1",
  "thresholds": {
    "groundednessPassRateMin": 0.95,
    "declineCorrectnessMin": 0.93,
    "bandOverlapMin": 0.80,
    "cohortSizeToleranceCount": 1
  },
