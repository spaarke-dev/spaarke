        "lookBackYears": "3"
      },
      "fixtureDocumentId": "doc-fixture-001-closing-letter",
      "mocked": {
        "cohortSize": 15,
        "precedentApplied": false,
        "expectedFacadeResultKind": "artifact"
      },
      "expected": {
        "responseKind": "artifact",
        "subject": "matter:M-FIXTURE-001",
        "predicate": "predictedCost",
        "p50CostBand": { "min": 220000, "max": 320000 },
