<task id="010" project="spaarke-environment-provisioning-app">
  <metadata>
    <title>Create DataverseEnvironmentRecord DTO</title>
    <phase>2</phase>
    <tags>bff-api, model</tags>
    <estimate>30m</estimate>
    <status>pending</status>
    <dependencies>none</dependencies>
    <parallel-safe>true</parallel-safe>
