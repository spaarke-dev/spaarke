<task id="081" project="sdap.bff.api-test-suite-repair-r2">
  <metadata>
    <title>P5.2 — CONDITIONAL: extend `.claude/constraints/bff-extensions.md` § F with unconditional-service-registration rule (main-session-only)</title>
    <phase>Phase 5</phase>
    <status>not-started</status>
    <estimated-effort>45-90 minutes</estimated-effort>
    <dependencies>011,080</dependencies>
