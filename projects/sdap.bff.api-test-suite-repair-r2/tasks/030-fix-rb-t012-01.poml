<task id="030" project="sdap.bff.api-test-suite-repair-r2">
  <metadata>
    <title>P3 — Fix RB-T012-01: SessionRestoreService NormaliseETag + ExtractODataETag quote handling</title>
    <phase>Phase 3: LOW Severity + Integration Stability</phase>
    <status>not-started</status>
    <estimated-effort>1-2 hours</estimated-effort>
