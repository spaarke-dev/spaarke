<task id="022" project="sdap.bff.api-test-suite-repair-r2">
  <metadata>
    <title>P2.W1 — Fix RB-T053-01: CapabilityRouter Layer-1 classifier false-positives (owner decision required)</title>
    <phase>Phase 2</phase>
    <status>not-started</status>
    <estimated-effort>2-6 hours (depends on chosen fix option)</estimated-effort>
