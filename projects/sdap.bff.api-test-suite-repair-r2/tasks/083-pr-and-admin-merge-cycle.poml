<task id="083" project="sdap.bff.api-test-suite-repair-r2">
  <metadata>
    <title>P5.4 — PR + admin-merge cycle (mirrors r1 close); merge to master ≤ 2026-08-31</title>
    <phase>Phase 5</phase>
    <status>not-started</status>
    <estimated-effort>1-2 hours</estimated-effort>
    <dependencies>082</dependencies>
    <blocks>090</blocks>
    <tags>phase-5, deploy, governance, merge, admin-merge</tags>
    <rigor-hint>STANDARD</rigor-hint>
    <rigor-reason>Process task: PR creation + admin-merge window + git ops. Minimal code change beyond git mechanics (potentially toggling `enforce_admins` via `gh api`). STANDARD per CLAUDE.md §8.</rigor-reason>
    <parallel-group>P5-final</parallel-group>
    <parallel-safe>false</parallel-safe>
    <parallel-reason>Merge gate; runs after task 082 produces green triple-run validation. Sequential by definition — cannot parallelize a PR-creation-and-merge step with anything else.</parallel-reason>
    <production-fix-per-ledger>false</production-fix-per-ledger>
    <repair-not-rewrite>false</repair-not-rewrite>
