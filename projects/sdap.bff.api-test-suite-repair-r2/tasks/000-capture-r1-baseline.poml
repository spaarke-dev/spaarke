    <criterion testable="true">Commit message references NFR-06</criterion>
    <criterion testable="true">No files modified under `src/`, `power-platform/`, `infra/`, `scripts/`, `tests/` — `git status` shows only `projects/sdap.bff.api-test-suite-repair-r2/` paths</criterion>
  </acceptance-criteria>

