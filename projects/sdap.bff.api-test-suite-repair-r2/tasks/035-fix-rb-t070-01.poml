    <file>projects/sdap-bff.api-test-suite-repair/ledgers/real-bug-ledger.md</file>
  </relevant-files>

  <steps>
    <step order="1">Load r1 ledger entry RB-T070-01 (lines ~495-520) for documented bug + recommended fix.</step>
