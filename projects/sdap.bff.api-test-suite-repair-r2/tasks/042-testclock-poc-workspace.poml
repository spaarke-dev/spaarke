    <file purpose="target-src-surface">src/server/api/Sprk.Bff.Api/Services/Workspace/</file>
    <file purpose="target-test-surface">tests/unit/Sprk.Bff.Api.Tests/Services/Workspace/</file>
    <file purpose="reference-test-timeprovider-1">tests/unit/Sprk.Bff.Api.Tests/Services/Insights/Precedents/PrecedentProjectionSyncTests.cs</file>
