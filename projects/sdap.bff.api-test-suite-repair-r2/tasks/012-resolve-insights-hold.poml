  </outputs>

  <acceptance-criteria>
    <criterion testable="true">RB-T028-02 ledger entry Status transitions to one of: `repaired` / `transferred-to-sibling` / `archived-pending-sibling-engagement`</criterion>
    <criterion testable="true">3 tests in `Layer2OutcomeExtractionTests.cs` per-test trait updated to match chosen path</criterion>
    <criterion testable="true">If path-b: build passes; 3 tests now Pass; per-fix triple-run shows Failed: 0 across 3 runs</criterion>
    <criterion testable="true">If path-a: sibling tracking ID captured in commit + ledger entry cross-reference</criterion>
    <criterion testable="true">If path-c: D-07 confirms 1-week window expiry; rationale in ledger entry</criterion>
