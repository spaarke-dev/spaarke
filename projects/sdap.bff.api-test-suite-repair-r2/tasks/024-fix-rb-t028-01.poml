<task id="024" project="sdap.bff.api-test-suite-repair-r2">
  <metadata>
    <title>P2.W2 — Fix RB-T028-01: AnalysisContextBuilder.BuildContinuationPrompt non-deterministic sort tiebreak</title>
    <phase>Phase 2</phase>
    <status>not-started</status>
    <estimated-effort>1-2 hours</estimated-effort>
    <dependencies>013,023</dependencies>
