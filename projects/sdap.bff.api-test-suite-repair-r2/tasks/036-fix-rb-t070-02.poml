<task id="036" project="sdap.bff.api-test-suite-repair-r2">
  <metadata>
    <title>P3 — Fix RB-T070-02: R2SseEventEmitter.CapabilityChangePayload omit RetryAfterSeconds when null</title>
    <phase>Phase 3: LOW Severity + Integration Stability</phase>
    <status>not-started</status>
    <estimated-effort>30-45 minutes</estimated-effort>
    <dependencies>029</dependencies>
    <blocks>038</blocks>
    <tags>phase-3, bff-api, real-bug-ledger, low-severity, production-fix, sse, serialization</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Production code modification in src/server/api/Sprk.Bff.Api/Api/Ai/; FULL rigor required for .cs changes (code-review + adr-check at Step 9.5).</rigor-reason>
    <parallel-group>P3-W1</parallel-group>
    <parallel-safe>true</parallel-safe>
