<task id="095" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>POST /api/memory/promotions/{id}/reject endpoint</title>
    <phase>4: WP5 6-Tier Memory Subsystem (sub-WP 4e)</phase>
    <status>not-started</status>
