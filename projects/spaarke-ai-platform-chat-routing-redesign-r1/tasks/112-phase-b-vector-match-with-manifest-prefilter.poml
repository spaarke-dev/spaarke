<task id="112" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>Phase B — vector match with manifest documentType pre-filter (Hybrid C primary)</title>
    <phase>5: WP2 File-Aware Classification</phase>
    <status>not-started</status>
    <estimated-hours>5</estimated-hours>
    <dependencies>111</dependencies>
    <blocks>113</blocks>
    <tags>bff-api, services, ai, azure-openai, azure-search</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Tags include 'bff-api' + 'ai' + 'azure-openai'; modifies `PlaybookDispatcher.cs`; performance budget binding (FR-17); FULL per task-execute Step 0.5.</rigor-reason>
    <parallel-group>5-B</parallel-group>
    <parallel-safe>false</parallel-safe>
