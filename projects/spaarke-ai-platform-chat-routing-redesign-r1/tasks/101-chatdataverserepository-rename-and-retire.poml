<task id="101" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>ChatDataverseRepository → IChatAuditRepository rename + retire placeholder methods (FR-25)</title>
    <phase>4: WP5 6-Tier Memory Subsystem (sub-WP 4f)</phase>
    <status>not-started</status>
    <estimated-hours>4</estimated-hours>
    <dependencies>100</dependencies>
