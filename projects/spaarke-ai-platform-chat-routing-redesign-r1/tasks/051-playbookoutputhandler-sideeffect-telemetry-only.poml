    <criterion testable="true">No SSE event emitted for SideEffect dispatch.</criterion>
    <criterion testable="true">No chat token emitted for SideEffect dispatch.</criterion>
    <criterion testable="true">ADR-015 tier-1 safety verified by test (no `userMessage` / `fileContent` in telemetry payload).</criterion>
    <criterion testable="true">`dotnet build` + tests exit 0.</criterion>
