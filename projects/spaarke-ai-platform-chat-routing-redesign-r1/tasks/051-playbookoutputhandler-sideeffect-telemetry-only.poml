      <file>.claude/adr/ADR-029-bff-publish-hygiene.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Read `PlaybookOutputHandler.cs` switch.</step>
    <step order="2">Add `SideEffect` case branch:
      (a) Emit structured telemetry event "playbook.side_effect_dispatched" with tier-1 safe fields `{playbookId, playbookName, tenantId, durationMs}`;
      (b) Explicitly return without emitting SSE or chat tokens.</step>
    <step order="3">Add unit test:
      (a) Invoke handler with `NodeDestination = SideEffect`;
      (b) Assert no SSE event captured + no chat token emitted;
      (c) Assert telemetry event captured with the expected tier-1 safe fields ONLY.</step>
    <step order="4">Verify ADR-015 compliance: grep test for absence of `userMessage` / `fileContent` / `userPrompt` in telemetry call.</step>
    <step order="5">Run `dotnet build` + tests; measure publish delta.</step>
    <step order="6">Update TASK-INDEX.md: task 051 → ✅.</step>
  </steps>

  <tools>
    <tool name="Read">PlaybookOutputHandler.cs + Telemetry directory</tool>
    <tool name="Edit">Add SideEffect case + test</tool>
    <tool name="Bash">dotnet build / test / publish</tool>
  </tools>

  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Ai/Chat/PlaybookOutputHandler.cs — SideEffect telemetry-only case</output>
    <output type="test">tests/unit/Sprk.Bff.Api.Tests/Services/Ai/Chat/PlaybookOutputHandlerSideEffectTests.cs</output>
