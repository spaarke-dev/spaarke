<task id="124" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>Bind Persona in Path 3 via IScopeResolverService.ResolvePersonaForChatAsync</title>
    <phase>6: WP6 Specialized Playbooks + Path 3</phase>
    <status>not-started</status>
    <estimated-hours>3</estimated-hours>
    <dependencies>123</dependencies>
    <blocks>132</blocks>
    <tags>bff-api, services, ai, ADR-033</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Modifies hot-path chat-summarize engine (.cs); persona binding affects every Path 3 turn; FULL per task-execute Step 0.5</rigor-reason>
    <parallel-group>6-D</parallel-group>
    <parallel-safe>true</parallel-safe>
