<task id="122" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>Extend PlaybookExecutionEngine.ExecuteChatSummarizeAsync (Path 3) with JpsRefResolver BEFORE LLM call</title>
    <phase>6: WP6 Specialized Playbooks + Path 3</phase>
    <status>not-started</status>
    <estimated-hours>5</estimated-hours>
    <dependencies>121</dependencies>
    <blocks>123,124,125,130</blocks>
