<task id="067" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>FileClassificationService — gpt-4o-mini documentType + confidence (NEW)</title>
    <phase>4: WP5 6-Tier Memory Subsystem (sub-WP 4b)</phase>
