      <file>docs/procedures/testing-and-code-quality.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Read peer integration test for style (`tests/integration/Sprk.Bff.Api.IntegrationTests/...Tests.cs`).</step>
    <step order="2">Author `UploadPipelineIntegrationTests.cs`:
      - Fixture: WebApplicationFactory with mocked `IOpenAiClient` returning deterministic results in ~200ms
      - Synthetic 50-page input: ~150K chars text content
      - POST to upload endpoint
      - Assert response shape: `{ fileId, summary, docType, confidence }`
      - Read back from session persistence; assert enriched fields populated
      - Capture logs; assert no tier-1-banned content</step>
    <step order="3">Latency assertion: total &lt; 4000ms (with mocked LLM latency = 250ms each, parallel paths complete &lt; 2s; add headroom).</step>
    <step order="4">Add second test case: small file (1 page) — assert &lt;1s total.</step>
    <step order="5">Run `dotnet test tests/integration/Sprk.Bff.Api.IntegrationTests/UploadPipeline/`.</step>
    <step order="6">code-review (Step 9.5).</step>
    <step order="7">Update TASK-INDEX.md: 073 → ✅.</step>
  </steps>

  <tools>
    <tool name="Read">Peer integration tests + ChatDocumentEndpoints</tool>
    <tool name="Write">UploadPipelineIntegrationTests.cs</tool>
    <tool name="Bash">dotnet test</tool>
  </tools>

