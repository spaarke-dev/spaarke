  </context>

  <constraints>
    <constraint source="ADR-010">DI minimalism — inject `IFileClassificationService`, `IFileSummarizationService`, `IFileManifestExtractor` via concrete-typed constructor parameters. NO `IServiceProvider.GetService&lt;T&gt;()`.</constraint>
    <constraint source="ADR-013">Service lives in `Services/Ai/Sessions/` — within the AI module. CRUD code consuming this orchestrator MUST go through `Services/Ai/PublicContracts/` facade (out of scope here — orchestrator is INSIDE the AI module).</constraint>
    <constraint source="ADR-015">Tier-1 logging: log fileId, sessionId, durationMs ONLY. NEVER log textContent, summary text, classification result.</constraint>
    <constraint source="ADR-029">Per-task publish-size measurement; report delta. New service should add &lt;0.5 MB.</constraint>
    <constraint source="architecture §6.1">Parallel paths: classification + summarization + manifest extraction MUST run via `Task.WhenAll` (architecture target: total ≤4s for 50-page PDF).</constraint>
    <constraint source="project">Test update obligation per CLAUDE.md §10 — author unit test stub in `tests/unit/Sprk.Bff.Api.Tests/Services/Ai/Sessions/` for orchestration logic.</constraint>
    <constraint source="bff-extensions.md">Placement justification: lives in `Services/Ai/Sessions/` because it composes session-level state. State this rationale in PR description.</constraint>
  </constraints>

