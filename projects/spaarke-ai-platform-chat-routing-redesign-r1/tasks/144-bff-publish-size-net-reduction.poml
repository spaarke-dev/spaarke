      <file>.claude/constraints/azure-deployment.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Run `dotnet publish -c Release src/server/api/Sprk.Bff.Api/ -o deploy/api-publish/`.</step>
    <step order="2">Compress the publish output (zip / tar) and measure compressed byte size — that's the NFR-01 metric.</step>
    <step order="3">Compare to baseline 45.65 MB. Compute delta + % change.</step>
    <step order="4">Author report at `notes/handoffs/144-bff-publish-final-summary.md` with: baseline, current, delta, % change, NFR-01 threshold check, expected NET REDUCTION confirmation.</step>
    <step order="5">If size did NOT reduce (grew or flat), escalate per CLAUDE.md §6 — investigation needed.</step>
    <step order="6">Update TASK-INDEX.md: task 144 → ✅.</step>
  </steps>

  <tools>
    <tool name="Bash">dotnet publish + compress + measure</tool>
    <tool name="Write">notes/handoffs/144-bff-publish-final-summary.md</tool>
  </tools>

  <outputs>
    <output type="docs">notes/handoffs/144-bff-publish-final-summary.md — final publish-size summary</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Publish-size measurement recorded.</criterion>
    <criterion testable="true">Delta vs 45.65 MB baseline computed.</criterion>
    <criterion testable="true">Below 60 MB hard-stop ceiling.</criterion>
    <criterion testable="true">NET REDUCTION confirmed (or escalation triggered).</criterion>
  </acceptance-criteria>

  <notes>
    Quick verification task. The report feeds task 150 wrap-up. If WP4 deletion did NOT reduce size, something's wrong — likely missed call sites still referencing dead types via TypeRef.
