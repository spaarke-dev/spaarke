<task id="061" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>Verify PaneEventBus.ts channel switches accept memory (read-only)</title>
    <phase>4: WP5 6-Tier Memory Subsystem (sub-WP 4a)</phase>
    <status>not-started</status>
    <estimated-hours>1</estimated-hours>
    <dependencies>060</dependencies>
    <blocks>064</blocks>
    <tags>frontend, testing, verification, ADR-030</tags>
    <rigor-hint>STANDARD</rigor-hint>
    <rigor-reason>Read-only verification per task-create Step 0.5; tags include `verification` (no code modification)</rigor-reason>
