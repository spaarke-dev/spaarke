      <file>.claude/adr/ADR-029-bff-publish-hygiene.md</file>
      <file>.claude/constraints/bff-extensions.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Read existing summarization patterns (`SessionSummarizationService.cs`, `SummarizationCompressionService.cs`) for style + signatures.</step>
    <step order="2">Define `IFileSummarizationService` + `FileSummarizationResult { string SummaryText, int SourceCharCount, string ModelUsed }`.</step>
    <step order="3">Implement service:
      - Constructor takes `IOpenAiClient`, options, `ILogger`
      - `SummarizeAsync` system prompt: "Produce a 1-paragraph (≤120 char) factual summary of this document. Be neutral; do not editorialize."
      - User prompt truncated to first ~8K chars (manageable input for cheap summarizer)
      - Calls gpt-4o-mini
      - Validates response length; truncates to 120 chars if model overshoots
      - Logs sessionId, fileId, durationMs, summaryCharCount (tier-1 safe)</step>
    <step order="4">Author unit test stub in `tests/unit/Sprk.Bff.Api.Tests/Services/Ai/Sessions/FileSummarizationServiceTests.cs`.</step>
    <step order="5">Run `dotnet build` + `dotnet test`.</step>
    <step order="6">Measure BFF publish size.</step>
    <step order="7">code-review + adr-check.</step>
    <step order="8">Update TASK-INDEX.md: 068 → ✅.</step>
  </steps>

  <tools>
    <tool name="Read">Existing summarization services + IOpenAiClient</tool>
    <tool name="Write">Service + interface + record + test stub</tool>
    <tool name="Bash">dotnet build / test / publish</tool>
  </tools>

  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Ai/Sessions/FileSummarizationService.cs (NEW)</output>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Ai/Sessions/IFileSummarizationService.cs (NEW)</output>
    <output type="test">tests/unit/Sprk.Bff.Api.Tests/Services/Ai/Sessions/FileSummarizationServiceTests.cs (NEW)</output>
