    <tool name="Bash">dotnet test; npm test (frontend if needed); verify cross-wave prereqs via TASK-INDEX inspection</tool>
    <tool name="Grep">T-005 static assertions on index targeting; T-009 verify zero remaining read paths</tool>
  </tools>

