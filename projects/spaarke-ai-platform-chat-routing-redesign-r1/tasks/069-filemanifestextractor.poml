<task id="069" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>FileManifestExtractor — sections / tables / pageCount / language (NEW)</title>
    <phase>4: WP5 6-Tier Memory Subsystem (sub-WP 4b)</phase>
    <status>not-started</status>
    <estimated-hours>2</estimated-hours>
    <dependencies>064</dependencies>
    <blocks>070,073</blocks>
    <tags>bff-api, services, ADR-010</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>New BFF service; modifies code surface; ADR-010 + ADR-029 binding</rigor-reason>
    <parallel-group>4-B</parallel-group>
    <parallel-safe>true</parallel-safe>
    <parallel-reason>NEW file — no overlap with peer 4-B tasks</parallel-reason>
