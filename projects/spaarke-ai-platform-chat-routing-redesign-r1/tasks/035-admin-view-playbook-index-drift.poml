  </outputs>

  <acceptance-criteria>
    <criterion testable="true">View named "Playbook Index Drift" exists in `savedquery` for `sprk_analysisplaybook`.</criterion>
    <criterion testable="true">FetchXml filter: `sprk_indexstatus IN ('stale', 'failed', 'not-indexed')`.</criterion>
    <criterion testable="true">Ribbon shows "Send to Index" command on this view.</criterion>
