    </files>
  </knowledge>

  <steps>
    <step order="1">Author the saved query (FetchXml) — `<filter><condition attribute='sprk_indexstatus' operator='in'>...</condition></filter>`.</step>
    <step order="2">Add the view to the unmanaged solution containing `sprk_analysisplaybook`.</step>
    <step order="3">Verify view appears in the admin model-driven app; check ribbon for "Send to Index" inheriting from task 033.</step>
    <step order="4">Update TASK-INDEX.md: task 035 → ✅.</step>
  </steps>

  <tools>
