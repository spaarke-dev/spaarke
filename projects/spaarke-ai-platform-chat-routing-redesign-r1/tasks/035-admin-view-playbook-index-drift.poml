<task id="035" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>Admin Power Apps view "Playbook Index Drift" (filtered status IN stale/failed/not-indexed)</title>
    <phase>2: WP1.5 Index Governance</phase>
    <status>not-started</status>
    <estimated-hours>1</estimated-hours>
    <dependencies>032,033</dependencies>
    <blocks>039</blocks>
