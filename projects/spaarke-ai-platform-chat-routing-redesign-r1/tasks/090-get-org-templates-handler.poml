<task id="090" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>GetOrgTemplatesHandler (T4 read-only) — reads org templates from Dataverse</title>
    <phase>4: WP5 6-Tier Memory Subsystem (sub-WP 4d)</phase>
