<task id="028c" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>Migrate 4 Pattern A consumers to IConsumerRoutingService</title>
    <phase>1R: sprk_playbookconsumer Routing Table</phase>
    <status>not-started</status>
    <estimated-hours>6</estimated-hours>
