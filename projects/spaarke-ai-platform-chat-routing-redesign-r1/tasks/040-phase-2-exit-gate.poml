  <constraints>
    <constraint source="spec">Every FR-08 through FR-14 acceptance criterion must be visibly satisfied.</constraint>
    <constraint source="project">Phase 3 may have started in parallel (wave 3-A prereq is 1-J, not 2-E). Exit gate failure does NOT auto-block Phase 3 progress that ran independently — but flag to owner.</constraint>
