<task id="032" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>Extend PlaybookEmbeddingService embed-input with documentTypes + intents + triggerPhrases from sprk_jpsmatchingmetadata</title>
