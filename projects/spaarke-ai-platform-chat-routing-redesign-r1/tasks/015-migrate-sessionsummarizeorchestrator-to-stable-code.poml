    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-013">No direct injection of `IOpenAiClient`/`IPlaybookService` into CRUD code; orchestrator already inside Services/Ai layer — OK.</constraint>
    <constraint source="ADR-014">Code lookup uses 5-min cache from task 010 endpoint or `IPlaybookLookupService` cached layer.</constraint>
    <constraint source="ADR-018">Lift to typed options preferred over raw `IConfiguration["..."]` indexer.</constraint>
    <constraint source="ADR-029">Per-task BFF publish-size measurement; expect minor delta only.</constraint>
