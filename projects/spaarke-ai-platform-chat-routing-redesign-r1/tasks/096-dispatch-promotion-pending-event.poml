    <criterion testable="true">Event `memory.promotion_pending` emitted after `QueueForApprovalAsync` Cosmos write success.</criterion>
    <criterion testable="true">Payload exactly matches `{ type, promotionId, factSummary, matterId, sessionId }`.</criterion>
    <criterion testable="true">`factSummary.Length &lt;= 80` — unit test asserts on factories with long fact strings.</criterion>
    <criterion testable="true">Event NOT emitted on Cosmos write failure.</criterion>
    <criterion testable="true">Channel string is `"memory"` (not `"workspace"`).</criterion>
    <criterion testable="true">`grep -n "fact[^S]" src/server/api/Sprk.Bff.Api/Services/Ai/Memory/MatterMemoryPromotionService.cs | grep -i "emit\|payload"` returns ZERO matches (no full fact content in payload).</criterion>
    <criterion testable="true">BFF publish delta ≤+0.05 MB.</criterion>
    <criterion testable="true">code-review + adr-check exit 0.</criterion>
  </acceptance-criteria>

  <notes>
