      <file>src/server/api/Sprk.Bff.Api/Services/Ai/Memory/TrustFrameInstructionInjector.cs</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="architecture §6.2">Composition order: persona → trust-frame → tool defs → workspace digest → layered cards → user prefs → glossary. Stable.</constraint>
    <constraint source="architecture §10.2">Static prefix ≤6K tokens; cost target ~$0.0075/turn with cache hit.</constraint>
    <constraint source="ADR-014">Byte-stability enables prompt-cache hit; any block content change must be intentional (e.g., new file upload triggers card recompute).</constraint>
    <constraint source="ADR-013">Composition lives in `Services/Ai/`.</constraint>
    <constraint source="ADR-015">Tier-1 logging — sessionId, totalPrefixTokens. NEVER prefix body.</constraint>
    <constraint source="ADR-029">Per-task publish-size measurement.</constraint>
    <constraint source="open-question §12.1.1">Place recently-discussed in DYNAMIC suffix initially; document for later benchmark.</constraint>
  </constraints>

