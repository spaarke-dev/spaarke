    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-013">Model lives in `Models/Chat/` ŌĆö within AI module surface.</constraint>
    <constraint source="ADR-015">Tier-1 safety: the enriched fields are persisted to Cosmos but tier-1 logging applies elsewhere (logging fileId only). Persistence here is OK ŌĆö tier-1 governs LOGS not STORAGE.</constraint>
    <constraint source="architecture ┬¦11.2">Additive extension only ŌĆö existing sessions with no enriched fields MUST deserialize cleanly with defaults (e.g., empty lists, null strings).</constraint>
    <constraint source="project">Follow R6 task 051 `SaveTabsAsync` precedent ŌĆö DO NOT introduce a new doc-type discriminator; extend existing `ChatSessionFile` record.</constraint>
