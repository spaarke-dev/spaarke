<task id="111" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>Phase A — per-file fingerprint (filename tokens + content type + textLength + sha256)</title>
    <phase>5: WP2 File-Aware Classification</phase>
