    </relevant-files>
  </context>

  <constraints>
    <constraint source="owner-clarification">Q17 — do NOT delete; rewrite + repurpose as canonical Summarize-NDA.</constraint>
    <constraint source="spec">FR-43 acceptance — PB-009 inspection report + post-rewrite vector match for "summarize this NDA" returns PB-009 as top-1.</constraint>
    <constraint source="spec">Use existing SKL-003 (NDA Review) + KNW-006 (NDA Standards) + KNW-005 (Defined Terms) — these are real seeded primitives; do not invent new ones for PB-009.</constraint>
    <constraint source="project">`sprk_playbookcode` MUST be `summarize-nda` (kebab-case, no `@v1` suffix per §1.7 naming).</constraint>
    <constraint source="project">Output schema must align with design §WP6 7-section NDA pattern (parties + direction, definition, exclusions, term + survival, permittedUse, remedies, redFlags).</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>projects/spaarke-ai-platform-chat-routing-redesign-r1/spec.md</file>
