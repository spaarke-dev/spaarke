  <acceptance-criteria>
    <criterion testable="true">Routing telemetry event emitted per dispatch (success + failure).</criterion>
    <criterion testable="true">Negative-sentinel test confirms NO user message text in serialized event.</criterion>
    <criterion testable="true">Negative-sentinel test confirms NO file content in serialized event.</criterion>
    <criterion testable="true">Positive test asserts tier-1 fields emitted correctly.</criterion>
