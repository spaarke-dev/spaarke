      <file>projects/spaarke-ai-platform-chat-routing-redesign-r1/spec.md</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="spec FR-1R-07">Idempotent UPSERT by alternate key `(consumertype + consumercode + environment)`. Rerun = no-op.</constraint>
    <constraint source="project">Reads env-var GUIDs from `appsettings.json` / `appsettings.Development.json` as authoritative source (NOT hardcoded in script).</constraint>
    <constraint source="project">Prints all 6 env-var GUIDs BEFORE write for manual review — defends against the 2026-06-24 UAT-2 env-var-misconfigured failure mode.</constraint>
    <constraint source="ADR-015">No user message content / file content in script logs; print only consumer codes + GUIDs + environment.</constraint>
    <constraint source="ADR-029">N/A — no BFF code change; publish-size unchanged.</constraint>
  </constraints>

