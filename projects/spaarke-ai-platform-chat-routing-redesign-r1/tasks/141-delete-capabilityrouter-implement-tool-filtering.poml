  <constraints>
    <constraint source="spec">FR-22 acceptance — single deletion commit; CI green; `grep CapabilityRouter src/` returns zero hits.</constraint>
    <constraint source="spec">FR-23 acceptance — tool list assembly unit tests pass with new logic; LLM receives correct tool subset per playbook.</constraint>
    <constraint source="spec">FR-24 — R6 FR-30 dedup semantics preserved through new dispatcher path; task 143 verifies.</constraint>
    <constraint source="ADR-013">No `IOpenAiClient` / `IPlaybookService` direct injection into CRUD code; tool filtering stays inside `Services/Ai/`.</constraint>
