  <acceptance-criteria>
    <criterion testable="true">Both-destination dispatch emits BOTH `workspace.tab_open` SSE AND chat ack token.</criterion>
    <criterion testable="true">Ack content: "I've added a {playbookName} result to the Workspace." (with substituted playbook name).</criterion>
    <criterion testable="true">Streaming preserved — `FieldDelta` events fire.</criterion>
    <criterion testable="true">`dotnet build` + tests exit 0.</criterion>
    <criterion testable="true">BFF publish delta within NFR-01 thresholds.</criterion>
