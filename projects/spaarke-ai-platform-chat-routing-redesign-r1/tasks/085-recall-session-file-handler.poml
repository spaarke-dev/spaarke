<task id="085" project="spaarke-ai-platform-chat-routing-redesign-r1">
  <metadata>
    <title>RecallSessionFileHandler (T2 + T5) — 6 purposes × 5 scopes, requireCitations default true</title>
    <phase>4: WP5 6-Tier Memory Subsystem (sub-WP 4d)</phase>
    <status>not-started</status>
    <estimated-hours>8</estimated-hours>
