<task id="CICD-010" project="ci-cd-unit-test-remediation-r1">
  <metadata>
    <title>Catalog last 50 sdap-ci.yml failures by category (legitimate / flaky / false-positive)</title>
    <status>complete</status>
    <estimated-effort>2 hours</estimated-effort>
    <phase>1 - Stream A</phase>
    <stream>A - CI tiering</stream>
    <rigor-level>STANDARD</rigor-level>
    <autonomous>true</autonomous>
    <parallel-safe>true</parallel-safe>
    <dependencies></dependencies>
    <tags>ci, diagnosis, baseline</tags>
  </metadata>

  <prompt>
    Pull the last 50 `sdap-ci.yml` workflow runs that did not succeed (failure or cancelled). Classify each by root cause: legitimate test failure, flaky test, infrastructure issue, false-positive (lint/format/style with no actual impact). Output a categorized table.
  </prompt>

  <role>CI/CD engineer doing diagnostic categorization.</role>

  <goal>A categorized failure inventory in `notes/sdap-ci-failure-catalog.md` that informs Tier 1 contents (which checks are worth blocking on).</goal>

  <inputs>
    <file purpose="workflow">.github/workflows/sdap-ci.yml</file>
  </inputs>

  <constraints>
    <constraint source="project">Read-only diagnosis; do not modify workflows or tests.</constraint>
  </constraints>

  <steps>
    <step order="1">`gh run list --workflow=sdap-ci.yml --limit 50 --status failure --json databaseId,conclusion,createdAt,displayTitle,headBranch`</step>
    <step order="2">For each run, fetch logs or jobs: `gh run view {id} --log-failed` (sample, not all)</step>
    <step order="3">Categorize each into: legitimate-test, flaky-test, infra-issue, false-positive (format/lint/style)</step>
    <step order="4">Tally by category; identify top 5 flaky tests by occurrence</step>
    <step order="5">Write `notes/sdap-ci-failure-catalog.md` with table + top-flakes list + categorization criteria</step>
  </steps>

  <outputs>
    <output type="notes">projects/ci-cd-unit-test-remediation-r1/notes/sdap-ci-failure-catalog.md</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Catalog covers 50 most recent failures</criterion>
    <criterion testable="true">Each run categorized with rationale</criterion>
    <criterion testable="true">Top 5 flaky tests identified by name</criterion>
  </acceptance-criteria>
</task>
