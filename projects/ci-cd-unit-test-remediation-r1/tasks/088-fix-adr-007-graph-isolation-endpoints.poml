<task id="CICD-088" project="ci-cd-unit-test-remediation-r1">
  <metadata>
    <title>Fix ADR-007 violation — isolate Microsoft.Graph SDK out of 18 endpoint classes (wrap Graph exceptions in SpeFileStore facade) — BLOCKS 071 cutover</title>
    <status>not-started</status>
    <estimated-effort>4-6 hours</estimated-effort>
    <phase>2.5 - Pre-cutover BFF ADR remediation</phase>
    <stream>A - CI tiering remediation</stream>
