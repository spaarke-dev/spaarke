<task id="ENV-026" project="Production Environment Setup R2">
  <metadata>
    <title>Migrate DocumentRelationshipViewer (code page) to runtime config resolution</title>
    <status>not-started</status>
    <estimated-effort>2 hours</estimated-effort>
    <phase>3</phase>
    <tags>code-page, typescript, auth, config</tags>
    <parallel-group>3</parallel-group>
    <dependencies>ENV-010</dependencies>
  </metadata>

  <prompt>
    Migrate DocumentRelationshipViewer code page (src/client/code-pages/DocumentRelationshipViewer/) from build-time .env.production config to runtime Dataverse Environment Variable resolution using resolveRuntimeConfig() from @spaarke/auth. This is the code page variant — a separate PCF control with the same name exists and is handled in ENV-031. Replace all process.env / import.meta.env references to BFF URL and MSAL Client ID with runtime resolution at bootstrap.
  </prompt>

  <role>React developer with Dataverse web resource experience</role>

  <goal>
    DocumentRelationshipViewer code page resolves BFF URL and MSAL Client ID from Dataverse Environment Variables at runtime. Build-time .env.production values are no longer used for these settings. The code page builds and runs correctly.
  </goal>

  <constraints>
    <constraint source="ADR-006">Code pages are standalone React 18 dialogs — use createRoot</constraint>
    <constraint source="ADR-022">Code pages bundle their own React 18 (not platform-provided)</constraint>
    <constraint source="project">Keep .env.development for local dev workflow</constraint>
    <constraint source="project">Must work in Dataverse iframe context</constraint>
    <constraint source="project">This is the code-pages variant; do not modify the PCF control (ENV-031)</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>src/client/shared/Spaarke.Auth/src/config.ts</file>
      <file>src/client/code-pages/AnalysisWorkspace/src/index.tsx</file>
      <file>.claude/constraints/pcf.md</file>
      <file>.claude/patterns/auth/msal-client.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Read current bootstrap">Read DocumentRelationshipViewer code page entry point (index.tsx or main.tsx). Identify all build-time env var references for BFF URL and MSAL Client ID.</step>
    <step order="2" name="Replace with runtime resolution">Replace build-time import.meta.env / process.env references with resolveRuntimeConfig() call. Update bootstrap sequence to await config before render.</step>
    <step order="3" name="Clean .env.production">Remove BFF URL and MSAL client ID from .env.production (or remove file if empty).</step>
    <step order="4" name="Remove DefinePlugin shim">If webpack config has DefinePlugin for BFF URL or MSAL config, remove it.</step>
    <step order="5" name="Build and verify">Run npm run build from DocumentRelationshipViewer directory. Verify bundle doesn't contain hardcoded dev URLs.</step>
  </steps>

  <outputs>
    <output type="code">src/client/code-pages/DocumentRelationshipViewer/src/index.tsx</output>
    <output type="code">src/client/code-pages/DocumentRelationshipViewer/.env.production</output>
    <output type="code">src/client/code-pages/DocumentRelationshipViewer/webpack.config.js</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">DocumentRelationshipViewer code page resolves BFF URL from Dataverse at runtime</criterion>
    <criterion testable="true">.env.production does not contain BFF URL or MSAL client ID</criterion>
    <criterion testable="true">npm run build succeeds</criterion>
    <criterion testable="true">Built bundle does not contain "spe-api-dev" or hardcoded MSAL client ID</criterion>
  </acceptance-criteria>
</task>
