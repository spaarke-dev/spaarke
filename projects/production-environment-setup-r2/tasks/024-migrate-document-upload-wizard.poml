<task id="ENV-024" project="Production Environment Setup R2">
  <metadata>
    <title>Migrate DocumentUploadWizard to runtime config resolution</title>
    <status>not-started</status>
    <estimated-effort>2 hours</estimated-effort>
    <phase>3</phase>
    <tags>code-page, typescript, auth, config</tags>
    <parallel-group>3</parallel-group>
    <dependencies>ENV-010</dependencies>
  </metadata>

  <prompt>
    Migrate DocumentUploadWizard solution (src/solutions/DocumentUploadWizard/) from build-time .env.production config to runtime Dataverse Environment Variable resolution using resolveRuntimeConfig() from @spaarke/auth. Replace all process.env / import.meta.env references to BFF URL and MSAL Client ID with runtime resolution at bootstrap.
  </prompt>

  <role>React developer with Dataverse web resource experience</role>

  <goal>
    DocumentUploadWizard resolves BFF URL and MSAL Client ID from Dataverse Environment Variables at runtime. Build-time .env.production values are no longer used for these settings. The code page builds and runs correctly.
  </goal>

  <constraints>
    <constraint source="ADR-006">Code pages are standalone React 18 dialogs — use createRoot</constraint>
    <constraint source="ADR-022">Code pages bundle their own React 18 (not platform-provided)</constraint>
    <constraint source="project">Keep .env.development for local dev workflow</constraint>
    <constraint source="project">Must work in Dataverse iframe context</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>src/client/shared/Spaarke.Auth/src/config.ts</file>
      <file>src/client/code-pages/AnalysisWorkspace/src/index.tsx</file>
      <file>.claude/constraints/pcf.md</file>
      <file>.claude/patterns/auth/msal-client.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Read current bootstrap">Read DocumentUploadWizard entry point (index.tsx or main.tsx). Identify all build-time env var references for BFF URL and MSAL Client ID.</step>
    <step order="2" name="Replace with runtime resolution">Replace build-time import.meta.env / process.env references with resolveRuntimeConfig() call. Update bootstrap sequence to await config before render.</step>
    <step order="3" name="Clean .env.production">Remove BFF URL and MSAL client ID from .env.production (or remove file if empty).</step>
    <step order="4" name="Remove build-time config injection">If webpack config or vite.config has entries that inject BFF URL or MSAL config at build time, remove them.</step>
    <step order="5" name="Build and verify">Run npm run build from DocumentUploadWizard directory. Verify bundle doesn't contain hardcoded dev URLs.</step>
  </steps>

  <outputs>
    <output type="code">src/solutions/DocumentUploadWizard/src/index.tsx</output>
    <output type="code">src/solutions/DocumentUploadWizard/.env.production</output>
    <output type="code">src/solutions/DocumentUploadWizard/webpack.config.js</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">DocumentUploadWizard resolves BFF URL from Dataverse at runtime</criterion>
    <criterion testable="true">.env.production does not contain BFF URL or MSAL client ID</criterion>
    <criterion testable="true">npm run build succeeds</criterion>
    <criterion testable="true">Built bundle does not contain "spe-api-dev" or hardcoded MSAL client ID</criterion>
  </acceptance-criteria>
</task>
