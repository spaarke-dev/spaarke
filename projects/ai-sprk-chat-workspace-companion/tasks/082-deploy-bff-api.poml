<?xml version="1.0" encoding="UTF-8"?>
<task id="082" project="ai-sprk-chat-workspace-companion">
  <metadata>
    <title>Deploy BFF API to Azure App Service</title>
    <phase>2G: Deployment</phase>
    <status>not-started</status>
    <estimated-hours>1</estimated-hours>
    <dependencies>080</dependencies>
    <blocks>090</blocks>
    <tags>deploy, azure, bff-api</tags>
    <rigor-hint>STANDARD</rigor-hint>
    <rigor-reason>Deployment task with explicit skill protocol</rigor-reason>
    <parallel-group>K</parallel-group>
    <parallel-safe>true</parallel-safe>
  </metadata>

  <prompt>
    Deploy the updated Sprk.Bff.Api to the Azure App Service (spe-api-dev-67e2xz) using the bff-deploy skill. The BFF has new endpoints from Phase 2C (context mapping) and Phase 2F (plan approval + write-back).
  </prompt>

  <role>
    SPAARKE platform developer. Expert in Azure App Service deployment via scripts/Deploy-BffApi.ps1.
  </role>

  <goal>
    Updated BFF API is deployed to spe-api-dev-67e2xz.azurewebsites.net. New endpoints GET /api/ai/chat/context-mappings/analysis/{analysisId} and POST /api/ai/chat/sessions/{sessionId}/plan/approve are live and accessible.
  </role>

  <context>
    <background>
      The BFF API gained three functional additions in this project: (1) AnalysisChatContextResolver service with Redis caching, (2) GET context-mappings/analysis endpoint, (3) POST plan/approve endpoint. All need to be deployed to dev environment for integration testing.
    </background>
    <relevant-files>
      <file>src/server/api/Sprk.Bff.Api/</file>
      <file>scripts/Deploy-BffApi.ps1</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-001">BFF deploys to Azure App Service (not Azure Functions)</constraint>
    <constraint source="skill">MUST use scripts/Deploy-BffApi.ps1 via bff-deploy skill</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-001-minimal-api.md</file>
      <file>docs/architecture/auth-azure-resources.md</file>
    </files>
    <patterns>
      <pattern name="bff-deploy skill" location=".claude/skills/bff-deploy/SKILL.md">
        Load and follow the bff-deploy skill for deployment procedure.
      </pattern>
    </patterns>
  </knowledge>

  <steps>
    <step order="1">Load .claude/skills/bff-deploy/SKILL.md and follow the deployment protocol</step>
    <step order="2">dotnet build src/server/api/Sprk.Bff.Api/ — verify clean build</step>
    <step order="3">Run scripts/Deploy-BffApi.ps1 targeting dev environment</step>
    <step order="4">Verify deployment: curl https://spe-api-dev-67e2xz.azurewebsites.net/healthz</step>
    <step order="5">Verify new endpoint is reachable: GET /api/ai/chat/context-mappings/analysis/test (expect 401 without auth — confirms route registered)</step>
    <step order="6">Update TASK-INDEX.md: change task 082 status to ✅ completed</step>
  </steps>

  <tools>
    <tool name="dotnet">Build .NET project</tool>
    <tool name="terminal">Run PowerShell deployment script and curl verification</tool>
  </tools>

  <outputs>
    <output type="code">Deployed BFF API at https://spe-api-dev-67e2xz.azurewebsites.net</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Given BFF deployment, when GET /healthz is called, then 200 OK is returned.</criterion>
    <criterion testable="true">Given BFF deployment, when GET /api/ai/chat/context-mappings/analysis/{id} is called without auth, then 401 is returned (route exists).</criterion>
    <criterion testable="true">dotnet build completes without errors before deployment.</criterion>
  </acceptance-criteria>

  <notes>
    Tasks 081 and 082 are in parallel group K — they can deploy simultaneously since they target different services (Dataverse vs Azure App Service). No shared state or file conflicts.
  </notes>

  <execution>
    <skill>.claude/skills/task-execute/SKILL.md</skill>
    <protocol>Depends on task 080. Load bff-deploy skill before starting. Verify build before deploying.</protocol>
  </execution>
</task>
