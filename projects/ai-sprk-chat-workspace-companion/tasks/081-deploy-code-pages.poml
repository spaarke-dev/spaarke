<?xml version="1.0" encoding="UTF-8"?>
<task id="081" project="ai-sprk-chat-workspace-companion">
  <metadata>
    <title>Deploy Code Pages: AnalysisWorkspace and SprkChatPane to Dataverse</title>
    <phase>2G: Deployment</phase>
    <status>not-started</status>
    <estimated-hours>2</estimated-hours>
    <dependencies>080, 031, 060, 061, 062</dependencies>
    <blocks>090</blocks>
    <tags>deploy, dataverse, frontend</tags>
    <rigor-hint>STANDARD</rigor-hint>
    <rigor-reason>Deployment task with explicit skill protocol; creates deployable artifacts</rigor-reason>
    <parallel-group>K</parallel-group>
    <parallel-safe>true</parallel-safe>
  </metadata>

  <prompt>
    Build and deploy the AnalysisWorkspace and SprkChatPane code pages to Dataverse using the code-page-deploy skill. Both code pages have been modified in this project and need the updated web resources published to the dev environment.
  </prompt>

  <role>
    SPAARKE platform developer. Expert in Dataverse web resource deployment via PAC CLI and webpack builds.
  </role>

  <goal>
    AnalysisWorkspace and SprkChatPane code pages are built and deployed to spaarkedev1.crm.dynamics.com. The updated InlineAiToolbar, QuickActionChips, SlashCommandMenu, and PlanPreviewCard are live in the dev environment.
  </role>

  <context>
    <background>
      Two code pages are modified in this project: AnalysisWorkspace (gets InlineAiToolbar + document_insert handler) and SprkChatPane (gets QuickActionChips, SlashCommandMenu, PlanPreviewCard, and context fetch). Both use the two-step webpack + inline HTML build pipeline per the code-page-deploy skill.
    </background>
    <relevant-files>
      <file>src/client/code-pages/AnalysisWorkspace/</file>
      <file>src/client/code-pages/SprkChatPane/</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-006">Code pages use React 18 bundled via webpack — verify bundle includes all new dependencies</constraint>
    <constraint source="skill">MUST follow code-page-deploy skill — two-step build (webpack + inline HTML generator)</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-006-anti-legacy-js.md</file>
    </files>
    <patterns>
      <pattern name="code-page-deploy skill" location=".claude/skills/code-page-deploy/SKILL.md">
        Load and follow the code-page-deploy skill for the two-step build pipeline.
      </pattern>
    </patterns>
  </knowledge>

  <steps>
    <step order="1">Load .claude/skills/code-page-deploy/SKILL.md and follow the deployment protocol</step>
    <step order="2">Build AnalysisWorkspace: cd src/client/code-pages/AnalysisWorkspace &amp;&amp; npm run build</step>
    <step order="3">Verify AnalysisWorkspace bundle size is reasonable (no unexpected deps)</step>
    <step order="4">Deploy AnalysisWorkspace web resource to Dataverse</step>
    <step order="5">Build SprkChatPane: cd src/client/code-pages/SprkChatPane &amp;&amp; npm run build</step>
    <step order="6">Deploy SprkChatPane web resource to Dataverse</step>
    <step order="7">Verify both web resources are published in dev environment</step>
    <step order="8">Update TASK-INDEX.md: change task 081 status to ✅ completed</step>
  </steps>

  <tools>
    <tool name="npm">Build TypeScript/React code pages</tool>
    <tool name="terminal">Run PAC CLI deployment commands</tool>
  </tools>

  <outputs>
    <output type="code">src/client/code-pages/AnalysisWorkspace/dist/ (built artifact)</output>
    <output type="code">src/client/code-pages/SprkChatPane/dist/ (built artifact)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Given AnalysisWorkspace code page, when build runs, then it completes without TypeScript errors.</criterion>
    <criterion testable="true">Given SprkChatPane code page, when build runs, then it completes without TypeScript errors.</criterion>
    <criterion testable="true">Both web resources are accessible in spaarkedev1.crm.dynamics.com dev environment after deployment.</criterion>
  </acceptance-criteria>

  <notes>
    Run npm install in Spaarke.UI.Components (shared library) first if QuickActionChips/SlashCommandMenu/PlanPreviewCard were added to the library exports. The shared library must be built (npm run build) before the code pages can import from it.
  </notes>

  <execution>
    <skill>.claude/skills/task-execute/SKILL.md</skill>
    <protocol>Depends on tasks 080, 031, 060, 061, 062. Load code-page-deploy skill before starting. Build shared library first.</protocol>
  </execution>
</task>
