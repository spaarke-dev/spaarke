<task id="073" project="ai-sprk-chat-workspace-companion">
  <metadata>
    <title>Implement Write-Back to sprk_analysisoutput.sprk_workingdocument</title>
    <phase>2F: BFF Plan Preview + Write-Back</phase>
    <status>not-started</status>
    <estimated-hours>3</estimated-hours>
    <dependencies>072</dependencies>
    <blocks>080</blocks>
    <tags>bff-api, backend, dataverse, ai</tags>
