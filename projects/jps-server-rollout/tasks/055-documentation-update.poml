<?xml version="1.0" encoding="utf-8"?>
<task id="055" project="jps-server-rollout">
  <metadata>
    <title>Update AI architecture guide, create JPS authoring guidelines, update project status (wrap-up)</title>
    <phase>5</phase>
    <tags>documentation</tags>
    <estimate>3h</estimate>
    <dependencies>050, 051, 052, 053, 054</dependencies>
    <parallel-group>none</parallel-group>
  </metadata>

  <prompt>
    <goal>Document the completed JPS server rollout: update AI architecture guide with JPS specifics, create JPS authoring guidelines for future prompt creation, and mark project as complete in README and status tracking.</goal>
    <context>
      The jps-server-rollout project completed:
      - Phase 1: Scope resolution (tasks 001-003)
      - Phase 2: $ref resolution (tasks 010-014)
      - Phase 3: Template parameters (tasks 020-023)
      - Phase 4: Handler migration (tasks 030-038)
      - Phase 5: E2E validation + documentation (tasks 050-055)

      Documentation should capture:
      1. Updated AI architecture guide explaining JPS pipeline
      2. JPS authoring guidelines for creating new actions
      3. Migration guide for converting legacy handlers
      4. Troubleshooting guide for JPS issues
      5. Project status update: Complete
    </context>
    <constraints>
      - Update docs/guides/SPAARKE-AI-ARCHITECTURE.md with JPS specifics
      - Create docs/guides/JPS-AUTHORING-GUIDE.md for prompt authors
      - Update project README.md with completion status
      - Reference completed tasks and examples
      - Maintain consistency with existing documentation style
      - Do NOT include any credentials or sensitive data
      - Follow ADR-015 (no prompt logging) — documentation examples should not expose actual prompts
    </constraints>
  </prompt>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-013-ai-architecture.md</file>
      <file>.claude/adr/ADR-015-no-prompt-logging.md</file>
      <file>docs/guides/SPAARKE-AI-ARCHITECTURE.md</file>
      <file>projects/jps-server-rollout/README.md</file>
      <file>projects/jps-server-rollout/CLAUDE.md</file>
      <file>projects/ai-json-prompt-schema-system/notes/jps-conversions/</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Read docs/guides/SPAARKE-AI-ARCHITECTURE.md to understand current structure and style</step>
    <step order="2">Add JPS-specific section to AI architecture guide:
      - JPS pipeline overview (JSON → resolve scopes → render → prompt schema → OpenAI)
      - Scope resolution process
      - $ref resolution process
      - Template parameter substitution
      - Choice resolution and branching
      - Override merge behavior
      - Format detection (JPS vs. legacy flat-text)
      - Handler migration strategy (consolidation vs. thin wrapper)
    </step>
    <step order="3">Create JPS-AUTHORING-GUIDE.md with:
      - JPS JSON structure (instruction, scopes, choices, parameters)
      - Example JPS for simple action (clause analyzer)
      - Example JPS for complex action (with choices, nested nodes)
      - Scope definition and reference ($ref usage)
      - Template parameter definition and substitution ({{varName}})
      - Choice condition syntax
      - Override merge examples
      - Best practices and common patterns
      - Troubleshooting (missing refs, malformed JSON, etc.)
    </step>
    <step order="4">Update project README.md:
      - Change status: In Progress → Complete
      - Summarize deliverables (5 phases completed)
      - Link to new documentation (JPS-AUTHORING-GUIDE.md)
      - Link to example JPS files (projects/ai-json-prompt-schema-system/notes/jps-conversions/)
      - Migration path for legacy handlers
    </step>
    <step order="5">Create lessons-learned or retrospective section (optional):
      - Key decisions made
      - Challenges encountered
      - Recommendations for future AI feature work
    </step>
    <step order="6">Review all documentation for:
      - Consistency with existing Spaarke docs
      - Clarity for both AI and non-AI developers
      - Completeness (all JPS features documented)
      - No exposed credentials or sensitive examples
    </step>
    <step order="7">Commit documentation changes with message referencing project completion</step>
  </steps>

  <tools>
    <tool>Read</tool>
    <tool>Edit</tool>
    <tool>Write</tool>
    <tool>Bash(git add)</tool>
    <tool>Bash(git commit)</tool>
  </tools>

  <outputs>
    <output>docs/guides/SPAARKE-AI-ARCHITECTURE.md</output>
    <output>docs/guides/JPS-AUTHORING-GUIDE.md</output>
    <output>projects/jps-server-rollout/README.md</output>
  </outputs>

  <acceptance-criteria>
    <criterion>AI architecture guide updated with JPS pipeline details</criterion>
    <criterion>JPS-AUTHORING-GUIDE created with structure, examples, best practices</criterion>
    <criterion>Guide covers scope refs, template parameters, choices, overrides</criterion>
    <criterion>Examples use realistic actions from jps-conversions/</criterion>
    <criterion>Project README updated to Complete status</criterion>
    <criterion>README includes migration guidance for legacy handlers</criterion>
    <criterion>Documentation consistent with Spaarke style and standards</criterion>
    <criterion>No credentials or sensitive data exposed</criterion>
    <criterion>Lessons-learned documented (if applicable)</criterion>
    <criterion>All documentation committed to git</criterion>
  </acceptance-criteria>
</task>
