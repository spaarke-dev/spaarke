<task id="065" project="spaarke-ai-platform-unification-r4">
  <metadata>
    <title>B-9: Migrate Spaarke.UI.Components ESLint v8 ‚Üí v9 (flat config)</title>
    <phase>Phase 6 ‚Äî Build hygiene cluster</phase>
    <status>not-started</status>
    <estimated-hours>2</estimated-hours>
    <dependencies>none</dependencies>
    <blocks>none</blocks>
