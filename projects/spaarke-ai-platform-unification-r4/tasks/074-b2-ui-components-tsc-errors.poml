    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-022">React 19 patterns only. Use `useRef&lt;T | null&gt;(null)` correctly. No `useRef` shims for backward compat.</constraint>
    <constraint source="ADR-021">Fluent v9 only. Handler types must use Fluent v9's actual event signatures.</constraint>
    <constraint source="project">EXCLUDE DatasetGrid/GridView.tsx and DatasetGrid/ListView.tsx — they belong to task 073.</constraint>
    <constraint source="project">No behavior change. Type fixes only.</constraint>
    <constraint source="project">If a fix reveals MORE errors (cascade), absorb them within budget; document any deferred ones for follow-up.</constraint>
    <constraint source="project">Do NOT add `// @ts-ignore` or `// @ts-nocheck`. Use correct types.</constraint>
    <constraint source="project">Do NOT cast with `as any`. If genuinely needed, use the SDK-boundary comment pattern from task 067 (rare case).</constraint>
  </constraints>

  <knowledge>
