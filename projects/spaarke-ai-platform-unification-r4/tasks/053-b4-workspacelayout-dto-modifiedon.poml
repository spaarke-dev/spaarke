    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-001">Minimal API only — extend the existing endpoint, do NOT introduce controllers.</constraint>
    <constraint source="ADR-008">Endpoint filters unchanged — the existing `WorkspaceLayoutAuthorizationFilter` already enforces authz; do NOT modify the filter pipeline.</constraint>
