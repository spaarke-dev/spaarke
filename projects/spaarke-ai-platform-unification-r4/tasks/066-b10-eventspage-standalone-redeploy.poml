<task id="066" project="spaarke-ai-platform-unification-r4">
  <metadata>
    <title>B-10: Build + redeploy standalone EventsPage web resource; verify parity</title>
    <phase>Phase 6 — Build hygiene cluster</phase>
    <status>not-started</status>
    <estimated-hours>0.5</estimated-hours>
    <dependencies>none</dependencies>
    <blocks>none</blocks>
    <tags>deploy, frontend, react</tags>
    <rigor-hint>MINIMAL</rigor-hint>
