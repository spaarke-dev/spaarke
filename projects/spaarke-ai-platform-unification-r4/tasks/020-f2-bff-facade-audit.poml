<task id="020" project="spaarke-ai-platform-unification-r4">
  <metadata>
    <title>F-2 BFF AI facade audit — count remaining direct CRUD→AI injections (NFR-03)</title>
    <phase>Phase 2: BFF governance audit</phase>
    <status>not-started</status>
    <estimated-hours>2</estimated-hours>
    <dependencies>none</dependencies>
    <blocks>none</blocks>
