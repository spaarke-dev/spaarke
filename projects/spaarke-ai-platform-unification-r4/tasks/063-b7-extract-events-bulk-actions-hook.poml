  <ui-tests>
    <test name="EventsPage bulk status update behavior unchanged">
      <url>https://{org}.crm.dynamics.com/main.aspx?appid={app-id}&amp;pagetype=webresource&amp;webresourceName=sprk_eventspage</url>
      <steps>
        <step>Open EventsPage standalone web resource</step>
        <step>Select 2-3 events in the grid</step>
        <step>Trigger "Close Events" bulk action from CommandBar</step>
        <step>Confirm dialog appears + accept</step>
        <step>Verify status updates to "Closed" on selected events</step>
        <step>Verify success toast appears</step>
        <step>Check console for JavaScript errors</step>
      </steps>
      <expected>Bulk status update completes identically to pre-extraction behavior; no console errors; toast shows count.</expected>
    </test>

    <test name="EventsPage bulk archive behavior unchanged">
      <steps>
        <step>Select 2-3 events</step>
        <step>Trigger "Archive" bulk action</step>
        <step>Verify events removed from active view</step>
        <step>Verify success toast appears</step>
        <step>Check console for errors</step>
      </steps>
      <expected>Bulk archive completes identically; no console errors.</expected>
    </test>

    <test name="Calendar widget behavior unchanged (if applicable)">
      <url>https://{org}.crm.dynamics.com/main.aspx?appid={app-id}&amp;pagetype=webresource&amp;webresourceName=sprk_spaarkeai</url>
      <steps>
        <step>Open SpaarkeAi page</step>
        <step>Mount Calendar widget into a workspace tab</step>
        <step>If bulk actions surface present, exercise one bulk action</step>
        <step>Verify behavior identical to pre-change</step>
      </steps>
      <expected>Calendar widget either (a) has unchanged bulk-action behavior, or (b) does not yet expose bulk actions (parity = no regression).</expected>
    </test>

    <test name="Dark mode compliance (ADR-021)">
      <steps>
        <step>Toggle dark mode in D365 settings</step>
        <step>Open EventsPage; trigger bulk action</step>
        <step>Verify toast + dialog colors adapt (no hardcoded white/black)</step>
        <step>Verify icons use currentColor or v9 semantic tokens</step>
      </steps>
      <expected>All colors use Fluent UI v9 semantic tokens per ADR-021.</expected>
    </test>
  </ui-tests>

  <acceptance-criteria>
    <criterion testable="true">Given the extraction, When `src/client/shared/Spaarke.Events.Components/src/hooks/useEventsBulkActions.ts` is read, Then it exports a hook with no host-specific imports (deps injected via argument).</criterion>
    <criterion testable="true">Given `EventsPage/src/App.tsx`, When grepped, Then it imports `useEventsBulkActions` from `@spaarke/events-components` and no longer declares the inline `executeBulkStatusUpdate` / `executeBulkArchive` functions.</criterion>
    <criterion testable="true">Given the EventsPage UI smoke test, When a bulk status update / archive is exercised, Then the behavior is identical to pre-extraction (events update; toast displays; no console errors).</criterion>
    <criterion testable="true">Given `npm run build` runs on `Spaarke.Events.Components` and `EventsPage`, When the build completes, Then both succeed with 0 errors.</criterion>
    <criterion testable="true">Given `tsc --noEmit` runs on both packages, When the check completes, Then 0 type errors.</criterion>
    <criterion testable="true">Given task 063 is being executed, When this task completes, Then TASK-INDEX.md shows task 063 as ✅ completed.</criterion>
  </acceptance-criteria>

