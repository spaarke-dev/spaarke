    <patterns>
      <pattern name="Calendar widget Pattern D (R3 task 115)" location="src/client/shared/Spaarke.events-components/ + src/solutions/LegalWorkspace/src/registrations/calendar.registration.ts">
        Canonical "shared-lib widget + thin registration shim" reference. Receiving widget mounted in workspace channel follows this pattern.
      </pattern>
      <pattern name="PaneEventBus typed channels (ADR-030)" location="src/client/shared/Spaarke.AI.Widgets/src/events/">
        Workspace / context / conversation / safety channels with typed payloads. Reuse `widget_load` type from 042 OR define here if executing first.
      </pattern>
    </patterns>
