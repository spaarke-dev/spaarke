<task id="R4-114" project="smart-todo-r4">
  <metadata>
    <title>FU-4 — Wire vitest for SmartTodo Code Page (no test shims)</title>
    <phase>Closeout (UAT round 14)</phase>
    <workstream>test infrastructure</workstream>
    <status>not-started</status>
    <estimated-effort>2-3 hrs</estimated-effort>
    <tags>testing, vitest, infra, no-shims</tags>
    <parallel-safe>true</parallel-safe>
    <dependencies>(none)</dependencies>
    <relevant-files>
      <file>src/solutions/SmartTodo/package.json (currently no test script)</file>
      <file>src/solutions/SmartTodo/src/hooks/__tests__/useLaunchContext.test.ts (22 specs)</file>
      <file>src/solutions/SmartTodo/src/services/__tests__/ (other spec shims)</file>
