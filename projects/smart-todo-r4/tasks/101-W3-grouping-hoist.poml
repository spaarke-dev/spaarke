  </outputs>

  <ui-tests>
    <test name="Widget shows 3 grouped sections (issue 6)">
      <url>npm run dev or post-deploy spaarkedev1 SpaarkeAi workspace</url>
      <steps>
        <step>Mount the SmartTodo widget in the workspace</step>
        <step>Verify 3 section headers: "Today", "Tomorrow", "Future" (or equivalent labels from useKanbanColumns)</step>
        <step>Verify each section shows item count next to the header</step>
        <step>Verify items appear under the correct section based on due date (test with at least one item per bucket)</step>
        <step>Verify an empty section shows a "No items" placeholder</step>
      </steps>
      <expected>Widget shows 3 grouped sections with items correctly bucketed; empty sections visible with placeholder</expected>
    </test>
    <test name="Code Page Kanban still renders (regression)">
      <steps>
        <step>Open the SmartTodo Code Page directly</step>
        <step>Verify the Kanban still shows 3 columns with items bucketed identically to before the hoist</step>
        <step>Verify drag-drop still works (Code Page Kanban is unchanged)</step>
      </steps>
      <expected>Code Page Kanban is functionally unchanged; only the import source moved</expected>
    </test>
    <test name="Selection works across groups (R4-099 compatibility)">
      <steps>
        <step>Click an item in "Today" — verify it selects</step>
        <step>Click an item in "Future" — verify it selects (and the Today selection clears)</step>
        <step>Click Open — verify the correct item opens via R4-100's launch path</step>
      </steps>
      <expected>Selection model from R4-099 works across grouped sections; Open invokes R4-100's launch path with the correct todoId</expected>
    </test>
  </ui-tests>

  <acceptance-criteria>
    <criterion testable="true">`useKanbanColumns` lives in `@spaarke/smart-todo-components` peer package; deleted from `src/solutions/SmartTodo/src/hooks/`</criterion>
    <criterion testable="true">Code Page consumer imports from `@spaarke/smart-todo-components`; Kanban renders unchanged (regression-safe)</criterion>
    <criterion testable="true">Widget renders 3 grouped sections (Today / Tomorrow / Future) with items bucketed via the hoisted hook</criterion>
    <criterion testable="true">Empty buckets render a "No items" placeholder (group structure always visible)</criterion>
    <criterion testable="true">Selection state from R4-099 carries across groups (single-select model holds)</criterion>
    <criterion testable="true">`npm run build` passes for `@spaarke/smart-todo-components`, SmartTodo, and LegalWorkspace</criterion>
    <criterion testable="true">No drag-drop logic, no react-dnd hoisted (widget scope = grouped lists only)</criterion>
    <criterion testable="true">No Fluent v8 components introduced; no inline styles; Griffel + tokens used throughout</criterion>
    <criterion testable="true">POML status flipped to complete; TASK-INDEX.md row + header counts updated; R4-020 deferred-hoist follow-up closed</criterion>
  </acceptance-criteria>

