<task id="R4-118" project="smart-todo-r4">
  <metadata>
    <title>NEW (2026-06-24) — Deploy sprk_wizard_commands.js + audit "Create To Do" ribbon coverage</title>
    <phase>Closeout (UAT round 14)</phase>
    <workstream>tech-debt hygiene + ribbon coverage</workstream>
    <status>not-started</status>
    <estimated-effort>1-2 hrs</estimated-effort>
