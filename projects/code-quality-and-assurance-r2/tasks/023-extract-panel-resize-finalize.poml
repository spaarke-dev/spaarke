<task id="023" project="code-quality-and-assurance-r2">
  <metadata>
    <title>Extract usePanelResize + Finalize Component Decomposition</title>
    <phase>3: Frontend Structural Decomposition</phase>
    <status>pending</status>
    <estimated-hours>2</estimated-hours>
    <dependencies>021, 022</dependencies>
