<task id="004" project="code-quality-and-assurance-r2">
  <metadata>
    <title>Delete Dead MsalAuthProvider.ts + Create Shared Logger</title>
    <phase>1: Quick Wins</phase>
    <status>pending</status>
    <estimated-hours>5</estimated-hours>
    <dependencies></dependencies>
