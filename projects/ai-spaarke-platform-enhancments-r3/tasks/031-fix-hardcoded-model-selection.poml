<task id="AIRA-031" project="ai-spaarke-platform-enhancments-r3">
  <metadata>
    <title>Fix Hardcoded Model Selection in GenericAnalysisHandler</title>
    <phase>4</phase>
    <estimate>3h</estimate>
    <tags>bff-api, ai</tags>
    <dependencies>none</dependencies>
    <parallel-group>G</parallel-group>
