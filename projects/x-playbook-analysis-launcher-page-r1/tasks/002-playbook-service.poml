<task id="002" project="playbook-analysis-launcher-page-r1">
  <metadata>
    <title>Create PlaybookService — Dataverse WebAPI Queries</title>
    <phase>1</phase>
    <status>not-started</status>
    <estimated-hours>3</estimated-hours>
    <dependencies>001</dependencies>
    <blocks>020, 021, 030</blocks>
    <tags>typescript, frontend, dataverse</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Core service with Dataverse WebAPI queries including N:N $expand</rigor-reason>
    <parallel-group>A</parallel-group>
    <parallel-safe>true</parallel-safe>
  </metadata>

  <prompt>
    Create the PlaybookService that loads all playbook entities and their N:N scope relationships
    from Dataverse WebAPI. Port the query logic from the existing AnalysisBuilderApp.tsx.
  </prompt>

  <role>
    SPAARKE platform developer. Expert in Dataverse WebAPI and N:N relationship queries.
  </role>

  <goal>
    Create `src/solutions/LegalWorkspace/src/components/Playbook/playbookService.ts` with methods
    to load playbooks, actions, skills, knowledge, tools, and playbook scopes via Xrm.WebApi.
  </goal>

  <context>
    <background>
      The existing PCF loads playbook data via parallel WebAPI calls in AnalysisBuilderApp.tsx
      (lines ~200-400). N:N relationships are loaded via $expand on the playbook entity.
      This service extracts that logic into a reusable module.
    </background>
    <relevant-files>
      <file>src/solutions/LegalWorkspace/src/components/Playbook/playbookService.ts</file>
      <file>src/client/pcf/AnalysisBuilder/control/components/AnalysisBuilderApp.tsx</file>
      <file>src/solutions/LegalWorkspace/src/components/Playbook/types.ts</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="project">Use Xrm.WebApi.online.retrieveMultipleRecords for queries</constraint>
    <constraint source="project">N:N scopes loaded via $expand on sprk_analysisplaybook</constraint>
    <constraint source="project">No new Dataverse entities or relationships</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-013-ai-architecture.md</file>
      <file>.claude/patterns/dataverse-webapi.md</file>
      <file>projects/playbook-analysis-launcher-page-r1/spec.md</file>
    </files>
    <patterns>
      <pattern name="WebAPI N:N query" location="src/client/pcf/AnalysisBuilder/control/components/AnalysisBuilderApp.tsx">
        $expand=sprk_playbook_skill,sprk_playbook_knowledge,sprk_playbook_tool,sprk_analysisplaybook_action
      </pattern>
    </patterns>
  </knowledge>

  <steps>
    <step order="1">Read existing WebAPI queries in AnalysisBuilderApp.tsx</step>
    <step order="2">Read types.ts from task 001</step>
    <step order="3">Create playbookService.ts with: loadPlaybooks(), loadActions(), loadSkills(), loadKnowledge(), loadTools()</step>
    <step order="4">Add loadPlaybookScopes(playbookId) method using $expand for N:N relationships</step>
    <step order="5">Add loadAllData() parallel loader that fetches all 5 entity types simultaneously</step>
    <step order="6">Map Dataverse response shapes to typed interfaces</step>
    <step order="7">Verify TypeScript compiles</step>
  </steps>

  <tools>
    <tool name="Read">Read existing PCF WebAPI code</tool>
    <tool name="Write">Create service file</tool>
    <tool name="Bash(npm)">Verify compilation</tool>
  </tools>

  <outputs>
    <output type="code">src/solutions/LegalWorkspace/src/components/Playbook/playbookService.ts</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">loadPlaybooks() returns IPlaybook[] from sprk_analysisplaybook</criterion>
    <criterion testable="true">loadPlaybookScopes(id) returns IPlaybookScopes with all 4 N:N relationships</criterion>
    <criterion testable="true">loadAllData() runs all queries in parallel via Promise.all</criterion>
    <criterion testable="true">TypeScript compiles without errors</criterion>
  </acceptance-criteria>
</task>
