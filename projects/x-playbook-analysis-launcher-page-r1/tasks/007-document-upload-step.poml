<task id="007" project="playbook-analysis-launcher-page-r1">
  <metadata>
    <title>Create DocumentUploadStep Wrapper Component</title>
    <phase>1</phase>
    <status>not-started</status>
    <estimated-hours>2</estimated-hours>
    <dependencies>001</dependencies>
    <blocks>030, 031</blocks>
    <tags>typescript, react, fluent-ui, frontend</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Wires existing upload components — critical integration path</rigor-reason>
    <parallel-group>C</parallel-group>
    <parallel-safe>true</parallel-safe>
  </metadata>

  <prompt>
    Create the DocumentUploadStep wizard step component that wraps existing FileUploadZone
    and upload services. MUST reuse existing upload components — zero new upload logic.
  </prompt>

  <role>
    SPAARKE platform developer. Reuses existing upload architecture per spec Section 6.6.
  </role>

  <goal>
    Create `src/solutions/LegalWorkspace/src/components/Playbook/DocumentUploadStep.tsx` that
    composes FileUploadZone + UploadedFileList + MultiFileUploadService for wizard context.
  </goal>

  <context>
    <background>
      Spec Section 6.6 mandates reusing existing upload components. The DocumentUploadStep
      is a thin wrapper that wires FileUploadZone (UI) with MultiFileUploadService (SPE upload)
      and EntityCreationService (Dataverse records) into wizard step callbacks.
    </background>
    <relevant-files>
      <file>src/solutions/LegalWorkspace/src/components/Playbook/DocumentUploadStep.tsx</file>
      <file>src/solutions/LegalWorkspace/src/components/CreateMatter/FileUploadZone.tsx</file>
      <file>src/solutions/LegalWorkspace/src/components/CreateMatter/UploadedFileList.tsx</file>
      <file>src/client/pcf/UniversalQuickCreate/control/services/MultiFileUploadService.ts</file>
      <file>src/solutions/LegalWorkspace/src/services/EntityCreationService.ts</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="project">Zero new upload UI — reuse FileUploadZone</constraint>
    <constraint source="project">Zero new SPE integration — reuse MultiFileUploadService</constraint>
    <constraint source="project">Zero new record creation — reuse EntityCreationService</constraint>
    <constraint source="ADR-021">Dark mode compliant</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-021-fluent-design-system.md</file>
      <file>.claude/adr/ADR-007-spe-filestore-facade.md</file>
      <file>projects/playbook-analysis-launcher-page-r1/spec.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Read FileUploadZone.tsx and UploadedFileList.tsx from CreateMatter/</step>
    <step order="2">Read MultiFileUploadService.ts for upload API</step>
    <step order="3">Read EntityCreationService.ts for record creation API</step>
    <step order="4">Create DocumentUploadStep.tsx with props: accept, multiple, onFilesReady, apiBaseUrl</step>
    <step order="5">Compose FileUploadZone for drag-drop + UploadedFileList for display</step>
    <step order="6">Wire upload trigger: on user action, call MultiFileUploadService then EntityCreationService</step>
    <step order="7">Expose documentIds via onFilesReady callback for wizard canAdvance</step>
    <step order="8">Verify import paths work across solution boundaries</step>
  </steps>

  <outputs>
    <output type="code">src/solutions/LegalWorkspace/src/components/Playbook/DocumentUploadStep.tsx</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Renders FileUploadZone and UploadedFileList — no new upload UI</criterion>
    <criterion testable="true">Uses MultiFileUploadService for SPE upload — no new upload logic</criterion>
    <criterion testable="true">Calls onFilesReady with documentIds after upload + record creation</criterion>
    <criterion testable="true">TypeScript compiles without errors</criterion>
  </acceptance-criteria>
</task>
