<task id="003" project="playbook-analysis-launcher-page-r1">
  <metadata>
    <title>Create AnalysisService — Record Creation with N:N Associations</title>
    <phase>1</phase>
    <status>not-started</status>
    <estimated-hours>3</estimated-hours>
    <dependencies>001</dependencies>
    <blocks>020, 021, 030</blocks>
    <tags>typescript, frontend, dataverse</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Critical service creating Dataverse records with N:N associations via Xrm.WebApi.execute</rigor-reason>
    <parallel-group>A</parallel-group>
    <parallel-safe>true</parallel-safe>
  </metadata>

  <prompt>
    Create the AnalysisService that creates sprk_analysis records and associates N:N scope
    relationships. Port the creation logic from AnalysisBuilderApp.tsx handleSave/handleExecute.
  </prompt>

  <role>
    SPAARKE platform developer. Expert in Dataverse WebAPI record creation and N:N associations.
  </role>

  <goal>
    Create `src/solutions/LegalWorkspace/src/components/Playbook/analysisService.ts` with methods
    to create an analysis record and associate skills, knowledge, tools via N:N relationships.
  </goal>

  <context>
    <background>
      The existing PCF creates analysis records using Xrm.WebApi.online.createRecord with
      @odata.bind lookups, then associates N:N relationships via Xrm.WebApi.online.execute()
      with AssociateRequest. See spec.md Section 8.2 for relationships.
    </background>
    <relevant-files>
      <file>src/solutions/LegalWorkspace/src/components/Playbook/analysisService.ts</file>
      <file>src/client/pcf/AnalysisBuilder/control/components/AnalysisBuilderApp.tsx</file>
      <file>src/solutions/LegalWorkspace/src/components/Playbook/types.ts</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="project">Use Xrm.WebApi.online.createRecord for the sprk_analysis record</constraint>
    <constraint source="project">Use Xrm.WebApi.online.execute with AssociateRequest for N:N</constraint>
    <constraint source="project">N:N relationships: sprk_analysis_skill, sprk_analysis_knowledge, sprk_analysis_tool</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-013-ai-architecture.md</file>
      <file>.claude/patterns/dataverse-webapi.md</file>
      <file>projects/playbook-analysis-launcher-page-r1/spec.md</file>
    </files>
    <patterns>
      <pattern name="N:N association" location="src/client/pcf/AnalysisBuilder/control/components/AnalysisBuilderApp.tsx">
        Xrm.WebApi.online.execute() with AssociateRequest for N:N scope associations
      </pattern>
    </patterns>
  </knowledge>

  <steps>
    <step order="1">Read existing creation/association logic in AnalysisBuilderApp.tsx (handleSave, handleExecute)</step>
    <step order="2">Read types.ts from task 001 for IAnalysisConfig</step>
    <step order="3">Create analysisService.ts with createAnalysis(config: IAnalysisConfig) method</step>
    <step order="4">Implement N:N association via associateScopes(analysisId, scopes) using Xrm.WebApi.online.execute</step>
    <step order="5">Add createAndAssociate() orchestrator that calls create + associate in sequence</step>
    <step order="6">Handle @odata.bind lookups for sprk_documentid and sprk_actionid</step>
    <step order="7">Verify TypeScript compiles</step>
  </steps>

  <outputs>
    <output type="code">src/solutions/LegalWorkspace/src/components/Playbook/analysisService.ts</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">createAnalysis() creates sprk_analysis record with correct lookups</criterion>
    <criterion testable="true">associateScopes() creates N:N associations for skills, knowledge, tools</criterion>
    <criterion testable="true">@odata.bind used for document and action lookups</criterion>
    <criterion testable="true">TypeScript compiles without errors</criterion>
  </acceptance-criteria>
</task>
