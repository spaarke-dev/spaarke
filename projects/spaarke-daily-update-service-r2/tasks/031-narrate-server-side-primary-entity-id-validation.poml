<task id="031" project="spaarke-daily-update-service-r2">
  <metadata>
    <title>`ParseChannelBullets` validates `primaryEntityId`; nulls invalid + logs (FR-17)</title>
    <phase>P2b: BFF /narrate Fix</phase>
    <status>not-started</status>
