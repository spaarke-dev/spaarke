      <file>projects/spaarke-daily-update-service-r2/CLAUDE.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">In `DailyBriefingEndpoints.cs`, locate `ParseChannelBullets` and the post-parse code path.</step>
    <step order="2">Build a `HashSet&lt;Guid&gt;` (or string set) of supplied `item.RegardingId` values for the channel.</step>
    <step order="3">For each parsed bullet: if `primaryEntityId` is non-null AND not in the set, null out `primaryEntityType`, `primaryEntityId`, `primaryEntityName`; log a structured warning with bullet content + the offending ID.</step>
    <step order="4">Build the project; verify green.</step>
    <step order="5">Update TASK-INDEX.md: change task 031 status from 🔲 to ✅.</step>
  </steps>

  <tools>
    <tool name="dotnet">Build .NET project.</tool>
  </tools>

  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/Api/Ai/DailyBriefingEndpoints.cs</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Server-side validation rejects `primaryEntityId` values not in the supplied set.</criterion>
    <criterion testable="true">Invalid bullets have nulled `primaryEntityType` + `primaryEntityId` + `primaryEntityName`.</criterion>
    <criterion testable="true">Warning is logged with bullet content for monitoring.</criterion>
  </acceptance-criteria>

  <notes>
