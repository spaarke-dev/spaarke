<task id="UDSS-034" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Deploy and verify Phase 4 end-to-end</title>
    <status>not-started</status>
    <phase>4</phase>
    <estimated-effort>3 hours</estimated-effort>
    <tags>deploy, verify, spa, integration</tags>
    <dependencies>UDSS-033</dependencies>
    <parallel-group>none</parallel-group>
  </metadata>
  <prompt>Deploy all Phase 4 SPA integration artifacts and verify end-to-end functionality. This includes the BFF adapters, Document Upload wizard in SPA, PlaybookLibraryShell in SPA, and theme integration. Test both Dataverse and SPA contexts to ensure no regressions.</prompt>
  <role>Senior developer with deployment and integration testing expertise</role>
  <goal>All Phase 4 SPA integration deployed and verified working end-to-end in both Dataverse and SPA contexts</goal>
  <constraints>
    <constraint source="deployment">Use existing deploy scripts for SPA deployment</constraint>
    <constraint source="testing">Verify both Dataverse (navigateTo) and SPA (direct route) contexts</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/skills/power-page-deploy/SKILL.md</file>
      <file>scripts/Deploy-ExternalWorkspaceSpa.ps1</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Build external-spa with all Phase 4 changes</step>
    <step id="2">Deploy SPA to Power Pages environment</step>
    <step id="3">Verify: Document Upload wizard opens and completes file upload in SPA context</step>
    <step id="4">Verify: PlaybookLibraryShell opens in full browse mode in SPA</step>
    <step id="5">Verify: PlaybookLibraryShell intent mode works in SPA</step>
    <step id="6">Verify: Dark mode rendering for all shared components in SPA</step>
    <step id="7">Regression test: Dataverse context wizards still work (navigateTo from workspace)</step>
    <step id="8">Regression test: AnalysisBuilder still works in Dataverse context</step>
  </steps>
  <acceptance-criteria>
    <criterion>SPA deployed successfully to Power Pages environment</criterion>
    <criterion>Document Upload wizard works end-to-end in SPA</criterion>
    <criterion>PlaybookLibraryShell works in both browse and intent modes in SPA</criterion>
    <criterion>Dark mode renders correctly for all shared components in SPA</criterion>
    <criterion>No regressions in Dataverse context (existing navigateTo flows unchanged)</criterion>
  </acceptance-criteria>
</task>
