<task id="UDSS-033" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Ensure shared components respect SPA theme (not Dataverse detection)</title>
    <status>not-started</status>
    <phase>4</phase>
    <estimated-effort>2 hours</estimated-effort>
    <tags>spa, theme</tags>
    <dependencies>031, 032</dependencies>
  </metadata>

  <prompt>
    Verify and fix that all shared components (DocumentUploadWizard, PlaybookLibraryShell,
    WizardShell) correctly respect the SPA's theme context rather than attempting Dataverse
    theme detection. In the SPA context, theme is provided by the SPA's FluentProvider —
    components should not call detectTheme() or read Dataverse-specific theme variables.
    Ensure dark mode works correctly in the SPA context.
  </prompt>

  <role>Senior TypeScript/React developer with theming and cross-platform UI experience</role>

  <goal>
    All shared components render correctly in both Dataverse and SPA theme contexts,
    with proper dark mode support in the SPA.
  </goal>

  <constraints>
    <constraint source="ADR-021">Fluent v9 tokens only, React 19, dark mode required.</constraint>
    <constraint source="ADR-012">Services must use IDataService abstraction.</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/patterns/pcf/theme-management.md</file>
      <file>src/client/shared/Spaarke.UI.Components/src/utils/detectTheme.ts</file>
      <file>src/client/external-spa/</file>
    </files>
  </knowledge>

  <steps>
    <step id="1">Audit shared components for any direct Dataverse theme detection calls (detectTheme, Xrm theme variables).</step>
    <step id="2">Ensure components use Fluent v9 tokens from the nearest FluentProvider context instead of hard-coded detection.</step>
    <step id="3">Verify SPA FluentProvider provides correct theme (light/dark) to shared components.</step>
    <step id="4">Test dark mode rendering for DocumentUploadWizard and PlaybookLibraryShell in SPA context.</step>
  </steps>

  <acceptance-criteria>
    <criterion>No shared component directly calls detectTheme() or reads Dataverse theme variables.</criterion>
    <criterion>Components use Fluent v9 tokens from FluentProvider context.</criterion>
    <criterion>Light mode renders correctly in SPA context.</criterion>
    <criterion>Dark mode renders correctly in SPA context.</criterion>
    <criterion>Components still render correctly in Dataverse context (no regression).</criterion>
  </acceptance-criteria>
</task>
