<task id="UDSS-017" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Remove all remaining inline wizard dialogs from Corporate Workspace WorkspaceGrid.tsx</title>
    <status>not-started</status>
    <phase>2</phase>
    <estimated-effort>6 hours</estimated-effort>
    <tags>corporate-workspace, refactor, navigateTo</tags>
    <dependencies>011, 012, 013, 014, 015</dependencies>
  </metadata>

  <prompt>
    Remove all remaining lazily-loaded inline wizard and dialog components from the Corporate
    Workspace WorkspaceGrid.tsx. Replace every inline dialog with a navigateTo call that opens
    the corresponding standalone Code Page. This is the final step that decouples the workspace
    from all wizard/dialog implementations, reducing WorkspaceGrid to a clean orchestration
    component under 500 LOC.
  </prompt>

  <role>Frontend developer with expertise in React 19, Fluent UI v9, Vite, and Dataverse Code Pages</role>

  <goal>
    WorkspaceGrid.tsx contains zero inline wizard/dialog components, all dialogs are opened
    via Xrm.Navigation.navigateTo calls to standalone Code Pages, and WorkspaceGrid.tsx is
    under 500 lines of code.
  </goal>

  <constraints>
    <constraint source="ADR-006">All standalone dialogs must use Code Pages opened via navigateTo — no inline lazy imports</constraint>
    <constraint source="ADR-012">Wizard components live in @spaarke/ui-components — workspace only calls navigateTo</constraint>
    <constraint source="ADR-021">Fluent v9 tokens only, React 19, dark mode support required</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-006-anti-legacy-js.md</file>
      <file>.claude/adr/ADR-012-shared-components.md</file>
      <file>.claude/patterns/webresource/full-page-custom-page.md</file>
      <file>src/solutions/LegalWorkspace/src/components/WorkspaceGrid.tsx</file>
    </files>
  </knowledge>

  <steps>
    <step id="1">Remove LazyEventWizardDialog import and its React.lazy(() => import()) declaration</step>
    <step id="2">Remove LazyTodoWizardDialog import and its React.lazy(() => import()) declaration</step>
    <step id="3">Remove LazyWorkAssignmentWizardDialog import and its React.lazy(() => import()) declaration</step>
    <step id="4">Remove LazySummarizeFilesDialog import and its React.lazy(() => import()) declaration</step>
    <step id="5">Remove LazyFindSimilarDialog import and its React.lazy(() => import()) declaration</step>
    <step id="6">Remove all associated useState hooks for dialog visibility (showEventWizard, showTodoWizard, showWorkAssignment, showSummarize, showFindSimilar, etc.)</step>
    <step id="7">Replace each dialog trigger with an Xrm.Navigation.navigateTo call — pass required params (parentId, documentIds, containerId) via URL data string</step>
    <step id="8">Implement post-dialog refresh handling — use navigateTo promise .then() to refresh affected grid sections after dialog closes</step>
    <step id="9">Remove all Suspense wrapper blocks that surrounded the lazy dialogs</step>
    <step id="10">Verify WorkspaceGrid.tsx is under 500 LOC — if over, extract helper functions to separate utility file</step>
    <step id="11">Run npm run build for LegalWorkspace — fix any compilation errors from removed imports/state</step>
    <step id="12">Test all 5 dialogs open correctly from workspace toolbar buttons and context menus</step>
  </steps>

  <acceptance-criteria>
    <criterion>Zero React.lazy() imports for wizard/dialog components remain in WorkspaceGrid.tsx</criterion>
    <criterion>Zero useState hooks for dialog visibility remain in WorkspaceGrid.tsx</criterion>
    <criterion>Zero Suspense blocks for dialogs remain in WorkspaceGrid.tsx</criterion>
    <criterion>All 5 dialogs (CreateEvent, CreateTodo, CreateWorkAssignment, SummarizeFiles, FindSimilar) open via navigateTo</criterion>
    <criterion>Each navigateTo call passes correct parameters via data string</criterion>
    <criterion>Post-dialog refresh works for each dialog (grid sections update after dialog closes)</criterion>
    <criterion>WorkspaceGrid.tsx is under 500 lines of code</criterion>
    <criterion>LegalWorkspace npm run build succeeds with zero errors</criterion>
  </acceptance-criteria>
</task>
