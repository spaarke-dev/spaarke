<task id="UDSS-043" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Add wizard buttons to sprk_event main form</title>
    <status>not-started</status>
    <phase>5</phase>
    <estimated-effort>3 hours</estimated-effort>
    <tags>ribbon, event, ribbondiffxml</tags>
    <dependencies>040</dependencies>
  </metadata>

  <prompt>
    Add command bar buttons to the sprk_event main form for launching wizard Code Pages.
    Buttons should include: Upload Document and Run Playbook. Each button wires to the
    corresponding function in sprk_wizard_commands.js. Use the ribbon-edit skill to export,
    modify RibbonDiffXml, and import back.
  </prompt>

  <role>Dataverse customizer with ribbon XML and command bar experience</role>

  <goal>
    sprk_event main form command bar has buttons for Upload Document and Run Playbook,
    each launching the correct wizard Code Page.
  </goal>

  <constraints>
    <constraint source="ADR-006">No legacy JS webresources for UI — buttons launch Code Pages via navigateTo.</constraint>
    <constraint source="ADR-021">Fluent v9 tokens only, React 19, dark mode required.</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/skills/ribbon-edit/SKILL.md</file>
      <file>.claude/patterns/pcf/dialog-patterns.md</file>
    </files>
  </knowledge>

  <steps>
    <step id="1">Export the Dataverse solution containing sprk_event entity customizations.</step>
    <step id="2">Locate or create RibbonDiffXml for sprk_event main form command bar.</step>
    <step id="3">Add button: "Upload Document" → Sprk.Commands.Wizards.openUploadDocument.</step>
    <step id="4">Add button: "Run Playbook" → Sprk.Commands.Wizards.openPlaybookLibrary.</step>
    <step id="5">Import modified solution back to Dataverse and publish.</step>
  </steps>

  <acceptance-criteria>
    <criterion>sprk_event main form command bar shows Upload Document and Run Playbook buttons.</criterion>
    <criterion>Each button calls the correct function in sprk_wizard_commands.js.</criterion>
    <criterion>Buttons pass formContext with entity type and record ID.</criterion>
    <criterion>Clicking each button opens the corresponding wizard Code Page in a dialog.</criterion>
    <criterion>Solution imports and publishes without errors.</criterion>
  </acceptance-criteria>
</task>
