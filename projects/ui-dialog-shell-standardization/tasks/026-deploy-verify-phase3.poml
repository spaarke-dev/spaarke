<task id="UDSS-026" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Deploy and verify Phase 3 end-to-end</title>
    <status>not-started</status>
    <phase>3</phase>
    <estimated-effort>3 hours</estimated-effort>
    <tags>deploy, verify, integration</tags>
    <dependencies>UDSS-022, UDSS-024, UDSS-025</dependencies>
    <parallel-group>none</parallel-group>
  </metadata>
  <prompt>Deploy all Phase 3 artifacts and verify end-to-end functionality. This includes the refactored AnalysisBuilder, the new PlaybookLibrary Code Page, updated Corporate Workspace with navigateTo playbook cards, and confirming QuickStart removal has no regressions.</prompt>
  <role>Senior developer with deployment and integration testing expertise</role>
  <goal>All Phase 3 artifacts deployed to dev environment and verified working end-to-end</goal>
  <constraints>
    <constraint source="deployment">Use existing deploy scripts — do not create new deployment automation</constraint>
    <constraint source="testing">Verify both happy path and error scenarios</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/skills/dataverse-deploy/SKILL.md</file>
      <file>.claude/skills/code-page-deploy/SKILL.md</file>
      <file>scripts/Deploy-LegalWorkspaceCustomPage.ps1</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Build all Phase 3 artifacts: AnalysisBuilder, PlaybookLibrary, LegalWorkspace</step>
    <step id="2">Deploy PlaybookLibrary Code Page (sprk_playbooklibrary) as new webresource</step>
    <step id="3">Deploy refactored AnalysisBuilder webresource</step>
    <step id="4">Deploy updated LegalWorkspace (Corporate Workspace)</step>
    <step id="5">Verify: AnalysisBuilder opens and functions as before (regression test)</step>
    <step id="6">Verify: Get Started cards open PlaybookLibrary with correct intent</step>
    <step id="7">Verify: PlaybookLibrary full browse mode works (no intent)</step>
    <step id="8">Verify: PlaybookLibrary intent mode auto-selects playbook and shows streamlined flow</step>
    <step id="9">Verify: QuickStart panel no longer appears anywhere</step>
    <step id="10">Verify: Dark mode rendering for all new/updated components</step>
  </steps>
  <acceptance-criteria>
    <criterion>All webresources deployed successfully to dev environment</criterion>
    <criterion>AnalysisBuilder functions identically to pre-refactor (no regression)</criterion>
    <criterion>PlaybookLibrary Code Page opens via navigateTo from workspace cards</criterion>
    <criterion>Intent pre-selection works for email-compose, assign-counsel, meeting-schedule</criterion>
    <criterion>No QuickStart panel visible in Corporate Workspace</criterion>
    <criterion>Dark mode renders correctly for all Phase 3 components</criterion>
  </acceptance-criteria>
</task>
