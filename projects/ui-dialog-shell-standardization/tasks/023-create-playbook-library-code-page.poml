<task id="UDSS-023" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Create PlaybookLibrary Code Page wrapper (sprk_playbooklibrary)</title>
    <status>not-started</status>
    <phase>3</phase>
    <estimated-effort>3 hours</estimated-effort>
    <tags>code-page, vite, playbook</tags>
    <dependencies>020</dependencies>
  </metadata>

  <prompt>
    Create a new PlaybookLibrary Code Page (sprk_playbooklibrary) under src/solutions/PlaybookLibrary/.
    This is a thin Vite-based wrapper (~30-50 LOC) that renders PlaybookLibraryShell from
    @spaarke/ui-components. It parses URL data params for entityType, entityId, intent, and mode,
    creates an XrmDataService, and renders the shell. This Code Page is the target for Corporate
    Workspace Get Started cards that launch playbook workflows.
  </prompt>

  <role>Senior TypeScript/React developer with Vite Code Page experience</role>

  <goal>
    src/solutions/PlaybookLibrary/ exists with Vite config, main.tsx, and builds to a single HTML
    file suitable for Dataverse web resource deployment as sprk_playbooklibrary.
  </goal>

  <constraints>
    <constraint source="ADR-012">Services must use IDataService abstraction.</constraint>
    <constraint source="ADR-026">Vite + vite-plugin-singlefile for Code Pages.</constraint>
    <constraint source="ADR-021">Fluent v9 tokens only, React 19, dark mode required.</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>src/solutions/EventsPage/</file>
      <file>src/client/shared/Spaarke.UI.Components/src/components/PlaybookLibraryShell/</file>
      <file>.claude/patterns/webresource/full-page-custom-page.md</file>
    </files>
  </knowledge>

  <steps>
    <step id="1">Create src/solutions/PlaybookLibrary/ directory structure following EventsPage pattern.</step>
    <step id="2">Create vite.config.ts with vite-plugin-singlefile, React plugin, and proper resolve aliases.</step>
    <step id="3">Create main.tsx with createRoot entry point, FluentProvider, URL param parsing, and PlaybookLibraryShell rendering.</step>
    <step id="4">Create package.json with build script and dependencies.</step>
    <step id="5">Build and verify single HTML output is produced.</step>
  </steps>

  <acceptance-criteria>
    <criterion>src/solutions/PlaybookLibrary/ exists with vite.config.ts, main.tsx, package.json.</criterion>
    <criterion>main.tsx is ~30-50 LOC thin wrapper rendering PlaybookLibraryShell.</criterion>
    <criterion>URL data params (entityType, entityId, intent, mode) are parsed and passed as props.</criterion>
    <criterion>Vite build produces a single HTML file.</criterion>
    <criterion>FluentProvider wraps the component with theme detection.</criterion>
  </acceptance-criteria>
</task>
