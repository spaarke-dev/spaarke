<task id="UDSS-009" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Update Corporate Workspace to use navigateTo for Matter + Project</title>
    <status>not-started</status>
    <phase>1</phase>
    <estimated-effort>4 hours</estimated-effort>
    <tags>corporate-workspace, refactor, navigateTo</tags>
    <dependencies>UDSS-006, UDSS-008</dependencies>
    <parallel-group>none</parallel-group>
  </metadata>
  <prompt>Refactor the Corporate Workspace (LegalWorkspace) to launch CreateMatter and CreateProject wizards via Xrm.Navigation.navigateTo instead of rendering them inline. Remove the lazy-loaded dialog components and their state management. Wire up post-dialog refresh callbacks.</prompt>
  <role>Frontend developer with Dataverse experience</role>
  <goal>Corporate Workspace launches Matter and Project wizards via navigateTo web resource dialogs instead of inline rendering</goal>
  <constraints>
    <constraint source="ADR-006">Standalone dialogs must use Code Pages opened via navigateTo — not inline PCF rendering</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/patterns/pcf/dialog-patterns.md</file>
      <file>src/solutions/LegalWorkspace/src/components/Shell/WorkspaceGrid.tsx</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Read WorkspaceGrid.tsx and identify all inline wizard rendering code</step>
    <step id="2">Remove LazyWizardDialog and LazyProjectWizardDialog imports</step>
    <step id="3">Remove isWizardOpen/isProjectWizardOpen state variables</step>
    <step id="4">Replace handler functions with navigateTo('sprk_creatematterwizard') and navigateTo('sprk_createprojectwizard') calls</step>
    <step id="5">Handle navigateTo Promise for data refresh (wire refetch callbacks on dialog close)</step>
    <step id="6">Remove Suspense wrapper blocks for the removed wizard components</step>
    <step id="7">Verify workspace renders correctly without inline wizard dialogs</step>
  </steps>
  <acceptance-criteria>
    <criterion>No inline CreateMatter or CreateProject dialog rendering in WorkspaceGrid</criterion>
    <criterion>navigateTo calls open the correct web resources</criterion>
    <criterion>Data refresh triggers correctly when dialogs close</criterion>
  </acceptance-criteria>
</task>
