<task id="UDSS-015" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Extract FindSimilar dialog to shared library + Code Page wrapper</title>
    <status>not-started</status>
    <phase>2</phase>
    <estimated-effort>4 hours</estimated-effort>
    <tags>shared-library, dialog, find-similar, code-page, vite</tags>
    <dependencies>001, 002, 004</dependencies>
    <parallel-group>phase2-wizard-extraction</parallel-group>
  </metadata>

  <prompt>
    Move the FindSimilar dialog (4 files) from LegalWorkspace inline components to the
    @spaarke/ui-components shared library, then create a standalone Vite Code Page wrapper.
    FindSimilar is a dialog (not a wizard) that uses AI Search to find similar documents.
    It may use a simpler layout than the multi-step wizards.
  </prompt>

  <role>Frontend developer with expertise in React 19, Fluent UI v9, Vite, and Dataverse Code Pages</role>

  <goal>
    FindSimilar dialog lives in @spaarke/ui-components/components/FindSimilarDialog/ with 4 files,
    a new src/solutions/FindSimilarDialog/ Code Page exists and builds successfully via Vite,
    and the dialog can be opened from Corporate Workspace via navigateTo.
  </goal>

  <constraints>
    <constraint source="ADR-012">Services must use IDataService abstraction</constraint>
    <constraint source="ADR-026">Vite + vite-plugin-singlefile for Code Pages — single HTML output</constraint>
    <constraint source="ADR-021">Fluent v9 tokens only, React 19, dark mode support required</constraint>
    <constraint source="ADR-006">Standalone dialogs must be Code Pages, not PCF wrappers</constraint>
    <constraint source="ADR-013">AI Search integration must go through BFF API</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-012-shared-components.md</file>
      <file>.claude/adr/ADR-026-full-page-custom-page-standard.md</file>
      <file>.claude/patterns/webresource/full-page-custom-page.md</file>
      <file>src/solutions/LegalWorkspace/src/components/FindSimilar/</file>
    </files>
  </knowledge>

  <steps>
    <step id="1">Move 4 files from LegalWorkspace/src/components/FindSimilar/ to src/client/shared/src/components/FindSimilarDialog/ — preserve search result rendering and AI Search integration</step>
    <step id="2">Refactor findSimilarService.ts to implement IDataService abstraction — preserve BFF API calls for AI Search</step>
    <step id="3">Export FindSimilarDialog from @spaarke/ui-components package index</step>
    <step id="4">Create src/solutions/FindSimilarDialog/ Code Page project with Vite config, viteSingleFile plugin, package.json, tsconfig.json</step>
    <step id="5">Create Code Page index.tsx that reads URL params (documentId, containerId), wraps dialog in FluentProvider + DialogShell</step>
    <step id="6">Run npm install and npm run build in both shared library and Code Page — fix any compilation errors</step>
    <step id="7">Verify single HTML file output exists in dist/ and is deployable as a Dataverse web resource</step>
  </steps>

  <acceptance-criteria>
    <criterion>4 dialog files exist in @spaarke/ui-components/components/FindSimilarDialog/</criterion>
    <criterion>findSimilarService.ts implements IDataService interface</criterion>
    <criterion>FindSimilarDialog is exported from shared library package index</criterion>
    <criterion>src/solutions/FindSimilarDialog/ builds successfully with Vite producing a single HTML file</criterion>
    <criterion>No remaining FindSimilar component files in LegalWorkspace/src/components/</criterion>
    <criterion>npm run build succeeds with zero errors in both shared library and Code Page</criterion>
  </acceptance-criteria>
</task>
