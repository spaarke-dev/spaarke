<task id="UDSS-013" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Extract CreateWorkAssignment wizard to shared library + Code Page wrapper</title>
    <status>not-started</status>
    <phase>2</phase>
    <estimated-effort>7 hours</estimated-effort>
    <tags>shared-library, wizard, work-assignment, code-page, vite</tags>
    <dependencies>001, 002, 004</dependencies>
    <parallel-group>phase2-wizard-extraction</parallel-group>
  </metadata>

  <prompt>
    Move the CreateWorkAssignment wizard (9 files) from LegalWorkspace inline components to the
    @spaarke/ui-components shared library, then create a standalone Vite Code Page wrapper.

    IMPORTANT: This wizard uses WizardShell directly, NOT CreateRecordWizard, because it has a
    different step sequence (SelectWork → AddFiles → EnterInfo → NextStepsSelection → AssignWork
    → CreateFollowOnEvent). The step orchestration is custom and must be preserved exactly.
  </prompt>

  <role>Frontend developer with expertise in React 19, Fluent UI v9, Vite, and Dataverse Code Pages</role>

  <goal>
    CreateWorkAssignment wizard lives in @spaarke/ui-components/components/CreateWorkAssignmentWizard/
    with 9 files, a new src/solutions/CreateWorkAssignmentWizard/ Code Page exists and builds
    successfully via Vite, and the wizard can be opened from Corporate Workspace via navigateTo.
  </goal>

  <constraints>
    <constraint source="ADR-012">Services must use IDataService abstraction — refactor workAssignmentService.ts to implement IDataService interface</constraint>
    <constraint source="ADR-026">Vite + vite-plugin-singlefile for Code Pages — single HTML output</constraint>
    <constraint source="ADR-021">Fluent v9 tokens only, React 19, dark mode support required</constraint>
    <constraint source="ADR-006">Standalone dialogs must be Code Pages, not PCF wrappers</constraint>
    <constraint source="custom">This wizard uses WizardShell directly — do NOT refactor to CreateRecordWizard pattern</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-012-shared-components.md</file>
      <file>.claude/adr/ADR-026-full-page-custom-page-standard.md</file>
      <file>.claude/patterns/webresource/full-page-custom-page.md</file>
      <file>src/solutions/LegalWorkspace/src/components/CreateWorkAssignment/</file>
    </files>
  </knowledge>

  <steps>
    <step id="1">Inventory all 9 files in CreateWorkAssignment/ — identify SelectWorkStep, AddFilesStep, EnterInfoStep, NextStepsSelectionStep, AssignWorkStep, CreateFollowOnEventStep, workAssignmentService.ts, types, and index</step>
    <step id="2">Move all 9 files to src/client/shared/src/components/CreateWorkAssignmentWizard/ — preserve WizardShell usage and custom step sequence</step>
    <step id="3">Refactor workAssignmentService.ts to implement IDataService abstraction while preserving multi-step create logic</step>
    <step id="4">Export CreateWorkAssignmentWizard from @spaarke/ui-components package index</step>
    <step id="5">Create src/solutions/CreateWorkAssignmentWizard/ Code Page project with Vite config, viteSingleFile plugin, package.json, tsconfig.json</step>
    <step id="6">Create Code Page index.tsx that reads URL params, wraps wizard in FluentProvider + DialogShell — pass through all required context (matterId, projectId)</step>
    <step id="7">Run npm install and npm run build in both shared library and Code Page — fix any compilation errors</step>
    <step id="8">Verify the custom step sequence (SelectWork → AddFiles → EnterInfo → NextStepsSelection → AssignWork → CreateFollowOnEvent) is preserved in extracted wizard</step>
  </steps>

  <acceptance-criteria>
    <criterion>9 wizard files exist in @spaarke/ui-components/components/CreateWorkAssignmentWizard/</criterion>
    <criterion>workAssignmentService.ts implements IDataService interface</criterion>
    <criterion>Wizard uses WizardShell directly — NOT CreateRecordWizard</criterion>
    <criterion>Custom step sequence is preserved exactly: SelectWork → AddFiles → EnterInfo → NextStepsSelection → AssignWork → CreateFollowOnEvent</criterion>
    <criterion>CreateWorkAssignmentWizard is exported from shared library package index</criterion>
    <criterion>src/solutions/CreateWorkAssignmentWizard/ builds successfully with Vite producing a single HTML file</criterion>
    <criterion>No remaining CreateWorkAssignment component files in LegalWorkspace/src/components/</criterion>
    <criterion>npm run build succeeds with zero errors in both shared library and Code Page</criterion>
  </acceptance-criteria>
</task>
