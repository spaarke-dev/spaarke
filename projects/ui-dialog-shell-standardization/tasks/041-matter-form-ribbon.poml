<task id="UDSS-041" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Add wizard buttons to sprk_matter main form command bar</title>
    <status>not-started</status>
    <phase>5</phase>
    <estimated-effort>4 hours</estimated-effort>
    <tags>ribbon, matter, ribbondiffxml</tags>
    <dependencies>040</dependencies>
  </metadata>

  <prompt>
    Add command bar buttons to the sprk_matter main form for launching wizard Code Pages.
    Buttons should include: Create Project, Create Event, Upload Document, and Run Playbook.
    Each button wires to the corresponding function in sprk_wizard_commands.js. Use the
    ribbon-edit skill to export the solution, modify RibbonDiffXml, and import back.
  </prompt>

  <role>Dataverse customizer with ribbon XML and command bar experience</role>

  <goal>
    sprk_matter main form command bar has buttons for Create Project, Create Event, Upload
    Document, and Run Playbook, each launching the correct wizard Code Page.
  </goal>

  <constraints>
    <constraint source="ADR-006">No legacy JS webresources for UI — buttons launch Code Pages via navigateTo.</constraint>
    <constraint source="ADR-021">Fluent v9 tokens only, React 19, dark mode required.</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/skills/ribbon-edit/SKILL.md</file>
      <file>.claude/patterns/pcf/dialog-patterns.md</file>
    </files>
  </knowledge>

  <steps>
    <step id="1">Export the Dataverse solution containing sprk_matter entity customizations.</step>
    <step id="2">Locate or create RibbonDiffXml for sprk_matter main form command bar.</step>
    <step id="3">Add button: "Create Project" → Sprk.Commands.Wizards.openCreateProject.</step>
    <step id="4">Add button: "Create Event" → Sprk.Commands.Wizards.openCreateEvent.</step>
    <step id="5">Add button: "Upload Document" → Sprk.Commands.Wizards.openUploadDocument.</step>
    <step id="6">Add button: "Run Playbook" → Sprk.Commands.Wizards.openPlaybookLibrary.</step>
    <step id="7">Import modified solution back to Dataverse and publish.</step>
  </steps>

  <acceptance-criteria>
    <criterion>sprk_matter main form command bar shows Create Project, Create Event, Upload Document, Run Playbook buttons.</criterion>
    <criterion>Each button calls the correct function in sprk_wizard_commands.js.</criterion>
    <criterion>Buttons pass formContext with entity type and record ID.</criterion>
    <criterion>Clicking each button opens the corresponding wizard Code Page in a dialog.</criterion>
    <criterion>Solution imports and publishes without errors.</criterion>
  </acceptance-criteria>
</task>
