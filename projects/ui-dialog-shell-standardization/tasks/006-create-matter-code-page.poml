<task id="UDSS-006" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Create CreateMatterWizard Code Page wrapper (Vite)</title>
    <status>not-started</status>
    <phase>1</phase>
    <estimated-effort>4 hours</estimated-effort>
    <tags>code-page, vite, wizard, matter</tags>
    <dependencies>UDSS-004, UDSS-005c</dependencies>
    <parallel-group>P1-code-pages</parallel-group>
  </metadata>
  <prompt>Create a Vite-based Code Page wrapper that renders the extracted CreateMatterWizard component as a standalone web resource. The wrapper handles theme detection, URL parameter parsing, auth initialization, and wires the Xrm adapter to the wizard. Output is a single HTML file deployable as a Dataverse web resource.</prompt>
  <role>Frontend developer with Vite experience</role>
  <goal>src/solutions/CreateMatterWizard/ with working Vite build producing single HTML output</goal>
  <constraints>
    <constraint source="ADR-026">Code Pages must use Vite with vite-plugin-singlefile for single HTML output</constraint>
    <constraint source="ADR-021">Use React 19 createRoot — Code Pages bundle their own React (not platform-provided)</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/adr/ADR-026-full-page-custom-page-standard.md</file>
      <file>.claude/patterns/webresource/full-page-custom-page.md</file>
      <file>src/solutions/EventsPage/</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Create src/solutions/CreateMatterWizard/ directory</step>
    <step id="2">Create package.json with dependencies: React 19, Fluent UI v9, @spaarke/ui-components, @spaarke/auth</step>
    <step id="3">Create vite.config.ts with viteSingleFile plugin</step>
    <step id="4">Create tsconfig.json</step>
    <step id="5">Create index.html with root div</step>
    <step id="6">Create src/main.tsx (~40 LOC): parseDataParams, detectTheme, initAuth, createRoot, render CreateMatterWizard with embedded=true and xrmDataServiceAdapter</step>
    <step id="7">Run npm install and npm run build</step>
    <step id="8">Verify single HTML file output in dist/</step>
  </steps>
  <acceptance-criteria>
    <criterion>Build produces a single HTML file in dist/</criterion>
    <criterion>Renders CreateMatterWizard with theme detection</criterion>
    <criterion>Uses Xrm adapter for data access</criterion>
  </acceptance-criteria>
</task>
