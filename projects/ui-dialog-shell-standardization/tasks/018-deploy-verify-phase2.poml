<task id="UDSS-018" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Deploy and verify Phase 2 end-to-end</title>
    <status>not-started</status>
    <phase>2</phase>
    <estimated-effort>4 hours</estimated-effort>
    <tags>deployment, verification, end-to-end, serial-gate</tags>
    <dependencies>016, 017</dependencies>
    <parallel-group>none</parallel-group>
  </metadata>
  <prompt>Build and deploy all Phase 2 Code Pages and the updated Corporate Workspace to Dataverse. Verify each wizard launches correctly from the workspace, creates records as expected, and displays properly in both light and dark modes. This is a serial gate — no Phase 3 work should begin until this task passes.</prompt>
  <role>Frontend developer with expertise in React 19, Fluent UI v9, and Dataverse Code Pages</role>
  <goal>All Phase 2 Code Pages deployed to Dataverse with clean display names, Corporate Workspace updated, and every wizard verified working end-to-end including dark mode</goal>
  <constraints>
    <constraint source="ADR-026">Vite + vite-plugin-singlefile for Code Pages</constraint>
    <constraint source="ADR-021">Fluent v9 tokens only, dark mode required — must test both themes</constraint>
    <constraint source="deployment">Use clean webresource display names — "Create New Event" not "sprk_createeventwizard"</constraint>
    <constraint source="serial-gate">This is a deployment gate — all Phase 2 work must be verified before Phase 3 begins</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/adr/ADR-026-full-page-custom-page-standard.md</file>
      <file>.claude/skills/dataverse-deploy/SKILL.md</file>
      <file>.claude/skills/code-page-deploy/SKILL.md</file>
      <file>scripts/Deploy-EventsPage.ps1</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Build all 5 new Code Pages (npm run build in each solution folder): CreateEventWizard, CreateTodoWizard, CreateWorkAssignmentWizard, SummarizeFilesWizard, FindSimilarDialog</step>
    <step id="2">Build the migrated DocumentUploadWizard (npm run build) to verify Vite migration output</step>
    <step id="3">Build the updated Corporate Workspace (npm run build in src/solutions/LegalWorkspace/)</step>
    <step id="4">Deploy each Code Page webresource with clean display names: "Create New Event" (sprk_createeventwizard), "Create New To Do" (sprk_createtodowizard), "Create Work Assignment" (sprk_createworkassignmentwizard), "Summarize Files" (sprk_summarizefileswizard), "Find Similar" (sprk_findsimilar)</step>
    <step id="5">Deploy the updated DocumentUploadWizard webresource</step>
    <step id="6">Deploy the updated Corporate Workspace webresource</step>
    <step id="7">Publish all customizations in Dataverse</step>
    <step id="8">Test CreateEvent wizard: open from workspace, create an event record, verify record appears after dialog close</step>
    <step id="9">Test CreateTodo wizard: open from workspace, create a todo (event with todoflag=true), verify record appears after dialog close</step>
    <step id="10">Test CreateWorkAssignment wizard: open from workspace, complete assignment flow, verify record created</step>
    <step id="11">Test SummarizeFiles wizard: open from workspace, select files, verify summarization completes</step>
    <step id="12">Test FindSimilar dialog: open from workspace, verify search results display correctly</step>
    <step id="13">Test dark mode: switch Dataverse to dark theme, verify all 5 wizards render correctly with Fluent v9 dark tokens</step>
    <step id="14">Test DocumentUploadWizard: verify Vite-built version works identically to previous webpack version</step>
    <step id="15">Verify no console errors in browser DevTools for any wizard</step>
  </steps>
  <acceptance-criteria>
    <criterion>All 5 new Code Pages deployed with clean display names</criterion>
    <criterion>DocumentUploadWizard deployed with Vite build</criterion>
    <criterion>Corporate Workspace deployed with navigateTo calls</criterion>
    <criterion>All customizations published</criterion>
    <criterion>CreateEvent wizard creates sprk_event record successfully</criterion>
    <criterion>CreateTodo wizard creates sprk_event with todoflag=true successfully</criterion>
    <criterion>CreateWorkAssignment wizard completes full assignment flow</criterion>
    <criterion>SummarizeFiles wizard completes file summarization</criterion>
    <criterion>FindSimilar dialog displays search results</criterion>
    <criterion>Post-dialog refresh works — workspace data updates after each dialog close</criterion>
    <criterion>All wizards render correctly in dark mode</criterion>
    <criterion>Zero console errors in browser DevTools</criterion>
  </acceptance-criteria>
</task>
