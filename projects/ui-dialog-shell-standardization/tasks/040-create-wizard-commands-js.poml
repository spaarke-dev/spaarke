<task id="UDSS-040" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Create sprk_wizard_commands.js webresource with launch functions</title>
    <status>not-started</status>
    <phase>5</phase>
    <estimated-effort>4 hours</estimated-effort>
    <tags>ribbon, webresource, commands</tags>
    <dependencies>018</dependencies>
  </metadata>

  <prompt>
    Create a JavaScript webresource (sprk_wizard_commands.js) containing launch functions for
    each wizard Code Page. Each function accepts entity context parameters (formContext or
    selectedItems) and calls Xrm.Navigation.navigateTo with the appropriate webresource name
    and data parameters. Functions include: openCreateMatter, openCreateProject, openCreateEvent,
    openCreateTodo, openUploadDocument, openPlaybookLibrary. Deploy the webresource to Dataverse.
  </prompt>

  <role>Senior JavaScript developer with Dataverse ribbon command experience</role>

  <goal>
    sprk_wizard_commands.js is deployed to Dataverse with working launch functions for all wizard
    Code Pages, callable from ribbon command definitions.
  </goal>

  <constraints>
    <constraint source="ADR-006">No legacy JS webresources for UI — this is a command/launcher script only, not a UI component.</constraint>
    <constraint source="ADR-021">Fluent v9 tokens only, React 19, dark mode required.</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/patterns/pcf/dialog-patterns.md</file>
      <file>.claude/skills/ribbon-edit/SKILL.md</file>
    </files>
  </knowledge>

  <steps>
    <step id="1">Create sprk_wizard_commands.js with namespace Sprk.Commands.Wizards.</step>
    <step id="2">Implement openCreateMatter function — navigateTo sprk_creatematterwizard with entity context.</step>
    <step id="3">Implement openCreateProject function — navigateTo sprk_createprojectwizard with entity context.</step>
    <step id="4">Implement openCreateEvent function — navigateTo sprk_createeventwizard with entity context.</step>
    <step id="5">Implement openCreateTodo function — navigateTo sprk_createtodowizard with entity context.</step>
    <step id="6">Implement openUploadDocument function — navigateTo sprk_documentuploadwizard with entity context.</step>
    <step id="7">Implement openPlaybookLibrary function — navigateTo sprk_playbooklibrary with entity context.</step>
    <step id="8">Deploy webresource to Dataverse dev environment.</step>
  </steps>

  <acceptance-criteria>
    <criterion>sprk_wizard_commands.js exists with Sprk.Commands.Wizards namespace.</criterion>
    <criterion>Functions exist: openCreateMatter, openCreateProject, openCreateEvent, openCreateTodo, openUploadDocument, openPlaybookLibrary.</criterion>
    <criterion>Each function calls Xrm.Navigation.navigateTo with correct webresource name and data params.</criterion>
    <criterion>Entity context (entityType, entityId) is extracted from formContext and passed as data.</criterion>
    <criterion>Dialog dimensions are set appropriately (85% width/height).</criterion>
    <criterion>Webresource is deployed to Dataverse dev environment.</criterion>
  </acceptance-criteria>
</task>
