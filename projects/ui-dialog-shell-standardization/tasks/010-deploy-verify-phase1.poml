<task id="UDSS-010" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Deploy and verify Phase 1 end-to-end</title>
    <status>not-started</status>
    <phase>1</phase>
    <estimated-effort>3 hours</estimated-effort>
    <tags>deploy, verification, phase-gate</tags>
    <dependencies>UDSS-009</dependencies>
    <parallel-group>none</parallel-group>
  </metadata>
  <prompt>Deploy all Phase 1 artifacts to the Dataverse dev environment and perform end-to-end verification. This is the phase gate — all wizard extractions, Code Pages, and workspace changes must work together in production-like conditions.</prompt>
  <role>Full-stack developer with deployment experience</role>
  <goal>Phase 1 deployed and verified end-to-end: both wizards open from workspace via navigateTo, consistent Dataverse chrome, refresh works, dark mode OK</goal>
  <constraints>
    <constraint source="deployment">Use code-page-deploy skill for web resource deployment</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/skills/code-page-deploy/SKILL.md</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Build both Code Pages (npm run build in CreateMatterWizard/ and CreateProjectWizard/)</step>
    <step id="2">Deploy sprk_creatematterwizard web resource (display name: "Create New Matter")</step>
    <step id="3">Deploy sprk_createprojectwizard web resource (display name: "Create New Project")</step>
    <step id="4">Deploy updated Corporate Workspace (LegalWorkspace build and deploy)</step>
    <step id="5">Test: Create Matter wizard opens from workspace via navigateTo</step>
    <step id="6">Test: Dataverse modal chrome is visible (title bar, close button)</step>
    <step id="7">Test: Post-dialog data refresh triggers correctly</step>
    <step id="8">Test: Dark mode renders correctly in both wizards</step>
  </steps>
  <acceptance-criteria>
    <criterion>Both wizards open from Corporate Workspace via navigateTo</criterion>
    <criterion>Consistent Dataverse modal chrome on both wizards</criterion>
    <criterion>Data refresh works after dialog close</criterion>
    <criterion>Dark mode renders correctly</criterion>
  </acceptance-criteria>
</task>
