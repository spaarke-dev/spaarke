  <prompt>
    <goal>Wire all Phase 1 components together and verify end-to-end flow: client detects context → calls mapping endpoint → selects playbook → creates session.</goal>
    <context>
      Phase 1 streams A, B, C have been implemented independently. This task integrates them
      and performs smoke testing to verify the full flow works.
    </context>
    <constraints>
      - MUST verify: context detection → API call → playbook selection → session creation
      - MUST verify: no-mapping fallback (generic chat mode)
      - MUST verify: Redis cache hit on second request
      - MUST run full dotnet build and test suite
    </constraints>
  </prompt>

  <knowledge>
    <files>
      <file>.claude/constraints/api.md</file>
      <file>.claude/constraints/pcf.md</file>
    </files>
  </knowledge>

  <steps>
    <step>Run full `dotnet build` to verify all components compile together</step>
    <step>Run `dotnet test` to verify no regressions</step>
    <step>Verify DI registration for ChatContextMappingService in Program.cs</step>
    <step>Verify endpoint registration in ChatEndpoints</step>
    <step>Build client: `cd src/client/code-pages/SprkChatPane && npm run build`</step>
    <step>Review integration points for any gaps</step>
  </steps>

  <outputs>
    <output>All components integrated and building together</output>
    <output>All tests passing</output>
  </outputs>

  <acceptance-criteria>
