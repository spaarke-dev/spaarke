<task id="004" project="ai-sprk-chat-context-awareness-r1">
  <metadata>
    <title>Create seed data JSON for PAC CLI import</title>
    <phase>1B</phase>
    <stream>dataverse</stream>
    <tags>dataverse, data</tags>
    <estimate>1h</estimate>
    <rigor>STANDARD</rigor>
    <parallel-group>A</parallel-group>
    <dependencies>003</dependencies>
  </metadata>

  <prompt>
    <goal>Create a PAC CLI-compatible JSON import file with initial mapping: matter/form → SprkChat Document Assistant playbook.</goal>
    <context>
      The seed data establishes the first context mapping so SprkChat automatically selects the
      Document Assistant playbook when opened from a matter form. Format must be compatible with
      `pac data import --data {file}`.
    </context>
    <constraints>
      - MUST be compatible with PAC CLI `pac data import` command
      - MUST map: entityType="sprk_matter", pageType="form" → Document Assistant playbook
      - MUST reference an existing sprk_aiplaybook record GUID
      - File location: `data/chat-context-mappings.json`
    </constraints>
  </prompt>

  <knowledge>
    <files>
      <file>.claude/patterns/dataverse/entity-operations.md</file>
    </files>
  </knowledge>

  <steps>
    <step>Look up existing sprk_aiplaybook GUIDs (Document Assistant playbook)</step>
    <step>Create data/chat-context-mappings.json with PAC CLI import format</step>
    <step>Include mapping record: matter/form → Document Assistant</step>
    <step>Validate JSON structure</step>
  </steps>

  <outputs>
    <output>data/chat-context-mappings.json</output>
  </outputs>

  <acceptance-criteria>
    <criterion>JSON file is valid PAC CLI import format</criterion>
    <criterion>Contains matter/form → Document Assistant mapping</criterion>
    <criterion>PAC data import succeeds without errors</criterion>
  </acceptance-criteria>
</task>
