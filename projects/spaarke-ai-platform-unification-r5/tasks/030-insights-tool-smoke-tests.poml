<task id="030" project="spaarke-ai-platform-unification-r5">
  <metadata>
    <title>D2-20 Insights tool smoke tests on Spaarke Dev (Wave D7 synthetic GUIDs + SME walkthrough)</title>
    <status>complete-code-scaffold-pending-sme</status>
