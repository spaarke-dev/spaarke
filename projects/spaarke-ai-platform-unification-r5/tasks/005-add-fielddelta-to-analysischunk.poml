  <metadata>
    <title>D1-05 Add `FieldDelta` variant to `AnalysisChunk` (additive SSE event type)</title>
    <status>not-started</status>
    <estimated-effort>2 hours</estimated-effort>
    <actual-effort></actual-effort>
