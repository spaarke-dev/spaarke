<task id="022" project="spaarke-ai-platform-unification-r5">
  <metadata>
    <title>D2-08 Upgrade `DocumentViewerWidget` (R4 stub) to use extracted `RichFilePreview` renderer</title>
    <status>code-authoring-complete</status>
    <estimated-effort>2 hours</estimated-effort>
    <actual-effort>~1h (sub-agent code-authoring scope; build/test/quality-gates deferred to main session)</actual-effort>
