      <dependency task="006" status="not-started">Azure OpenAI Structured Outputs streaming ŌĆö orchestrator's playbook delegation produces `FieldDelta` chunks via this path.</dependency>
      <dependency task="010" status="not-started">`sprk_analysisaction` seed "Summarize Document for Chat" ŌĆö orchestrator references this action GUID when invoking the playbook.</dependency>
      <dependency task="011" status="not-started">`sprk_analysisplaybook` configuration ŌĆö orchestrator passes this playbook ID to `IPlaybookService` / `AnalysisOrchestrationService.ExecutePlaybookAsync`.</dependency>
    </dependencies>
