<task id="007" project="spaarke-ai-platform-unification-r5">
  <metadata>
    <title>D1-07 Session-files cleanup `IHostedService` (background job)</title>
    <status>complete</status>
    <estimated-effort>4 hours</estimated-effort>
    <actual-effort>4 hours</actual-effort>
