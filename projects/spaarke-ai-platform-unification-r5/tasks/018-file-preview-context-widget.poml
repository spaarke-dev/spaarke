<task id="018" project="spaarke-ai-platform-unification-r5">
  <metadata>
    <title>D2-09 Build `FilePreviewContextWidget` (Context pane; non-modal)</title>
    <status>not-started</status>
    <estimated-effort>1 day</estimated-effort>
    <actual-effort></actual-effort>
    <assigned>AI Agent</assigned>
    <started></started>
