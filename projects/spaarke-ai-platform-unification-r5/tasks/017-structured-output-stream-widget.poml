<task id="017" project="spaarke-ai-platform-unification-r5">
  <metadata>
    <title>D2-07 Build `StructuredOutputStreamWidget` (Workspace; schema-driven; dual-purpose Summarize streaming + Insights static rendering)</title>
    <status>code-authoring-complete</status>
    <estimated-effort>1 day</estimated-effort>
