      <file>tests/unit/Sprk.Bff.Api.Tests/Services/Ai/Chat/PlaybookChatContextProviderTests.cs</file>
      <file>tests/unit/Sprk.Bff.Api.Tests/Services/Ai/Chat/SprkChatAgentFactoryTests.cs</file>
    </relevant-files>
  </context>

  <knowledge>
    <files>
      <file>projects/spaarke-ai-platform-unification-r5/notes/summarize-vertical-remediation-plan.md</file>
      <file>projects/spaarke-ai-platform-unification-r5/notes/task-030-summarize-walkthrough.md</file>
      <file>projects/spaarke-ai-platform-unification-r5/CLAUDE.md</file>
      <file>projects/spaarke-ai-platform-unification-r5/spec.md</file>
      <file>.claude/adr/ADR-010-di-minimalism.md</file>
      <file>src/server/api/Sprk.Bff.Api/CLAUDE.md</file>
    </files>
  </knowledge>

  <constraints>
    <constraint>Backward-compatible: `UploadedFiles` on ChatContext MUST be nullable with default null; existing callers that don't set it continue to work unchanged.</constraint>
    <constraint>System-prompt suffix MUST be compact — token budget matters. Manifest only (fileId + fileName); never include extracted text/binary content.</constraint>
    <constraint>ADR-015: no leakage of file content into logs or prompt context beyond manifest metadata.</constraint>
    <constraint>R5 §3.1 reuse mandate: do NOT introduce a parallel ChatContext or context provider; extend the existing.</constraint>
    <constraint>ADR-010 DI minimalism: no new top-level Program.cs registrations; ChatContext + provider + factory are existing surfaces.</constraint>
    <constraint>Do NOT change the tool description for InvokeSummarizePlaybookTool — task 015 set the LOAD-BEARING description for NFR-12 / UR-01 tool routing; this task only changes the WORLD STATE the LLM sees, not the tool description.</constraint>
  </constraints>

  <steps>
    <step>Load notes/summarize-vertical-remediation-plan.md §3.2 + §4 row 033 + §5 acceptance.</step>
    <step>Read ChatContext.cs, PlaybookChatContextProvider.cs (full), SprkChatAgentFactory.cs lines around system prompt composition.</step>
    <step>Read existing PlaybookChatContextProvider unit tests + SprkChatAgentFactory unit tests for patterns.</step>
    <step>Add nullable UploadedFiles field to ChatContext record (additive — record-with semantics).</step>
    <step>Update all branches in PlaybookChatContextProvider.GetContextAsync to forward session.UploadedFiles into the returned ChatContext.</step>
    <step>Update SprkChatAgentFactory to inject the file-manifest suffix into the system prompt when context.UploadedFiles is non-empty.</step>
    <step>Add 5 unit tests per task acceptance criteria.</step>
    <step>Run `dotnet build -c Release src/server/api/Sprk.Bff.Api/` — verify 0 errors.</step>
    <step>Run targeted tests + full unit suite — verify all pass; 0 regressions.</step>
    <step>Per CLAUDE.md §10: publish-size verification (delta expected ≈ 0 since pure logic, no new packages).</step>
    <step>Commit with conventional message; reference remediation plan.</step>
    <step>Update TASK-INDEX.md status 🔲 → ✅.</step>
  </steps>

  <acceptance-criteria>
    <criterion>ChatContext has additive nullable UploadedFiles field; existing callers compile + run unchanged.</criterion>
    <criterion>PlaybookChatContextProvider surfaces session.UploadedFiles on the returned ChatContext when session has them.</criterion>
    <criterion>SprkChatAgentFactory adds a compact system-prompt suffix listing uploaded fileId + fileName when context.UploadedFiles non-empty.</criterion>
    <criterion>System-prompt suffix does NOT include extracted text content (manifest only); prompt token count stays reasonable.</criterion>
    <criterion>All 5 new unit tests pass; existing tests unaffected.</criterion>
    <criterion>Full unit suite passes; 0 regressions.</criterion>
    <criterion>BFF publish-size delta ≤ +50 KB (logic-only change).</criterion>
  </acceptance-criteria>

