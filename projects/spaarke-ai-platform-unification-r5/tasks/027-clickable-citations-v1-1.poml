  <examples>
    <example name="Citation rendering — clickable vs non-clickable branching" location="N/A — implementation pattern">
      ```tsx
      const dispatch = useDispatchPaneEvent();
      const styles = useStyles();

      return (
        &lt;&gt;
          {citations.map((c, i) =&gt; {
            const label = `[${i + 1}]`;
            return c.href ? (
              &lt;Button
                key={i}
                appearance="subtle"
                size="small"
                className={styles.citationButton}
                onClick={() =&gt; dispatch('context', {
                  type: 'context_update',
                  contextType: 'document',
                  contextData: { url: c.href, displayName: c.source },
                })}
              &gt;{label}&lt;/Button&gt;
            ) : (
              &lt;span key={i} className={styles.citationLabel}&gt;{label}&lt;/span&gt;
            );
          })}
        &lt;/&gt;
      );
      ```
    </example>
    <example name="Synthetic mixed-mode payload (scenario b)" location="N/A — verification fixture">
      ```ts
      // Wave F spike-outcome contingency: observation-citation href populated,
