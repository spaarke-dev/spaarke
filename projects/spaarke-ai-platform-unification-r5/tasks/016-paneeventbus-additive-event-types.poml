    <file purpose="pane-event-bus-source">src/client/shared/Spaarke.AI.Widgets/src/events/PaneEventBus.ts</file>
    <file purpose="pane-event-index">src/client/shared/Spaarke.AI.Widgets/src/events/index.ts</file>
  </inputs>

  <constraints>
    <constraint source="ADR-030">PaneEventBus channel set is permanently CLOSED at 4 (`workspace` | `context` | `conversation` | `safety`). MUST NOT add a 5th channel. Event-type discriminants WITHIN channels are additive.</constraint>
    <constraint source="ADR-030">All event payloads MUST be typed (no `any`; `unknown` acceptable for genuinely polymorphic fields with subscriber-side narrowing). Match the existing PaneEventTypes.ts style.</constraint>
    <constraint source="R5 CLAUDE.md §3.1 reuse mandate">MUST NOT add a new PaneEventBus channel (explicitly listed under "Specifically prohibited"). MUST extend within existing 4 channels.</constraint>
    <constraint source="R5 CLAUDE.md §3.2">R5 introduces NO new feature flags. New event types are unconditional additions to the typed union.</constraint>
    <constraint source="R5 CLAUDE.md §3.4">Exactly these 5 new event types: `workspace.streaming_started`, `workspace.field_delta`, `workspace.streaming_complete`, `context.files_staged`, `context.file_selected`. No additions, no renames.</constraint>
    <constraint source="spec NFR-09">Existing subscribers ignore unknown discriminants. New event types MUST be additive to `WorkspacePaneEvent.type` and `ContextPaneEvent.type` unions, NOT replace or restructure existing literals.</constraint>
    <constraint source="spec NFR-10">Back-compat for AnalysisChunk SSE protocol — N/A directly to this task (no SSE code change here), but the additive principle applies identically. Confirm in task notes.</constraint>
    <constraint source="spec NFR-07">BFF publish-size — this task is pure frontend TypeScript; no BFF binary impact. Confirm publish-size delta = 0 MB in task notes.</constraint>
    <constraint source="ADR-010">DI minimalism — N/A for this task (no service registrations). Confirm.</constraint>
    <constraint source="project">Existing JSDoc style and field-grouping ("// ── X fields ──") comment style MUST be preserved. New fields use the same documentation density as existing fields.</constraint>
    <constraint source="project">No edits to `PaneEventBus.ts` runtime class are needed (channels list is unchanged at 4). If any edit is proposed, STOP and escalate — that would be a 5th-channel violation.</constraint>
  </constraints>

