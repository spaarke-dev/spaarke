  <acceptance-criteria>
    <criterion testable="true">`PaneEventTypes.ts` `WorkspacePaneEvent.type` union includes the 3 new literals `'streaming_started'`, `'field_delta'`, `'streaming_complete'` adjacent to existing literals; existing 11 literals unchanged.</criterion>
