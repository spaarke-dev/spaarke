  <acceptance-criteria>
    <criterion testable="true">Bulk-action bar appears when `selection.size &gt;= 1`; hides at 0; sticky above column-header row in list view.</criterion>
    <criterion testable="true">Bar shows count badge "N selected", Clear affordance, and 6 actions (Email · Download · Pin · Delete · Document Type · Share link).</criterion>
    <criterion testable="true">Download selected: calls `POST /api/documents/bulk-download` via `authenticatedFetch`; downloads returned zip stream as browser file.</criterion>
    <criterion testable="true">Pin selected: writes to localStorage key `spaarke.docs.pinned.{userId}.{matterId}`; pinned rows sort to top per task 041.</criterion>
    <criterion testable="true">Delete selected: opens confirmation Dialog; on confirm, soft-deletes via Xrm.WebApi.</criterion>
    <criterion testable="true">Document Type → selected: applies optimistic UI; on success shows 5s Undo toast; on failure reverts + shows error toast with Retry.</criterion>
    <criterion testable="true">Share link: opens email composer with body containing Dataverse record URLs per selected doc (NOT SPE files).</criterion>
    <criterion testable="true">Failures degrade gracefully — error toast with Retry where appropriate.</criterion>
    <criterion testable="true">PCF builds clean; zero hardcoded hex/rgb; uses `authenticatedFetch` for bulk-download.</criterion>
    <criterion testable="true">axe WCAG 2.1 AA zero violations in light AND dark.</criterion>
    <criterion testable="true">`code-review` + `adr-check` skills pass.</criterion>
    <criterion testable="true">TASK-INDEX.md shows task 045 as ✅ completed.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="Bar visibility tied to selection size">
      <steps>
        <step>Select 0 rows — verify bar hidden.</step>
        <step>Select 1 row — verify bar visible with "1 selected" badge.</step>
        <step>Select 3 rows — verify "3 selected".</step>
        <step>Click Clear — verify selection cleared + bar hidden.</step>
      </steps>
      <expected>Bar appears at ≥1 selection only.</expected>
    </test>
    <test name="Download selected returns zip">
      <steps>
        <step>Select 3 documents.</step>
        <step>Click Download selected.</step>
        <step>Network tab: confirm `POST /api/documents/bulk-download` with `documentIds` array.</step>
        <step>Browser downloads zip file with filename matching `documents-{matterIdOrBulk}-{timestamp}.zip`.</step>
      </steps>
      <expected>Single zip downloaded; auth header present (via authenticatedFetch).</expected>
    </test>
    <test name="Doc Type optimistic UI + 5s Undo">
      <steps>
        <step>Select 5 documents with Doc Type = "Memo".</step>
        <step>Change Doc Type → "Contract" via the bulk menu.</step>
        <step>Verify rows update immediately to "Contract" (optimistic).</step>
        <step>Verify 5s Undo toast appears.</step>
        <step>Click Undo within 5s — verify rows revert to "Memo".</step>
      </steps>
      <expected>Optimistic UI works; Undo reverts.</expected>
    </test>
    <test name="Delete confirmation Dialog">
      <steps>
        <step>Select 2 documents; click Delete selected.</step>
        <step>Verify confirmation Dialog appears with count.</step>
        <step>Click Confirm — verify rows soft-deleted; verify success toast.</step>
      </steps>
      <expected>Confirmation gate present; delete operates on selection.</expected>
    </test>
    <test name="Share link composes Dataverse URLs">
      <steps>
        <step>Select 2 documents; click Share link.</step>
        <step>Verify email composer opens with body containing 2 lines, each `{DocName} → https://{env}.crm.dynamics.com/main.aspx?etn=sprk_document&amp;id={guid}&amp;pagetype=entityrecord`.</step>
      </steps>
      <expected>Body format matches spec; NO SPE file attachments.</expected>
    </test>
    <test name="Dark mode compliance (ADR-021)">
      <steps>
        <step>Toggle dark mode.</step>
        <step>Select rows; verify bar, toolbar buttons, confirmation Dialog, toasts use v9 dark tokens.</step>
        <step>Run axe-core.</step>
      </steps>
      <expected>Zero WCAG violations.</expected>
    </test>
  </ui-tests>

  <notes>
    Depends on task 041 (multi-select state exists) and task 051 (`POST /api/documents/bulk-download` BFF endpoint). The Email-multi-doc-with-zip case may require server-side support beyond the existing email pipeline — if not yet available, escalate per CLAUDE.md §6 (human input required for scope expansion). Optimistic UI rollback for Doc Type requires careful state tracking — store the original values for the 5s window so Undo can restore them. Toaster mount may already exist; verify before adding a duplicate.
  </notes>

