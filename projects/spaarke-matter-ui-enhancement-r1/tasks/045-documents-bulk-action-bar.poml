  <constraints>
    <constraint source="spec">FR-DOC-02 — bar visible when ≥1 row checked; hides at 0; sticky above column-header row</constraint>
    <constraint source="spec">FR-DOC-02 — bar shows: count badge ("N selected"), Clear, 6 actions</constraint>
    <constraint source="spec">FR-DOC-02 — Email selected: SPE files as attachments; multi-doc = single email with zip attachment</constraint>
    <constraint source="spec">FR-DOC-02 — Download selected: calls `POST /api/documents/bulk-download`; multi-doc = single zip response</constraint>
    <constraint source="spec">FR-DOC-02 — Pin selected: localStorage flag (per-user-per-matter); no Dataverse write</constraint>
    <constraint source="spec">FR-DOC-02 — Delete selected: soft-delete via Xrm.WebApi; requires confirmation `Dialog`</constraint>
    <constraint source="spec">FR-DOC-02 — Document Type → selected: bulk Xrm.WebApi update; OPTIMISTIC UI; 5s Undo toast on success; error toast with Retry on failure</constraint>
    <constraint source="spec">FR-DOC-02 — Share link: email composer pre-populated with body `{DocName} → {DataverseRecordURL}` per selected doc (NOT SPE files); URL format `https://{env}.crm.dynamics.com/main.aspx?etn=sprk_document&amp;id={guid}&amp;pagetype=entityrecord`</constraint>
    <constraint source="spec">NFR-02 — axe WCAG 2.1 AA zero violations</constraint>
    <constraint source="spec">NFR-04 — Fluent v9 tokens only</constraint>
    <constraint source="ADR-006">PCF UI surface; form binding preserved</constraint>
    <constraint source="ADR-021">Fluent v9 semantic tokens only; dark mode parity</constraint>
    <constraint source="ADR-022">React 16/17 compatible</constraint>
    <constraint source="ADR-028">Spaarke Auth v2 `@spaarke/auth` `authenticatedFetch` MUST be used for `POST /api/documents/bulk-download` (no manual bearer headers)</constraint>
    <constraint source="design.md">§6.0 binding — `/fluent-v9-component` MUST be invoked at Step 0.5</constraint>
  </constraints>

