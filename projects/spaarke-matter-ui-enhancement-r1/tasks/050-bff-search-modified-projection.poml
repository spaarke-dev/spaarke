  <acceptance-criteria>
    <criterion testable="true">SearchResult.cs has ModifiedAt (DateTimeOffset?) + ModifiedBy (string?) with correct JsonPropertyName attributes.</criterion>
    <criterion testable="true">/api/ai/search projection returns non-null modifiedAt + modifiedBy for documents that have them (FR-BFF-01 Acceptance).</criterion>
    <criterion testable="true">Existing fields (DocumentId, Name, CreatedAt, CreatedBy, etc.) unchanged in the projection (FR-BFF-01 Acceptance).</criterion>
    <criterion testable="true">Integration test passes; covers presence of new fields + presence of existing fields.</criterion>
    <criterion testable="true">No new DI registrations (ADR-010), no new NuGet packages (ADR-029), no HIGH CVE introductions.</criterion>
