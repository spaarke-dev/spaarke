  <acceptance-criteria>
    <criterion testable="true">MetricCard.tsx compiles and `npm run build:prod` produces a clean bundle.</criterion>
    <criterion testable="true">A test chart def with `fieldPivot.fields[0].badge = { text: "overdue", tone: "danger", position: "inline" }` renders the value with a red Fluent v9 Badge next to it — once FR-DV-03 is authored, Matter Tasks shows "4 [overdue]".</criterion>
    <criterion testable="true">All existing MetricCard chart defs (per task-001 inventory) render byte-identically (pixel-diff zero).</criterion>
    <criterion testable="true">Zero hex/rgb literals introduced; Fluent v9 Badge component used.</criterion>
    <criterion testable="true">No `@fluentui/react` (v8) imports; no React 18+ APIs used.</criterion>
    <criterion testable="true">`code-review` + `adr-check` pass.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="Backward compat — existing MetricCard renders unchanged">
      <steps>
        <step>Deploy modified VisualHost to dev</step>
        <step>Open a record bound to an existing MetricCard chart def (from task-001 inventory)</step>
        <step>Compare DOM + screenshot against pre-change baseline</step>
      </steps>
      <expected>Zero visual diff in light + dark; axe scan clean</expected>
    </test>
    <test name="Badge renders inline next to value">
      <steps>
        <step>Author a test chart def with per-field badge tone "danger"</step>
        <step>Render on a record where the value is non-zero</step>
      </steps>
      <expected>Badge appears immediately after the value in a flex row with proper Fluent v9 color tokens for "danger"</expected>
    </test>
    <test name="Dark mode + axe">
      <steps>
        <step>Toggle MDA dark mode; re-render the MetricCard with badge</step>
        <step>Run axe DevTools scan</step>
      </steps>
      <expected>Dark-mode Badge colors via Fluent v9 tokens; zero WCAG 2.1 AA violations</expected>
    </test>
  </ui-tests>

