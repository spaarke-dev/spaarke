<task id="042" project="spaarke-matter-ui-enhancement-r1">
  <metadata>
    <title>Documents PCF — Tags filter from sprk_documenttype with OR-semantics multi-select (FR-DOC-05)</title>
    <phase>4: Documents PCF</phase>
    <status>not-started</status>
    <estimated-hours>4-6</estimated-hours>
    <dependencies>012, 041</dependencies>
    <blocks>043</blocks>
    <tags>pcf, react, fluent-ui, frontend, semantic-search</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>PCF code change consuming shared `TagFilter` + integrating with command bar; Fluent v9 component authoring (binding `/fluent-v9-component`); ADR-021 + ADR-022 binding; modifies production SemanticSearchControl</rigor-reason>
    <parallel-group>none</parallel-group>
    <parallel-safe>false</parallel-safe>
    <parallel-reason>shared file SemanticSearchControl.tsx with other Phase 4 tasks (040, 041, 043-046)</parallel-reason>
