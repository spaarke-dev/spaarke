  <acceptance-criteria>
    <criterion testable="true">Tags filter trigger renders in command bar with label "Tags" (or "Tags (N)" when ≥1 selected).</criterion>
    <criterion testable="true">Menu items populated from `sprk_documenttype` option set, sorted alphabetically by label.</criterion>
    <criterion testable="true">Multi-select OR semantics verified: selecting 2 tags returns the union of matching documents.</criterion>
    <criterion testable="true">Active-tags chip row appears below command bar when ≥1 selected; chip × removes single; "Clear all" empties selection.</criterion>
    <criterion testable="true">Footer count reflects filtered result: e.g., "Showing 5 of 31 documents · filtered by 2 tags".</criterion>
    <criterion testable="true">Existing FilterPanel Document Type dropdown REMOVED (no duplicate).</criterion>
    <criterion testable="true">PCF builds clean (`npm run build:prod`); zero hardcoded hex/rgb.</criterion>
    <criterion testable="true">axe WCAG 2.1 AA zero violations in light AND dark.</criterion>
    <criterion testable="true">`code-review` + `adr-check` skills pass.</criterion>
    <criterion testable="true">TASK-INDEX.md shows task 042 as ✅ completed.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="Tags dropdown populates from sprk_documenttype">
      <steps>
        <step>Open the Tags filter trigger.</step>
        <step>Verify menu items match `sprk_documenttype` option-set values (alphabetically sorted by label).</step>
      </steps>
      <expected>Menu items match option set; alphabetical order.</expected>
    </test>
    <test name="OR-semantics multi-select">
      <steps>
        <step>Select "Contract" and "Memo" tags.</step>
        <step>Verify results show union of documents where `documentType` ∈ {Contract, Memo}.</step>
        <step>Verify footer count: "Showing X of Y documents · filtered by 2 tags".</step>
      </steps>
      <expected>OR-match; footer reflects count.</expected>
    </test>
    <test name="Chip row + Clear all">
      <steps>
        <step>Select 3 tags.</step>
        <step>Verify chip row below command bar shows 3 chips + Clear all.</step>
        <step>Click a chip × — verify that tag removed; count updates.</step>
        <step>Click Clear all — verify chip row hides; results unfiltered.</step>
      </steps>
      <expected>Chip interactions update selection.</expected>
    </test>
    <test name="Dark mode compliance (ADR-021)">
      <steps>
        <step>Toggle dark mode.</step>
        <step>Verify Tags trigger, menu, chips, footer count all use v9 dark tokens.</step>
        <step>Run axe-core.</step>
      </steps>
      <expected>Zero WCAG violations; all tokens.</expected>
    </test>
  </ui-tests>

  <notes>
    Depends on task 010 (TagFilter component) + task 012 (barrel export) + task 041 (command bar exists from view toggle work). The sidebar `FilterPanel.tsx` removal is the next task (043, FR-DOC-06) — here we only remove the Document Type dropdown element from the panel, not the panel itself. Existing OptionSet fetch via `DataverseMetadataService.fetchOptionSet` is unchanged.
  </notes>

