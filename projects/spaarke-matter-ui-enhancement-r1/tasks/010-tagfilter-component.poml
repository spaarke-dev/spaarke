  <acceptance-criteria>
    <criterion testable="true">`src/client/shared/Spaarke.UI.Components/src/components/TagFilter.tsx` exists and exports a `TagFilter` React component with props matching FR-SC-01 exactly: `{ options: TagFilterOption[], selected: string[], onChange: (selected: string[]) =&gt; void, label?: string, sortAlphabetical?: boolean }`.</criterion>
    <criterion testable="true">`TagFilterOption` and `TagFilterProps` types are exported from `src/client/shared/Spaarke.UI.Components/src/types/TagFilter.ts`.</criterion>
    <criterion testable="true">Multi-select OR semantics work per FR-SC-01: selecting two checkbox items results in `onChange` being called with both values; the component holds no internal selection state for these (it is controlled).</criterion>
    <criterion testable="true">When `selected.length &gt;= 1`, a chip row renders below the trigger button; clicking a chip's × invokes `onChange` with that value removed; clicking "Clear all" invokes `onChange([])`.</criterion>
    <criterion testable="true">`sortAlphabetical: true` causes menu items to render alphabetically by `label`; default (false/undefined) preserves caller-supplied order.</criterion>
    <criterion testable="true">Component contains zero hardcoded hex/rgb values (verifiable by grep) and uses Fluent v9 `tokens` exclusively for color/spacing.</criterion>
    <criterion testable="true">Component renders correctly in both `webLightTheme` and `webDarkTheme` (verified in dev harness).</criterion>
    <criterion testable="true">No React 18+ exclusive APIs imported; `npm run build:prod` succeeds in `@spaarke/ui-components` and in both PCFs.</criterion>
    <criterion testable="true">`code-review` + `adr-check` skills pass with no unresolved findings.</criterion>
    <criterion testable="true">TASK-INDEX.md shows task 010 as ✅ completed.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="Component renders in light + dark theme">
      <steps>
        <step>Mount `TagFilter` inside a FluentProvider with `webLightTheme`; confirm trigger button, menu items, and chip row render with v9 tokens.</step>
        <step>Re-mount inside FluentProvider with `webDarkTheme`; confirm contrast passes axe; no hardcoded colors visible.</step>
      </steps>
      <expected>Both themes render without contrast violations; same component layout; no theme-specific overrides needed.</expected>
    </test>
    <test name="Multi-select OR semantics + chip removal">
      <steps>
        <step>Mount `TagFilter` with 5 options, controlled `selected` from parent state.</step>
        <step>Click two checkboxes — verify `onChange` called twice with cumulative arrays.</step>
        <step>Click a chip's × — verify `onChange` called with that value removed.</step>
        <step>Click "Clear all" — verify `onChange([])`.</step>
      </steps>
      <expected>All four interactions invoke `onChange` with the correct payload; chip row hides when `selected.length === 0`.</expected>
    </test>
    <test name="axe scan passes in both themes">
      <steps>
        <step>Run `axe-core` against the rendered component in `webLightTheme`.</step>
        <step>Run `axe-core` against the rendered component in `webDarkTheme`.</step>
      </steps>
      <expected>Zero WCAG 2.1 AA violations in either theme.</expected>
    </test>
  </ui-tests>

  <notes>
    Barrel export of `TagFilter` from `src/client/shared/Spaarke.UI.Components/src/index.ts` is intentionally deferred to task 012 to serialize the barrel update across tasks 010 and 011 and avoid merge conflicts. The first PCF consumer (Semantic Search Tags filter, FR-DOC-05) is implemented in a later Phase 2 task. Keep this component strictly generic — no `sprk_documenttype`-specific defaults; the option-set source is owned by the consumer, not by this component.
  </notes>

