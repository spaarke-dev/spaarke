    </relevant-files>
  </context>

  <constraints>
    <constraint source="spec">FR-SC-01 — props are `{ options, selected, onChange, label?, sortAlphabetical? }`; component is generic (NOT bound to document type)</constraint>
    <constraint source="spec">FR-SC-01 — multi-select OR semantics; chip × removes individual tag; "Clear all" empties selection</constraint>
    <constraint source="spec">FR-SC-01 — exported from barrel `src/index.ts`</constraint>
    <constraint source="spec">NFR-02 — axe DevTools WCAG 2.1 AA, zero violations, light AND dark</constraint>
    <constraint source="spec">NFR-04 — Fluent v9 tokens only; zero hardcoded hex/rgb in touched files</constraint>
    <constraint source="ADR-012">Single shared implementation in `@spaarke/ui-components`; no parallel per-PCF copies</constraint>
    <constraint source="ADR-021">Fluent UI v9 design system; semantic tokens only; dark mode required</constraint>
    <constraint source="ADR-022">Compatible with React 16/17 (PCF platform); no React 18+ exclusive APIs (no `use()`, no `useTransition` requirement, no server components)</constraint>
    <constraint source="design.md">§6.0 binding rule — `/fluent-v9-component` MUST be invoked at task start before reading/writing any Fluent v9 file</constraint>
  </constraints>

