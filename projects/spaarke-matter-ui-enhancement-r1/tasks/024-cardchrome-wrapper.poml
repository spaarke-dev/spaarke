  <ui-tests>
    <test name="Backward compat â€” existing cards render correctly inside CardChrome">
      <steps>
        <step>Deploy modified VisualHost to dev</step>
        <step>Open records bound to existing chart defs (Matter KPI Scorecard, Matter Financial Metrics Scorecard, others)</step>
        <step>Inspect DOM: each card now has a CardChrome wrapper with title + expand icon top-right; the card body is unchanged</step>
