        <step>Toggle MDA dark mode; re-render all cards</step>
        <step>Run axe DevTools scan</step>
      </steps>
      <expected>CardChrome header colors via Fluent v9 tokens resolve correctly; zero WCAG 2.1 AA violations</expected>
    </test>
  </ui-tests>

