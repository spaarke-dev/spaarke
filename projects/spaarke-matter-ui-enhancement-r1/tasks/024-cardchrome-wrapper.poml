        <step>Confirm `handleExpandClick` is invoked and the configured entity list view opens with the matter filter applied</step>
      </steps>
      <expected>Drill-through behavior identical to today; no new code paths exercised</expected>
    </test>
    <test name="AI sparkle hidden in v1">
