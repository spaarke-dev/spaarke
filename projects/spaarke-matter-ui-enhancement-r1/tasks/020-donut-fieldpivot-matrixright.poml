  </outputs>

  <acceptance-criteria>
    <criterion testable="true">DonutChart.tsx and ChartRenderer.tsx compile and `npm run build:prod` produces a clean bundle.</criterion>
    <criterion testable="true">A test chart def with `donutLayout: "matrixRight"`, `donutCenterMode: "meanOfFields"`, `showBreakdownRows: true`, 3 fieldPivot fields, and `valueFormat: "letterGrade"` renders donut + 3 labeled rows + center "B+" (or equivalent) with "85/100" sub-value once FR-DV-01 is authored.</criterion>
    <criterion testable="true">ALL existing Donut chart defs from the task-001 inventory render byte-identically (pixel-diff zero in regression evidence).</criterion>
    <criterion testable="true">Segment colors come from `getTokenSetColors()` — zero hex/rgb literals introduced.</criterion>
    <criterion testable="true">No `@fluentui/react` (v8) imports in touched files; no React 18+ APIs used.</criterion>
    <criterion testable="true">`code-review` + `adr-check` pass.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="Backward compat — existing Donut renders unchanged">
      <steps>
        <step>Deploy modified VisualHost to dev</step>
        <step>Open a record bound to an existing Donut chart def (from task-001 inventory)</step>
        <step>Compare DOM + screenshot against pre-change baseline</step>
      </steps>
      <expected>Zero visual diff in light + dark; axe scan clean</expected>
    </test>
    <test name="matrixRight layout renders correctly">
      <steps>
        <step>Author a test chart def with the five new keys (matrixRight, meanOfFields, etc.)</step>
        <step>Render on a record with 3 fieldPivot field values</step>
        <step>Inspect grid layout, center value formatting, segment colors</step>
      </steps>
      <expected>Donut left + 3 breakdown rows right; center shows mean as letterGrade; segments colored per `colorThresholds[].tokenSet`</expected>
    </test>
    <test name="Dark mode + axe">
      <steps>
        <step>Toggle MDA dark mode; re-render the matrixRight donut</step>
        <step>Run axe DevTools scan</step>
      </steps>
      <expected>Dark-mode colors via Fluent v9 tokens; zero WCAG 2.1 AA violations</expected>
    </test>
  </ui-tests>

  <notes>
    Parallel-group C: this task touches DonutChart.tsx + ChartRenderer.tsx + cardConfigResolver.ts. Tasks 023 (HSBar) and 024 (CardChrome + VisualHostRoot) touch different files and can ship in parallel. Tasks 021/022 touch MetricCard.tsx and are NOT in this group (different files). If cardConfigResolver.ts shared-type edits conflict with 023's same-file edits, coordinate via the parallel-group lead.
  </notes>

