  </knowledge>
  <steps>
    <step order="0">Context check + FR-2.6 + Q6 owner clarification (SystemAdmin policy)</step>
    <step order="1">Create JobsEndpoints.cs static class with MapAdminJobsEndpoints extension</step>
    <step order="2">Implement GET / endpoint: list ScheduledJobRegistry + map to status DTO</step>
    <step order="3">Implement GET /{jobId}/status endpoint with last 10 runs</step>
    <step order="4">Register in Program.cs with .RequireAuthorization("SystemAdmin")</step>
    <step order="5">Unit tests: list returns expected, status returns 404 for unknown jobId, 403 for non-admin</step>
    <step order="6">Build + tests + publish-size</step>
  </steps>
  <acceptance-criteria>
    <criterion testable="true">GET /api/admin/jobs returns list of registered jobs with status</criterion>
    <criterion testable="true">GET /api/admin/jobs/{jobId}/status returns detailed status + last 10 runs</criterion>
    <criterion testable="true">Non-admin token gets 403</criterion>
    <criterion testable="true">Unknown jobId returns 404</criterion>
  </acceptance-criteria>
