  <steps>
    <step order="0">Context check + load FR-3H1.2 + FR-1B.2 from spec.md</step>
    <step order="1">Add `_handlebars.RegisterHelper("joinIds", ...)` per spec snippet</step>
    <step order="2">Unit tests for 4 scenarios</step>
