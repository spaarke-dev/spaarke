  </outputs>

  <acceptance-criteria>
    <criterion testable="true">`{{joinIds ['a','b','c']}}` renders "a,b,c"</criterion>
    <criterion testable="true">`{{joinIds []}}` renders ""</criterion>
    <criterion testable="true">`{{joinIds null}}` renders ""</criterion>
