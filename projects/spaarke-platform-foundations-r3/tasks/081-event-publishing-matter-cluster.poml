  </knowledge>
  <steps>
    <step order="0">Context check + FR-2P2.6 + Q2</step>
    <step order="1">Create MembershipEventPublisher (Singleton) that wraps Service Bus topic client</step>
    <step order="2">For each matter mutation endpoint per inventory: detect lookup mutation in request → publish event after successful mutation</step>
    <step order="3">Fire-and-forget: publish exceptions logged as warnings (do NOT throw)</step>
    <step order="4">Unit tests: detect mutation, publish event, fire-and-forget on publisher failure</step>
    <step order="5">Integration test: end-to-end mutation → event published to topic</step>
  </steps>
  <acceptance-criteria>
    <criterion testable="true">Matter lookup mutations publish events</criterion>
    <criterion testable="true">Publish failure logs warning but mutation succeeds</criterion>
    <criterion testable="true">Integration test passes</criterion>
  </acceptance-criteria>
</task>
