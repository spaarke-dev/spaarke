    </files>
  </knowledge>
  <steps>
    <step order="0">Context check</step>
    <step order="1">Add validation in MembershipEndpoints.cs handler</step>
    <step order="2">Return ProblemDetails 400 with type "transitive-chain-too-deep"</step>
    <step order="3">Unit tests</step>
  </steps>
  <acceptance-criteria>
    <criterion testable="true">2+ hop request returns 400 with ProblemDetails</criterion>
    <criterion testable="true">1-hop request works correctly</criterion>
