<task id="R3-055" project="spaarke-platform-foundations-r3">
  <metadata>
    <title>1-hop max enforcement on `includeRelated` chains</title>
    <status>completed</status>
    <completion-date>2026-06-21</completion-date>
    <phase>P6.5</phase>
    <parallel-group>none</parallel-group>
