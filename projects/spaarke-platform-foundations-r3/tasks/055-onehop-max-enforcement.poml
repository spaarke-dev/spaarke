  <prompt>Add explicit validation: `includeRelated` accepts comma-separated entity logical names; if any entity reference appears in a transitive chain &gt; 1 hop, return 400 BadRequest with explanatory ProblemDetails.</prompt>
  <goal>Multi-hop requests rejected at endpoint validation, before any Dataverse query. Clear error message.</goal>
  <constraints>
    <constraint source="ADR-019">ProblemDetails for errors</constraint>
    <constraint source="spec Q3">1 hop max enforced explicitly</constraint>
  </constraints>
  <knowledge>
    <topic>endpoint-validation</topic>
