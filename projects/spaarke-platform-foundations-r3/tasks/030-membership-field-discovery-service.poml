      <file>projects/spaarke-platform-foundations-r3/spec.md</file>
    </files>
  </knowledge>
  <steps>
    <step order="0">Context check + FR-1A.1 through FR-1A.4 + Q4</step>
    <step order="1">Define MembershipDescriptor model (field, role, identityType, source)</step>
    <step order="2">Implement IMembershipFieldDiscoveryService.DiscoverAsync(entityType) — query EntityDefinitions API</step>
    <step order="3">Filter to Lookups whose Targets contain configured identity tables (per MembershipOptions.IncludedIdentityTables)</step>
    <step order="4">Apply GlobalFieldExclusions</step>
    <step order="5">Apply EntityOverrides (ExcludedFields, IncludedFields, FieldRoleOverrides)</step>
    <step order="6">Derive role name via CamelCase strategy (strip sprk_ + strip trailing digits + camelCase)</step>
    <step order="7">Cache result in Redis with 1h TTL</step>
    <step order="8">Unit tests: each filter step, role-name strategy, override application, cache hit/miss</step>
    <step order="9">Integration test: discover sprk_matter against spaarkedev1 → assert AC-1A.1 expected fields</step>
  </steps>
  <acceptance-criteria>
    <criterion testable="true">Discovery for sprk_matter returns expected fields per AC-1A.1</criterion>
    <criterion testable="true">Role-name strategy: sprk_AssignedAttorney1 → "assignedAttorney"</criterion>
    <criterion testable="true">sprk_assignedlawfirm1/2 resolves to identityType=Organization (per Q4)</criterion>
    <criterion testable="true">Per-entity overrides applied (e.g., sprk_assignedlawfirm1 → role "assignedLawFirm")</criterion>
    <criterion testable="true">Metadata cache hit on second call (no Dataverse re-query)</criterion>
    <criterion testable="true">Unit + integration tests pass</criterion>
  </acceptance-criteria>
</task>
