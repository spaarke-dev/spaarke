    <relevant-files>
      <file>src/server/api/Sprk.Bff.Api/Services/Ai/Membership/IMembershipResolverService.cs</file>
      <file>src/server/api/Sprk.Bff.Api/Services/Ai/Membership/MembershipResolverService.cs</file>
