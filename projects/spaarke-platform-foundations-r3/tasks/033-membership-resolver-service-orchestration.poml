<task id="R3-033" project="spaarke-platform-foundations-r3">
  <metadata>
    <title>`MembershipResolverService` — orchestration (discovery + normalization + FetchXML query)</title>
    <status>not-started</status>
    <phase>P4</phase>
    <parallel-group>H (with 034)</parallel-group>
    <parallel-safe>true</parallel-safe>
    <rigor>FULL</rigor>
