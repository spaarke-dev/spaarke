<task id="R3-014" project="spaarke-platform-foundations-r3">
  <metadata>
    <title>Retry/backoff + idempotency in ScheduledJobHost</title>
    <status>completed</status>
    <phase>P2</phase>
    <parallel-group>D (with 013)</parallel-group>
    <parallel-safe>true</parallel-safe>
    <rigor>FULL</rigor>
