<task id="R3-024" project="spaarke-platform-foundations-r3">
  <metadata>
    <title>Migrate `sprk_analysisplaybook.sprk_configjson` schedule fields to new framework</title>
    <status>not-started</status>
    <phase>P3</phase>
    <parallel-group>none</parallel-group>
    <parallel-safe>true</parallel-safe>
