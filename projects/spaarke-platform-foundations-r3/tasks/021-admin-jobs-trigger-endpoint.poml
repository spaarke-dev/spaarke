  <prompt>Implement POST /api/admin/jobs/{jobId}/trigger — dispatches the job out-of-band (Trigger=ManualAdmin); returns {runId, status, startedAt}.</prompt>
  <goal>Admin can run any registered job on demand. Trigger writes sprk_backgroundjobrun with trigger=ManualAdmin. SystemAdmin policy enforced.</goal>
  <constraints>
    <constraint source="ADR-008">Endpoint-filter auth</constraint>
    <constraint source="spec">Trigger field = ManualAdmin OptionSet value</constraint>
    <constraint source="NFR-08">runId carries correlationId</constraint>
  </constraints>
  <knowledge>
    <topic>admin-endpoint-pattern</topic>
    <files>
      <file>docs/adr/ADR-008-endpoint-filters.md</file>
      <file>.claude/patterns/api/endpoint-definition.md</file>
      <file>.claude/constraints/bff-extensions.md</file>
      <file>projects/spaarke-platform-foundations-r3/spec.md</file>
    </files>
  </knowledge>
  <steps>
    <step order="0">Context check + FR-2.6 (trigger endpoint)</step>
    <step order="1">Add POST /{jobId}/trigger handler in JobsEndpoints.cs</step>
    <step order="2">Resolve job from ScheduledJobRegistry; build JobRunContext with Trigger=ManualAdmin + fresh correlationId</step>
    <step order="3">Invoke ScheduledJobHost.TriggerNowAsync (new method on host)</step>
    <step order="4">Return {runId, status="Running", startedAt}</step>
    <step order="5">Unit tests: valid trigger, unknown jobId 404, non-admin 403, in-flight job idempotent</step>
  </steps>
  <acceptance-criteria>
    <criterion testable="true">POST returns 202 Accepted with {runId, status, startedAt}</criterion>
    <criterion testable="true">sprk_backgroundjobrun row written with trigger=ManualAdmin</criterion>
    <criterion testable="true">404 for unknown jobId; 403 for non-admin</criterion>
  </acceptance-criteria>
</task>
