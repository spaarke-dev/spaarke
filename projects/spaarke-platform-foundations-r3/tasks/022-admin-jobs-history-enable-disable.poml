<task id="R3-022" project="spaarke-platform-foundations-r3">
  <metadata>
    <title>`GET /history` + `POST /enable` + `POST /disable` endpoints</title>
    <status>completed</status>
    <phase>P3</phase>
    <parallel-group>F (with 020, 021)</parallel-group>
    <parallel-safe>true</parallel-safe>
    <rigor>FULL</rigor>
    <estimated-effort>2h</estimated-effort>
    <tags>bff-api,admin-endpoints,scheduling</tags>
    <relevant-files>
      <file>src/server/api/Sprk.Bff.Api/Api/Admin/JobsEndpoints.cs</file>
      <file>tests/unit/Sprk.Bff.Api.Tests/Api/Admin/JobsEndpointsTests.cs</file>
