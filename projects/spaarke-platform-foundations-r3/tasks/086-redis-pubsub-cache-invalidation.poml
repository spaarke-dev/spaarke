  <prompt>On junction-row write (by either handler 084 or recon job 085), publish to Redis channel `membership-cache-invalidate` carrying `{userId, entityType}`. All BFF instances subscribed; evict matching cache entries.</prompt>
  <goal>Membership cache invalidates correctly when junction-row changes. Stale cache cleared within seconds.</goal>
  <constraints>
    <constraint source="ADR-009">Redis pub/sub pattern</constraint>
    <constraint source="spec FR-2P2.8">Channel `membership-cache-invalidate`</constraint>
  </constraints>
  <knowledge>
    <topic>redis-pubsub-cache-invalidation</topic>
    <files>
      <file>docs/adr/ADR-009-redis-caching.md</file>
      <file>.claude/patterns/api/resilience.md</file>
      <file>projects/spaarke-platform-foundations-r3/spec.md</file>
    </files>
  </knowledge>
  <steps>
    <step order="0">Context check + FR-2P2.8</step>
    <step order="1">Implement MembershipCacheInvalidator with Publish + Subscribe on Redis channel</step>
    <step order="2">Wire publisher into MembershipJunctionUpdater + MembershipReconciliationJob</step>
    <step order="3">Wire subscriber into MembershipResolverService startup (evict on message)</step>
    <step order="4">Unit tests: publish + subscribe roundtrip</step>
    <step order="5">Integration test: junction write → cache evicted on remote BFF instance</step>
  </steps>
  <acceptance-criteria>
