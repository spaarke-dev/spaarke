  </metadata>
  <prompt>On junction-row write (by either handler 084 or recon job 085), publish to Redis channel `membership-cache-invalidate` carrying `{userId, entityType}`. All BFF instances subscribed; evict matching cache entries.</prompt>
  <goal>Membership cache invalidates correctly when junction-row changes. Stale cache cleared within seconds.</goal>
  <constraints>
    <constraint source="ADR-009">Redis pub/sub pattern</constraint>
    <constraint source="spec FR-2P2.8">Channel `membership-cache-invalidate`</constraint>
  </constraints>
