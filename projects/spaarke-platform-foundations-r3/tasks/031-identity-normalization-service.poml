<task id="R3-031" project="spaarke-platform-foundations-r3">
  <metadata>
    <title>`IdentityNormalizationService` — systemuser → {contactId, email, teamIds, BU, organizationIds}</title>
    <status>not-started</status>
    <phase>P4</phase>
    <parallel-group>G (with 030, 032)</parallel-group>
    <parallel-safe>true</parallel-safe>
    <rigor>FULL</rigor>
