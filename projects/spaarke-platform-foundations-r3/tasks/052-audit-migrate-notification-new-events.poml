  </knowledge>
  <steps>
    <step order="0">Context check</step>
    <step order="1">Audit playbook for broken patterns</step>
    <step order="2">Migrate if applicable; document if not</step>
  </steps>
  <acceptance-criteria>
    <criterion testable="true">Audit completed + outcome documented</criterion>
    <criterion testable="true">If migrated, playbook produces non-zero notifications</criterion>
  </acceptance-criteria>
</task>
