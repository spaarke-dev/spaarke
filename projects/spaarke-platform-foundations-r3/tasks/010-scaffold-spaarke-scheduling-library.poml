      <file>projects/spaarke-platform-foundations-r3/spec.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="0">Context check + FR-2.1</step>
    <step order="1">Create project structure under `src/server/shared/Spaarke.Scheduling/`</step>
    <step order="2">Author csproj: net8.0, ProjectReference to Spaarke.Core, PackageReference Cronos</step>
    <step order="3">Add project to `Spaarke.sln`</step>
    <step order="4">Add ProjectReference from `Sprk.Bff.Api.csproj`</step>
    <step order="5">Solution build + verify Cronos resolves + verify no HIGH CVE</step>
    <step order="6">Capture publish-size baseline change</step>
  </steps>

  <acceptance-criteria>
    <criterion testable="true">`dotnet build Spaarke.sln` succeeds</criterion>
    <criterion testable="true">`dotnet list package --vulnerable --include-transitive` shows no new HIGH CVE</criterion>
    <criterion testable="true">BFF publish-size delta reported (expected +~50KB)</criterion>
