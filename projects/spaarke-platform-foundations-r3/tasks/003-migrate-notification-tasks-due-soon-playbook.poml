<task id="R3-003" project="spaarke-platform-foundations-r3">
  <metadata>
    <title>Migrate `notification-tasks-due-soon.json` from `??` to `{{default}}`</title>
    <status>not-started</status>
    <phase>P1</phase>
    <parallel-group>B (with 004)</parallel-group>
    <parallel-safe>true</parallel-safe>
    <rigor>FULL</rigor>
    <estimated-effort>30min</estimated-effort>
    <tags>playbook-config,migration,handlebars</tags>
    <relevant-files>
      <file>projects/spaarke-daily-update-service/notes/playbooks/notification-tasks-due-soon.json</file>
    </relevant-files>
