    <file purpose="canonical-source-playbook">projects/spaarke-daily-update-service/notes/playbooks/daily-briefing-narrate.json</file>
    <file purpose="canonical-source-action">projects/spaarke-daily-update-service/notes/playbooks/actions/brief-narrate-tldr.action.json</file>
