  <acceptance-criteria>
    <criterion testable="true">SPAARKE-PLAYBOOK-LLM-OUTPUT-PATTERN.md exists at docs/architecture/ + ≤ 400 lines + answers all sections listed in Step 2</criterion>
    <criterion testable="true">BUILD-A-NEW-NARRATIVE-OUTPUT-CONSUMER.md exists at docs/guides/ + ≤ 400 lines + includes both worked examples</criterion>
