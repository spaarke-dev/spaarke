<task id="135" project="spaarke-ai-platform-unification-r7">
  <metadata>
    <title>Verify per-bullet entity links (EnrichBulletWithEntityRefs) work for all 6 entity types</title>
    <phase>Wave 12 — MVP Completion</phase>
    <wave>12</wave>
    <sub-wave>12.2</sub-wave>
    <rigor-hint>STANDARD</rigor-hint>
    <rigor-reason>verification + selective code adjustment if gaps found</rigor-reason>
