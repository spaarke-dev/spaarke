<task id="R7-067" project="spaarke-ai-platform-unification-r7">
  <metadata>
    <title>CREATE docs/guides/ai-guide-consumer-wiring.md — maker-facing tutorial for wiring a new consumer</title>
    <status>not-started</status>
    <wave>6</wave>
    <estimated-effort>3-4 hours</estimated-effort>
    <tags>docs, wave-6</tags>
    <rigor-level>STANDARD</rigor-level>
    <parallel-safe>true</parallel-safe>
