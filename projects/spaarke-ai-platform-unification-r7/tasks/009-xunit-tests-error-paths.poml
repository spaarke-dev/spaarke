    <patterns>
      <pattern name="AiAnalysisNodeExecutor error tests" location="tests/unit/Sprk.Bff.Api.Tests/Services/Ai/Nodes/AiAnalysisNodeExecutorTests.cs">
        Sibling error-path tests. Mock LLM to throw / return malformed; assert NodeOutput.Error code + message. Mirror exactly for the equivalent AiCompletion paths.
      </pattern>
      <pattern name="NodeErrorCodes" location="src/server/api/Sprk.Bff.Api/Models/Ai/NodeErrorCodes.cs">
        Existing error-code class. Tests assert against these named constants, not magic strings.
      </pattern>
    </patterns>
  </knowledge>

  <context>
