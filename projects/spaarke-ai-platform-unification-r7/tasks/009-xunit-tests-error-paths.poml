<task id="R7-009" project="spaarke-ai-platform-unification-r7">
  <metadata>
    <title>xUnit tests — error paths (missing prompt, malformed JSON, LLM error) (FR-14)</title>
    <status>completed</status>
    <wave>1</wave>
    <estimated-effort>2-3 hours</estimated-effort>
    <tags>bff-api, testing, wave-1</tags>
    <rigor-level>FULL</rigor-level>
    <parallel-safe>true</parallel-safe>
    <dependencies>007</dependencies>
    <fr-coverage>FR-14 (error-path coverage), FR-13 (Validate() error contract), NFR-05 (&gt;85% coverage)</fr-coverage>
