  </outputs>

  <acceptance-criteria>
    <criterion testable="true">6 new helpers registered: json, map, flatten, distinct, concat, join</criterion>
    <criterion testable="true">Each helper has ≥4 test cases covering null/empty/happy/scalar paths</criterion>
    <criterion testable="true">Subexpression composition `{{distinct (concat (map A 'x') (map B 'y'))}}` resolves correctly in an integration-style test</criterion>
    <criterion testable="true">All pre-existing TemplateEngine tests still pass (zero regression)</criterion>
    <criterion testable="true">`dotnet build` zero errors; full BFF test suite passes</criterion>
