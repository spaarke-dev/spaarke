<task id="R7-112" project="spaarke-ai-platform-unification-r7">
  <metadata>
    <title>Register custom Handlebars helpers: json, map, flatten, distinct, concat, join</title>
    <status>not-started</status>
    <wave>11</wave>
    <estimated-effort>3 hours</estimated-effort>
    <tags>bff-api, code-impl, ai, wave-11</tags>
    <rigor-level>FULL</rigor-level>
    <rigor-reason>Modifies .cs (TemplateEngine); tags include `bff-api`; helpers are reusable infrastructure — bugs compound across all downstream playbook expressions. FULL per task-execute Step 0.5.</rigor-reason>
    <parallel-safe>true</parallel-safe>
    <parallel-group>W11-C</parallel-group>
