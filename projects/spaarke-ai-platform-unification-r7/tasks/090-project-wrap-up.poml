<?xml version="1.0" encoding="UTF-8"?>
<task id="R7-090-wrapup" project="spaarke-ai-platform-unification-r7">
  <metadata>
    <title>Wrap-up — README → Complete, lessons-learned.md, archive project</title>
    <status>not-started</status>
    <wave>10</wave>
    <estimated-effort>2-3 hours</estimated-effort>
    <tags>wrapup, wave-10</tags>
    <rigor-level>STANDARD</rigor-level>
    <parallel-safe>false</parallel-safe>
    <dependencies>101 (R4 graduation UAT signed off PASS)</dependencies>
    <fr-coverage>Project close + test-diet gate (BINDING per CLAUDE.md §7) + portfolio/sibling-worktree sync</fr-coverage>
  </metadata>

  <prompt>
    Project close. Invoke /test-diet BINDING gate first (reconciles tests added during R7 against ADR-038
    build-vs-maintain criteria), then flip project state to Complete across README + CLAUDE + current-task,
    write lessons-learned.md, update portfolio INDEX, close GitHub Issue #501, and document sibling-worktree
    unblocks. Optional final step: invoke /repo-cleanup for hygiene audit. NO commit yet — main session commits
    the wrap-up bundle.

    The 090-project-wrap-up filename is reserved (not 102) per CLAUDE.md §7 + task-create convention; the
    "090" prefix triggers test-diet binding per task-execute Step 11.
  </prompt>

  <role>
    Project-close steward. Mechanical sequence — test-diet, README flip, lessons capture, portfolio update,
    sibling unblock. The judgment work is the lessons-learned: be honest about what hurt, what spec missed,
    what would change next time. R7 is the dispatch-reform project that closes R4 and unblocks Action Engine R1;
    the lessons here inform the next 2-3 projects.
  </role>

  <goal>
    R7 project closed:
    1. /test-diet invoked; report at `notes/test-diet-report.md`; reviewer applied DELETE/KEEP/MOVE commands
    2. README.md Status flipped from "In Progress" to "Complete"; Last Updated bumped to project-close date
    3. CLAUDE.md Phase: Complete; Current Task: none; Next Action: archived
    4. current-task.md: Status: none; Next action: /repo-cleanup
    5. notes/handoffs/lessons-learned.md exists — what went well, what hurt, what would change, anything spec missed
    6. projects/INDEX.md updated — R7 row marked Archived (or removed per Maintenance Contract)
    7. GitHub Issue #501 Status: Completed; Closed Date: today (via gh GraphQL)
    8. Sibling worktrees unblocked: R4 (`spaarke-daily-update-service-r4`) cleared to archive; Action Engine R1 (`ai-spaarke-action-engine-r1`) cleared to resume past Phase 0
    9. Optional: /repo-cleanup hygiene audit invoked
    10. Wrap-up PR description cites notes/test-diet-report.md per CLAUDE.md §7 (or documents skip rationale)
  </goal>

  <inputs>
    <file purpose="readme">projects/spaarke-ai-platform-unification-r7/README.md</file>
    <file purpose="project-claude">projects/spaarke-ai-platform-unification-r7/CLAUDE.md</file>
    <file purpose="current-task">projects/spaarke-ai-platform-unification-r7/current-task.md</file>
    <file purpose="task-index">projects/spaarke-ai-platform-unification-r7/tasks/TASK-INDEX.md</file>
    <file purpose="graduation-report">projects/spaarke-ai-platform-unification-r7/notes/handoffs/graduation-verification.md</file>
    <file purpose="uat-handoff">projects/spaarke-ai-platform-unification-r7/notes/handoffs/r4-graduation-uat.md</file>
    <file purpose="portfolio-index">projects/INDEX.md</file>
    <file purpose="root-claude-§7">CLAUDE.md (§7 Task Completion + test-diet gate BINDING)</file>
    <file purpose="test-diet-skill">.claude/skills/test-diet/SKILL.md</file>
    <file purpose="repo-cleanup-skill">.claude/skills/repo-cleanup/SKILL.md</file>
  </inputs>

  <constraints>
    <constraint source="CLAUDE.md §7 (BINDING)">090-wrapup-* tasks MUST invoke /test-diet before marking project complete. /test-diet reconciles tests added/modified during R7 against ADR-038 17-ban classifier. Output: projects/spaarke-ai-platform-unification-r7/notes/test-diet-report.md. Skipping is a HARD WARNING — wrap-up PR description MUST cite the report or document skip rationale. Binding ≥6 months from 2026-06-26.</constraint>
    <constraint source="CLAUDE.md §7">Task Completion — reset current-task.md for next task; update TASK-INDEX 🔲 → ✅; project close means current-task.md status = "none" + next action = /repo-cleanup.</constraint>
    <constraint source="ADR-038">Testing Strategy — /test-diet enforces ADR-038 §7 build-vs-maintain criteria. MAINTAIN-class tests stay at KEEP path; SCAFFOLDING-class deleted; AMBIGUOUS require reviewer judgment.</constraint>
    <constraint source="task-create skill convention">Filename is `090-project-wrap-up.poml` (not 102); "090" prefix is the skill's reserved id for project-close. Task ID is `R7-090-wrapup` (distinguishable from any other 090-prefixed task).</constraint>
    <constraint source="projects/INDEX.md Maintenance Contract">R7 row marked Archived (or removed per the contract's archived-project convention).</constraint>
    <constraint source="bff-extensions.md">Wrap-up task does NOT modify BFF; no publish-size check needed.</constraint>
    <constraint source="DO NOT commit">Main session commits the full wrap-up bundle at end; do not commit individual files in this task.</constraint>
  </constraints>

  <knowledge>
    <topic>project-close</topic>
    <files>
      <file>.claude/skills/test-diet/SKILL.md</file>
      <file>.claude/skills/repo-cleanup/SKILL.md</file>
      <file>CLAUDE.md (§7 Task Completion + test-diet BINDING)</file>
      <file>docs/adr/ADR-038-testing-strategy.md (17-ban classifier)</file>
