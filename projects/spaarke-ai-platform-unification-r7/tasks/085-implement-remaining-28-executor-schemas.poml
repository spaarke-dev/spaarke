  </outputs>

  <acceptance-criteria>
    <criterion>All 28 non-priority executors have non-empty `GetConfigSchema()` returns</criterion>
    <criterion>Each schema declares at least 1 field with type, default, description</criterion>
    <criterion>BFF endpoint returns all 33 schemas correctly</criterion>
    <criterion>Canvas renders typed inputs for every executor (no "No schema available" placeholder)</criterion>
    <criterion>dotnet build passes: 0 errors, 0 new warnings</criterion>
    <criterion>Publish-size delta documented (expected: <+0.5 MB)</criterion>
    <criterion>No new HIGH-severity CVE</criterion>
    <criterion>code-review + adr-check pass at Step 9.5</criterion>
    <criterion>TASK-INDEX.md shows 085 ✅</criterion>
  </acceptance-criteria>
</task>
