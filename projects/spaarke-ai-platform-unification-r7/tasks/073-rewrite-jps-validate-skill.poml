  </inputs>

  <constraints>
    <constraint source="CLAUDE.md §3 Sub-Agent Write Boundary">Sub-agents CANNOT write to `.claude/` paths. Main session executes this task. No parallel dispatch.</constraint>
    <constraint source="spec FR-32">Each rewritten skill cites §3.1 WHY history and validates against `node.sprk_executortype`, not Action lookup.</constraint>
    <constraint source="spec FR-16">Wave 3 typed config schemas — each executor exposes `GetConfigSchema()` returning DTO; BFF serves via endpoint. Validation uses this schema.</constraint>
    <constraint source="design.md §2 Invariants 2-3 + Invariant 5">Single-hop dispatch + Action as prompt template + per-executor typed config schemas.</constraint>
