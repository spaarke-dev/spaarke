<task id="R7-113" project="spaarke-ai-platform-unification-r7">
  <metadata>
    <title>Eliminate {{lambda}} from source by adding {{flatMap}} helper + rewriting allowList expression</title>
    <status>not-started</status>
    <wave>11</wave>
    <estimated-effort>2-3 hours</estimated-effort>
    <tags>bff-api, code-impl, ai, dataverse-data, wave-11</tags>
