    <patterns>
      <pattern name="AiAnalysisNodeExecutorTests" location="tests/unit/Sprk.Bff.Api.Tests/Services/Ai/Nodes/AiAnalysisNodeExecutorTests.cs">
        Canonical sibling test file. Uses Moq for IOpenAiClient; constructs NodeExecutionContext via test helpers; asserts NodeOutput.Ok shape. Mirror the structure.
      </pattern>
      <pattern name="NodeExecutionContext test-helper" location="tests/unit/Sprk.Bff.Api.Tests/Services/Ai/Nodes/">
        Existing helper builders for NodeExecutionContext — reuse to avoid hand-constructing the context in every test.
      </pattern>
    </patterns>
  </knowledge>

  <context>
