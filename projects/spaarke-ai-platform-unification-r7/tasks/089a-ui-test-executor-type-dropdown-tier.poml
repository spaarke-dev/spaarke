  <outputs>
    <output type="document">projects/spaarke-ai-platform-unification-r7/notes/handoffs/089a-ui-test-results.md</output>
    <output type="screenshots">projects/spaarke-ai-platform-unification-r7/assets/089a-{test}.png (3 screenshots)</output>
