  </tools>

  <outputs>
    <output type="modified-file">src/client/shared/Spaarke.DailyBriefing.Components/src/components/DailyBriefingApp.tsx (or sibling — affordance + Dialog wrapper)</output>
    <output type="new-file">src/client/shared/Spaarke.DailyBriefing.Components/test/PlaybookLibraryAffordance.test.tsx</output>
