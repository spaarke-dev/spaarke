  </inputs>

  <constraints>
    <constraint source="CLAUDE.md §3 Sub-Agent Write Boundary">Sub-agents CANNOT write to `.claude/` paths. Main session executes this task. No parallel dispatch.</constraint>
    <constraint source="spec FR-32">Each rewritten skill cites §3.1 WHY history and validates against `node.sprk_executortype`, not Action lookup.</constraint>
    <constraint source="design.md §2 Invariant 2">Single-hop dispatch — `node.sprk_executortype` is the only load-bearing dispatch signal.</constraint>
    <constraint source="spec FR-03/FR-04">`sprk_actiontypeid` lookup + `sprk_executoractiontype` INT are dropped/decorative post-R7. Audit flags references.</constraint>
    <constraint source="spec FR-05">`sprk_analysisactiontype` lookup table survives as decorative Action category browser (e.g., "Summarize", "Analyze"). Audit flags load-bearing usage — references for browse-only are fine.</constraint>
    <constraint source="CLAUDE.md §11">REWRITE of existing skill — §11 triple does not apply.</constraint>
  </constraints>

  <knowledge>
    <topic>jps-skill-authoring</topic>
    <files>
