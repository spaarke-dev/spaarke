<task id="R7-110" project="spaarke-ai-platform-unification-r7">
  <metadata>
    <title>Audit current orchestrator template resolution + design RunContext.NodeOutputs surface</title>
    <status>not-started</status>
    <wave>11</wave>
    <estimated-effort>2-3 hours</estimated-effort>
    <tags>audit, bff-api, planning, wave-11</tags>
