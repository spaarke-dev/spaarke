      <item>Task 047 cumulative wave publish-size check.</item>
    </related-work>
  </context>

  <steps>
    <step order="0" name="Rigor Declaration">
      Output: 🔒 RIGOR LEVEL: FULL · 📋 REASON: dataverse-schema deletion, tag dataverse-schema+deletion, FR-03 acceptance gate — quality gates Step 9.5 required · Proceeding with Step 0...
