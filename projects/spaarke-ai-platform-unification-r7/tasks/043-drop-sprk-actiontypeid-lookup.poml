  <constraints>
    <constraint source="spec FR-03">DELETE `sprk_analysisaction.sprk_actiontypeid` (lookup field). Action no longer carries dispatch identity. Acceptance: field removed from Dataverse; AnalysisActionService no longer references it.</constraint>
