<task id="R7-089b" project="spaarke-ai-platform-unification-r7">
  <metadata>
    <title>UI test — typed config forms for 5 priority executors</title>
    <status>completed</status>
    <wave>8</wave>
    <estimated-effort>2-3 hours</estimated-effort>
    <tags>code-page, testing, ui-test, wave-8</tags>
    <rigor-level>FULL</rigor-level>
    <parallel-safe>true</parallel-safe>
    <dependencies>084</dependencies>
    <fr-coverage>FR-23 (typed forms UI test coverage)</fr-coverage>
  </metadata>

  <prompt>
    Browser-based UI test of the typed config forms for the 5 priority executors per FR-23.
    Uses Claude Code Chrome integration per `/ui-test` skill. Verifies:
    - AiAnalysis form renders with documentScope, toolBindings, temperature, promptOverride fields
    - AiCompletion form renders with temperature, maxOutputTokens, promptOverride fields
    - Condition form renders with expression, trueBranch, falseBranch fields
    - EntityNameValidator form renders with entitySetName, uniqueCheck, maxLength fields
    - CreateNotification form renders with recipientType, template, priority fields
    - Each form's per-field validation works (required-field empty → error shown)
    - Form-state syncs to `sprk_configjson` (legacy field preserved)
    Tests run against deployed PlaybookBuilder Code Page in spaarkedev1.
  </prompt>

  <role>
    QA + frontend engineer. Familiar with Claude Code Chrome integration, schema-driven UI testing,
    and form-validation testing patterns.
  </role>

  <goal>
    Documented UI test results:
    1. Browser-based test pass/fail report for each of the 5 priority forms
    2. Screenshots of each form in default + validation-error states
    3. Console logs capture (zero errors expected)
    4. `sprk_configjson` round-trip verification (1 spot check)
    5. Results recorded in `projects/spaarke-ai-platform-unification-r7/notes/handoffs/089b-ui-test-results.md`
    6. Any FAILs filed via `/project-defer-issue-tracking`
  </goal>

  <inputs>
    <file purpose="design-spec">projects/spaarke-ai-platform-unification-r7/spec.md</file>
    <file purpose="project-claude">projects/spaarke-ai-platform-unification-r7/CLAUDE.md</file>
    <file purpose="ui-test-skill">.claude/skills/ui-test/SKILL.md</file>
    <file purpose="typed-form">src/client/code-pages/PlaybookBuilder/src/components/properties/TypedConfigForm.tsx</file>
    <file purpose="adr-021">docs/adr/ADR-021-dark-mode-semantic-tokens.md</file>
  </inputs>

  <constraints>
    <constraint source="ui-test SKILL.md">Browser-based testing requires `--chrome`. If not available, manual fallback.</constraint>
    <constraint source="ADR-021">Verify semantic-token colors visually — task 089c covers dedicated dark-mode pass. This task focuses on functional behavior.</constraint>
    <constraint source="ADR-038">UI tests at KEEP path. Results documented in handoffs.</constraint>
    <constraint source="CLAUDE.md §11">No new components — testing existing UI.</constraint>
  </constraints>

  <knowledge>
    <topic>testing/ui-tests</topic>
    <files>
      <file>.claude/skills/ui-test/SKILL.md</file>
