  </outputs>

  <acceptance-criteria>
    <criterion>Test 1: AiAnalysis form — all 4 fields render + required-field validation — PASS</criterion>
    <criterion>Test 2: AiCompletion form — all 3 fields render + SpinButton min/max — PASS</criterion>
    <criterion>Test 3: Condition form — all 3 required fields validate — PASS</criterion>
    <criterion>Test 4: EntityNameValidator form — all 3 fields incl. Switch — PASS</criterion>
    <criterion>Test 5: CreateNotification form — all 3 fields incl. 2 Dropdowns — PASS</criterion>
