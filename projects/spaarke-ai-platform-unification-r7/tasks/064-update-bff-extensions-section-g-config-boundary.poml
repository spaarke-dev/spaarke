<task id="R7-064" project="spaarke-ai-platform-unification-r7">
  <metadata>
    <title>UPDATE .claude/constraints/bff-extensions.md §G (config boundary) for new node-dispatch model</title>
    <status>not-started</status>
    <wave>6</wave>
    <estimated-effort>1-2 hours</estimated-effort>
    <tags>docs, skill-directives, wave-6</tags>
    <rigor-level>STANDARD</rigor-level>
    <parallel-safe>false</parallel-safe>
