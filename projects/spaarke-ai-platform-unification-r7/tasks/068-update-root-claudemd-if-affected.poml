<task id="R7-068" project="spaarke-ai-platform-unification-r7">
  <metadata>
    <title>UPDATE root CLAUDE.md if §13 System Entry Points or §17 Pointers table affected by R7</title>
    <status>not-started</status>
    <wave>6</wave>
    <estimated-effort>30-60 min</estimated-effort>
