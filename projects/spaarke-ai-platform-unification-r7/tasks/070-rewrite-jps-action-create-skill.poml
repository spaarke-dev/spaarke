<task id="R7-070" project="spaarke-ai-platform-unification-r7">
  <metadata>
    <title>REWRITE `.claude/skills/jps-action-create/SKILL.md` (FR-32)</title>
    <status>not-started</status>
    <wave>7</wave>
    <estimated-effort>2-3 hours</estimated-effort>
    <tags>skill-directives, docs, wave-7</tags>
    <rigor-level>STANDARD</rigor-level>
    <parallel-safe>false</parallel-safe>
