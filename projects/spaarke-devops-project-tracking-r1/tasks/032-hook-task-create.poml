<task id="DEVOPS-032" project="Spaarke DevOps Project Tracking r1">
  <metadata>
    <title>Inject Task Count hook into /task-create</title>
    <status>completed</status>
    <phase>4</phase>
    <estimated-effort>0.5 hour</estimated-effort>
