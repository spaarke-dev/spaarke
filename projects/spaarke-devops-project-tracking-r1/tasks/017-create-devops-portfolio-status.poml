<task id="DEVOPS-017" project="Spaarke DevOps Project Tracking r1">
  <metadata>
    <title>Create /devops-portfolio-status skill (dashboard + snapshot)</title>
    <status>completed</status>
    <phase>2</phase>
    <estimated-effort>2.5 hours</estimated-effort>
    <actual-effort>~10 minutes</actual-effort>
    <completed>2026-06-23</completed>
    <tags>skill-creation, devops, portfolio-status, dashboard, snapshot</tags>
    <dependencies>010</dependencies>
    <parallel-group>none</parallel-group>
    <parallel-safe>false</parallel-safe>
  </metadata>

  <prompt>
Author `/devops-portfolio-status` skill per FR-13. Prints a concise dashboard (active Epics → their Projects → rollup metrics) to terminal in <30 seconds. Optional `--snapshot` writes `docs/portfolio/snapshot-{YYYY-MM-DD}.md` formatted for stakeholders per D-10 (Epic-by-Epic narrative, not raw field dump).

NOTE: This task modifies `.claude/skills/` — main session only.
  </prompt>

  <role>Skill author with eye for stakeholder-readable output. Raw GitHub field IDs do NOT leak into snapshot markdown — names only.</role>

  <goal>
Terminal output answers in <30 seconds: "What Epics are active? How many projects in each? Rough portfolio status?" `--snapshot` produces a markdown file with no raw field IDs leaking; the file reads like a stakeholder briefing.
  </goal>

  <constraints>
    <constraint source="NFR-07">Spaarke skill convention</constraint>
    <constraint source="spec FR-13 + D-10">Snapshot is human-readable narrative, NOT raw field dump</constraint>
    <constraint source="spec D-10">Audience: engineering owner + engineers + stakeholders/leadership (not customers)</constraint>
    <constraint source="root CLAUDE.md §3">Main session only</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>projects/spaarke-devops-project-tracking-r1/spec.md</file>
      <file>.claude/skills/INDEX.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="0" name="Context check">Confirm task 010 ✅.</step>
    <step order="1" name="Author SKILL.md frontmatter + Prerequisites + Purpose">Standard.</step>
    <step order="2" name="Author Steps — terminal mode">(a) Query Project #2 items: all Epics + all Projects with their field values. (b) Group Projects under their Parent Epic. (c) Compute per-Epic rollup: total projects, in-progress count, planned count, on-hold count, completed count, cancelled count. (d) Print concise table per Epic.</step>
    <step order="3" name="Author Steps — snapshot mode">(a) Query same data. (b) Render Epic-by-Epic narrative markdown: Epic name as ##; under each, list Projects with brief one-line status, projected dates. (c) Write to `docs/portfolio/snapshot-{YYYY-MM-DD}.md`. (d) Print "Snapshot written to {path}" + remind user to commit.</step>
    <step order="4" name="Author Failure Modes">Project #2 unreachable, no Epics yet (suggest `/devops-epic-create`), `docs/portfolio/` doesn't exist (create it).</step>
    <step order="5" name="Update INDEX.md">Add row.</step>
    <step order="6" name="Smoke test">Run against current portfolio (after Phase 1 tasks 001-005 land 12 Epics). Verify terminal output + snapshot file format.</step>
  </steps>

  <tools>
    <tool name="Edit">.claude/skills/* files</tool>
    <tool name="Write">New SKILL.md</tool>
    <tool name="gh">Smoke test</tool>
  </tools>

  <outputs>
    <output type="skill">.claude/skills/devops-portfolio-status/SKILL.md</output>
    <output type="config">.claude/skills/INDEX.md (one new row)</output>
    <output type="notes" ephemeral="true">projects/spaarke-devops-project-tracking-r1/notes/spikes/phase2-portfolio-status-smoke-{date}.md</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">SKILL.md exists with NFR-07 sections</criterion>
    <criterion testable="true">Terminal output renders in <30 seconds</criterion>
    <criterion testable="true">`--snapshot` writes valid markdown to `docs/portfolio/snapshot-{date}.md`</criterion>
    <criterion testable="true">Snapshot file contains zero raw GitHub field IDs (only field names + values)</criterion>
    <criterion testable="true">INDEX.md updated</criterion>
  </acceptance-criteria>
</task>
