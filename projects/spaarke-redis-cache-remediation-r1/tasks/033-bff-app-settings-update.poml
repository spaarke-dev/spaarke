  </knowledge>
  <steps>
    <step order="1">Resolve `{dev-kv}` from baseline notes.</step>
    <step order="2">`az webapp config appsettings set -g rg-spaarke-dev -n spaarke-bff-dev --settings Redis__Enabled=true Redis__InstanceName="spaarke:" "ConnectionStrings__Redis=@Microsoft.KeyVault(VaultName={dev-kv};SecretName=Redis-ConnectionString)" Redis__AllowInMemoryFallback=false`.</step>
    <step order="3">Verify: query and confirm all 4 settings reflect new values; KV reference resolves (not "Key Vault Reference Could Not Be Resolved").</step>
    <step order="4">Append to `notes/cutover-deploy-log.md`.</step>
    <step order="5">Update TASK-INDEX + current-task.</step>
  </steps>
  <tools><tool name="Bash">az CLI</tool><tool name="Write">log append</tool></tools>
  <outputs><output type="azure">spaarke-bff-dev App Settings (modified)</output></outputs>
  <acceptance-criteria>
    <criterion testable="true">All 4 App Settings reflect new values per FR-14.</criterion>
    <criterion testable="true">KV reference resolves (`az webapp config appsettings list --query "[?name=='ConnectionStrings__Redis'].value"` does NOT contain "Could Not Be Resolved").</criterion>
