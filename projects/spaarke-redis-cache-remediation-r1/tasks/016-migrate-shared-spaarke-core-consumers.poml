    </files>
  </knowledge>
  <steps>
    <step order="1">Open inventory Shared section.</step>
    <step order="2">For each BFF site using `DistributedCacheExtensions.CreateKey`: rewrite via `ITenantCache`.</step>
    <step order="3">`dotnet build` + `dotnet test`.</step>
