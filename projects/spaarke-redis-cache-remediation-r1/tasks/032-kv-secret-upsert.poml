<?xml version="1.0" encoding="UTF-8"?>
<task id="032" project="spaarke-redis-cache-remediation-r1">
  <metadata>
    <title>Key Vault Redis-ConnectionString secret upsert</title>
    <phase>3: Dev environment cutover</phase>
    <status>not-started</status>
    <estimated-hours>1</estimated-hours>
    <dependencies>031</dependencies>
    <blocks>033</blocks>
    <tags>azure, deploy, auth, infrastructure</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Live secret operation; binds ADR-028</rigor-reason>
    <parallel-group>Phase3</parallel-group>
    <parallel-safe>false</parallel-safe>
    <parallel-reason>Phase 3 cutover sequence — strictly serial</parallel-reason>
  </metadata>
  <prompt>Upsert `Redis-ConnectionString` secret in the canonical dev KV (from task 030 baseline). Value = StackExchange-compatible connection string built from `spaarke-bff-redis-dev` host + SSL port + primary key.</prompt>
  <role>Spaarke operator; KV secret management.</role>
  <goal>`az keyvault secret show --vault-name {dev-kv} --name Redis-ConnectionString` returns the new connection string; secret version captured in cutover log.</goal>
  <context><background>Per ADR-028 and FR-14, the connection string lives in KV — never plain text in App Settings.</background><relevant-files><file>{dev-kv} (Azure KV)</file></relevant-files></context>
  <constraints>
    <constraint source="ADR-028">KV reference syntax; MI reads.</constraint>
    <constraint source="spec">FR-14 — secret upsert.</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>projects/spaarke-redis-cache-remediation-r1/notes/dev-cutover-baseline.md</file>
      <file>projects/spaarke-redis-cache-remediation-r1/notes/cutover-deploy-log.md</file>
      <file>projects/spaarke-redis-cache-remediation-r1/spec.md</file>
      <file>.claude/adr/ADR-028-spaarke-auth-architecture.md</file>
    </files>
  </knowledge>
  <steps>
    <step order="1">Retrieve primary key: `az redis list-keys -g spe-infrastructure-westus2 -n spaarke-bff-redis-dev --query primaryKey -o tsv`.</step>
    <step order="2">Build connection string: `{host}:6380,password={primaryKey},ssl=True,abortConnect=False`. Note: `abortConnect=False` in the CONNECTION-STRING is OK — `AbortOnConnectFail = true` is set in CODE (CacheModule). They are different.</step>
    <step order="3">`az keyvault secret set --vault-name {dev-kv} --name Redis-ConnectionString --value "<connection-string>"`. Capture version.</step>
    <step order="4">Verify: `az keyvault secret show --vault-name {dev-kv} --name Redis-ConnectionString` returns the new value.</step>
    <step order="5">Append to `notes/cutover-deploy-log.md`.</step>
    <step order="6">Update TASK-INDEX + current-task.</step>
  </steps>
  <tools><tool name="Bash">az CLI</tool><tool name="Write">log append</tool></tools>
  <outputs><output type="azure">Redis-ConnectionString secret in dev KV (new version)</output></outputs>
  <acceptance-criteria>
    <criterion testable="true">Secret exists at new version; value parses to expected host + port + key.</criterion>
    <criterion testable="true">Cutover log records the secret version.</criterion>
  </acceptance-criteria>
  <execution><skill>.claude/skills/task-execute/SKILL.md</skill><protocol>FULL rigor.</protocol></execution>
</task>
