      <file>docs/guides/redis-cache-azure-setup.md (REFERENCE — current alert documentation §8)</file>
    </relevant-files>
  </context>
  <constraints>
    <constraint source="spec">FR-04 — exactly 3 alerts: hit-rate &lt;80%/15min, P95 &gt;100ms/5min, memory &gt;80%/15min. Bicep-deployed, not markdown.</constraint>
    <constraint source="azure-deployment.md">Idempotent deploy; reuse existing action group; emit clear error messages.</constraint>
    <constraint source="spec">Acceptance: `az monitor metrics alert list -g rg-spaarke-dev` shows the 3 alerts after deploy.</constraint>
  </constraints>
