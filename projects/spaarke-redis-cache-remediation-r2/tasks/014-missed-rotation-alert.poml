<task id="014" project="spaarke-redis-cache-remediation-r2">
  <metadata>
    <title>Missed-rotation alert (>100 days) added to alerts.bicep</title>
    <phase>2: Theme B — Redis key rotation automation</phase>
    <status>not-started</status>
    <estimated-hours>1</estimated-hours>
