    <constraint source="spec">FR-09 — per-env SP isolation; compromised env SP must not rotate other envs.</constraint>
    <constraint source="spec">Acceptance: `az role assignment list --assignee {sp-id} --all` shows scoped permissions per env.</constraint>
  </constraints>
