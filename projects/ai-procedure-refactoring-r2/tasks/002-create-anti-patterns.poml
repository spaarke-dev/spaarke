<task id="002" project="ai-procedure-refactoring-r2">
  <metadata>
    <title>Create ANTI-PATTERNS.md</title>
    <phase>1</phase>
    <tags>standards, documentation, anti-patterns</tags>
    <estimate>2h</estimate>
    <status>pending</status>
