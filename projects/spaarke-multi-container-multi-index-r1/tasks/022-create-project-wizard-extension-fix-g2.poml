<task id="022" project="spaarke-multi-container-multi-index-r1">
  <metadata>
    <title>CreateProjectWizard — fix latent G2 (`sprk_containerid`) + add `sprk_searchindexname` (FR-WIZ-02)</title>
    <phase>A: Wizards</phase>
    <status>not-started</status>
    <estimated-hours>3-4</estimated-hours>
    <dependencies>020</dependencies>
    <blocks>028</blocks>
