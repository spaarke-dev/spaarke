  <constraints>
    <constraint source="spec.md §5">Drop `searchIndexName` bound property from manifest. PCF resolves via `context.webAPI` with `$expand=sprk_aisearchindexid($select=sprk_searchindexname)`. Wire format (string) downstream unchanged.</constraint>
    <constraint source=".claude/skills/pcf-deploy/SKILL.md">5-location version bump REQUIRED: ControlManifest.Input.xml, main .tsx (footer string), Solution/solution.xml, Solution/Controls/.../ControlManifest.xml, Solution/pack.ps1.</constraint>
    <constraint source="ADR-022">PCF stays React 16. Do NOT use React 18-only APIs (createRoot, useTransition, etc.).</constraint>
    <constraint source="ADR-028">All BFF calls via `authenticatedFetch` from `@spaarke/auth` — unchanged.</constraint>
    <constraint source="ADR-021">Fluent UI v9 tokens for any new UI (this task has no new UI; pure logic change).</constraint>
    <constraint source="NFR-10">PCF clean-rebuild required before pack — `npm run build:prod` (NOT `npm run build`) per FAILURE-MODES.md#AP-1.</constraint>
  </constraints>

