<task id="043" project="spaarke-multi-container-multi-index-r1">
  <metadata>
    <title>Code page — UI tests + parameter parsing tests</title>
    <phase>E: SemanticSearch Code Page</phase>
    <status>not-started</status>
    <estimated-hours>3-5</estimated-hours>
    <dependencies>041, 042</dependencies>
    <blocks>044</blocks>
    <tags>testing, unit-test, e2e-test, react, frontend, fluent-ui</tags>
    <rigor-hint>STANDARD</rigor-hint>
    <rigor-reason>Test creation task. `testing` tag. New test files. Carries ADR-021 (dark-mode) + ADR-022 (React 18) constraints. Not source-code logic.</rigor-reason>
    <parallel-group>none</parallel-group>
    <parallel-safe>false</parallel-safe>
    <parallel-reason>Must follow 041 + 042 (both code-page changes complete) and precede 044 (deploy depends on tests green).</parallel-reason>
