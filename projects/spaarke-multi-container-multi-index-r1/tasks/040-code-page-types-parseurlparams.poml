<task id="040" project="spaarke-multi-container-multi-index-r1">
  <metadata>
    <title>Code page — extend `types/index.ts` `AppUrlParams` + `parseUrlParams.ts` (FR-CP-01)</title>
    <phase>E: SemanticSearch Code Page</phase>
    <status>not-started</status>
    <estimated-hours>3-5</estimated-hours>
