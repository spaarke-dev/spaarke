      <file>projects/spaarke-multi-container-multi-index-r1/design.md</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-012">Logic in `@spaarke/ui-components` (DocumentRecordService.ts).</constraint>
    <constraint source="ADR-022">Code page React 18; shared lib portable.</constraint>
    <constraint source="ADR-028">No new auth wiring; Xrm.WebApi for Dataverse reads.</constraint>
    <constraint source="design.md INV (Document container field)">Canonical Document container field is `sprk_graphdriveid`. `sprk_containerid` MUST stay NULL on `sprk_document`. Do NOT add `sprk_containerid` to the Document payload under any circumstances.</constraint>
    <constraint source="spec.md FR-WIZ-07">Document payload includes `sprk_searchindexname` (resolved via task 026's chain) alongside existing `sprk_graphdriveid`.</constraint>
    <constraint source="design.md INV-5">If payload already has a non-empty `sprk_searchindexname`, do NOT overwrite.</constraint>
  </constraints>

  <knowledge>
    <files>
