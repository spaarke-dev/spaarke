<task id="027" project="spaarke-multi-container-multi-index-r1">
  <metadata>
    <title>DocumentUploadWizard — `DocumentRecordService.buildRecordPayload` includes `sprk_searchindexname` (FR-WIZ-07)</title>
    <phase>A: Wizards</phase>
    <status>not-started</status>
    <estimated-hours>2-3</estimated-hours>
    <dependencies>026</dependencies>
    <blocks>028</blocks>
    <tags>react, typescript, shared-library, frontend</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Modifies `.ts` payload-assembly code; carries ADR-012 / ADR-022 / ADR-028 obligations; INV-5 enforcement; carries a critical "do NOT add `sprk_containerid` on Document" constraint per design INV.</rigor-reason>
    <parallel-group>none</parallel-group>
    <parallel-safe>false</parallel-safe>
    <parallel-reason>Depends on the resolver added in task 026. Same code-page area, serial execution.</parallel-reason>
