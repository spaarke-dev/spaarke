  <acceptance-criteria>
    <criterion testable="true">Side pane shows a single "Search Index" Dropdown at top; 4 domain tabs removed.</criterion>
    <criterion testable="true">Dropdown lists 8 options (per task 101 seed) sourced from `sprk_aisearchindex` via DV Web API; ordered by sprk_displayorder.</criterion>
    <criterion testable="true">Default selection follows URL envelope → isdefault=true → first row precedence.</criterion>
    <criterion testable="true">Selecting "Matters" sends request with scope='entity', entityType='matter', searchIndexName='spaarke-records-index'.</criterion>
    <criterion testable="true">Selecting "All Records" sends request with scope='all' (no entityType), searchIndexName='spaarke-records-index'.</criterion>
    <criterion testable="true">"Relevance Threshold" + "Search Mode" controls visible in side pane below the existing filters.</criterion>
    <criterion testable="true">Popover info icons replace inline-help labels.</criterion>
    <criterion testable="true">All unit + component tests pass.</criterion>
    <criterion testable="true">Dark-mode renders correctly per ADR-021 (token-based; no hex).</criterion>
  </acceptance-criteria>

