  <constraints>
    <constraint source="spec.md FR-PCF-02">`SemanticSearchApiService.search()` MUST include `searchIndexName` in the request body when non-empty (omit when empty).</constraint>
    <constraint source="ADR-006">PCF only â€” no webresource shim path; all BFF calls happen from the PCF service.</constraint>
    <constraint source="ADR-022">PCF stays React 16-safe. No React 18-only APIs.</constraint>
    <constraint source="ADR-028">All BFF calls use `authenticatedFetch` from `@spaarke/auth`. No `Bearer ${token}` literals. No `new PublicClientApplication`. No `accessToken` prop drilling.</constraint>
    <constraint source="spec.md NFR-09">Code review confirms no `Bearer ${token}` literals; no `new PublicClientApplication`; all BFF calls use `authenticatedFetch`.</constraint>
    <constraint source="project">Omit the field entirely from the JSON body when empty/null â€” do not send empty string. BFF treats absence as "fall through to existing tenant chain" (FR-BFF-04).</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-006-pcf-over-webresources.md</file>
