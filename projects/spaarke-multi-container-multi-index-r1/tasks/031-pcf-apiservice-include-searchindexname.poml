    <patterns>
      <pattern name="Spaarke Auth v2 binding" location=".claude/patterns/auth/spaarke-sso-binding.md">
        `authenticatedFetch` is the only sanctioned BFF call mechanism in PCF + code-page surfaces. It transparently injects the OBO token. Never use raw `fetch` with a `Bearer ${token}` header.
      </pattern>
      <pattern name="Omit-when-empty body composition" location="spec.md FR-BFF-04">
        BFF treats absence of `searchIndexName` as "use the 2-tier tenant default chain". Therefore the client MUST omit the field entirely when value is null/empty/whitespace â€” not send empty string.
      </pattern>
    </patterns>
  </knowledge>

  <steps>
