  <acceptance-criteria>
    <criterion testable="true">Standalone SummarizeFilesWizard: send-email round-trip passes → outbound `sprk_communication` record created with `statuscode = Sent`.</criterion>
    <criterion testable="true">LegalWorkspace SummarizeFiles: send-email round-trip passes → outbound `sprk_communication` record created.</criterion>
    <criterion testable="true">Both records have `sprk_internetmessageid` populated (or known-issue warn-log documented per FR-22 best-effort).</criterion>
    <criterion testable="true">Both records have correct file attachments linked.</criterion>
    <criterion testable="true">Validation tests: `TO_REQUIRED` and `TO_INVALID_EMAIL` surface via canonical wrapper.</criterion>
