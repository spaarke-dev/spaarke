    <patterns>
      <pattern name="xUnit + Moq + FluentAssertions" location=".claude/patterns/testing/unit-test-structure.md">
        Arrange / Act / Assert; one logical assertion per test; descriptive test names (`MethodName_Condition_ExpectedOutcome`); mock external services via Moq; use FluentAssertions for readable expectations.
      </pattern>
      <pattern name="Jest test layout" location="src/client/shared/Spaarke.UI.Components/src/services/__tests__/">
        `*.test.ts` co-located in `__tests__/`; mocks via `jest.fn()` for injected dependencies (e.g., `authenticatedFetch`); `describe` / `it` structure.
      </pattern>
      <pattern name="ProblemDetails JSON shape" location=".claude/adr/ADR-019-problemdetails-error-responses.md">
        `{ type, title, status, detail, instance | traceId, correlationId?, code? }`. Test cases exercise both populated and partial shapes.
      </pattern>
    </patterns>
