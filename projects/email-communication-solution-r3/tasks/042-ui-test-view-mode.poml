<task id="042" project="email-communication-solution-r3">
  <metadata>
    <title>UI test — EmailComposer Code Page `mode=view` read-only display</title>
    <phase>Wave 2 — EmailComposer Code Page + Entry Surfaces</phase>
    <status>not-started</status>
    <estimated-hours>2</estimated-hours>
    <dependencies>038</dependencies>
    <blocks>099</blocks>
    <tags>ui-test, e2e-test, frontend, fluent-ui</tags>
    <rigor-hint>STANDARD</rigor-hint>
    <rigor-reason>Browser-based UI test using `ui-test` skill; deterministic scenario; gated by task 038 (Form Component Control swap so view mode reachable via record navigation)</rigor-reason>
    <parallel-group>I</parallel-group>
