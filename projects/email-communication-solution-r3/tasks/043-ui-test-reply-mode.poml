  <ui-tests>
    <test name="Reply mode prefill and send">
      <navigation>
        <url>https://{org}/WebResources/sprk_emailcomposer?data=%7B%22mode%22%3A%22reply%22%2C%22id%22%3A%22{existing-record-guid}%22%7D</url>
        <description>Open EmailComposer Code Page in reply mode for an existing `sprk_communication` record. Existing record must have populated `from`, `subject`, `body`, AND `sprk_internetmessageid` (task 003 prerequisite).</description>
      </navigation>
      <steps>
        <step order="1">Navigate to URL; wait for app mount + record load (max 5s)</step>
        <step order="2">Verify zero console errors on cold load</step>
        <step order="3">Verify To field is prefilled with the original record's `from` address (Fluent Tag visible)</step>
        <step order="4">Verify Cc field is empty</step>
        <step order="5">Verify Subject field is prefilled with `Re: ${original.subject}`. If original subject already starts with `Re:`, verify NO double-prefix (still just `Re: <subject>`)</step>
        <step order="6">Verify Body field is prefilled with: user reply area (empty) + divider + quoted original body</step>
        <step order="7">Verify Attachments section is empty (attachments NOT carried per FR-11)</step>
        <step order="8">Verify Associations section carries the original record's associations</step>
        <step order="9">Type user reply text in Body: `Thanks â€” confirming receipt.`</step>
        <step order="10">Click Send button; wait for response (max 10s)</step>
        <step order="11">Verify success state displayed</step>
        <step order="12">Verify Dataverse-side: query the new `sprk_communication` record (most recent) and confirm `sprk_inreplyto` references the original record's GUID. Use `Xrm.WebApi` from DevTools or the ui-test skill's Dataverse query helper.</step>
        <step order="13">Verify zero console errors throughout</step>
      </steps>
      <expected-outcomes>
        <outcome>Code Page loads in reply mode with prefilled To, Subject (Re: prefix), Body (wrapped original)</outcome>
        <outcome>Attachments NOT carried (FR-11)</outcome>
        <outcome>Associations carried from original</outcome>
        <outcome>Send creates new `sprk_communication` with `sprk_inreplyto` pointing to original</outcome>
        <outcome>If original has `sprk_threadid`, the new record inherits it</outcome>
        <outcome>Zero console errors throughout</outcome>
      </expected-outcomes>
      <dark-mode-check>
        <step>Toggle dark mode; verify reply UI adapts</step>
        <step>Smoke check; comprehensive in task 045</step>
      </dark-mode-check>
      <console-error-check>
        <target>0 errors</target>
        <description>Zero errors from cold load through Send completion.</description>
      </console-error-check>
    </test>
  </ui-tests>

