    <constraint source="project">Send via BFF `/api/communications/send` with `existingCommunicationId` field ‚Äî coordinate Wave 0 update if missing</constraint>
    <constraint source="project">Validation: Save Draft blocked only on `TO_INVALID_EMAIL`; Send blocked on full canonical set (task 020 contract)</constraint>
  </constraints>

