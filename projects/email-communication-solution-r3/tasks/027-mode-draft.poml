  <acceptance-criteria>
    <criterion testable="true">Draft loads from sourceRecord; all editable fields populated.</criterion>
    <criterion testable="true">Save Draft updates the existing record (statuscode unchanged); validation blocks only TO_INVALID_EMAIL.</criterion>
    <criterion testable="true">Send transitions statuscode to Sent + invokes Graph SendMail (via BFF) using existingCommunicationId.</criterion>
    <criterion testable="true">Discard deletes the record + invokes `onClose`.</criterion>
    <criterion testable="true">Save Draft via Xrm.WebApi.updateRecord per DATA-ACCESS-DECISION-CRITERIA.md.</criterion>
