      <file>src/client/shared/Spaarke.UI.Components/src/components/EmailComposer/types.ts (if it exists; check for shared `CommunicationAssociation`, `AttachmentSourceKind`)</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="spec FR-03">Canonical signature: `{ open, onClose, initialTo?, initialSubject?, associations?, attachmentSources?, onSent?, onError? }`. NO `onSend`.</constraint>
    <constraint source="spec FR-14">Legacy `onSend` REMOVED entirely (not deprecated, not aliased) — break-and-migrate forcing function.</constraint>
    <constraint source="ADR-019">`onError` parameter typed as `SendCommunicationError` (typed ProblemDetails class, not `Error` or string).</constraint>
    <constraint source="project">Interface MUST be re-exported from `@spaarke/ui-components` top-level barrel.</constraint>
    <constraint source="project">Single canonical definition — any duplicate `ISendEmailDialogProps` in the legacy `SendEmailDialog/` location must be removed.</constraint>
    <constraint source="repo">`npm run build` + `npm run lint` in `@spaarke/ui-components` MUST remain green.</constraint>
