  <constraints>
    <constraint source="ADR-021">Fluent UI v9 ONLY (`@fluentui/react-components`); no v8/v0; dark mode via Fluent theme provider only</constraint>
    <constraint source="ADR-028">Engine does NOT import `@spaarke/auth` — host injects `authenticatedFetch` via props (NFR-02)</constraint>
    <constraint source="ADR-019">Engine `send()` throws `SendCommunicationError` (typed) on non-2xx — never returns `{success: false}` or pushes to `warnings[]`</constraint>
    <constraint source="ADR-033">Single-engine constraint — this IS the only React component that knows email-send mechanics; wrappers must be thin</constraint>
    <constraint source="ADR-010">No new DI registrations (engine is pure client; CommunicationModule only registers server-side)</constraint>
    <constraint source="NFR-01">React 18 only — no PCF React 16 compatibility considerations</constraint>
    <constraint source="NFR-03">Three explicit mount variants: page (full-width form), dialog (~600px compact), inline (no header/action bar — wizard owns)</constraint>
    <constraint source="NFR-09">Engine renders semantic landmarks (`role="region"`, `aria-label`) for screen-reader navigation; live region reserved for validation errors (populated in task 020)</constraint>
    <constraint source="project">Engine MUST `forwardRef` and expose `IEmailComposerHandle` via `useImperativeHandle` with methods: `validate()`, `send()`, `saveDraft()`, `getState()`</constraint>
    <constraint source="project">State machine MUST be a `useReducer` (single source of truth) — NOT scattered `useState` calls</constraint>
    <constraint source="project">Engine MUST compile and render at end of this task — sub-components are stub placeholders filled by 012-019</constraint>
  </constraints>

