<task id="033" project="email-communication-solution-r3">
  <metadata>
    <title>Mount `<SendEmailPage />` wrapper into EmailComposer Code Page App</title>
    <phase>Wave 2 — EmailComposer Code Page + Entry Surfaces</phase>
