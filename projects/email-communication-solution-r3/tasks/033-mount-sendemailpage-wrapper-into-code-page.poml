  <acceptance-criteria>
    <criterion testable="true">`<SendEmailPage />` is mounted inside `<App />`, receiving all required props.</criterion>
    <criterion testable="true">`authenticatedFetch` flows from auth context to wrapper props (no direct `@spaarke/auth` import in shared lib).</criterion>
    <criterion testable="true">URL params from `useUrlParams()` correctly map to wrapper props (5 modes verified).</criterion>
