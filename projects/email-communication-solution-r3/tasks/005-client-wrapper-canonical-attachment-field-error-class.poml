<task id="005" project="email-communication-solution-r3">
  <metadata>
    <title>Client wrapper — Add `attachmentDriveItemIds` canonical field + `SendCommunicationError` class</title>
    <phase>Wave 0 — Foundations + Non-Breaking BFF</phase>
    <status>not-started</status>
    <estimated-hours>3</estimated-hours>
