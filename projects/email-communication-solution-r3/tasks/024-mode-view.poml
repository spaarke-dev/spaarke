  </outputs>

  <acceptance-criteria>
    <criterion testable="true">`view` mode renders sourceRecord fields read-only.</criterion>
    <criterion testable="true">No editable controls; sub-components honor `readOnly` prop.</criterion>
    <criterion testable="true">AttachmentList rows are download-linked via SPE facade endpoint (no direct SPE access — ADR-007).</criterion>
