  </context>

  <constraints>
    <constraint source="ADR-021">Fluent v9 only; read-only display uses Fluent labels + tags (not disabled inputs)</constraint>
    <constraint source="ADR-007">Attachment download links use existing SPE facade endpoint — no direct SPE/Graph access from client</constraint>
    <constraint source="ADR-033">View mode is part of the canonical engine — DO NOT create a parallel read-only viewer</constraint>
    <constraint source="NFR-09">Read-only fields still keyboard-accessible (focusable to inspect content)</constraint>
    <constraint source="project">UQ2 — Edit button rendered but DISABLED in spec v1; engine has transition logic ready</constraint>
  </constraints>

