<task id="055" project="email-communication-solution-r3">
  <metadata>
    <title>Smoke test FilePreviewDialog "Send by Email" flow end-to-end in dev</title>
    <phase>Wave 3 — SendEmailDialog + FilePreview</phase>
    <status>not-started</status>
    <estimated-hours>1.5</estimated-hours>
