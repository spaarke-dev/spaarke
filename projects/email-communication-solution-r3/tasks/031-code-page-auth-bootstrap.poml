    <patterns>
      <pattern name="Code Page auth bootstrap (canonical)" location=".claude/patterns/auth/spaarke-sso-binding.md">
        Code Page bootstraps `@spaarke/auth` at app entry; exposes `authenticatedFetch` to React tree; shared lib components receive it via props.
      </pattern>
      <pattern name="Auth bootstrap exemplar (working impl)" location="src/client/code-pages/DocumentRelationshipViewer/src/services/auth/">
        Three-file pattern: `MsalAuthProvider.ts` (provider wrapper), `msalConfig.ts` (config constants), `authInit.ts` (boot sequence).
      </pattern>
    </patterns>
