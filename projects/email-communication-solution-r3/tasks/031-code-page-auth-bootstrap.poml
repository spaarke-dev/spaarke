<task id="031" project="email-communication-solution-r3">
  <metadata>
    <title>Wire `@spaarke/auth` v2 bootstrap into EmailComposer Code Page</title>
    <phase>Wave 2 — EmailComposer Code Page + Entry Surfaces</phase>
