    </relevant-files>
  </context>

  <constraints>
    <constraint source="spec FR-18">5 valid modes: `compose|view|reply|forward|draft`. Any other value â†’ error UI</constraint>
    <constraint source="spec FR-18">`id` is required for `view|reply|forward|draft`; missing â†’ error UI</constraint>
    <constraint source="spec FR-18">`compose` mode: `id` not required; optional prefill fields (`to`, `cc`, `subject`, `body`, `associatedTo`) honored</constraint>
    <constraint source="project">Use Dataverse `data=` convention as primary parser; direct `?mode=â€¦` as fallback only</constraint>
    <constraint source="project">URL decoding must handle JSON-encoded payloads (`data=%7B%22mode%22%3A%22compose%22%7D`) AND straight strings</constraint>
    <constraint source="project">No raw HTML injection from URL â†’ all params consumed as strings; never `dangerouslySetInnerHTML` of URL content</constraint>
    <constraint source="project">No `.claude/` writes in this Wave 2 task</constraint>
  </constraints>

