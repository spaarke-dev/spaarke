      <file>src/client/shared/Spaarke.UI.Components/src/components/EmailComposer/index.ts (UPDATE)</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-021">Fluent UI v9 only — `Card`, `Button`, `MessageBar`, `Toolbar`, `Tag`</constraint>
    <constraint source="ADR-033">Single canonical attachment list — DO NOT clone per-source UIs</constraint>
    <constraint source="NFR-04">Hard caps: 150 count, 35 MB total; soft warning at 25 MB total</constraint>
    <constraint source="NFR-09">Each attachment row has descriptive `aria-label` (e.g., "Remove attachment Contract.pdf, 2.4 MB, from SPE")</constraint>
    <constraint source="project">Controlled component — engine reducer owns `attachments` state</constraint>
    <constraint source="project">Source-picker button slots rendered in order from `attachmentSources` prop; each is a stub button labeled per source kind</constraint>
    <constraint source="project">Cap enforcement triggers validation error via `onValidationError` callback — codes `ATTACHMENTS_TOO_MANY` / `ATTACHMENT_TOO_LARGE` per FR-08</constraint>
  </constraints>

