<task id="040" project="email-communication-solution-r3">
  <metadata>
    <title>Document the embeddable-launch pattern for EmailComposer Code Page (Surface 3)</title>
    <phase>Wave 2 — EmailComposer Code Page + Entry Surfaces</phase>
