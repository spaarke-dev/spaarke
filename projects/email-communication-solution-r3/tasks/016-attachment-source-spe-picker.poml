<task id="016" project="email-communication-solution-r3">
  <metadata>
    <title>SpeAttachmentSource — SPE document browser picker</title>
    <phase>Wave 1 — Engine + Wrappers + Sub-Components</phase>
    <status>not-started</status>
    <estimated-hours>3</estimated-hours>
    <dependencies>014</dependencies>
    <blocks>020</blocks>
    <tags>react, frontend, fluent-ui, spe, communication</tags>
    <rigor-hint>STANDARD</rigor-hint>
    <rigor-reason>Source-specific picker; SPE container browsing is a known pattern in the lib; no architecture decisions. STANDARD covers it.</rigor-reason>
    <parallel-group>D</parallel-group>
    <parallel-safe>true</parallel-safe>
    <fr-refs>FR-07</fr-refs>
