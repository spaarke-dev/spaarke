      <file>src/client/shared/Spaarke.UI.Components/src/components/EmailComposer/index.ts (UPDATE)</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-021">Fluent v9 only — `Button` (primary + subtle), `Spinner`</constraint>
    <constraint source="NFR-03">Returns null when `mount === 'inline'` (wizard chrome owns nav)</constraint>
    <constraint source="NFR-09">Buttons keyboard accessible; Send button has `aria-describedby` when disabled with reason (e.g., "validation errors prevent send")</constraint>
  </constraints>

