<task id="017" project="email-communication-solution-r3">
  <metadata>
    <title>RelatedRecordAttachmentSource — related-record document picker</title>
    <phase>Wave 1 — Engine + Wrappers + Sub-Components</phase>
    <status>not-started</status>
    <estimated-hours>3</estimated-hours>
