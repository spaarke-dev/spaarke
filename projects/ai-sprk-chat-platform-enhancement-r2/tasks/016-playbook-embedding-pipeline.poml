<?xml version="1.0" encoding="UTF-8"?>
<task id="R2-016" project="SprkChat Platform Enhancement R2">
  <metadata>
    <title>Playbook Embedding Pipeline — Index Playbooks into AI Search on Create/Update</title>
    <status>completed</status>
    <phase>2</phase>
    <tags>bff-api, ai, search</tags>
    <estimated-effort>medium</estimated-effort>
    <parallel-group>B</parallel-group>
    <parallel-safe>true</parallel-safe>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>BFF API code implementation — creates background embedding pipeline triggered by Dataverse playbook changes; integrates Azure OpenAI embedding generation with AI Search index writes; correctness is critical for PlaybookDispatcher Stage 1</rigor-reason>
    <dependencies>[003, 006]</dependencies>
  </metadata>

  <prompt>
    Create a background embedding pipeline that indexes playbooks into the `playbook-embeddings` AI
    Search index whenever a playbook is created or updated. This feeds Stage 1 of the PlaybookDispatcher.

    **Trigger mechanism**:
    - Dataverse plugin or webhook calls a new BFF API endpoint `POST /api/ai/playbooks/{playbookId}/index`
      after create/update. The BFF endpoint processes this asynchronously (fire-and-forget after
      enqueuing, returns `202 Accepted` immediately).
    - The actual embedding generation and indexing runs in the background via the existing
      `BackgroundService` (ADR-001) or a new `IBackgroundTaskQueue` enqueue pattern — follow the
      existing pattern in the BFF for background processing.

    **Embedding generation**:
    - Concatenate the following playbook fields into a single text document for embedding:
      `{name}\n{description}\n{triggerPhrases}\n{tags}`
      where `triggerPhrases` is the `sprk_triggerPhrases` field from Dataverse (newline-delimited)
    - Generate embedding via Azure OpenAI `text-embedding-3-large` (3072 dimensions) — use the
      existing embedding client in the BFF

    **Index write**:
    - Before writing, delete any existing document with the same `playbookId` from the index to
      prevent duplicates (de-duplicate by field filter, not by document ID)
    - Write to `playbook-embeddings` index with fields:
      `id` (GUID), `playbookId`, `name`, `recordType`, `entityType`, `tags`, `contentVector3072`
    - Use the existing `SemanticSearchService` or Azure AI Search SDK for the index write

    **Error handling**:
    - Log embedding generation failures at Warning level with playbook ID (no content)
    - Do not surface indexing failures to the API caller — the response is always `202 Accepted`
    - If embedding fails, leave the old index entry (stale is better than missing)

    **Endpoint**: `POST /api/ai/playbooks/{playbookId}/index`
    - Body: none (playbookId in route is sufficient — fetch full playbook from Dataverse)
    - Returns: `202 Accepted` immediately
    - Authorization: internal service-to-service (Dataverse plugin calls this with a service account token)
  </prompt>

  <role>Senior .NET developer with Azure AI and Minimal API expertise</role>

  <goal>
    When a playbook is created or updated in Dataverse, the BFF receives a trigger, enqueues the
    embedding generation, and eventually writes the embedding to the `playbook-embeddings` AI Search
    index. PlaybookDispatcher Stage 1 vector search returns the indexed playbook as a candidate within
    seconds of the playbook being saved.
  </goal>

  <inputs>
    <file purpose="Project specification — FR-18 (trigger metadata fields), playbook embedding index requirements">projects/ai-sprk-chat-platform-enhancement-r2/spec.md</file>
    <file purpose="Project AI context — DI budget, background processing pattern, ADR constraints">projects/ai-sprk-chat-platform-enhancement-r2/CLAUDE.md</file>
    <file purpose="SemanticSearchService — existing AI Search integration for index writes">src/server/api/Sprk.Bff.Api/Services/Ai/SemanticSearch/SemanticSearchService.cs</file>
    <file purpose="Existing indexing services — background processing patterns in use">src/server/api/Sprk.Bff.Api/Services/Ai/Indexing/</file>
    <file purpose="Minimal API endpoint definition pattern">../.claude/patterns/api/endpoint-definition.md</file>
    <file purpose="AI architecture — dual IChatClient, background service pattern">docs/architecture/AI-ARCHITECTURE.md</file>
  </inputs>

  <constraints>
    <constraint source="ADR-001">MUST use Minimal API for the trigger endpoint; background processing MUST use BackgroundService or IBackgroundTaskQueue pattern — MUST NOT use Azure Functions</constraint>
    <constraint source="ADR-010">MUST NOT add new DI registrations for this feature if possible — wire into existing indexing infrastructure</constraint>
    <constraint source="ADR-014">Embedding results MUST be cached with version-keyed keys if reused; MUST NOT cache them per-message (embeddings are per-playbook, not per-user-message)</constraint>
    <constraint source="ADR-015">MUST NOT log playbook content or trigger phrases — log only playbook ID and indexing metadata</constraint>
    <constraint source="ADR-016">Embedding API calls MUST be rate-limited; MUST bound concurrent indexing operations</constraint>
    <constraint source="spec">Index write MUST de-duplicate: delete existing entry for playbookId before writing new one</constraint>
  </constraints>

