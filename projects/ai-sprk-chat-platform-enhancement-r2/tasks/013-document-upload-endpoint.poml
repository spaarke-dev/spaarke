<?xml version="1.0" encoding="UTF-8"?>
<task id="R2-013" project="SprkChat Platform Enhancement R2">
  <metadata>
    <title>Document Upload Endpoint — Multipart Upload with Document Intelligence Processing and Session-Scoped Storage</title>
    <status>pending</status>
    <phase>2</phase>
    <tags>bff-api, api, ai, document-intelligence</tags>
    <estimated-effort>large</estimated-effort>
    <parallel-group>A</parallel-group>
    <parallel-safe>true</parallel-safe>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>BFF API code implementation — creates a new Minimal API endpoint with file upload, Document Intelligence processing, Redis session storage, and DocumentContextService integration; multiple ADR constraints apply; FR-13 requirement</rigor-reason>
    <dependencies>[011]</dependencies>
  </metadata>

  <prompt>
    Create a new BFF API endpoint that accepts user-uploaded documents, processes them via Document
    Intelligence for text extraction, stores extracted content in session-scoped Redis, and injects
    the content into the SprkChat conversation context.

    **Endpoint**: `POST /api/ai/chat/sessions/{sessionId}/documents`
    - Content-Type: `multipart/form-data`
    - Form field: `file` (binary)
    - Form field: `filename` (string, optional — fallback to original name)

    **File type validation**: Accept only PDF, DOCX, TXT, MD. Reject others with
    `422 Unprocessable Entity` using `ProblemDetails` format.

    **File size limit**: 50MB maximum. Reject larger files with `413 Request Entity Too Large`.

    **Processing pipeline**:
    1. Read multipart form data from the request
    2. Validate file type and size
    3. Route to Document Intelligence (`DocumentIntelligenceExtractor` or equivalent) for text extraction
       — this is the same service used for SPE documents, reuse it
    4. Store extracted text in Redis with key pattern: `doc-upload:{sessionId}:{documentId}` and
       TTL matching session lifetime (default 4 hours). This is session-scoped storage per NFR-06.
    5. Generate a `documentId` (GUID) for the uploaded file — this ID is used in subsequent calls
    6. Call `DocumentContextService.InjectDocumentContextAsync(sessionId, documentId, [])` to
       pre-warm the chunk index for the document
    7. Return `202 Accepted` with processing status body:
       ```json
       {
         "documentId": "...",
         "filename": "...",
         "status": "processing|ready",
         "pageCount": N,
         "tokenEstimate": N,
         "wasTruncated": false
       }
       ```

    **Authorization**: Apply `ChatSessionAuthorizationFilter` (or equivalent) to verify the caller
    owns the sessionId before processing the upload.

    **Rate limiting**: Apply upload-specific rate limit (lower than chat rate limit — max 5 uploads
    per minute per user) per ADR-016.

    **Session cleanup**: When the session ends (expiry or explicit close), the Redis keys for uploaded
    documents MUST auto-expire with the session TTL to satisfy NFR-06.
  </prompt>

  <role>Senior .NET developer with Azure AI and Minimal API expertise</role>

  <goal>
    A working `POST /api/ai/chat/sessions/{sessionId}/documents` endpoint that accepts PDF/DOCX/TXT/MD
    files up to 50MB, extracts text via Document Intelligence, stores extracted content in session-scoped
    Redis, and returns document metadata. Dragging a PDF into chat makes its content available for AI
    reasoning within ~10 seconds (FR-13, NFR-02).
  </goal>

  <inputs>
    <file purpose="Project specification — FR-13, NFR-02 (15s processing), NFR-06 (session cleanup), ADR constraints">projects/ai-sprk-chat-platform-enhancement-r2/spec.md</file>
    <file purpose="Project AI context — MUST rules, endpoint patterns, DI budget">projects/ai-sprk-chat-platform-enhancement-r2/CLAUDE.md</file>
    <file purpose="Existing chat endpoints — patterns to follow for new endpoint registration">src/server/api/Sprk.Bff.Api/Api/Ai/ChatEndpoints.cs</file>
    <file purpose="Text extraction services — reuse existing Document Intelligence integration">src/server/api/Sprk.Bff.Api/Services/Ai/TextExtraction/</file>
    <file purpose="Minimal API endpoint definition pattern">../.claude/patterns/api/endpoint-definition.md</file>
    <file purpose="Authorization endpoint filter pattern">../.claude/patterns/api/endpoint-filters.md</file>
    <file purpose="Redis distributed cache pattern">../.claude/patterns/caching/distributed-cache.md</file>
  </inputs>

  <constraints>
    <constraint source="ADR-001">MUST use Minimal API pattern — `app.MapPost(...)` — no MVC controllers</constraint>
    <constraint source="ADR-008">MUST apply authorization endpoint filter — MUST NOT use global middleware for session ownership verification</constraint>
    <constraint source="ADR-009">MUST use `IDistributedCache` (Redis) for session-scoped document storage — MUST NOT store extracted text in memory or on disk</constraint>
    <constraint source="ADR-015">MUST NOT log extracted document text content — log only document ID, file name (without content), page count, token estimate</constraint>
    <constraint source="ADR-016">MUST apply rate limiting — upload endpoint needs stricter limit (5 uploads/minute/user) than the chat endpoint</constraint>
    <constraint source="spec NFR-06">Session-scoped upload storage MUST auto-delete when session expires — Redis TTL must be set to session lifetime</constraint>
    <constraint source="spec NFR-02">Text extraction MUST complete within 15 seconds for documents under 50 pages</constraint>
  </constraints>

