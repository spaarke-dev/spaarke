<task id="R2-031" project="SprkChat Platform Enhancement R2">
  <metadata>
    <title>SSE Token-by-Token Streaming UI in SprkChat</title>
    <status>pending</status>
    <phase>3</phase>
    <tags>frontend, streaming</tags>
    <estimated-effort>large</estimated-effort>
    <parallel-group>C</parallel-group>
    <parallel-safe>true</parallel-safe>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Modifies useSseStream.ts hook and SprkChat.tsx (54KB core component). Streaming state management, AbortController cancellation, and typing indicator are complex UX concerns. Frontend streaming tag. Multiple files modified across hooks and components.</rigor-reason>
    <dependencies>[004, 006]</dependencies>
  </metadata>

  <prompt>
    Enhance the `useSseStream` hook for true token-by-token progressive rendering in SprkChat. Add a typing indicator (animated dots) while waiting for the first token. Implement smooth text accumulation in the message bubble without flickering. Handle `typing_start` and `typing_end` SSE events from the BFF. Support cancellation via AbortController when the user takes a cancellation action during streaming.
  </prompt>

  <role>Senior full-stack developer</role>

  <goal>
    SprkChat displays a typing indicator (animated dots) after a user sends a message, then transitions smoothly to token-by-token text accumulation as the AI streams its response. The text accumulates without visible flicker or re-layout. User can cancel mid-stream. The streaming state is cleanly managed in the hook with proper cleanup on unmount and cancellation.
  </goal>

  <inputs>
    <file purpose="Project specification — FR-09 SSE streaming, NFR-01 first token &lt;500ms">projects/ai-sprk-chat-platform-enhancement-r2/spec.md</file>
    <file purpose="Project AI context — streaming architecture, MUST rules">projects/ai-sprk-chat-platform-enhancement-r2/CLAUDE.md</file>
    <file purpose="Hook to enhance — current SSE consumption implementation">src/client/shared/Spaarke.UI.Components/src/components/SprkChat/hooks/useSseStream.ts</file>
    <file purpose="Main component — where streaming state is consumed">src/client/shared/Spaarke.UI.Components/src/components/SprkChat/SprkChat.tsx</file>
    <file purpose="ADR-021 — Fluent v9 semantic tokens, dark mode">../.claude/adr/ADR-021-fluent-design-system.md</file>
    <file purpose="SSE streaming canonical pattern from BFF">../.claude/patterns/ai/streaming-endpoints.md</file>
  </inputs>

  <constraints>
    <constraint source="spec NFR-01">First token MUST be visible within 500ms of user sending a message — minimize state update batching delays</constraint>
    <constraint source="spec MUST">MUST NOT cache streaming tokens (ADR-014) — do not persist in-progress token accumulation to any cache or storage</constraint>
    <constraint source="ADR-021">Typing indicator animation MUST use Fluent v9 motion tokens — no custom CSS animations using hard-coded timing</constraint>
    <constraint source="spec">Cancellation via AbortController MUST propagate to the BFF SSE connection — not just hide the UI</constraint>
    <constraint source="spec">MUST handle SSE error events gracefully — show error state in chat, do not crash the component</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>projects/ai-sprk-chat-platform-enhancement-r2/spec.md</file>
      <file>projects/ai-sprk-chat-platform-enhancement-r2/CLAUDE.md</file>
      <file>src/client/shared/Spaarke.UI.Components/src/components/SprkChat/hooks/useSseStream.ts</file>
      <file>src/client/shared/Spaarke.UI.Components/src/components/SprkChat/SprkChat.tsx</file>
      <file>src/client/shared/Spaarke.UI.Components/src/components/SprkChat/types.ts</file>
      <file>src/client/shared/Spaarke.UI.Components/src/components/SprkChat/hooks/useChatSession.ts</file>
      <file>.claude/patterns/ai/streaming-endpoints.md</file>
      <file>.claude/adr/ADR-021-fluent-design-system.md</file>
