  </inputs>

  <constraints>
    <constraint source="ADR-009">MUST cache assembled ChatAnalysisContext in Redis with 30-min TTL per existing pattern — MUST NOT re-query Dataverse on every message</constraint>
    <constraint source="ADR-013">MUST flow ChatHostContext for entity-scoped queries — MUST NOT hardcode entity type names or record IDs</constraint>
    <constraint source="ADR-014">Cache key MUST include tenantId: `chat-context:{tenantId}:{sessionId}` — MUST NOT use per-capability or per-user keys (context is session-scoped)</constraint>
    <constraint source="ADR-015">MUST NOT log entity-specific field values (matter name, case details) — log only entity type, record ID, and cache hit/miss metadata</constraint>
    <constraint source="spec NFR-03">Full context assembly MUST complete within 3 seconds with Redis cache hit; Dataverse query path on cache miss is allowed to take longer</constraint>
    <constraint source="spec FR-16">MUST return ONLY the capabilities from the analysis's actual playbook + active scopes — MUST NOT return all capabilities for every session (replace stub behavior)</constraint>
  </constraints>

