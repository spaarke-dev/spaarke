  <constraints>
    <constraint source="ADR-007">MUST use SpeFileStore facade for all document retrieval — MUST NOT inject or use GraphServiceClient above the facade</constraint>
    <constraint source="ADR-010">MUST NOT add DocumentContextService to DI — MUST be instantiated by SprkChatAgentFactory.ResolveTools() or the agent factory method; DI budget is already at 16 (over limit)</constraint>
    <constraint source="ADR-013">MUST flow ChatHostContext through the pipeline; MUST use SpeFileStore for file operations; MUST extend BFF, not a separate service</constraint>
    <constraint source="ADR-015">MUST NOT log document text content — log only document ID, chunk counts, and token budget metadata; MUST send minimum necessary text to AI model</constraint>
    <constraint source="spec NFR-05">MUST NOT exceed 128K total token context window — 30K document budget is part of the overall budget; enforce hard limit with graceful truncation</constraint>
    <constraint source="spec FR-03">Chunk selection MUST be conversation-aware: re-select relevant chunks using embedding similarity to the latest user message after each turn (not static selection at session init)</constraint>
  </constraints>

