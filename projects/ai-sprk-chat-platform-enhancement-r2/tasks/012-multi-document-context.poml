    <file purpose="Core chat agent — ChatHostContext definition and document IDs flow">src/server/api/Sprk.Bff.Api/Services/Ai/Chat/SprkChatAgent.cs</file>
    <file purpose="Text extraction pattern — existing chunking infrastructure">../.claude/patterns/ai/text-extraction.md</file>
  </inputs>

  <constraints>
    <constraint source="ADR-016">Parallel document retrieval MUST be bounded — use `SemaphoreSlim` or a bounded `Channel` to limit concurrency to max 5 documents processed simultaneously; MUST NOT use unbounded `Task.WhenAll`</constraint>
    <constraint source="ADR-015">MUST NOT log document text content for any of the multiple documents — log only document IDs, chunk counts, and per-document token allocations</constraint>
    <constraint source="spec NFR-05">Total tokens across all documents MUST NOT exceed 30K budget — enforce hard cap with graceful truncation when allocation is exhausted</constraint>
    <constraint source="spec FR-12">MUST support at least 5 simultaneous documents within the shared 30K budget — proportional allocation must degrade gracefully as N increases</constraint>
    <constraint source="ADR-013">MUST flow ChatHostContext.DocumentIds through the pipeline — multi-document mode activates automatically when multiple IDs are present</constraint>
  </constraints>

