  </inputs>

  <constraints>
    <constraint source="ADR-006">MUST use Code Pages for dialog output type — `dialog_open` event MUST reference a `webresourceName` (Code Page name), NOT a model-driven app dialog or JavaScript alert</constraint>
    <constraint source="ADR-010">MUST NOT add PlaybookOutputHandler to DI — factory instantiation only</constraint>
    <constraint source="ADR-013">MUST flow `ChatHostContext` into the output handler for entity-scoped Code Page navigation and file operations</constraint>
    <constraint source="ADR-014">MUST NOT cache intermediate AI-generated field values used for dialog pre-population — they are ephemeral, session-specific</constraint>
    <constraint source="spec FR-07">MUST support all five output types: text, dialog, navigation, download, insert — incomplete implementation is not acceptable</constraint>
    <constraint source="spec FR-08">HITL path MUST open dialog for human review; autonomous path MUST execute directly without dialog — both paths MUST emit appropriate SSE completion events</constraint>
  </constraints>

