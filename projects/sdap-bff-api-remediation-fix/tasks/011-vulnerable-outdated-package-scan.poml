<task id="011" project="sdap-bff-api-remediation-fix">
  <metadata>
    <title>Vulnerable + outdated package scan (feeds Outcome B)</title>
    <status>completed</status>
    <estimated-effort>30 minutes</estimated-effort>
    <actual-effort>~5 minutes</actual-effort>
    <assigned>AI agent</assigned>
    <started>2026-05-24</started>
    <completed>2026-05-24</completed>
    <tags>bff-api, security, inventory, phase-1</tags>
    <parallel-group>B</parallel-group>
    <parallel-safe>true</parallel-safe>
    <parallel-reason>Read-only scan commands</parallel-reason>
    <rigor>STANDARD</rigor>
  </metadata>

  <prompt>
    Run the vulnerable-transitive + outdated package scans against `Sprk.Bff.Api.csproj`. These
    outputs drive Outcome B (security hygiene) and inform which transitive bumps go into Phase 4
    tasks 043–045+ as vuln-patch candidates. Active known issue at pipeline pre-flight: NU1903
    HIGH on `Microsoft.Kiota.Abstractions 1.21.2`.
  </prompt>

  <role>Security-aware .NET package analyst.</role>

  <goal>
    Two files committed to `inventory/`: `vulnerable.txt` (output of `dotnet list package --vulnerable
    --include-transitive`) and `outdated.txt` (output of `dotnet list package --outdated`). Plus
    a brief summary at the top of each noting HIGH-severity counts.
  </goal>

  <inputs>
    <file purpose="csproj">src/server/api/Sprk.Bff.Api/Sprk.Bff.Api.csproj</file>
    <file purpose="claude">src/server/api/Sprk.Bff.Api/CLAUDE.md</file>
  </inputs>

  <constraints>
    <constraint source="design.md §6 Phase 1">Read-only scan; no remediation in this task</constraint>
    <constraint source="src/server/api/Sprk.Bff.Api/CLAUDE.md">Kiota packages MUST stay version-matched at 1.21.2 — note this in summary if Kiota appears</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>src/server/api/Sprk.Bff.Api/CLAUDE.md</file>
      <file>.claude/constraints/bff-extensions.md</file>
      <file>projects/sdap-bff-api-remediation-fix/spec.md</file>
    </files>
  </knowledge>

  <context>
    <background>
      Pipeline pre-flight already confirmed at least one HIGH NU1903 on Microsoft.Kiota.Abstractions
      1.21.2 (GHSA-7j59-v9qr-6fq9). This task enumerates the full set. Coordinate with the 15+ open
      Dependabot PRs touching Sprk.Bff.Api/ (see CLAUDE.md Implementation Notes) — avoid wasted
      patch work where Dependabot is already proposing a bump.
    </background>
    <dependencies><dependency task="008" status="not-started">Phase 0 gate</dependency></dependencies>
  </context>

  <steps>
    <step order="1">`dotnet list src/server/api/Sprk.Bff.Api/Sprk.Bff.Api.csproj package --vulnerable --include-transitive > projects/sdap-bff-api-remediation-fix/inventory/vulnerable.txt`</step>
    <step order="2">`dotnet list src/server/api/Sprk.Bff.Api/Sprk.Bff.Api.csproj package --outdated > projects/sdap-bff-api-remediation-fix/inventory/outdated.txt`</step>
    <step order="3">Count HIGH / MEDIUM / LOW severity entries in vulnerable.txt; prepend summary header</step>
    <step order="4">List which Dependabot PRs (from open list) address findings here</step>
    <step order="5">Update TASK-INDEX.md status</step>
  </steps>

  <tools><tool name="dotnet">Package scans</tool><tool name="gh">Cross-reference Dependabot PRs</tool></tools>

  <outputs>
    <output type="report">projects/sdap-bff-api-remediation-fix/inventory/vulnerable.txt</output>
    <output type="report">projects/sdap-bff-api-remediation-fix/inventory/outdated.txt</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">vulnerable.txt has summary header with HIGH/MEDIUM/LOW counts</criterion>
    <criterion testable="true">NU1903 (Microsoft.Kiota.Abstractions) appears in vulnerable.txt OR is documented as already resolved</criterion>
    <criterion testable="true">outdated.txt enumerates every outdated transitive</criterion>
    <criterion testable="true">Dependabot PR cross-reference noted</criterion>
  </acceptance-criteria>
</task>
