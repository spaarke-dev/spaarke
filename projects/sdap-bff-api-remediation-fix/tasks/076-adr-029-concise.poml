<task id="076" project="sdap-bff-api-remediation-fix">
  <metadata>
    <title>ADR-029 (concise) at `.claude/adr/` + INDEX update (FR-D1 part 1)</title>
    <status>not-started</status>
    <estimated-effort>2 hours</estimated-effort>
    <assigned>AI agent (developer) — main session only</assigned>
    <tags>bff-api, adr, codification, outcome-d, phase-6</tags>
    <parallel-group>none</parallel-group>
    <parallel-safe>false</parallel-safe>
    <parallel-reason>.claude/ paths require main-session-only per sub-agent write boundary</parallel-reason>
    <rigor>STANDARD</rigor>
  </metadata>

  <prompt>
    Create `.claude/adr/ADR-029-bff-publish-hygiene.md` (concise version, 100-150 lines per `.claude/adr/INDEX.md` convention). Record publish hygiene policy: framework-dependent `linux-x64` only, no sourcemaps, vuln scan in CI, quarterly review cadence. Update `.claude/adr/INDEX.md` to include ADR-029.

    SUB-AGENT BOUNDARY: This task is main-session-only.
  </prompt>

  <role>ADR author + main session.</role>

  <goal>`.claude/adr/ADR-029-bff-publish-hygiene.md` exists with proper structure (Context, Decision, Consequences, Status, Date); `.claude/adr/INDEX.md` lists ADR-029.</goal>

  <inputs>
    <file purpose="adr-index">.claude/adr/INDEX.md</file>
    <file purpose="adr-pattern">.claude/adr/ADR-007-spefilestore.md (template style)</file>
    <file purpose="constraint">.claude/constraints/azure-deployment.md</file>
    <file purpose="bff-extensions">.claude/constraints/bff-extensions.md (already references ADR-029 as forthcoming)</file>
  </inputs>

  <constraints>
    <constraint source=".claude/adr/INDEX.md">Concise format 100–150 lines; MUST / MUST NOT structure</constraint>
    <constraint source="root CLAUDE.md §3">Main-session-only for .claude/ paths</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/INDEX.md</file>
      <file>.claude/adr/ADR-007-spefilestore.md</file>
      <file>.claude/adr/ADR-013-ai-architecture.md</file>
      <file>.claude/constraints/azure-deployment.md</file>
      <file>.claude/constraints/bff-extensions.md</file>
      <file>projects/sdap-bff-api-remediation-fix/design.md</file>
    </files>
  </knowledge>

  <context>
    <background>ADR-029 codifies the publish hygiene policy. `bff-extensions.md` already references ADR-029 as "forthcoming" — this task fulfills that reference.</background>
    <dependencies><dependency task="054" status="not-started">Phase 4 gate</dependency></dependencies>
  </context>

  <steps>
    <step order="1">Read ADR-007 to match concise-ADR template style</step>
    <step order="2">Author `.claude/adr/ADR-029-bff-publish-hygiene.md` with: Status (Accepted), Date (today), Context, Decision (MUSTs + MUST NOTs), Consequences, Related (links to ADR-001, ADR-007, ADR-013)</step>
    <step order="3">Add row to `.claude/adr/INDEX.md` table (alphabetical or chronological per existing convention)</step>
    <step order="4">Verify `.claude/constraints/bff-extensions.md` reference to "forthcoming ADR-029" now resolves correctly</step>
    <step order="5">Commit (main session, single commit); update TASK-INDEX.md</step>
  </steps>

  <tools><tool name="git">commit (.claude/ requires main session)</tool></tools>

  <outputs>
    <output type="docs">.claude/adr/ADR-029-bff-publish-hygiene.md</output>
    <output type="docs">.claude/adr/INDEX.md (new entry)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">ADR-029 file present with all required sections</criterion>
    <criterion testable="true">Line count between 100-150</criterion>
    <criterion testable="true">INDEX.md lists ADR-029</criterion>
