    <criterion testable="true">adr-check output: no violations</criterion>
    <criterion testable="true">repo-cleanup output: structure validated, ephemeral files archived</criterion>
    <criterion testable="true">All 56 tasks in TASK-INDEX.md ✅ or ⏸ with rationale</criterion>
  </acceptance-criteria>
</task>
