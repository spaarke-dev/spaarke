  <steps>
    <step order="1">Add workflow step: `find publish-test/wwwroot -name "*.map" | wc -l` — fail if non-zero</step>
    <step order="2">Test by injecting a `.map` file; verify CI fails</step>
    <step order="3">Commit; update TASK-INDEX.md</step>
  </steps>

