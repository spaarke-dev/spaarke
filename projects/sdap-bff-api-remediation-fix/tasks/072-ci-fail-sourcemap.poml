  <prompt>
    Add CI step in `sdap-ci.yml` that fails if any `*.map` files exist in `publish/wwwroot/`. Codifies FR-A2 policy.
  </prompt>

  <role>CI/CD engineer.</role>
  <goal>Workflow step exists; test PR with intentionally added `.map` file fails CI.</goal>

  <inputs><file purpose="workflow">.github/workflows/sdap-ci.yml</file></inputs>
  <constraints><constraint source="spec.md FR-C2">Fails on any *.js.map in publish/wwwroot/</constraint></constraints>

