    <tags>bff-api, risk-categorization, phase-2, gate</tags>
    <parallel-group>none</parallel-group>
    <parallel-safe>false</parallel-safe>
    <parallel-reason>Aggregates 020 + 021 outputs; gate for Phase 3</parallel-reason>
