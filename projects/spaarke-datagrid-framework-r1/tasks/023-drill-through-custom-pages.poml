      <file>src/solutions/sprk_invoicespage/index.html</file>
      <file>src/solutions/sprk_invoicespage/package.json</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-026">Vite + `vite-plugin-singlefile` + React 19 + Fluent v9; output is a single .html file uploaded as Dataverse web resource.</constraint>
    <constraint source="ADR-021">Fluent v9 + tokens; dark mode required.</constraint>
    <constraint source="NFR-11">`applyStylesToPortals={true}` on root `FluentProvider` — non-negotiable.</constraint>
    <constraint source="project">Each page ~50 lines of TypeScript (excluding Vite config + index.html scaffolding). Shell only — no business logic.</constraint>
    <constraint source="project">URL param parsing: `entityName / filterField / filterValue / matterId` (whatever VisualHost CardChrome passes).</constraint>
    <constraint source="project">Default `dataverseClient = new XrmDataverseClient()` since host is MDA.</constraint>
  </constraints>

  <knowledge>
    <files>
