      <file>tests/integration/Sprk.Bff.Api.IntegrationTests/Helpers/MockServiceClientFactory.cs</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="bff-extensions.md">Test update obligation ‚Äî PR modifying `Sprk.Bff.Api/Services/` MUST add corresponding tests. This task closes the obligation for tasks 011-014.</constraint>
    <constraint source="ADR-008">Cross-entity privilege bypass test mandatory for `/fetch` endpoint.</constraint>
    <constraint source="testing.md">Integration tests use `WebApplicationFactory&lt;Program&gt;`; mock `IOrganizationService` / `ServiceClient` for Dataverse calls; do NOT hit real tenant in CI.</constraint>
    <constraint source="project">Test cache hit/miss for the 3 cached endpoints (savedquery, savedqueries, metadata) ‚Äî verify second call within TTL is &lt;10ms and doesn't hit ServiceClient mock.</constraint>
  </constraints>

