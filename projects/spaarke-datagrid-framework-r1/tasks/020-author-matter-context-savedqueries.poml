      <file>projects/spaarke-datagrid-framework-r1/design.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Interview Ralph (escalation point): what columns should KPI Assessment Matter-context view show? Order? Widths? Sort order?</step>
    <step order="2">Same for Invoice view.</step>
    <step order="3">Document answers in `notes/drafts/020-savedquery-column-layouts.md`.</step>
    <step order="4">Use `dataverse-create-schema` skill OR Dataverse MCP tools (`mcp__dataverse__create_record`) to author the 2 savedquery records with appropriate FetchXML + layoutXml.</step>
    <step order="5">Validate both savedqueries via direct call: `GET /api/data/v9.2/savedqueries({savedqueryid})` returns the record correctly.</step>
    <step order="6">Document savedQueryIds in `notes/drafts/020-savedquery-ids.md` for tasks 021 + 022 reference.</step>
    <step order="7">Update TASK-INDEX (020 ✅); unblock 021 + 022.</step>
  </steps>

  <tools>
    <tool name="dataverse-create-schema">Skill for authoring savedqueries</tool>
    <tool name="dataverse MCP">Authoring + validation</tool>
