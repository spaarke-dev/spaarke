  <outputs>
    <output type="docs">projects/spaarke-datagrid-framework-r1/notes/drafts/020-savedquery-column-layouts.md</output>
    <output type="docs">projects/spaarke-datagrid-framework-r1/notes/drafts/020-savedquery-ids.md</output>
