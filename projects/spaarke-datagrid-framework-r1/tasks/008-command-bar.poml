<?xml version="1.0" encoding="UTF-8"?>
<task id="008" project="spaarke-datagrid-framework-r1">
  <metadata>
    <title>CommandBar primitive with 6 built-in actions + custom registry + CSV export</title>
    <phase>1: Phase A — Foundation</phase>
    <status>not-started</status>
    <estimated-hours>4</estimated-hours>
    <dependencies>003</dependencies>
    <blocks>009</blocks>
    <tags>fluent-ui, frontend, react, typescript</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>UI primitive with 6 actions; CSV export logic; ADR-021 + NFR-03; Storybook required; Fluent v9 Dialog confirmation pattern</rigor-reason>
    <parallel-group>A2</parallel-group>
    <parallel-safe>true</parallel-safe>
  </metadata>

  <prompt>
    Build the `<CommandBar />` primitive with 6 built-in actions (create-form, delete-selected, refresh, export-excel, edit-columns, edit-filters) plus a `custom` action that invokes host-registered handlers. Lift CRUD defaults from EventsPage (`openNewEventForm`, `deleteSelectedEvents`, `executeBulkStatusUpdate`) generalized for any entity. Replace `window.confirm` with Fluent v9 `<Dialog>`. RFC 4180 CSV with UTF-8 BOM.
  </prompt>

  <role>
    SPAARKE platform developer. Expert in Fluent v9 `<Toolbar>` + `<Dialog>` confirmation pattern + CSV generation. Familiar with `Xrm.Navigation.openForm` + `Xrm.WebApi.deleteRecord` for default handlers.
  </role>

  <goal>
    `src/components/DataGrid/commandBar/CommandBar.tsx` ships, 6 default handlers work via `IDataverseClient` / `Xrm.Navigation`, custom handlers invoked via `registerCommandHandler` registry, CSV export validated against Excel + LibreOffice, MDA OOB visual parity passes.
  </goal>

  <context>
    <background>
      Per FR-DG-08 (command bar) + FR-DG-14 (CRUD lift) + FR-DG-17 (CSV export). Visual parity with MDA OOB toolbar per [design.md §11.5.2]. Default handlers lifted from EventsPage: `openNewEventForm` ([App.tsx:461]) → generic `openCreateForm(entityName, parentContext)`; `deleteSelectedEvents` ([App.tsx:687]) → generic `deleteSelected(entityName, ids)` with Fluent v9 `<Dialog>` confirmation instead of `window.confirm`. `executeBulkStatusUpdate` ([App.tsx:731]) lifted as the framework handler `BulkUpdateField` available via registry.
    </background>
    <relevant-files>
      <file>src/client/shared/Spaarke.UI.Components/src/components/DataGrid/commandBar/CommandBar.tsx</file>
      <file>src/client/shared/Spaarke.UI.Components/src/components/DataGrid/commandBar/defaults.ts</file>
      <file>src/client/shared/Spaarke.UI.Components/src/components/DataGrid/commandBar/csvExport.ts</file>
      <file>src/client/shared/Spaarke.UI.Components/src/components/DataGrid/commandBar/registry.ts</file>
      <file>src/client/shared/Spaarke.UI.Components/storybook/CommandBar.stories.tsx</file>
      <file>src/solutions/EventsPage/src/App.tsx</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-021">Fluent v9 `<Toolbar>` + `<Dialog>`; tokens; dark mode.</constraint>
    <constraint source="ADR-022">React-16-safe.</constraint>
    <constraint source="NFR-03">`applyStylesToPortals` on `<Dialog>` surface.</constraint>
    <constraint source="project">NO `window.confirm` — use Fluent v9 `<Dialog>` for confirmation.</constraint>
    <constraint source="project">Bulk delete uses `Promise.all(ids.map(id => Xrm.WebApi.deleteRecord(...)))` with progress feedback for >10 records (lift `executeBulkStatusUpdate` pattern).</constraint>
    <constraint source="project">CSV: RFC 4180 quoting (double-quote escaping); UTF-8 BOM (`﻿` prefix); filename `{entityName}-{savedQueryName}-{yyyymmdd}.csv`.</constraint>
    <constraint source="project">CSV scope: visible columns of currently-loaded records, respecting active filter chip state (per Q-D answer — does NOT auto-fetch all pages).</constraint>
    <constraint source="project">Custom handlers via `useDataGridContext().registry.command.{id}` resolution; conflict policy = last-write-wins + `console.warn`.</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-021-fluent-design-system.md</file>
      <file>.claude/patterns/ui/fluent-v9-component-authoring.md</file>
      <file>.claude/skills/fluent-v9-component/SKILL.md</file>
      <file>projects/spaarke-datagrid-framework-r1/spec.md</file>
      <file>projects/spaarke-datagrid-framework-r1/design.md</file>
    </files>
    <patterns>
      <pattern name="EventsPage CRUD" location="src/solutions/EventsPage/src/App.tsx#L375-L715">Lift: `openNewEventForm` (line 461) → `openCreateForm`; `deleteSelectedEvents` (line 687) → `deleteSelected` with Dialog; `executeBulkStatusUpdate` (line 731) → `BulkUpdateField`.</pattern>
      <pattern name="Fluent v9 Dialog confirmation" location="https://react.fluentui.dev/?path=/docs/components-dialog--default">Controlled `open` state; `<DialogActions>` with Cancel + Confirm buttons.</pattern>
      <pattern name="MDA OOB toolbar parity" location="design.md §11.5.2">Compact, icon-then-label, overflow menu for &gt;6 actions; primary action emphasized.</pattern>
    </patterns>
  </knowledge>

  <steps>
    <step order="1">Run `/fluent-v9-component` skill Step 0.5 checklist.</step>
    <step order="2">Author `commandBar/defaults.ts` exporting the 6 default handlers + their default labels/icons.</step>
    <step order="3">Author `commandBar/csvExport.ts`: pure function `exportCsv(records, columns, savedQueryName, entityName): Blob` with RFC 4180 quoting + UTF-8 BOM.</step>
    <step order="4">Author `commandBar/registry.ts`: registry map exposed via `useDataGridContext()`; `registerCommandHandler(id, handler)` mutates with `console.warn` on conflict.</step>
    <step order="5">Author `commandBar/CommandBar.tsx`: `<Toolbar>` rendering 6 actions per configjson `commandBar` config; primary action (create) emphasized; overflow menu when &gt;6 items; `<Dialog>` for bulk delete confirmation (replaces `window.confirm`).</step>
    <step order="6">Implement bulk delete with `Promise.all` + progress notification for &gt;10 records (Fluent v9 `<Spinner>` + status text).</step>
    <step order="7">Wrap Dialog surface in inner `<FluentProvider applyStylesToPortals theme={inheritedTheme}>`.</step>
    <step order="8">Author Storybook stories: default 6 actions, custom handler registered, bulk delete with confirmation, CSV export trigger; light + dark each.</step>
    <step order="9">Unit tests: `csvExport` quoting (commas, quotes, newlines), UTF-8 BOM presence, filename format.</step>
    <step order="10">axe-core scan; verify zero serious/critical.</step>
    <step order="11">Validate CSV in Excel + LibreOffice (manual); confirm UTF-8 chars render.</step>
    <step order="12">Build + verify; update TASK-INDEX (008 ✅).</step>
    <step order="13">Document deviations if any.</step>
  </steps>

  <tools>
    <tool name="npm">Build + Storybook + axe + Jest</tool>
    <tool name="Edit">Author the files</tool>
  </tools>

  <outputs>
    <output type="code">src/client/shared/Spaarke.UI.Components/src/components/DataGrid/commandBar/CommandBar.tsx</output>
    <output type="code">src/client/shared/Spaarke.UI.Components/src/components/DataGrid/commandBar/defaults.ts</output>
    <output type="code">src/client/shared/Spaarke.UI.Components/src/components/DataGrid/commandBar/csvExport.ts</output>
    <output type="code">src/client/shared/Spaarke.UI.Components/src/components/DataGrid/commandBar/registry.ts</output>
    <output type="code">src/client/shared/Spaarke.UI.Components/storybook/CommandBar.stories.tsx</output>
    <output type="test">src/client/shared/Spaarke.UI.Components/tests/csvExport.test.ts</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Given 5 records with comma + quote + newline in fields, when CSV exports, then RFC 4180 quoting is correct (escaped double quotes, fields with special chars wrapped in quotes).</criterion>
    <criterion testable="true">Given the CSV file, when opened in Excel + LibreOffice, then UTF-8 chars render correctly (BOM works).</criterion>
    <criterion testable="true">Given user clicks "Delete Selected" with 3 records selected, when confirmation `<Dialog>` opens, then no `window.confirm` is called (only Fluent v9 Dialog).</criterion>
    <criterion testable="true">Given custom handler registered for "MarkPaid" then registered again for "MarkPaid", when registered, then `console.warn` is emitted and last write wins.</criterion>
    <criterion testable="true">Given dark mode, when toolbar + Dialog open, then dark theme renders correctly.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="CommandBar 6 actions">
      <url>http://localhost:6006/?path=/story/commandbar--default</url>
      <steps>
        <step>Verify all 6 default actions visible</step>
        <step>Click "Refresh"; verify console fires `onCommandInvoke('refresh', [], ctx)`</step>
        <step>Click "Export Excel"; verify CSV download triggers</step>
      </steps>
      <expected>All actions work; CSV downloads with correct filename</expected>
    </test>
    <test name="Bulk delete confirmation Dialog">
      <steps>
        <step>Select 3 rows in Storybook story</step>
        <step>Click "Delete Selected"</step>
        <step>Verify Fluent v9 `<Dialog>` opens (NOT browser confirm)</step>
        <step>Click "Confirm"; verify delete fires</step>
      </steps>
      <expected>Dialog used, no window.confirm</expected>
    </test>
    <test name="Dark mode (NFR-03)">
      <steps>
        <step>Toggle dark; open delete Dialog</step>
        <step>Verify Dialog renders dark-themed</step>
      </steps>
      <expected>No light-mode bleed</expected>
    </test>
  </ui-tests>

  <notes>
    Biggest UI task in Phase A — 6 actions + CSV + registry + Dialog confirmation. The CSV `﻿` BOM matters for Excel UTF-8 — without it, Excel mojibake's special chars. The `executeBulkStatusUpdate` lift is the load-bearing pattern for the registry — it lets EventsPage's Mark Complete/Cancel/Reassign/Archive work as registered handlers in Phase D without re-implementing the bulk update plumbing. Parallels tasks 004, 005, 006, 007 (Wave A2).
  </notes>

  <execution>
    <skill>.claude/skills/task-execute/SKILL.md</skill>
    <protocol>Mandatory `/fluent-v9-component` Step 0.5. Run all unit tests + manual CSV validation + dark mode check before marking complete.</protocol>
  </execution>
</task>
