<task id="031" project="spaarke-datagrid-framework-r1">
  <metadata>
    <title>Rewrite EventsPage/App.tsx as ~150-line thin host (DataGrid + Calendar pane + BulkUpdateEventStatus handler)</title>
    <phase>4: Phase D — EventsPage Migration</phase>
    <status>completed</status>
    <estimated-hours>4</estimated-hours>
    <dependencies>009,030</dependencies>
    <blocks>032,034</blocks>
    <tags>fluent-ui, frontend, react, e2e-test, migration</tags>
