<task id="072" project="file-preview-dialog-with-auth-enhancements">
  <metadata>
    <title>Migrate DocumentRelationshipViewer PCF Auth to @spaarke/auth</title>
    <phase>8</phase>
    <tags>auth, migration, pcf</tags>
    <estimate>2-3 hours</estimate>
    <dependencies>060</dependencies>
    <parallel-group>F</parallel-group>
    <rigor>FULL</rigor>
  </metadata>
  <prompt>
    <goal>Replace DocumentRelationshipViewer PCF auth with @spaarke/auth — removing ~446 lines</goal>
    <context>
      DocumentRelationshipViewer PCF control has a class-based auth pattern: MsalAuthProvider.ts
      (277 lines), msalConfig.ts (124 lines), and auth.ts types (45 lines). The pilot migration
      (task 060) validated the pattern. This task applies the same proven approach.
    </context>
    <constraints>
      - MUST follow the proven pilot pattern from task 060
      - MUST update all service consumers
      - MUST remove auth files and types after migration
      - MUST bump ControlManifest.Input.xml version
      - MUST verify build succeeds
    </constraints>
  </prompt>
  <knowledge>
    <files>
      <file>src/client/pcf/DocumentRelationshipViewer/DocumentRelationshipViewer/services/auth/MsalAuthProvider.ts</file>
      <file>src/client/pcf/DocumentRelationshipViewer/DocumentRelationshipViewer/services/auth/msalConfig.ts</file>
      <file>src/client/pcf/DocumentRelationshipViewer/DocumentRelationshipViewer/services/auth/auth.ts</file>
      <file>.claude/constraints/pcf.md</file>
    </files>
  </knowledge>
  <steps>
    <step>Read current auth files: MsalAuthProvider.ts (277 lines), msalConfig.ts (124 lines), auth.ts (45 lines)</step>
    <step>Identify all consumers of MsalAuthProvider in the DocumentRelationshipViewer</step>
    <step>Install @spaarke/auth as a dependency</step>
    <step>Replace MsalAuthProvider singleton with initAuth() call</step>
    <step>Update all service consumers to use authenticatedFetch()</step>
    <step>Remove auth files: MsalAuthProvider.ts, msalConfig.ts, auth.ts, and auth/ directory</step>
    <step>Remove @azure/msal-browser from direct dependencies if no longer needed</step>
    <step>Bump version in ControlManifest.Input.xml</step>
    <step>Build PCF control and verify no errors</step>
  </steps>
  <outputs>
    <output>src/client/pcf/DocumentRelationshipViewer/package.json (updated)</output>
    <output>src/client/pcf/DocumentRelationshipViewer/DocumentRelationshipViewer/index.ts (updated)</output>
    <output>src/client/pcf/DocumentRelationshipViewer/ControlManifest.Input.xml (version bumped)</output>
  </outputs>
  <acceptance-criteria>
    <criterion>MsalAuthProvider.ts (277 lines) deleted</criterion>
    <criterion>msalConfig.ts (124 lines) deleted</criterion>
    <criterion>auth.ts (45 lines) deleted</criterion>
    <criterion>auth/ directory completely removed</criterion>
    <criterion>All consumers use authenticatedFetch()</criterion>
    <criterion>ControlManifest.Input.xml version bumped</criterion>
    <criterion>PCF build compiles without errors</criterion>
    <criterion>Net line removal: ~446 lines</criterion>
  </acceptance-criteria>
</task>
