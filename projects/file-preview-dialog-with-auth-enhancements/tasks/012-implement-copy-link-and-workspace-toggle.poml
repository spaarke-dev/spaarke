<task id="012" project="file-preview-dialog-with-auth-enhancements">
  <metadata>
    <title>Implement Copy Link and Workspace Toggle Toolbar Actions</title>
    <phase>2</phase>
    <tags>fluent-ui, toolbar, clipboard, dataverse</tags>
    <estimate>2-3 hours</estimate>
    <dependencies>010</dependencies>
    <parallel-group>A</parallel-group>
    <rigor>FULL</rigor>
  </metadata>
  <prompt>
    <goal>Implement Copy Link and Add to/Remove from Workspace toolbar actions in FilePreviewDialog</goal>
    <context>
      This task implements the remaining two toolbar actions: Copy Link (copies the Dataverse record
      URL to clipboard) and Workspace Toggle (pins/unpins a document to the user's workspace).
      Copy Link constructs the record URL from Xrm.Utility.getGlobalContext().getClientUrl() and
      uses the Clipboard API with an execCommand fallback. Workspace Toggle reads the current
      sprk_workspaceflag state and toggles it via Xrm.WebApi.updateRecord(), updating the icon
      between PinRegular and PinOffRegular. Both helpers are extracted into filePreviewService.ts
      for reuse.
    </context>
    <constraints>
      - MUST use navigator.clipboard.writeText with document.execCommand('copy') fallback
      - MUST show "Copied!" feedback for 2 seconds after successful copy
      - MUST use Xrm.WebApi.updateRecord() for workspace flag toggle
      - MUST call onWorkspaceFlagChanged callback after successful toggle
      - MUST use PinRegular/PinOffRegular icons for workspace toggle state
      - MUST extract helpers into filePreviewService.ts for reusability
    </constraints>
  </prompt>
  <knowledge>
    <files>
      <file>src/solutions/LegalWorkspace/src/services/xrmProvider.ts</file>
      <file>.claude/constraints/auth.md</file>
      <file>src/solutions/LegalWorkspace/src/components/FilePreview/FilePreviewDialog.tsx</file>
    </files>
  </knowledge>
  <steps>
    <step>Read xrmProvider.ts for getXrm() helper and Xrm API access patterns</step>
    <step>Create src/solutions/LegalWorkspace/src/components/FilePreview/filePreviewService.ts</step>
    <step>Implement copyDocumentLink(documentId: string) in filePreviewService.ts — construct URL from getClientUrl(), use clipboard API with execCommand fallback</step>
    <step>Implement setWorkspaceFlag(documentId: string, pinned: boolean) in filePreviewService.ts — call Xrm.WebApi.updateRecord('sprk_document', documentId, { sprk_workspaceflag: pinned })</step>
    <step>Wire up Copy Link toolbar button: call copyDocumentLink(), set copySuccess state to true, auto-reset after 2 seconds via setTimeout</step>
    <step>Update Copy Link button label/icon to show "Copied!" feedback when copySuccess is true</step>
    <step>Wire up Workspace Toggle toolbar button: read initial isPinned from isInWorkspace prop, toggle via setWorkspaceFlag(), update isPinned state, call onWorkspaceFlagChanged callback</step>
    <step>Use PinRegular icon when not pinned, PinOffRegular when pinned; show isPinning loading state during API call</step>
    <step>Add error handling for both clipboard and Xrm.WebApi operations</step>
    <step>Verify TypeScript compiles without errors</step>
  </steps>
  <outputs>
    <output>src/solutions/LegalWorkspace/src/components/FilePreview/filePreviewService.ts</output>
    <output>src/solutions/LegalWorkspace/src/components/FilePreview/FilePreviewDialog.tsx (updated)</output>
  </outputs>
  <acceptance-criteria>
    <criterion>filePreviewService.ts created with copyDocumentLink() and setWorkspaceFlag() helpers</criterion>
    <criterion>Copy Link copies record URL to clipboard using navigator.clipboard.writeText</criterion>
    <criterion>Copy Link falls back to execCommand('copy') when Clipboard API unavailable</criterion>
    <criterion>Copied! feedback shown for 2 seconds after successful copy</criterion>
    <criterion>Workspace toggle updates sprk_workspaceflag via Xrm.WebApi.updateRecord()</criterion>
    <criterion>Icon toggles between PinRegular and PinOffRegular based on state</criterion>
    <criterion>isPinning loading state shown during workspace flag update</criterion>
    <criterion>onWorkspaceFlagChanged callback invoked after successful toggle</criterion>
    <criterion>TypeScript compiles without errors</criterion>
  </acceptance-criteria>
</task>
