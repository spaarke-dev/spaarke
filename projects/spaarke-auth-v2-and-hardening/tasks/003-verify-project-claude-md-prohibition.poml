<task id="AUTHV2-003" project="Spaarke Auth v2 + Hardening">
  <metadata>
    <title>Verify project CLAUDE.md prohibition section is correct + complete</title>
    <phase>0 — Pre-flight</phase>
    <tags>docs, pre-flight, agent-enforcement</tags>
    <status>not-started</status>
    <estimated-effort>10 minutes</estimated-effort>
