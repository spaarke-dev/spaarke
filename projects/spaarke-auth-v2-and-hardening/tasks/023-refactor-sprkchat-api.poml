<task id="AUTHV2-023" project="Spaarke Auth v2 + Hardening">
  <metadata>
    <title>Refactor SprkChat API — drop accessToken prop; require authenticatedFetch + getAccessToken</title>
    <phase>B — Consumer migration</phase>
    <tags>auth, ui-components, sprkchat, react, FULL</tags>
    <status>completed</status>
    <estimated-effort>2 hours</estimated-effort>
    <dependencies>020</dependencies>
