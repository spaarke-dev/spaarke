  <prompt>SemanticSearch has a separate MsalAuthProvider that returns `Bearer ${token}` strings. External SPA has bff-client.ts with raw Bearer headers. Migrate both to @spaarke/auth.</prompt>
  <role>Senior React engineer.</role>
  <goal>SemanticSearch + External SPA use @spaarke/auth v2 useAuth() hook + authenticatedFetch. No parallel auth stacks.</goal>
  <knowledge>
    <files>
      <file>src/client/code-pages/SemanticSearch/src/services/auth/MsalAuthProvider.ts</file>
      <file>src/client/code-pages/SemanticSearch/src/services/authInit.ts</file>
