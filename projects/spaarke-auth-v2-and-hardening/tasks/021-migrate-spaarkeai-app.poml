<task id="AUTHV2-021" project="Spaarke Auth v2 + Hardening">
  <metadata>
    <title>Migrate SpaarkeAi App.tsx — eliminate one-shot useEffect token snapshot</title>
    <phase>B — Consumer migration</phase>
    <tags>auth, code-page, react, spaarkeai, FULL</tags>
    <status>completed</status>
    <estimated-effort>1 hour</estimated-effort>
