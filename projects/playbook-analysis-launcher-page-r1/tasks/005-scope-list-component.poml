<task id="005" project="playbook-analysis-launcher-page-r1">
  <metadata>
    <title>Create ScopeList Component</title>
    <phase>1</phase>
    <status>not-started</status>
    <estimated-hours>2</estimated-hours>
    <dependencies>001</dependencies>
    <blocks>006</blocks>
    <tags>typescript, react, fluent-ui, frontend</tags>
    <rigor-hint>FULL</rigor-hint>
