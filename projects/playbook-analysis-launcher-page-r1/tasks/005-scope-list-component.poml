  <prompt>
    Create the ScopeList generic component — checkbox/radio list for selecting scope items
    (actions, skills, knowledge, tools). Port from existing PCF ScopeList.tsx.
  </prompt>

  <role>
    SPAARKE platform developer. Expert in Fluent UI v9 and generic React components.
  </role>

  <goal>
    Create `src/solutions/LegalWorkspace/src/components/Playbook/ScopeList.tsx` — a generic
    list component supporting both single-select (radio) and multi-select (checkbox) modes.
  </goal>

  <context>
    <background>
      The existing PCF ScopeList.tsx (251 lines) renders a list of items with checkbox/radio
      selection. This extracts it as a generic component with proper Fluent v9 styling.
    </background>
    <relevant-files>
      <file>src/solutions/LegalWorkspace/src/components/Playbook/ScopeList.tsx</file>
      <file>src/client/pcf/AnalysisBuilder/control/components/ScopeList.tsx</file>
      <file>src/solutions/LegalWorkspace/src/components/Playbook/types.ts</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-021">Use Fluent v9 Checkbox and RadioGroup components</constraint>
    <constraint source="ADR-021">Zero hardcoded colors</constraint>
    <constraint source="ADR-012">Generic component — works with any item type having id + name</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-021-fluent-design-system.md</file>
      <file>.claude/patterns/fluent-ui-theming.md</file>
      <file>projects/playbook-analysis-launcher-page-r1/spec.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Read existing PCF ScopeList.tsx</step>
    <step order="2">Create ScopeList.tsx with generic type parameter T extends { id: string; name: string }</step>
    <step order="3">Add props: items, multiSelect, selectedIds, onSelectionChange, isLoading</step>
    <step order="4">Use Fluent v9 Checkbox for multi-select, RadioGroup for single-select</step>
    <step order="5">Add description text display for items with description field</step>
    <step order="6">Add loading state with Skeleton</step>
    <step order="7">Verify TypeScript compiles</step>
  </steps>

  <outputs>
    <output type="code">src/solutions/LegalWorkspace/src/components/Playbook/ScopeList.tsx</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">ScopeList renders items as checkbox list when multiSelect=true</criterion>
    <criterion testable="true">ScopeList renders items as radio group when multiSelect=false</criterion>
    <criterion testable="true">onSelectionChange fires with updated selection set</criterion>
    <criterion testable="true">Zero hardcoded colors</criterion>
    <criterion testable="true">TypeScript compiles without errors</criterion>
  </acceptance-criteria>
</task>
