<task id="004" project="playbook-analysis-launcher-page-r1">
  <metadata>
    <title>Create PlaybookCardGrid Component</title>
    <phase>1</phase>
    <status>not-started</status>
    <estimated-hours>2</estimated-hours>
    <dependencies>001</dependencies>
    <blocks>020, 021</blocks>
    <tags>typescript, react, fluent-ui, frontend</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>React UI component with Fluent v9, dark mode required (ADR-021)</rigor-reason>
    <parallel-group>B</parallel-group>
    <parallel-safe>true</parallel-safe>
  </metadata>

  <prompt>
    Create the PlaybookCardGrid component — a card selector grid showing available playbooks.
    Port from the existing PCF PlaybookSelector.tsx but use React 18 and Fluent v9 semantic tokens.
  </prompt>

  <role>
    SPAARKE platform developer. Expert in Fluent UI v9 and React 18 component development.
  </role>

  <goal>
    Create `src/solutions/LegalWorkspace/src/components/Playbook/PlaybookCardGrid.tsx` — a responsive
    card grid for selecting playbooks with loading state, selection highlight, and dark mode support.
  </goal>

  <context>
    <background>
      The existing PCF PlaybookSelector.tsx renders playbook cards in a grid. This component
      extracts that UI into a reusable component using Fluent v9 Card components and semantic
      tokens for dark mode compliance.
    </background>
    <relevant-files>
      <file>src/solutions/LegalWorkspace/src/components/Playbook/PlaybookCardGrid.tsx</file>
      <file>src/client/pcf/AnalysisBuilder/control/components/PlaybookSelector.tsx</file>
      <file>src/solutions/LegalWorkspace/src/components/Playbook/types.ts</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-021">Zero hardcoded colors — use Fluent v9 semantic tokens only</constraint>
    <constraint source="ADR-021">Must render correctly in light, dark, and high-contrast themes</constraint>
    <constraint source="ADR-012">Reusable component — no workspace-specific imports</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-021-fluent-design-system.md</file>
      <file>.claude/adr/ADR-012-shared-component-library.md</file>
      <file>.claude/patterns/fluent-ui-theming.md</file>
      <file>projects/playbook-analysis-launcher-page-r1/spec.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Read existing PlaybookSelector.tsx from PCF</step>
    <step order="2">Read types.ts for IPlaybook interface</step>
    <step order="3">Create PlaybookCardGrid.tsx with props: playbooks, selectedId, onSelect, isLoading</step>
    <step order="4">Use Fluent v9 Card, CardHeader, makeStyles with semantic tokens</step>
    <step order="5">Add responsive grid layout (CSS Grid or Flex)</step>
    <step order="6">Add loading skeleton state using Fluent Skeleton</step>
    <step order="7">Add selection highlight using colorBrandBackground2 token</step>
    <step order="8">Verify no hardcoded colors (ADR-021 compliance)</step>
  </steps>

  <outputs>
    <output type="code">src/solutions/LegalWorkspace/src/components/Playbook/PlaybookCardGrid.tsx</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Renders playbook cards in a responsive grid</criterion>
    <criterion testable="true">Selected card has visual highlight using semantic tokens</criterion>
    <criterion testable="true">Loading state shows Fluent Skeleton components</criterion>
    <criterion testable="true">Zero hardcoded colors — all Fluent v9 semantic tokens</criterion>
    <criterion testable="true">TypeScript compiles without errors</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="PlaybookCardGrid Renders">
      <steps>
        <step>Render component with mock playbook data</step>
        <step>Verify cards display name and description</step>
        <step>Click a card and verify selection callback</step>
      </steps>
      <expected>Cards render, selection works, no console errors</expected>
    </test>
    <test name="Dark Mode Compliance (ADR-021)">
      <steps>
        <step>Render in dark theme FluentProvider</step>
        <step>Verify card backgrounds use semantic tokens</step>
        <step>Verify selection highlight adapts to dark theme</step>
      </steps>
      <expected>All colors adapt to dark theme via semantic tokens</expected>
    </test>
  </ui-tests>
</task>
