<task id="043" project="playbook-analysis-launcher-page-r1">
  <metadata>
    <title>Portability Check — No Workspace-Specific Imports</title>
    <phase>4</phase>
    <status>not-started</status>
    <estimated-hours>1</estimated-hours>
    <dependencies>034</dependencies>
    <blocks>050</blocks>
    <tags>testing, frontend</tags>
    <rigor-hint>MINIMAL</rigor-hint>
    <rigor-reason>Static analysis check — grep for imports</rigor-reason>
    <parallel-group>F</parallel-group>
