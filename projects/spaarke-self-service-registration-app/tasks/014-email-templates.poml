<task id="REG-014" project="Spaarke Self-Service Registration App">
  <metadata>
    <title>Email Templates and Registration Email Service</title>
    <status>not-started</status>
    <estimated-effort>2 hours</estimated-effort>
    <phase>1</phase>
    <tags>bff-api, email, templates</tags>
    <parallel-group>P1</parallel-group>
    <parallel-safe>true</parallel-safe>
    <dependencies>001</dependencies>
  </metadata>

  <prompt>
    Create 4 branded HTML email templates and a RegistrationEmailService that renders and sends
    them via the existing Spaarke Communication Service (POST /api/communications/send).
    Templates: admin notification (new request), welcome (account provisioned), expiration warning
    (3 days before), expired notification (account disabled). Each template uses string interpolation
    for dynamic values (name, username, password, dates, URLs).
  </prompt>

  <role>Full-stack developer with HTML email template and .NET service experience</role>

  <goal>
    4 HTML email templates with Spaarke branding and a RegistrationEmailService that renders
    templates with dynamic data and sends via Communication Service. Unit tests verify rendering.
  </goal>

  <knowledge>
    <files>
      <file>projects/spaarke-self-service-registration-app/spec.md</file>
      <file>src/server/api/Sprk.Bff.Api/Services/Communication/CommunicationService.cs</file>
      <file>.claude/patterns/api/send-email-integration.md</file>
    </files>
  </knowledge>

  <constraints>
    <constraint source="spec">Welcome email must include: username, temp password, access URL, browser tip, expiry date, quick start guide, support contact</constraint>
    <constraint source="spec">Admin notification must include: request details, link to MDA record</constraint>
    <constraint source="spec">Expiration warning: 3 days before, extension contact, production access CTA</constraint>
    <constraint source="spec">Expired: account disabled, thank you, production access CTA</constraint>
    <constraint source="spec">Send via POST /api/communications/send with SharedMailbox mode</constraint>
    <constraint source="spec">fromMailbox: noreply@spaarke.com</constraint>
  </constraints>

  <steps>
    <step order="1" name="Read Communication Service">Understand SendCommunicationRequest model and send patterns</step>
    <step order="2" name="Create admin notification template">HTML with request details, MDA deep link</step>
    <step order="3" name="Create welcome email template">HTML with credentials, access URL, browser tip, expiry</step>
    <step order="4" name="Create expiration warning template">HTML with extension CTA, production access offer</step>
    <step order="5" name="Create expired notification template">HTML with account disabled message, production CTA</step>
    <step order="6" name="Create RegistrationEmailService">Renders templates, sends via Communication Service</step>
    <step order="7" name="Write unit tests">Test template rendering with various inputs</step>
    <step order="8" name="Verify build">dotnet build and dotnet test</step>
  </steps>

  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Registration/EmailTemplates/AdminNotificationTemplate.html</output>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Registration/EmailTemplates/WelcomeTemplate.html</output>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Registration/EmailTemplates/ExpirationWarningTemplate.html</output>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Registration/EmailTemplates/ExpiredTemplate.html</output>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Registration/RegistrationEmailService.cs</output>
    <output type="test">tests/unit/Sprk.Bff.Api.Tests/Services/Registration/RegistrationEmailServiceTests.cs</output>
  </outputs>

  <acceptance-criteria>
    <criterion>4 HTML templates render correctly with placeholder values</criterion>
    <criterion>Welcome email includes all required fields from spec</criterion>
    <criterion>RegistrationEmailService sends via Communication Service POST endpoint</criterion>
    <criterion>Templates use consistent Spaarke branding</criterion>
    <criterion>Unit tests verify template rendering</criterion>
  </acceptance-criteria>
</task>
