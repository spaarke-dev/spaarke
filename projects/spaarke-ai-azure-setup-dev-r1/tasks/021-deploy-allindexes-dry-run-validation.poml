<task id="021" project="spaarke-ai-azure-setup-dev-r1">
  <metadata>
    <title>Validate Deploy-AllIndexes.ps1: -DryRun + -VerifyOnly smoke test</title>
    <phase>3: Deploy Infrastructure</phase>
    <status>completed</status>
