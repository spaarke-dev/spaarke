  <constraints>
    <constraint source="FR-02">MUST contain: prerequisites, step-by-step procedure (provision → KV secret → Deploy-AllIndexes → verify), per-index schema deploy + ingestion procedure, troubleshooting, post-deploy verification commands, environment-specific variables</constraint>
    <constraint source="project">Lowercase filename per user preference: `ai-search-azure-setup.md`</constraint>
