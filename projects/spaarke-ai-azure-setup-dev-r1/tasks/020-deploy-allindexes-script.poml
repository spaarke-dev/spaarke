    </relevant-files>
  </context>

  <constraints>
    <constraint source="FR-07">Required params: -Environment (ValidateSet dev/staging/prod/demo), -Indexes subset, -DryRun, -VerifyOnly, -Force (NFR-05 prod/demo gate), -CutoverBffSettings</constraint>
    <constraint source="FR-07">SupportsShouldProcess; wrap every destructive call in if ($PSCmdlet.ShouldProcess(...))</constraint>
    <constraint source="FR-07">Catalog-driven; idempotent; post-deploy invariant verifier per index (vector dim, key field, required-filterable fields, schema policy compliance)</constraint>
    <constraint source="FR-07">Retire in same PR: Deploy-IndexSchemas.ps1, Deploy-InvoiceSearchIndex.ps1, deploy-invoice-index.ps1, deploy-invoice-index.bicep, deploy-session-files-index.ps1, Create-PlaybookEmbeddingsIndex.ps1</constraint>
    <constraint source="NFR-01">Idempotent — safe to re-run; no destructive side effects without explicit -Force</constraint>
    <constraint source="NFR-02">Post-deploy verifier fail-fast on policy violations (non-zero exit, log index + field + violation)</constraint>
    <constraint source="NFR-05">Force gate for prod/demo</constraint>
    <constraint source="NFR-06">-DryRun + -VerifyOnly supported</constraint>
    <constraint source="NFR-12">Total runtime for full 7-index deploy &lt; 30 min target</constraint>
    <constraint source="ADR-013">Honor SemaphoreSlim patterns if applicable (n/a for schema deploy; relevant for ingestion phase 5)</constraint>
    <constraint source="ADR-028">KV references use @Microsoft.KeyVault(VaultName=spaarke-spekvcert;SecretName=...) form (CutoverBffSettings)</constraint>
  </constraints>

