<task id="UDSS-003" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Create mock IDataService adapter for unit testing</title>
    <status>not-started</status>
    <phase>1</phase>
    <estimated-effort>2 hours</estimated-effort>
    <tags>shared-library, testing, adapter</tags>
    <dependencies>UDSS-001</dependencies>
    <parallel-group>P1-adapters</parallel-group>
  </metadata>
  <prompt>Create mock adapter implementations with jest.fn() stubs for all service interfaces. These mocks enable unit testing of extracted wizard components without requiring a Dataverse runtime environment.</prompt>
  <role>Frontend developer</role>
  <goal>Mock adapters with jest.fn() stubs for all service interfaces</goal>
  <constraints>
    <constraint source="ADR-012">Mock adapters must implement the same interfaces as real adapters to ensure type safety in tests</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/adr/ADR-012-shared-components.md</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Create __mocks__/mockDataService.ts with jest.fn() stubs for all IDataService methods</step>
    <step id="2">Create __mocks__/mockUploadService.ts with jest.fn() stubs for all IUploadService methods</step>
    <step id="3">Create __mocks__/mockNavigationService.ts with jest.fn() stubs for all INavigationService methods</step>
    <step id="4">Create __mocks__/createMockServices.ts helper factory that returns all 3 mock services</step>
    <step id="5">Verify mock types match interfaces with TypeScript strict mode</step>
  </steps>
  <acceptance-criteria>
    <criterion>Mock factory creates all 3 services with correct types</criterion>
    <criterion>TypeScript validates type compatibility between mocks and interfaces</criterion>
  </acceptance-criteria>
</task>
