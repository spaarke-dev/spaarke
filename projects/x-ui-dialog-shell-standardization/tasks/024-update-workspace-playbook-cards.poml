<task id="UDSS-024" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Update Corporate Workspace playbook cards to navigateTo</title>
    <status>not-started</status>
    <phase>3</phase>
    <estimated-effort>4 hours</estimated-effort>
    <tags>workspace, playbook, navigation</tags>
    <dependencies>UDSS-021, UDSS-023</dependencies>
    <parallel-group>none</parallel-group>
  </metadata>
  <prompt>Update the Corporate Workspace Get Started action card handlers so that playbook-intent cards (email-compose, assign-counsel, meeting-schedule) use Xrm.Navigation.navigateTo to open sprk_playbooklibrary with the appropriate intent parameter, instead of invoking the inline QuickStart panel.</prompt>
  <role>Senior frontend developer</role>
  <goal>All playbook-related Get Started cards in Corporate Workspace open sprk_playbooklibrary via navigateTo with intent parameter</goal>
  <constraints>
    <constraint source="ADR-006">Code Pages opened via navigateTo — no inline panels for standalone workflows</constraint>
    <constraint source="ADR-021">Fluent v9 tokens only; dark mode required</constraint>
    <constraint source="file-ownership">ONLY touch ActionCardHandlers.ts and related navigation code in LegalWorkspace</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>src/solutions/LegalWorkspace/src/components/ActionCardHandlers.ts</file>
      <file>.claude/patterns/pcf/dialog-patterns.md</file>
      <file>src/solutions/PlaybookLibrary/</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Read ActionCardHandlers.ts to identify all playbook-intent card handlers</step>
    <step id="2">Update each handler to use Xrm.Navigation.navigateTo with webresource sprk_playbooklibrary and intent query parameter</step>
    <step id="3">Set navigateTo dialog dimensions (85% width, 85% height) matching existing patterns</step>
    <step id="4">Handle navigateTo Promise for post-dialog refresh (refetch workspace data on close)</step>
    <step id="5">Test each card: email-compose, assign-counsel, meeting-schedule — verify correct intent passed</step>
    <step id="6">Verify existing non-playbook cards are unaffected</step>
  </steps>
  <acceptance-criteria>
    <criterion>All playbook-intent cards open sprk_playbooklibrary via navigateTo</criterion>
    <criterion>Intent parameter correctly passed for each card type</criterion>
    <criterion>Post-dialog refresh occurs when navigateTo Promise resolves</criterion>
    <criterion>Non-playbook action cards continue to work unchanged</criterion>
    <criterion>Dialog dimensions match project standard (85% x 85%)</criterion>
  </acceptance-criteria>
</task>
