<task id="UDSS-041" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Add wizard buttons to sprk_matter form command bar</title>
    <status>not-started</status>
    <phase>5</phase>
    <estimated-effort>4 hours</estimated-effort>
    <tags>ribbon, matter, command-bar</tags>
    <dependencies>UDSS-040</dependencies>
    <parallel-group>P5-ribbons</parallel-group>
  </metadata>
  <prompt>Add ribbon/command bar buttons to the sprk_matter entity main form for launching wizard Code Pages. Buttons include: Create Project, Create Event, Create Todo, Upload Documents, Summarize Files, Find Similar, and Open Playbook Library. Each button calls the corresponding function in sprk_wizard_commands.js.</prompt>
  <role>Senior developer with Dataverse ribbon customization expertise</role>
  <goal>sprk_matter form command bar has buttons for all applicable wizard Code Pages, wired to sprk_wizard_commands.js functions</goal>
  <constraints>
    <constraint source="ribbon">Follow ribbon-edit skill procedure for solution export/import</constraint>
    <constraint source="ADR-006">Buttons open Code Pages via navigateTo — no custom page wrappers</constraint>
    <constraint source="file-ownership">ONLY touch files in infrastructure/dataverse/ribbon/MatterRibbons/ — do NOT modify other entity ribbons</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/skills/ribbon-edit/SKILL.md</file>
      <file>infrastructure/dataverse/ribbon/</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Read existing Matter ribbon customizations to understand current button layout</step>
    <step id="2">Define button metadata: labels, icons, tooltip text, display rules (show on main form only)</step>
    <step id="3">Add "Create Project" button → Spaarke.Commands.Wizards.openCreateProjectWizard</step>
    <step id="4">Add "Create Event" button → Spaarke.Commands.Wizards.openCreateEventWizard</step>
    <step id="5">Add "Create Todo" button → Spaarke.Commands.Wizards.openCreateTodoWizard</step>
    <step id="6">Add "Upload Documents" button → Spaarke.Commands.Wizards.openDocumentUploadWizard</step>
    <step id="7">Add "Summarize Files" button → Spaarke.Commands.Wizards.openSummarizeFilesWizard</step>
    <step id="8">Add "Find Similar" button → Spaarke.Commands.Wizards.openFindSimilarDialog</step>
    <step id="9">Add "Playbook Library" button → Spaarke.Commands.Wizards.openPlaybookLibrary</step>
    <step id="10">Group buttons logically in the command bar (e.g., "Wizards" group or "AI" group)</step>
    <step id="11">Export ribbon XML for version control</step>
  </steps>
  <acceptance-criteria>
    <criterion>All wizard buttons visible on sprk_matter main form command bar</criterion>
    <criterion>Each button wired to correct sprk_wizard_commands.js function</criterion>
    <criterion>Buttons grouped logically in command bar</criterion>
    <criterion>Buttons have appropriate icons and tooltips</criterion>
    <criterion>Ribbon XML exported and saved in infrastructure/dataverse/ribbon/MatterRibbons/</criterion>
  </acceptance-criteria>
</task>
