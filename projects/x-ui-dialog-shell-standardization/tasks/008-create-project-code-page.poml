<task id="UDSS-008" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Create CreateProjectWizard Code Page wrapper (Vite)</title>
    <status>not-started</status>
    <phase>1</phase>
    <estimated-effort>3 hours</estimated-effort>
    <tags>code-page, vite, wizard, project</tags>
    <dependencies>UDSS-004, UDSS-005c</dependencies>
    <parallel-group>P1-code-pages</parallel-group>
  </metadata>
  <prompt>Create a Vite-based Code Page wrapper for the extracted CreateProjectWizard component. Follow the same pattern established in UDSS-006 (CreateMatterWizard Code Page).</prompt>
  <role>Frontend developer</role>
  <goal>src/solutions/CreateProjectWizard/ with working Vite build producing single HTML output</goal>
  <constraints>
    <constraint source="ADR-026">Code Pages must use Vite with vite-plugin-singlefile for single HTML output</constraint>
    <constraint source="ADR-021">Use React 19 createRoot — Code Pages bundle their own React</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/adr/ADR-026-full-page-custom-page-standard.md</file>
      <file>.claude/patterns/webresource/full-page-custom-page.md</file>
      <file>src/solutions/EventsPage/</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Create src/solutions/CreateProjectWizard/ directory</step>
    <step id="2">Copy boilerplate from CreateMatterWizard Code Page (package.json, vite.config.ts, tsconfig.json, index.html)</step>
    <step id="3">Update src/main.tsx to render CreateProjectWizard instead of CreateMatterWizard</step>
    <step id="4">Run npm install and npm run build</step>
  </steps>
  <acceptance-criteria>
    <criterion>Build produces a single HTML file in dist/</criterion>
    <criterion>Renders CreateProjectWizard with theme detection</criterion>
  </acceptance-criteria>
</task>
