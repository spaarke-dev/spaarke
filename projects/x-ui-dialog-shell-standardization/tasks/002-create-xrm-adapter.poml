<task id="UDSS-002" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Create Xrm.WebApi adapter implementing IDataService</title>
    <status>not-started</status>
    <phase>1</phase>
    <estimated-effort>3 hours</estimated-effort>
    <tags>shared-library, adapter, dataverse</tags>
    <dependencies>UDSS-001</dependencies>
    <parallel-group>P1-adapters</parallel-group>
  </metadata>
  <prompt>Create concrete adapter implementations that bridge the IDataService, IUploadService, and INavigationService interfaces to the Xrm.WebApi runtime. These adapters are used by Code Page wrappers to provide Dataverse data access to extracted wizard components.</prompt>
  <role>Frontend developer with Dataverse experience</role>
  <goal>Concrete IDataService implementation using Xrm.WebApi, ready for Code Page consumers</goal>
  <constraints>
    <constraint source="ADR-012">Adapters live in utils/adapters/ — they are the ONLY place where Xrm.WebApi is referenced directly</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/adr/ADR-012-shared-components.md</file>
      <file>.claude/patterns/pcf/dialog-patterns.md</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Create utils/adapters/xrmDataServiceAdapter.ts implementing IDataService via Xrm.WebApi</step>
    <step id="2">Create utils/adapters/xrmUploadServiceAdapter.ts implementing IUploadService</step>
    <step id="3">Create utils/adapters/xrmNavigationServiceAdapter.ts implementing INavigationService (navigateTo, openForm)</step>
    <step id="4">Create utils/adapters/index.ts barrel exporting all adapters</step>
    <step id="5">Export adapters from utils/index.ts</step>
    <step id="6">Add JSDoc documentation to all public methods</step>
  </steps>
  <acceptance-criteria>
    <criterion>All 3 adapters compile and implement the correct interfaces from UDSS-001</criterion>
    <criterion>No non-Xrm external dependencies are introduced</criterion>
    <criterion>Adapters are exported from utils barrel</criterion>
  </acceptance-criteria>
</task>
