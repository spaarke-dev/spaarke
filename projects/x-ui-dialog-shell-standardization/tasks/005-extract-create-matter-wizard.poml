<task id="UDSS-005" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Extract CreateMatter wizard to shared library (no barrel update)</title>
    <status>not-started</status>
    <phase>1</phase>
    <estimated-effort>7 hours</estimated-effort>
    <tags>shared-library, wizard, matter, refactor</tags>
    <dependencies>UDSS-001, UDSS-002</dependencies>
    <parallel-group>P1-extract-wizards</parallel-group>
  </metadata>
  <prompt>Extract the CreateMatter wizard from LegalWorkspace into the shared component library. Refactor all direct Xrm.WebApi calls to use IDataService abstraction. Add an embedded prop for Dataverse chrome mode. IMPORTANT: Do NOT modify components/index.ts barrel — that is handled in UDSS-005c to avoid file ownership conflicts with parallel tasks.</prompt>
  <role>Senior frontend developer with React and Fluent UI v9 expertise</role>
  <goal>CreateMatter wizard components moved to @spaarke/ui-components/components/CreateMatterWizard/ with IDataService abstraction. Barrel export NOT updated (done in UDSS-005c).</goal>
  <constraints>
    <constraint source="ADR-012">IDataService abstraction required — no direct Xrm.WebApi calls in shared library components</constraint>
    <constraint source="ADR-021">All UI must use Fluent v9 tokens; dark mode must be supported</constraint>
    <constraint source="file-ownership">ONLY touch files in components/CreateMatterWizard/ folder — do NOT modify components/index.ts barrel</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/adr/ADR-012-shared-components.md</file>
      <file>.claude/adr/ADR-021-fluent-design-system.md</file>
      <file>src/solutions/LegalWorkspace/src/components/CreateMatter/</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Read all 15 files in src/solutions/LegalWorkspace/src/components/CreateMatter/ to understand current structure</step>
    <step id="2">Create @spaarke/ui-components/components/CreateMatterWizard/ directory</step>
    <step id="3">Copy and refactor files (WizardDialog → CreateMatterWizard, etc.) into the new directory</step>
    <step id="4">Refactor matterService.ts to accept IDataService parameter instead of calling Xrm.WebApi directly</step>
    <step id="5">Add embedded prop for Dataverse chrome mode (controls whether wizard renders its own title bar or relies on Dataverse modal chrome)</step>
    <step id="6">Create local index.ts within CreateMatterWizard/ folder ONLY — do NOT touch components/index.ts</step>
    <step id="7">Run tsc on the folder to verify compilation</step>
  </steps>
  <acceptance-criteria>
    <criterion>All 15 files moved and refactored in CreateMatterWizard/ directory</criterion>
    <criterion>matterService uses IDataService parameter — no direct Xrm.WebApi calls</criterion>
    <criterion>Compiles successfully with tsc</criterion>
    <criterion>embedded prop controls title bar rendering</criterion>
    <criterion>components/index.ts barrel is NOT modified</criterion>
  </acceptance-criteria>
</task>
