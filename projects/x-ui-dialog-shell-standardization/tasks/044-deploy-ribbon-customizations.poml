<task id="UDSS-044" project="UI Dialog Shell Standardization">
  <metadata>
    <title>Deploy all ribbon customizations</title>
    <status>not-started</status>
    <phase>5</phase>
    <estimated-effort>2 hours</estimated-effort>
    <tags>deploy, ribbon</tags>
    <dependencies>UDSS-041, UDSS-042, UDSS-043</dependencies>
    <parallel-group>none</parallel-group>
  </metadata>
  <prompt>Deploy all ribbon customizations for Matter, Project, and Event entity forms to the dev environment. Import the updated solution with ribbon XML changes and publish all customizations.</prompt>
  <role>Senior developer with Dataverse deployment expertise</role>
  <goal>All ribbon customizations deployed and visible on Matter, Project, and Event entity forms in dev environment</goal>
  <constraints>
    <constraint source="deployment">Follow dataverse-deploy and ribbon-edit skill procedures</constraint>
    <constraint source="testing">Verify buttons appear on each entity form after deployment</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/skills/dataverse-deploy/SKILL.md</file>
      <file>.claude/skills/ribbon-edit/SKILL.md</file>
    </files>
  </knowledge>
  <steps>
    <step id="1">Review all ribbon XML files from tasks 041, 042, 043 for completeness</step>
    <step id="2">Package ribbon changes into Dataverse solution</step>
    <step id="3">Import solution to dev environment</step>
    <step id="4">Publish all customizations</step>
    <step id="5">Verify sprk_wizard_commands.js webresource is deployed and accessible</step>
    <step id="6">Verify buttons appear on sprk_matter form command bar</step>
    <step id="7">Verify buttons appear on sprk_project form command bar</step>
    <step id="8">Verify buttons appear on sprk_event form command bar</step>
  </steps>
  <acceptance-criteria>
    <criterion>Solution imported successfully without errors</criterion>
    <criterion>All customizations published</criterion>
    <criterion>Wizard buttons visible on Matter, Project, and Event forms</criterion>
    <criterion>sprk_wizard_commands.js webresource accessible in environment</criterion>
  </acceptance-criteria>
</task>
