<task id="PPI-033" project="Production Performance Improvement R1">
  <metadata>
    <title>Remove String Allocations from Log Parameters (G5)</title>
    <status>completed</status>
    <estimated-effort>2 hours</estimated-effort>
    <phase>4</phase>
    <domain>G</domain>
    <tags>bff-api, logging, performance</tags>
    <parallel-group>P4-ALL</parallel-group>
    <dependencies>Phase 3 complete</dependencies>
  </metadata>

  <prompt>
    Remove unnecessary string allocations from log parameters. Replace Substring, concatenation,
    and string interpolation in log calls with cheap alternatives (length, boolean checks).
  </prompt>

  <role>.NET developer with performance optimization expertise</role>

  <goal>
    Zero unnecessary string allocations in log parameters. All replaced with cheap alternatives.
  </goal>

  <inputs>
    <file purpose="spec">projects/production-performance-improvement-r1/spec.md</file>
  </inputs>

  <constraints>
    <constraint source="ADR-015">Log identifiers/sizes, not content</constraint>
  </constraints>

  <knowledge>
    <topic>logging, performance</topic>
    <files>
      <file>.claude/constraints/api.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Search for string operations in log calls">
      Grep for Substring, string concatenation (+), string interpolation in logger calls.
    </step>
    <step order="2" name="Replace with cheap alternatives">
      Substring → Length/HasValue checks. Concatenation → separate parameters.
    </step>
    <step order="3" name="Build and test">
      Run `dotnet build` and `dotnet test`.
    </step>
  </steps>

  <tools>
    <tool name="dotnet">Build and test .NET projects</tool>
  </tools>

  <outputs>
    <output type="code">Various files with string allocations in logs (modified)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Zero Substring calls in log parameters</criterion>
    <criterion testable="true">Zero string concatenation in log parameters</criterion>
    <criterion testable="true">Build and tests pass</criterion>
  </acceptance-criteria>
</task>
