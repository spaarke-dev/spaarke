<task id="PPI-034" project="Production Performance Improvement R1">
  <metadata>
    <title>Remove Obsolete Tool Handlers (F3)</title>
    <status>completed</status>
    <estimated-effort>4 hours</estimated-effort>
    <phase>4</phase>
    <domain>F</domain>
    <tags>bff-api, code-quality, cleanup</tags>
    <parallel-group>P4-ALL</parallel-group>
    <dependencies>Phase 3 complete</dependencies>
  </metadata>

  <prompt>
    Remove 6 obsolete tool handlers (~5,500 lines total) that have been replaced by JPS-based
    GenericAnalysisHandler. All JPS replacements verified complete with 217 tests passing.
    Handlers: ClauseAnalyzer, DateExtractor, EntityExtractor, FinancialCalculator, RiskDetector,
    ClauseComparison.
  </prompt>

  <role>Senior .NET developer with DI and service architecture expertise</role>

  <goal>
    All 6 obsolete handlers removed from codebase and DI registrations. Zero [Obsolete] handlers
    compiled. JPS replacements continue to function. ~5,500 lines of dead code eliminated.
  </goal>

  <inputs>
    <file purpose="spec">projects/production-performance-improvement-r1/spec.md</file>
    <file purpose="target">src/server/api/Sprk.Bff.Api/Services/Ai/Tools/</file>
  </inputs>

  <constraints>
    <constraint source="ADR-010">DI minimalism — removing handlers reduces DI registration count</constraint>
    <constraint source="owner">Remove now — old approach is outdated; will rebuild smarter if needed</constraint>
    <constraint source="project">Verify JPS configs exist for all 5 analysis types before deletion</constraint>
  </constraints>

  <knowledge>
    <topic>di, service-architecture, jps</topic>
    <files>
      <file>.claude/constraints/api.md</file>
      <file>.claude/patterns/api/service-registration.md</file>
      <file>src/server/api/Sprk.Bff.Api/Services/Ai/Handlers/GenericAnalysisHandler.cs</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Verify JPS replacements exist">
      Confirm all 5 JPS configuration files exist and GenericAnalysisHandler routes correctly.
    </step>
    <step order="2" name="Remove handler files">
      Delete all 6 handler .cs files from Services/Ai/Tools/.
    </step>
    <step order="3" name="Remove DI registrations">
      Remove AddSingleton/AddScoped registrations for obsolete handlers.
    </step>
    <step order="4" name="Remove string-based references">
      Search for handler class names in orchestration services. Remove or update references.
    </step>
    <step order="5" name="Run full test suite">
      Run `dotnet test` — all 217+ JPS tests must pass.
    </step>
    <step order="6" name="Verify build clean">
      Run `dotnet build` — zero warnings about obsolete references.
    </step>
  </steps>

  <tools>
    <tool name="dotnet">Build and test .NET projects</tool>
  </tools>

  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Ai/Tools/ (6 files deleted)</output>
    <output type="code">src/server/api/Sprk.Bff.Api/ (DI registrations modified)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">All 6 obsolete handler files deleted</criterion>
    <criterion testable="true">Zero [Obsolete] handler DI registrations</criterion>
    <criterion testable="true">Zero string-based references to deleted handlers</criterion>
    <criterion testable="true">All JPS tests pass (217+)</criterion>
    <criterion testable="true">Build succeeds with zero obsolete warnings</criterion>
  </acceptance-criteria>
</task>
