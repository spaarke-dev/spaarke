<task id="PPI-032" project="Production Performance Improvement R1">
  <metadata>
    <title>Production Log Level Configuration (G4)</title>
    <status>not-started</status>
    <estimated-effort>2 hours</estimated-effort>
    <phase>4</phase>
    <domain>G</domain>
    <tags>bff-api, logging, configuration</tags>
    <parallel-group>P4-ALL</parallel-group>
    <dependencies>Phase 3 complete</dependencies>
  </metadata>

  <prompt>
    Add per-service log level configuration for production. The 3 chattiest services
    (ScopeResolverService: 142 calls, AnalysisOrchestrationService: 106, DriveItemOperations: 82)
    should run at Warning level in production. Add appsettings.Production.json with tuned levels.
  </prompt>

  <role>.NET developer with ASP.NET Core logging configuration expertise</role>

  <goal>
    Production log levels tuned per-service. Chatty services at Warning. Overall log volume
    significantly reduced in production while preserving Debug/Info in development.
  </goal>

  <inputs>
    <file purpose="spec">projects/production-performance-improvement-r1/spec.md</file>
    <file purpose="target">src/server/api/Sprk.Bff.Api/appsettings.json</file>
  </inputs>

  <constraints>
    <constraint source="project">Development environment must retain full logging</constraint>
  </constraints>

  <knowledge>
    <topic>logging, configuration</topic>
    <files>
      <file>.claude/constraints/api.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Create production logging config">
      Add or update appsettings.Production.json with per-service log levels.
    </step>
    <step order="2" name="Configure chatty services at Warning">
      Set ScopeResolverService, AnalysisOrchestrationService, DriveItemOperations to Warning.
    </step>
    <step order="3" name="Set framework defaults">
      Microsoft.AspNetCore → Warning, Microsoft.Graph → Warning.
    </step>
    <step order="4" name="Build and test">
      Run `dotnet build` and `dotnet test`.
    </step>
  </steps>

  <tools>
    <tool name="dotnet">Build and test .NET projects</tool>
  </tools>

  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/appsettings.Production.json (created/modified)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Production log levels configured per-service</criterion>
    <criterion testable="true">Chatty services at Warning in production</criterion>
    <criterion testable="true">Development retains full logging</criterion>
    <criterion testable="true">Build and tests pass</criterion>
  </acceptance-criteria>
</task>
