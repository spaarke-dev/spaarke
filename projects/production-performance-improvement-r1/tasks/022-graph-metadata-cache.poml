<task id="PPI-022" project="Production Performance Improvement R1">
  <metadata>
    <title>Graph Metadata Cache (A1)</title>
    <status>completed</status>
    <estimated-effort>6 hours</estimated-effort>
    <phase>3</phase>
    <domain>A</domain>
    <tags>bff-api, graph, caching, redis</tags>
    <parallel-group>P3-B</parallel-group>
    <dependencies>Phase 2 complete</dependencies>
  </metadata>

  <prompt>
    Implement distributed Redis cache for Graph API metadata responses per ADR-009. This is the
    highest-impact caching layer — file metadata, folder listings, container-to-drive mappings,
    and permissions will go from 100-300ms to ~5ms on cache hit (90%+ hit rate expected).
  </prompt>

  <role>Senior .NET developer with Microsoft Graph, Redis caching, and SpeFileStore expertise</role>

  <goal>
    Graph metadata cached in Redis with ETag-versioned keys. File listing (cached) < 50ms p95.
    Cache hit rate > 85%. All caching through SpeFileStore facade per ADR-007.
  </goal>

  <inputs>
    <file purpose="spec">projects/production-performance-improvement-r1/spec.md</file>
    <file purpose="target">src/server/api/Sprk.Bff.Api/Infrastructure/Graph/DriveItemOperations.cs</file>
    <file purpose="pattern">src/server/api/Sprk.Bff.Api/Services/GraphTokenCache.cs</file>
    <file purpose="pattern">src/server/api/Sprk.Bff.Api/Infrastructure/Caching/DistributedCacheExtensions.cs</file>
  </inputs>

  <constraints>
    <constraint source="ADR-009">IDistributedCache, ETag-versioned keys, no L1 without profiling</constraint>
    <constraint source="ADR-007">All Graph operations through SpeFileStore facade</constraint>
    <constraint source="project">Tenant-scoped cache keys</constraint>
  </constraints>

  <knowledge>
    <topic>redis-caching, graph-api, spe-file-store</topic>
    <files>
      <file>.claude/constraints/api.md</file>
      <file>.claude/patterns/api/distributed-cache.md</file>
      <file>.claude/patterns/api/token-cache.md</file>
      <file>src/server/api/Sprk.Bff.Api/Services/GraphTokenCache.cs</file>
      <file>src/server/api/Sprk.Bff.Api/Infrastructure/Caching/DistributedCacheExtensions.cs</file>
      <file>src/server/api/Sprk.Bff.Api/Infrastructure/Caching/CacheMetrics.cs</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Design cache key patterns">
      Define keys: metadata (5min), folder listing (2min), container-to-drive (24h), permissions (5min).
    </step>
    <step order="2" name="Implement metadata cache">
      Add cache-aside in DriveItemOperations for file metadata. ETag-versioned keys.
    </step>
    <step order="3" name="Implement folder listing cache">
      Cache folder children responses. Short TTL for freshness.
    </step>
    <step order="4" name="Implement container-to-drive cache">
      Cache stable container-to-drive ID mappings with long TTL (24h).
    </step>
    <step order="5" name="Implement permissions cache">
      Cache drive item permissions with short TTL (5min) for security sensitivity.
    </step>
    <step order="6" name="Add cache metrics and telemetry">
      Track hit/miss rates per cache type using CacheMetrics.
    </step>
    <step order="7" name="Test and verify">
      Run `dotnet build` and `dotnet test`.
    </step>
  </steps>

  <tools>
    <tool name="dotnet">Build and test .NET projects</tool>
  </tools>

  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/Infrastructure/Graph/DriveItemOperations.cs (modified)</output>
    <output type="code">src/server/api/Sprk.Bff.Api/Infrastructure/Graph/ (cache service if needed)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">File metadata cached with ETag-versioned keys (5min TTL)</criterion>
    <criterion testable="true">Folder listings cached (2min TTL)</criterion>
    <criterion testable="true">Container-to-drive mappings cached (24h TTL)</criterion>
    <criterion testable="true">Cache metrics track hit/miss rates</criterion>
    <criterion testable="true">All caching through SpeFileStore facade</criterion>
    <criterion testable="true">Build and tests pass</criterion>
  </acceptance-criteria>
</task>
