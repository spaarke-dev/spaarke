<task id="PPI-050" project="Production Performance Improvement R1">
  <metadata>
    <title>Test Suite Re-enablement (D1)</title>
    <status>not-started</status>
    <estimated-effort>4 hours</estimated-effort>
    <phase>6</phase>
    <domain>D</domain>
    <tags>ci-cd, testing</tags>
    <parallel-group>P6-A</parallel-group>
    <dependencies>Phase 5 complete</dependencies>
  </metadata>

  <prompt>
    Fix interface updates that caused test disablement. Re-enable dotnet test in the deployment
    pipeline. Add test results as a deployment gate (fail = no deploy).
  </prompt>

  <role>.NET developer with CI/CD and testing expertise</role>

  <goal>Test suite runs in CI/CD. Failures block deployment. All tests pass.</goal>

  <inputs><file purpose="spec">projects/production-performance-improvement-r1/spec.md</file></inputs>
  <constraints><constraint source="project">All existing tests must pass before re-enabling gate</constraint></constraints>
  <knowledge><topic>ci-cd, testing</topic><files><file>.claude/constraints/testing.md</file></files></knowledge>

  <steps>
    <step order="1" name="Run test suite locally">Run `dotnet test`. Identify and fix failing tests.</step>
    <step order="2" name="Fix interface mismatches">Update test mocks/stubs for changed interfaces.</step>
    <step order="3" name="Re-enable in CI/CD">Add `dotnet test` step to GitHub Actions workflow.</step>
    <step order="4" name="Configure as gate">Set test step as required — failure blocks deployment.</step>
  </steps>

  <tools><tool name="dotnet">Build and test</tool></tools>
  <outputs>
    <output type="code">.github/workflows/ (modified)</output>
    <output type="code">tests/ (fixed tests)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">All tests pass locally</criterion>
    <criterion testable="true">Tests run in CI/CD pipeline</criterion>
    <criterion testable="true">Test failure blocks deployment</criterion>
  </acceptance-criteria>
</task>
