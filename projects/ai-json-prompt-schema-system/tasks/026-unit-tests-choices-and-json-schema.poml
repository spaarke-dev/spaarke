    </files>
  </knowledge>

  <steps>
    <step order="1">Add test class for $choices resolution in PromptSchemaRendererTests.cs</step>
    <step order="2">Write tests: ResolvesChoicesFromDownstreamNode, HandlesUnresolvableReference, InjectsEnumValues</step>
    <step order="3">Add test class for JSON Schema generation</step>
    <step order="4">Write tests: GeneratesStringSchema, GeneratesNumberSchema, GeneratesBooleanSchema, GeneratesArraySchema, GeneratesObjectSchema, IncludesEnumFromChoices, IncludesConstraints</step>
    <step order="5">Add pre-execution validation tests</step>
    <step order="6">Run tests: `dotnet test tests/unit/Sprk.Bff.Api.Tests/`</step>
