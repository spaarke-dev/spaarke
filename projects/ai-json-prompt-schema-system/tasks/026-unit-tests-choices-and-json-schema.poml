  <prompt>
    <goal>Write unit tests for $choices resolution, JSON Schema generation, and pre-execution validation.</goal>
    <context>
      Tests cover: (1) $choices reference parsing and resolution from mock downstream nodes,
      (2) JSON Schema Draft-07 generation from output.fields with all type mappings,
      (3) Pre-execution validation for JPS schemas.
    </context>
    <constraints>
      - Mock downstream node data for $choices tests
      - Validate generated JSON Schema against Draft-07 spec
      - Test all field type mappings (string, number, boolean, array, object)
      - Test enum injection from $choices
      - Test graceful degradation for unresolvable references
    </constraints>
  </prompt>

  <knowledge>
    <files>
