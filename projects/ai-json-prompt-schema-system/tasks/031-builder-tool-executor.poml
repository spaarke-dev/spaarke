<task id="031" project="ai-json-prompt-schema-system">
  <metadata>
    <title>Implement configure_prompt_schema Tool Executor</title>
    <phase>4</phase>
    <tags>bff-api, api, implement</tags>
    <estimate>3h</estimate>
    <dependencies>030, 002</dependencies>
    <parallel-group>B</parallel-group>
  </metadata>

  <prompt>
    <goal>Implement the tool executor for configure_prompt_schema that generates full JPS JSON from simplified parameters and supports auto-wired $choices.</goal>
    <context>
      When the Builder Agent calls configure_prompt_schema, the executor:
      1. Parses parameters (nodeId, role, task, constraints, outputFields, useStructuredOutput, autoWireChoices)
      2. Generates a complete JPS JSON schema from these inputs
      3. If autoWireChoices=true, traverses canvas edges to find downstream UpdateRecord nodes and auto-connects $choices
      4. Sets metadata.authorLevel=3, metadata.author="builder-agent"
      5. Stores the JPS JSON in the node's Action scope (sprk_systemprompt)
    </context>
    <constraints>
      - Generate valid JPS JSON with $schema and $version fields
      - Auto-wire $choices by traversing canvas edges when autoWireChoices=true
      - Set metadata.authorLevel=3, metadata.author="builder-agent", metadata.createdAt=now
      - Handle errors gracefully (return tool error response, not exception)
      - Follow existing tool executor patterns in BuilderToolExecutor.cs
    </constraints>
  </prompt>

  <knowledge>
    <files>
      <file>projects/ai-json-prompt-schema-system/design.md</file>
      <file>projects/ai-json-prompt-schema-system/spec.md</file>
      <file>src/server/api/Sprk.Bff.Api/Services/Ai/Builder/BuilderToolExecutor.cs</file>
      <file>.claude/constraints/ai.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Read BuilderToolExecutor.cs for existing tool execution patterns</step>
    <step order="2">Add handler for configure_prompt_schema tool calls</step>
    <step order="3">Implement JPS JSON generation from simplified parameters</step>
    <step order="4">Implement autoWireChoices: traverse canvas edges → find downstream UpdateRecord → set $choices references</step>
    <step order="5">Set metadata fields (authorLevel=3, author, createdAt)</step>
    <step order="6">Store generated schema in node's Action scope</step>
    <step order="7">Verify build: `dotnet build src/server/api/Sprk.Bff.Api/`</step>
  </steps>

  <tools>
    <tool>Read</tool>
    <tool>Edit</tool>
    <tool>Grep</tool>
    <tool>Bash(dotnet build)</tool>
  </tools>

  <outputs>
    <output>src/server/api/Sprk.Bff.Api/Services/Ai/Builder/BuilderToolExecutor.cs (modified)</output>
  </outputs>

  <acceptance-criteria>
    <criterion>Generates valid JPS JSON from simplified parameters</criterion>
    <criterion>autoWireChoices traverses edges and connects $choices</criterion>
    <criterion>metadata.authorLevel=3 set correctly</criterion>
    <criterion>Errors return tool error response, not exceptions</criterion>
    <criterion>Project builds without errors</criterion>
  </acceptance-criteria>
</task>
