<task id="SPE-055" project="SDAP SPE Admin App">
  <metadata>
    <title>Container Column CRUD Endpoints</title>
    <status>not-started</status>
    <estimated-effort>2h</estimated-effort>
    <tags>bff-api, api, graph, phase-2</tags>
    <phase>phase-2</phase>
    <dependencies>SPE-013</dependencies>
  </metadata>
  <prompt>Implement full CRUD endpoints for container columns. Columns define the metadata schema for items stored within a container, allowing administrators to add structured fields like text, date, choice, and other types to organize container content.</prompt>
  <role>Senior .NET Backend Developer with Microsoft Graph API expertise</role>
  <goal>Working GET, POST, PATCH, and DELETE endpoints for container columns via Graph API, verified by tests.</goal>
  <constraints>
    <constraint source="ADR-001">Use Minimal API endpoint pattern — no controllers</constraint>
    <constraint source="ADR-008">Use endpoint filters for authorization — no global middleware</constraint>
    <constraint source="ADR-007">Do not leak Graph SDK types above the service facade</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>src/server/api/Sprk.Bff.Api/CLAUDE.md</file>
      <file>.claude/adr/ADR-001.md</file>
    </files>
  </knowledge>
  <context>
    <background>Container columns define custom metadata fields that can be applied to items within a container. Supported column types include text, boolean, dateTime, currency, choice, number, personOrGroup, and hyperlinkOrPicture. These columns enable structured data capture beyond the default file properties.</background>
  </context>
  <steps>
    <step order="1" name="define-dtos">Define ContainerColumnDto and CreateColumnRequest/UpdateColumnRequest with name, description, columnType, required, indexed, and type-specific settings</step>
    <step order="2" name="add-graph-methods">Add ListColumnsAsync, CreateColumnAsync, UpdateColumnAsync, DeleteColumnAsync to SpeAdminGraphService</step>
    <step order="3" name="add-list-endpoint">Add GET /api/spe/containers/{id}/columns endpoint</step>
    <step order="4" name="add-create-endpoint">Add POST /api/spe/containers/{id}/columns endpoint with validation</step>
    <step order="5" name="add-update-endpoint">Add PATCH /api/spe/containers/{id}/columns/{columnId} endpoint</step>
    <step order="6" name="add-delete-endpoint">Add DELETE /api/spe/containers/{id}/columns/{columnId} endpoint</step>
    <step order="7" name="apply-auth-filter">Apply SpeAdminAuthFilter to all endpoints</step>
    <step order="8" name="add-tests">Write unit tests for all four operations</step>
  </steps>
  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/Features/SpeAdmin/Models/ContainerColumnDto.cs</output>
    <output type="code">src/server/api/Sprk.Bff.Api/Features/SpeAdmin/SpeAdminGraphService.cs</output>
    <output type="code">src/server/api/Sprk.Bff.Api/Features/SpeAdmin/SpeAdminEndpoints.cs</output>
    <output type="code">tests/Sprk.Bff.Api.Tests/Features/SpeAdmin/ContainerColumnTests.cs</output>
  </outputs>
  <acceptance-criteria>
    <criterion testable="true">GET /api/spe/containers/{id}/columns returns list of columns</criterion>
    <criterion testable="true">POST /api/spe/containers/{id}/columns creates a column and returns 201</criterion>
    <criterion testable="true">PATCH /api/spe/containers/{id}/columns/{columnId} updates column properties</criterion>
    <criterion testable="true">DELETE /api/spe/containers/{id}/columns/{columnId} removes the column</criterion>
    <criterion testable="true">Invalid column type is rejected with 400</criterion>
    <criterion testable="true">SpeAdminAuthFilter is applied to all endpoints</criterion>
    <criterion testable="true">Unit tests pass for all CRUD operations</criterion>
  </acceptance-criteria>
</task>
