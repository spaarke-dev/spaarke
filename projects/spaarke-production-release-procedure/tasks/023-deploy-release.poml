<task id="PRPR-023" project="Production Release Procedure">
  <metadata>
    <title>Create Deploy-Release.ps1</title>
    <status>not-started</status>
    <estimated-effort>4 hours</estimated-effort>
    <assigned>Claude Code</assigned>
    <tags>powershell, deploy, automation</tags>
    <phase>3</phase>
    <dependencies>
      <dependency task="PRPR-020" />
      <dependency task="PRPR-021" />
      <dependency task="PRPR-022" />
    </dependencies>
  </metadata>

  <prompt>
    Create `scripts/Deploy-Release.ps1` — the master release orchestrator that orchestrates the
    full release pipeline for one or more environments: pre-flight → build → BFF API → solutions →
    web resources → validate → tag.

    Calls Build-AllClientComponents.ps1, Deploy-BffApi.ps1, Deploy-DataverseSolutions.ps1,
    Deploy-AllWebResources.ps1, and Validate-DeployedEnvironment.ps1. Reads config/environments.json
    for environment details. Supports multi-environment sequential deployment.
  </prompt>

  <role>
    Senior DevOps engineer familiar with Azure, Dataverse, and release orchestration.
  </role>

  <goal>
    A working `scripts/Deploy-Release.ps1` that orchestrates a complete Spaarke release
    across one or more environments with pre-flight checks, gates, and release tagging.
  </goal>

  <constraints>
    <constraint source="spec-FR-04">Must support -EnvironmentUrl (string or array), -WhatIf, -SkipPhase, -SkipBuild, -Version</constraint>
    <constraint source="spec-FR-04">Sequential per-environment deployment with stop-on-failure option</constraint>
    <constraint source="spec-FR-07">MUST call existing deploy scripts — do NOT reimplement their logic</constraint>
    <constraint source="spec-FR-09">Create git tag in v{major}.{minor}.{patch} format after successful deployment</constraint>
    <constraint source="project">BFF URL must be host-only — validate in pre-flight from environments.json</constraint>
    <constraint source="project">Read environment details from config/environments.json</constraint>
  </constraints>

  <knowledge>
    <topic>release orchestration, deployment pipeline, Azure, Dataverse</topic>
    <files>
      <file>projects/spaarke-production-release-procedure/spec.md</file>
      <file>projects/spaarke-production-release-procedure/CLAUDE.md</file>
      <file>docs/procedures/production-release.md</file>
      <file>config/environments.json</file>
      <file>scripts/Build-AllClientComponents.ps1</file>
      <file>scripts/Deploy-BffApi.ps1</file>
      <file>scripts/Deploy-DataverseSolutions.ps1</file>
      <file>scripts/Deploy-AllWebResources.ps1</file>
      <file>scripts/Validate-DeployedEnvironment.ps1</file>
      <file>scripts/Provision-Customer.ps1</file>
      <file>scripts/README.md</file>
      <file>.claude/patterns/auth/bff-url-normalization.md</file>
    </files>
  </knowledge>

  <context>
    <background>
      This is the master orchestrator — the single script an operator runs to deploy a release.
      It's the script counterpart to Provision-Customer.ps1: Provision = new environment,
      Deploy-Release = update existing. They share sub-scripts but have different top-level flows.
    </background>
    <dependencies>
      <dependency task="PRPR-020" status="not-started">Environment registry (config/environments.json)</dependency>
      <dependency task="PRPR-021" status="not-started">Build orchestrator (Build-AllClientComponents.ps1)</dependency>
      <dependency task="PRPR-022" status="not-started">Web resource orchestrator (Deploy-AllWebResources.ps1)</dependency>
    </dependencies>
  </context>

  <steps>
    <step order="1" name="Study Provision-Customer.ps1">Understand the existing orchestration pattern to follow</step>
    <step order="2" name="Study sub-scripts">Read Deploy-BffApi.ps1, Deploy-DataverseSolutions.ps1 parameter signatures</step>
    <step order="3" name="Write script skeleton">Parameters, CmdletBinding, environment resolution from registry</step>
    <step order="4" name="Implement pre-flight">Git status, CI check, auth validation, BFF URL validation</step>
    <step order="5" name="Implement build phase">Call Build-AllClientComponents.ps1 (skip if -SkipBuild)</step>
    <step order="6" name="Implement environment loop">For each environment: BFF API → Solutions → Web Resources → Validate</step>
    <step order="7" name="Implement BFF API deploy">Call Deploy-BffApi.ps1 with environment-specific params</step>
    <step order="8" name="Implement solution deploy">Call Deploy-DataverseSolutions.ps1</step>
    <step order="9" name="Implement web resource deploy">Call Deploy-AllWebResources.ps1</step>
    <step order="10" name="Implement validation">Call Validate-DeployedEnvironment.ps1</step>
    <step order="11" name="Implement release tagging">Create git tag with -Version or auto-suggest</step>
    <step order="12" name="Add -SkipPhase support">Allow skipping specific phases</step>
    <step order="13" name="Add summary report">Per-environment results with timing</step>
    <step order="14" name="Test -WhatIf">Verify WhatIf shows full plan without executing</step>
  </steps>

  <tools>
    <tool name="git">Version control and tagging</tool>
  </tools>

  <outputs>
    <output type="code">scripts/Deploy-Release.ps1</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">scripts/Deploy-Release.ps1 exists and is valid PowerShell</criterion>
    <criterion testable="true">Reads environment details from config/environments.json</criterion>
    <criterion testable="true">Pre-flight checks: git status, BFF URL validation</criterion>
    <criterion testable="true">Calls Build-AllClientComponents.ps1, Deploy-BffApi.ps1, Deploy-DataverseSolutions.ps1, Deploy-AllWebResources.ps1, Validate-DeployedEnvironment.ps1</criterion>
    <criterion testable="true">-EnvironmentUrl accepts single string or array</criterion>
    <criterion testable="true">-WhatIf previews without deploying</criterion>
    <criterion testable="true">-SkipPhase skips specific phases</criterion>
    <criterion testable="true">-SkipBuild skips build phase</criterion>
    <criterion testable="true">Creates git tag in v{major}.{minor}.{patch} format</criterion>
    <criterion testable="true">Sequential per-environment deployment</criterion>
    <criterion testable="true">Summary report per environment</criterion>
  </acceptance-criteria>
</task>
