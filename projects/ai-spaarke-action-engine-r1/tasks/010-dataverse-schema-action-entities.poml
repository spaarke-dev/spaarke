      <file>.claude/skills/dataverse-deploy/SKILL.md</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-002">Thin Dataverse plugins. MUST NOT register plugins on these entities. Triggers via webhooks deferred to R2.</constraint>
    <constraint source="ADR-017">`sprk_actionrun.status` field MUST use the canonical state sequence `Queued | Running | Completed | Failed | Poisoned | Cancelled`. No invented states.</constraint>
    <constraint source="ADR-018">`sprk_action.governance` JSON block MUST include feature-flag + kill-switch references.</constraint>
    <constraint source="ADR-019">If any custom API is registered against these entities (deferred to later phase), error responses use ProblemDetails RFC 7807.</constraint>
    <constraint source="project">Publisher prefix `sprk_`. All entities tenant-scoped via `tenantId` text field (NFR-05).</constraint>
    <constraint source="project">`sprk_action.playbookId` is a lookup → existing `sprk_aiplaybook`; cascade delete behavior: Referential Restrict (block deletion of referenced Playbook).</constraint>
    <constraint source="project">All four entities packaged into the same solution for atomic deploy.</constraint>
  </constraints>

