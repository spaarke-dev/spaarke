<task id="032" project="ai-spaarke-action-engine-r1">
  <metadata>
    <title>`InteractiveInChatGateResolver` — inline chat card; user approves in conversation</title>
    <phase>Phase 3: IGateResolver + Approval Surface</phase>
    <status>not-started</status>
    <estimated-hours>5</estimated-hours>
    <dependencies>030</dependencies>
