<task id="045" project="ai-spaarke-action-engine-r1">
  <metadata>
    <title>Feature flag + kill-switch wiring on Action governance block (ADR-018) + admin disable endpoint</title>
    <phase>Phase 4: Action Execution Runtime</phase>
    <status>not-started</status>
    <estimated-hours>4</estimated-hours>
    <dependencies>040</dependencies>
    <blocks>060, 061, 062, 063</blocks>
