  </context>

  <constraints>
    <constraint source="ADR-002">Thin Dataverse plugins. MUST NOT register plugins on `sprk_toolregistry`.</constraint>
    <constraint source="ADR-019">If any custom API is registered against this entity (deferred to later phase), error responses use ProblemDetails RFC 7807.</constraint>
    <constraint source="project">Field set is exactly the 13-field LAVERN extended metadata per spec FR-07 + design §5. No extra fields without spec amendment.</constraint>
    <constraint source="project">All Choice columns use the exact label set from spec.md FR-07. Classification = { Deterministic, AI, Hybrid }; CostClass = { Free, Cheap, Expensive }; LatencyClass = { Sub100ms, Sub1s, Sub10s, LongRunning }; AuthMode = { Obo, AppOnly, None }; ModelTier = { Premium, Standard, Fast, Embedding, NotApplicable }; Idempotency = { Idempotent, NonIdempotent, IdempotentByKey }.</constraint>
    <constraint source="project">JSON fields stored as Text(Memo) with `Format = TextArea`. BFF deserializes via System.Text.Json.</constraint>
    <constraint source="project">Tenant-scoped via required `tenantId` text field (NFR-05).</constraint>
    <constraint source="project">Packed into the same solution as task 010 entities for atomic deploy.</constraint>
  </constraints>

