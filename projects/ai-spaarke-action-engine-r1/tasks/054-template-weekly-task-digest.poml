    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-013">AI placement: Template lives in Dataverse + `infra/insights/schemas/`. No CRUD-side caller injects orchestration internals.</constraint>
    <constraint source="ADR-015">Audit on every Tool dispatch this Template makes (Tier 2 hash + Tier 3 work history). Gate decisions (approve/reject/timeout) audited. Recipient is hashed in audit, not plaintext.</constraint>
    <constraint source="ADR-018">Feature flag `feature.actionEngine.template.weeklyTaskDigest` referenced in governance block.</constraint>
    <constraint source="ADR-029">Publish size impact: zero — JSON + Dataverse seed only.</constraint>
    <constraint source="ADR-004">Job Contract idempotency: `IdempotencyKey` = `"weekly-task-digest:{instanceId}:{cronFireTimeUtc}"`. Re-delivery of the cron-fire message MUST NOT create a duplicate run.</constraint>
    <constraint source="project">`SendEmail` Tool has `humanGate.required = true` by default. Instance-level override permitted but logged (spec.md FR-20 acceptance).</constraint>
    <constraint source="project">Validate via `jps-validate` before deployment.</constraint>
    <constraint source="project">Cron expression rendered from `dayOfWeek` + `timeOfDay` parameters; Template carries the cron template, Instance carries the parameter values.</constraint>
    <constraint source="project">Default `IGateResolver` for this Template: `InteractiveInChatGateResolver` if the Instance was authored from a chat surface; `DataverseQueueGateResolver` if from a scheduled background path. The Template declares both as acceptable; the runtime selects based on invocation surface.</constraint>
  </constraints>

