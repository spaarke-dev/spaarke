<task id="071" project="ai-spaarke-action-engine-r1">
  <metadata>
    <title>Deploy Action Engine Dataverse solution + seed default playbook + 3 starter Templates via `dataverse-deploy` + `Deploy-Playbook.ps1` + `Seed-JpsActions.ps1`</title>
    <phase>Phase 6: Quality Gates + Deployment</phase>
    <status>not-started</status>
