      <file>projects/ai-spaarke-action-engine-r1/notes/deployments/dataverse-deploy-{date}.md</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-002">Thin Dataverse plugins. Action triggers via webhooks (R2 scope), NOT plugins. No new plugin code in this deploy.</constraint>
    <constraint source="dataverse-deploy skill">Use unmanaged solution (ADR-022); use publisher `Spaarke` with prefix `sprk_`; rebuild fresh; never reuse old ZIPs; pack with `pack.ps1`.</constraint>
    <constraint source="project">Seed scripts MUST be idempotent â€” re-running them does NOT create duplicate playbook/Template rows. Use upsert by name.</constraint>
    <constraint source="project">Tool Registry semantic index population is part of this task â€” after Tool rows seed, populate `spaarke-resource-registry-index`.</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/constraints/plugins.md</file>
