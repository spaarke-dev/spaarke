<task id="031" project="ai-spaarke-action-engine-r1">
  <metadata>
    <title>`DataverseQueueGateResolver` — writes to `sprk_gate_approval`; resumes on approval-record update</title>
    <phase>Phase 3: IGateResolver + Approval Surface</phase>
    <status>not-started</status>
    <estimated-hours>5</estimated-hours>
