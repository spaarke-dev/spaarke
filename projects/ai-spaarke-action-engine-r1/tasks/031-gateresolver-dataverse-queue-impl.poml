  <constraints>
    <constraint source="ADR-001">.NET 8 Minimal API + BackgroundService.</constraint>
    <constraint source="ADR-002">Thin Dataverse plugins. Plugin (if used for the webhook bridge) stays &lt;200 LoC + &lt;50ms p95. This task does NOT add plugin code; resume is wired in Phase 4.</constraint>
    <constraint source="ADR-004">Idempotent gate creation: duplicate `(ActionRunId, ToolDispatchId)` MUST NOT create duplicate approval records. Use `IIdempotencyService`.</constraint>
    <constraint source="ADR-008">Endpoint-filter authorization. Resume endpoint (added Phase 4) MUST use `.AddEndpointFilter&lt;&gt;()`.</constraint>
    <constraint source="ADR-010">Feature-module DI. Keyed-DI registration in `AddGatesFeature()`.</constraint>
    <constraint source="ADR-013">AI Architecture (refined 2026-05-20). BFF placement.</constraint>
    <constraint source="ADR-015">Audit per gate decision: Tier 2 hash + Tier 3 work history. Both initial Pending write AND terminal resume MUST audit.</constraint>
    <constraint source="ADR-019">ProblemDetails for any HTTP errors surfaced by resume endpoint (Phase 4).</constraint>
    <constraint source="ADR-029">Publish-size delta ≤ 5 MB compressed. This task adds ≤300 LoC + Dataverse SDK calls (already loaded); expected delta &lt; 0.1 MB.</constraint>
    <constraint source="bff-extensions.md">Pre-merge checklist: placement = BFF; no new NuGet packages; publish-size impact verified; ADRs cited.</constraint>
    <constraint source="project">Default `GateType` routing: `MeaningCritical`, `EthicsCritical`, `FinalDelivery` → `DataverseQueueGateResolver`. Action Definitions can override per design §5.</constraint>
  </constraints>

