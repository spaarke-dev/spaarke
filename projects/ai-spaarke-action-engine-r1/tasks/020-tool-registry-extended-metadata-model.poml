<task id="020" project="ai-spaarke-action-engine-r1">
  <metadata>
    <title>Tool Registry — Extended Metadata Model &amp; Serialization</title>
    <phase>Phase 2: Tool Registry + Discovery</phase>
    <status>not-started</status>
    <estimated-hours>5</estimated-hours>
    <dependencies>011, 014, 015</dependencies>
