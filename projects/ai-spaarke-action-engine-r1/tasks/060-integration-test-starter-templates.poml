<task id="060" project="ai-spaarke-action-engine-r1">
  <metadata>
    <title>Integration test `ActionEngine.IntegrationTests.StarterTemplates` — three Templates author + execute end-to-end (G1)</title>
    <phase>Phase 6: Quality Gates + Deployment</phase>
    <status>not-started</status>
    <estimated-hours>4</estimated-hours>
    <dependencies>053, 054, 055</dependencies>
    <blocks>070, 071, 090</blocks>
