<task id="043" project="ai-spaarke-action-engine-r1">
  <metadata>
    <title>AuditEnrichmentMiddleware extension — Tool dispatch context (ADR-015 Tier 2 hash + Tier 3 Cosmos work history)</title>
    <phase>Phase 4: Action Execution Runtime</phase>
    <status>not-started</status>
    <estimated-hours>4</estimated-hours>
    <dependencies>026, 041</dependencies>
    <blocks>060, 061, 062, 063</blocks>
