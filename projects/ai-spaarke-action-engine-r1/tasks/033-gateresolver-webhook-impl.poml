<task id="033" project="ai-spaarke-action-engine-r1">
  <metadata>
    <title>`WebhookGateResolver` — POST to configured URL with HMAC signing; resumes on callback (ADR-028)</title>
    <phase>Phase 3: IGateResolver + Approval Surface</phase>
    <status>not-started</status>
