    <output type="code">Producer + consumer call sites updated</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Payload type uses `todoId`; no `eventId` in the new path.</criterion>
    <criterion testable="true">Cross-block update propagates within one render cycle.</criterion>
