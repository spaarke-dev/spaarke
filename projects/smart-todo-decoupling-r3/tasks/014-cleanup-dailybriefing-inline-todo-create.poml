      <file>src/solutions/SmartTodo/src/services/DataverseService.ts (reference for sprk_todo create patterns)</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="FR-29">Zero `sprk_todoflag` + `sprk_eventtodo` references in `src/solutions/DailyBriefing/` after this task. JSDoc migration notes OK.</constraint>
    <constraint source="OS-1">No compat shim.</constraint>
    <constraint source="ADR-024">Use `PolymorphicResolverService.applyResolverFields` if regarding context is present.</constraint>
    <constraint source="NFR-01">Fluent v9 (if any UI touched).</constraint>
    <constraint source="Product portability">No hardcoded org URLs / tenant IDs.</constraint>
