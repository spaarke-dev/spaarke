<task id="014" project="smart-todo-decoupling-r3">
  <metadata>
    <title>Cleanup `DailyBriefing/useInlineTodoCreate.ts` legacy `sprk_todoflag` write (audit-surfaced by task 013)</title>
    <phase>Phase 2: Shared-Lib Hoist (audit-surfaced follow-up)</phase>
