<task id="020" project="smart-todo-decoupling-r3">
  <metadata>
    <title>Repoint SmartTodo kanban queries from `sprk_event` to `sprk_todo`</title>
    <phase>Phase 3: SmartTodo Code Page Repoint</phase>
    <status>not-started</status>
    <estimated-effort>3-4 hours</estimated-effort>
