<task id="085" project="smart-todo-decoupling-r3">
  <metadata>
    <title>Final repo-wide legacy-reference grep sweep (verify FR-29 zero hits)</title>
    <phase>Phase 9: Cleanup & Documentation</phase>
    <status>not-started</status>
    <estimated-effort>1-2 hours</estimated-effort>
    <dependencies>005, 011, 020, 031, 081, 083</dependencies>
