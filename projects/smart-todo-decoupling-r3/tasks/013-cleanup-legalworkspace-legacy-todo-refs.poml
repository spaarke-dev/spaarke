    </relevant-files>
  </context>

  <constraints>
    <constraint source="FR-29">Zero `sprk_todoflag`, `sprk_eventtodo`, `_sprk_regardingevent_value` (in todo path) references in `src/solutions/LegalWorkspace/` after this task. JSDoc migration notes referencing the LEGACY shape are OK.</constraint>
    <constraint source="OS-1">No compat shim. Local CreateTodo + CreateWorkAssignment routes through the new shared lib wizards (or removes the auto-create feature for WorkAssignment per task 031's decision).</constraint>
    <constraint source="ADR-024">Multi-entity resolution: when creating sprk_todo with a regarding parent, use `PolymorphicResolverService.applyResolverFields` (via the shared CreateTodoWizard which already wires this).</constraint>
    <constraint source="NFR-01">Fluent v9 + semantic tokens + Griffel only.</constraint>
    <constraint source="NFR-10">A11y preserved (no regression in keyboard nav, SR labels).</constraint>
    <constraint source="Product portability">No hardcoded org URLs / tenant IDs.</constraint>
  </constraints>

