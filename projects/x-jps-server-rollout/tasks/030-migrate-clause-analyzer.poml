<?xml version="1.0" encoding="utf-8"?>
<task id="030" project="jps-server-rollout">
  <metadata>
    <title>Consolidate ClauseAnalyzerHandler into GenericAnalysisHandler + JPS</title>
    <phase>4</phase>
    <tags>bff-api, refactor</tags>
    <estimate>2h</estimate>
    <dependencies>014, 022</dependencies>
    <parallel-group>consolidation</parallel-group>
  </metadata>

  <prompt>
    <goal>Remove ClauseAnalyzerHandler and migrate its functionality to GenericAnalysisHandler by creating a JPS JSON definition for the clause analysis action. Update tool configuration to route to GenericAnalysisHandler.</goal>
    <context>
      ClauseAnalyzerHandler (Services/Ai/Tools/ClauseAnalyzerHandler.cs) contains no custom logic beyond prompt building.
      Its sole responsibility is constructing a prompt for analyzing legal clauses.
      This is an ideal candidate for consolidation: extract the prompt template, convert to JPS JSON format, and let GenericAnalysisHandler render it.

      Consolidation steps:
      1. Review ClauseAnalyzerHandler logic and extract the hardcoded prompt
      2. Create JPS JSON file: projects/ai-json-prompt-schema-system/notes/jps-conversions/clause-analyzer.json
      3. Update tool configuration (likely in ToolFrameworkExtensions or tool registry) to route "clause_analyzer" action to GenericAnalysisHandler
      4. Verify no other code depends on ClauseAnalyzerHandler
      5. Remove or deprecate the handler class
    </context>
    <constraints>
      - Follow .claude/patterns/ai/analysis-scopes.md for JPS structure
      - Ensure JPS JSON matches the prompt behavior of the original handler
      - No custom handler logic should be lost; all validation rules must be in JPS constraints
      - Update tool configuration atomically (no broken references during transition)
      - Follow ADR-010 (DI minimalism) — remove handler DI registration if present
    </constraints>
  </prompt>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-010-di-minimalism.md</file>
      <file>.claude/adr/ADR-013-ai-architecture.md</file>
      <file>.claude/constraints/api.md</file>
      <file>.claude/patterns/ai/analysis-scopes.md</file>
      <file>projects/jps-server-rollout/CLAUDE.md</file>
      <file>projects/ai-json-prompt-schema-system/notes/jps-conversions/</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Read ClauseAnalyzerHandler.cs to understand its logic and prompt construction</step>
    <step order="2">Extract the prompt template and any static configuration (e.g., temperature, max tokens)</step>
    <step order="3">Create JPS JSON file (projects/ai-json-prompt-schema-system/notes/jps-conversions/clause-analyzer.json) following the example format from task 014</step>
    <step order="4">Search codebase for references to ClauseAnalyzerHandler:
      - Find DI registration (likely in ToolFrameworkExtensions.cs)
      - Find tool configuration/routing entries
      - Verify no other handlers depend on it
    </step>
    <step order="5">Update tool configuration to route "clause_analyzer" action to GenericAnalysisHandler with the new JPS reference</step>
    <step order="6">Remove ClauseAnalyzerHandler class or mark as [Obsolete] with migration guidance</step>
    <step order="7">Remove DI registration if present</step>
    <step order="8">Build the project: `dotnet build src/server/api/Sprk.Bff.Api/`</step>
    <step order="9">Run all tests to verify no broken references: `dotnet test src/server/api/Sprk.Bff.Api.Tests/`</step>
  </steps>

  <tools>
    <tool>Read</tool>
    <tool>Edit</tool>
    <tool>Bash(dotnet build)</tool>
    <tool>Bash(dotnet test)</tool>
    <tool>Grep</tool>
  </tools>

  <outputs>
    <output>projects/ai-json-prompt-schema-system/notes/jps-conversions/clause-analyzer.json</output>
    <output>src/server/api/Sprk.Bff.Api/Services/Ai/Tools/ClauseAnalyzerHandler.cs</output>
    <output>src/server/api/Sprk.Bff.Api/Services/Ai/ToolFrameworkExtensions.cs</output>
  </outputs>

  <acceptance-criteria>
    <criterion>ClauseAnalyzerHandler logic extracted to JPS JSON</criterion>
    <criterion>JPS JSON created and follows analysis-scopes pattern</criterion>
    <criterion>Tool configuration updated to route to GenericAnalysisHandler</criterion>
    <criterion>ClauseAnalyzerHandler removed or deprecated</criterion>
    <criterion>DI registration removed</criterion>
    <criterion>No other code references ClauseAnalyzerHandler</criterion>
    <criterion>Project builds successfully</criterion>
    <criterion>All tests pass</criterion>
  </acceptance-criteria>
</task>
