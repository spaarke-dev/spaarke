      <file>.claude/patterns/webresource/full-page-custom-page.md</file>
      <file>docs/guides/SHARED-UI-COMPONENTS-GUIDE.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Determine ActionCard import path from task 012">
      Read `projects/spaarke-ai-platform-unification-r3/current-task.md` AND task 012 completion
      notes. If task 012 lifted ActionCard to `@spaarke/ui-components`, import from there.
      Otherwise import from the LegalWorkspace path (`src/solutions/LegalWorkspace/src/components/GetStarted/ActionCard.tsx`).
      Document the decision in the file header comment.
    </step>
    <step order="2" name="Scaffold the widget file">
      Create `src/client/shared/Spaarke.AI.Widgets/src/widgets/context/GetStartedCardsWidget.tsx`.
      Export `GetStartedCardsWidget` as a default + named export. Define a prop type
      `{ onCardClick?: (widgetType: string) => void }` (defaults to no-op).
    </step>
    <step order="3" name="Define the 7-card configuration">
      Create a constant array of 7 card definitions: `{ widgetType: string, label: string, icon: ReactNode, description?: string }`. Use the FR-19 mapping:
      Create Matter → `create-matter-wizard`,
      Create Project → `create-project-wizard`,
      Assign Work → `assign-work` (special-cased — invokes Xrm.Navigation in task 045),
      Summarize Files → `document-upload-wizard`,
      Find Similar → `find-similar-wizard`,
      Send Email → `email-compose`,
      Schedule Meeting → `meeting-schedule`.
    </step>
    <step order="4" name="Render 2-column scrollable grid via makeStyles">
      Use `makeStyles` to define the container: `display: 'grid'`, `gridTemplateColumns: '1fr 1fr'`,
      `gap: tokens.spacingHorizontalS`, `overflowY: 'auto'`, `padding: tokens.spacingHorizontalM`.
      Render 7 ActionCard instances mapping over the config array. Pass `onClick` to each card
      so it calls `props.onCardClick?.(card.widgetType)`.
    </step>
    <step order="5" name="Implement keyboard navigation">
      Wire `onKeyDown` at the grid container level: arrow keys move focus across cards (visual
      focus + DOM focus follow tab index); Enter / Space activates the focused card's onClick.
      Each card should have `tabIndex={0}` and proper ARIA role="button" (likely already inherited
      from ActionCard — verify and don't double-up).
    </step>
    <step order="6" name="Add ARIA labels + role for accessibility">
      Container has `role="grid"` + `aria-label="Get Started actions"`. Each card has clear,
      action-oriented `aria-label` like "Create Matter — start a new matter workspace". Verify
      screen reader hears the labels (manual smoke).
    </step>
    <step order="7" name="Dark-mode parity check + build">
      Run `npm run build` against the Spaarke.AI.Widgets package. In Vite dev (or after deploying
      to test env), confirm cards look correct in both light and dark mode. Match LegalWorkspace
      card styling exactly (compare side-by-side at the GetStarted section of standalone
      LegalWorkspace).
    </step>
  </steps>

  <tools>
    <tool name="Read">Read task 012 notes, ActionCard source, LegalWorkspace GetStarted section for visual reference</tool>
    <tool name="Write">Create new GetStartedCardsWidget.tsx</tool>
    <tool name="Grep">Find ActionCard exports + Fluent v9 icon imports used in LegalWorkspace</tool>
    <tool name="Bash">Run `npm run build` against Spaarke.AI.Widgets</tool>
  </tools>

  <outputs>
    <output type="code">src/client/shared/Spaarke.AI.Widgets/src/widgets/context/GetStartedCardsWidget.tsx</output>
    <output type="report">Task completion report confirming widget renders 7 cards with FR-18 layout + accessibility</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">`GetStartedCardsWidget.tsx` exists at the specified path and exports the component.</criterion>
    <criterion testable="true">Component imports `ActionCard` from the path determined by task 012 — NOT a copy-pasted local implementation.</criterion>
    <criterion testable="true">Renders exactly 7 cards in CSS grid with `gridTemplateColumns: '1fr 1fr'` and `gap: tokens.spacingHorizontalS`.</criterion>
    <criterion testable="true">Container is vertically scrollable (`overflowY: 'auto'`).</criterion>
    <criterion testable="true">Each card has a Fluent v9 `@fluentui/react-icons` icon + label matching the FR-19 mapping.</criterion>
    <criterion testable="true">Each card has `onClick` wired to `props.onCardClick?.(widgetType)`.</criterion>
    <criterion testable="true">Keyboard navigation works: arrow keys move focus, Enter activates.</criterion>
    <criterion testable="true">Container has `role="grid"` + `aria-label="Get Started actions"`; each card has descriptive `aria-label`.</criterion>
    <criterion testable="true">No hex literals, no `rgba(...)` literals; all styling via `tokens.*`.</criterion>
    <criterion testable="true">Visual parity with LegalWorkspace GetStarted ActionCards in both light and dark modes.</criterion>
    <criterion testable="true">`npm run build` succeeds with no new TS / lint errors.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="7 cards render in 2-column grid">
      Mount GetStartedCardsWidget in a test harness or in the Context pane (after task 042 swaps it in).
      Confirm 7 cards are visible, arranged in 2 columns. Verify labels: Create Matter, Create Project,
      Assign Work, Summarize Files, Find Similar, Send Email, Schedule Meeting.
    </test>
    <test name="Vertical scroll on narrow viewport">
      Resize the Context pane to narrow width. Confirm the grid scrolls vertically when cards exceed
      visible area; horizontal layout (2 columns) is preserved.
    </test>
    <test name="Keyboard navigation">
      Tab into the widget. Use arrow keys to move focus across cards. Press Enter on a focused card
      — confirm onClick callback fires with the correct widgetType (verify via console.log in dev
      harness).
    </test>
    <test name="Dark Mode Compliance (ADR-021, NFR-06)">
      Toggle dark mode. Confirm:
      <steps>
        <step>Card backgrounds adapt via Fluent v9 neutral-background tokens (no white in dark mode)</step>
        <step>Card text adapts via neutral-foreground tokens (no black in dark mode)</step>
        <step>Card icons use brand foreground 1 (visible in both themes)</step>
        <step>Card hover / focus rings use Fluent v9 stroke / focus-stroke tokens</step>
      </steps>
    </test>
    <test name="ARIA + screen-reader smoke">
      Activate a screen reader. Tab to the widget. Confirm container is announced as "Get Started actions, grid"
      and each card is announced with its full aria-label.
    </test>
    <test name="No console errors">
      Open browser devtools. Confirm zero JavaScript errors or React warnings on mount and interaction.
    </test>
  </ui-tests>

