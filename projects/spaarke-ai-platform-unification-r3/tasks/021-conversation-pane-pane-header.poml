      <file>.claude/patterns/webresource/full-page-custom-page.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Read ConversationPane.tsx">
      Open `src/solutions/SpaarkeAi/src/components/conversation/ConversationPane.tsx`. Locate
      (a) the `Chat | History` tab button JSX, (b) the local React state controlling active tab,
      (c) handlers that switch tabs, (d) the existing import block. Make a mental map of what
      to delete vs. retain.
    </step>
    <step order="2" name="Add PaneHeader + ChatRegular imports">
      Import `PaneHeader` from `@spaarke/ui-components` (the export added by task 010) and
      `ChatRegular` from `@fluentui/react-icons`. Use the package path, not a relative import.
    </step>
    <step order="3" name="Remove tab buttons + related state">
      Delete the `Chat | History` tab button JSX block. Delete the React state and handlers
      that tracked the active tab. Remove now-orphaned imports.
    </step>
    <step order="4" name="Insert PaneHeader at the top of the pane">
      At the top of the pane content, render `<PaneHeader title="Assistant" icon={&lt;ChatRegular /&gt;} rightSlot={/* placeholder for task 022 */} /&gt;`. Use a TODO comment to mark the placeholder so task 022 can swap it in without re-discovery.
    </step>
    <step order="5" name="Verify icon color via tokens">
      The PaneHeader internal styling (built in task 010) must already apply
      `tokens.colorBrandForeground1` to the icon. Confirm visually — no inline color overrides
      added in this file.
    </step>
    <step order="6" name="Light + dark mode visual diff">
      In Vite dev or Power Apps host, compare the new ConversationPane header against
      ContextPaneController's existing header in both light and dark modes. Spacing,
      typography, and icon alignment must match. Capture screenshots if available; commit
      a short visual-diff note in `notes/visual-diffs/021-pane-header.md` if any subtle
      discrepancies surface.
    </step>
  </steps>

  <tools>
    <tool name="Read">Read ConversationPane.tsx + ContextPaneController.tsx for visual reference</tool>
    <tool name="Edit">Remove tab JSX + state, add PaneHeader + import</tool>
    <tool name="Grep">Find any external consumers of removed tab-state exports (should be none)</tool>
    <tool name="Bash">Run `npm run build` against SpaarkeAi to verify no TS / lint errors</tool>
  </tools>

  <outputs>
    <output type="code">src/solutions/SpaarkeAi/src/components/conversation/ConversationPane.tsx</output>
    <output type="report">Task completion report confirming Chat/History tabs removed and PaneHeader integrated; rightSlot placeholder noted for task 022</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">`ConversationPane.tsx` imports `PaneHeader` from `@spaarke/ui-components` and `ChatRegular` from `@fluentui/react-icons`.</criterion>
    <criterion testable="true">`ConversationPane.tsx` does not contain any "Chat" / "History" tab button JSX or related local state hooks.</criterion>
    <criterion testable="true">`&lt;PaneHeader title="Assistant" icon={...}&gt;` is rendered at the top of the pane content.</criterion>
    <criterion testable="true">A `rightSlot` placeholder (TODO comment) exists for task 022 to wire the History button.</criterion>
    <criterion testable="true">Visual diff vs ContextPaneController's existing header shows matching typography, spacing, and brand-colored icon in both light and dark modes.</criterion>
    <criterion testable="true">`npm run build` succeeds with no new TS / lint errors.</criterion>
    <criterion testable="true">No `accessToken` props introduced (ADR-028 invariants preserved).</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="PaneHeader parity — light mode">
      In SpaarkeAi welcome state, verify the Assistant pane shows `<PaneHeader>` with
      ChatRegular icon in brand color, title "Assistant", and a placeholder rightSlot
      (empty until task 022). Compare against the Context pane header for typography
      and spacing parity.
    </test>
    <test name="PaneHeader parity — dark mode (NFR-06, ADR-021)">
      Toggle to dark mode. Confirm icon color shifts via Fluent v9 tokens (no hex leaks),
      title remains legible, header background uses correct neutral-background tokens.
    </test>
    <test name="No tab control regression">
      Confirm no Chat / History tab buttons render; no clickable tab-like affordances
      remain in the header band.
    </test>
  </ui-tests>

