      <file>.claude/patterns/auth/bff-url-normalization.md</file>
      <file>.claude/patterns/webresource/full-page-custom-page.md</file>
      <file>docs/guides/WORKSPACE-AI-PREFILL-GUIDE.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Read existing WorkspacePane.tsx">
      Open `src/solutions/SpaarkeAi/src/components/workspace/WorkspacePane.tsx` and capture the current
      structure (props, tab system, layout container, any existing welcome state). Note imports and
      anything that calls BFF directly so the migration is comprehensive.
    </step>
    <step order="2" name="Import PaneHeader + AppsListRegular">
      Add `import { PaneHeader } from '@spaarke/ui-components';` and
      `import { AppsListRegular } from '@fluentui/react-icons';`. Confirm both are resolvable from the
      shared library and the Fluent v9 icon package already in the project's dependency graph.
    </step>
    <step order="3" name="Render PaneHeader at the top">
      Add `&lt;PaneHeader title="Workspace" icon={&lt;AppsListRegular /&gt;} /&gt;` (or with a `rightSlot`
      placeholder for task 032 to wire) as the first child of the pane root. Apply `makeStyles` tokens
      for surrounding spacing — no hex.
    </step>
    <step order="4" name="Import WorkspaceShell from LegalWorkspace">
      Add `import { WorkspaceShell } from '...legal-workspace-shell-entry...';` — verify the correct
      import path by reading `src/solutions/LegalWorkspace/src/components/Shell/WorkspaceShell.tsx` and
      any barrel exports. The shell is the canonical container that renders sections per layout.
    </step>
    <step order="5" name="Fetch user's default layout via authenticatedFetch">
      Add a React `useEffect` (or use an existing hook pattern from `useWorkspaceLayouts.ts`) that
      calls `authenticatedFetch` from `@spaarke/auth` against `GET /api/workspace/layouts/default`.
      Build the URL via `buildBffApiUrl()` per `bff-url-normalization.md`. Store the result in state;
      no `accessToken` snapshotting. Handle the loading state gracefully (spinner or skeleton).
    </step>
    <step order="6" name="Render WorkspaceShell inside Home tab area">
      Inside the Home tab content slot, render `&lt;WorkspaceShell layout={defaultLayout} /&gt;` (the
      exact prop shape may differ — match the API of `WorkspaceShell` exactly). Confirm sections
      render inside the pane at the correct widths.
    </step>
    <step order="7" name="Visual parity check vs standalone LegalWorkspace">
      Open the standalone LegalWorkspace code page in a separate browser tab. Compare visually with
      WorkspacePane at narrower widths (the Workspace pane is narrower than the full-page LegalWorkspace).
      Note any section that overflows or wraps incorrectly. If `WorkspaceShell` needs a `compact`-style
      prop, document it but DO NOT modify `WorkspaceShell` in this task (NFR-10 backwards compat) — open
      a follow-up if needed.
    </step>
    <step order="8" name="Update TASK-INDEX and commit">
      Update `projects/spaarke-ai-platform-unification-r3/tasks/TASK-INDEX.md`: this task's status
      to ✅ completed. Commit changes per project conventions.
    </step>
  </steps>

  <tools>
    <tool name="Read">Read existing WorkspacePane.tsx, WorkspaceShell.tsx, useWorkspaceLayouts.ts</tool>
    <tool name="Edit">Modify WorkspacePane.tsx</tool>
    <tool name="Grep">Confirm zero `accessToken` snapshots and zero hex/rgba literals in modified code</tool>
    <tool name="Bash">npm build verification</tool>
  </tools>

  <outputs>
    <output type="code">src/solutions/SpaarkeAi/src/components/workspace/WorkspacePane.tsx (modified)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Cold load of SpaarkeAi shows the Workspace pane with `&lt;PaneHeader&gt;` at top, brand-colored `AppsListRegular` icon, title "Workspace".</criterion>
    <criterion testable="true">The Home tab area renders `WorkspaceShell` populated with the user's default layout (fetched from `GET /api/workspace/layouts/default`).</criterion>
    <criterion testable="true">All BFF calls in this file go through `authenticatedFetch`; grep for `accessToken` in `WorkspacePane.tsx` returns zero matches.</criterion>
    <criterion testable="true">Visual parity check at narrower widths — sections render in the Workspace pane in a layout that matches the standalone LegalWorkspace's behavior under similar widths.</criterion>
    <criterion testable="true">Standalone LegalWorkspace code page (opened in a separate tab) continues to function identically — no regressions (FR-25, NFR-10).</criterion>
    <criterion testable="true">Source contains zero hex literals and zero `rgba(...)` literals; all colors via `tokens.*`.</criterion>
    <criterion testable="true">`npm run build` succeeds in the SpaarkeAi workspace with no new TypeScript errors and no new lint warnings.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="WorkspacePane Renders PaneHeader + LegalWorkspace Home Tab">
      <url>https://{org}.crm.dynamics.com/main.aspx?appid={app-id}&amp;pagetype=custom&amp;name=spaarke_spaarkeai</url>
      <steps>
        <step>Navigate to the SpaarkeAi code page in Power Apps host</step>
        <step>Verify Workspace pane renders the shared `&lt;PaneHeader&gt;` at top</step>
        <step>Verify the `AppsListRegular` icon is visible in `tokens.colorBrandForeground1`</step>
        <step>Verify pane title reads "Workspace"</step>
        <step>Verify the Home tab area shows LegalWorkspace sections (i.e. the default layout's sections)</step>
        <step>Open the standalone LegalWorkspace code page in a new tab; compare section layout at narrower widths</step>
        <step>Check browser DevTools console for JavaScript errors</step>
      </steps>
      <expected>WorkspacePane shows the PaneHeader + an embedded LegalWorkspace Home tab. No console errors. Visual layout matches the standalone LegalWorkspace at narrower widths.</expected>
    </test>

    <test name="Dark Mode Compliance (ADR-021)">
      <steps>
        <step>Toggle dark mode in D365 settings (or the test harness theme toggle)</step>
        <step>Verify PaneHeader background, title text, and icon all adapt to dark theme</step>
        <step>Verify LegalWorkspace Home tab sections also adapt to dark mode</step>
        <step>Confirm no hardcoded white/black colors visible in dark mode</step>
      </steps>
      <expected>All colors use Fluent UI v9 semantic tokens per ADR-021. Dark mode renders correctly with no hex-literal regressions.</expected>
    </test>

    <test name="Default Layout Fetch via authenticatedFetch (ADR-028)">
      <steps>
        <step>Open browser DevTools → Network tab</step>
        <step>Cold-load the SpaarkeAi page</step>
        <step>Locate the `GET /api/workspace/layouts/default` request</step>
        <step>Verify it has an `Authorization: Bearer ...` header (token fetched per-request)</step>
        <step>Verify no `accessToken` is stored in React component props or state (use React DevTools)</step>
      </steps>
      <expected>Default-layout request authenticated via per-request token; no token snapshots in component state per ADR-028 INV-1..INV-8.</expected>
    </test>
  </ui-tests>

  <execution>
    This task MUST be executed via the `task-execute` skill from `.claude/skills/task-execute/SKILL.md`.
