<task id="030" project="spaarke-ai-platform-unification-r3">
  <metadata>
    <title>Migrate WorkspacePane to shared PaneHeader and embed LegalWorkspace as Home tab</title>
    <phase>Phase C — Workspace Pane</phase>
    <status>completed</status>
    <estimated-hours>4</estimated-hours>
