  <steps>
    <step order="1" name="Read spike memo">
      Open `projects/spaarke-ai-platform-unification-r3/notes/spikes/001-fr07-attachments-payload.md`.
      Determine: YES (endpoint already accepts `attachments[]` — proceed end-to-end here) or
      NO (backend extension needed — stage frontend only and surface block). Confirm the
      exact field name + casing the backend expects.
    </step>
    <step order="2" name="Locate the send-message call site">
      In `SprkChat.tsx`, find where `useChatSession.sendMessage` (or equivalent) is called.
      Identify the payload object being constructed.
    </step>
    <step order="3" name="Add attachments to payload">
      Extend the payload constructor to include `attachments: ChatAttachment[]` when
      `attachments.length &gt; 0`. Field name + casing must match what the spike memo
      identified. Omit the field entirely when no attachments (avoid sending `[]` if the
      backend treats absent as "no attachments").
    </step>
    <step order="4" name="Branch on spike outcome">
      IF spike = YES: leave the wiring active; proceed to end-to-end test in step 5.
      IF spike = NO: wrap the new field in a feature flag (`ATTACHMENTS_PAYLOAD_ENABLED`)
      defaulted to `false`; mark the task BLOCKED on Phase E in the completion report; do
      not enable the flag until task 050 ships. Either way, the frontend code is committed.
    </step>
    <step order="5" name="Clear state on successful send">
      After `sendMessage` resolves successfully, call `clearAll()` on the hook to reset
      chips + attachments. On error, do NOT clear — leave the chips intact so the user can
      retry. Confirm the existing error telemetry path (from task 022's helper) still fires
      correctly when send fails.
    </step>
    <step order="6" name="End-to-end test (if spike = YES)">
      In Vite dev with a running BFF: cold load → attach 2 .txt files referencing distinct
      content (e.g., "the sky is blue" and "fish are gold") → send "Summarize the attached
      files". Confirm the AI reply mentions both pieces of content. Repeat with 5 files +
      mixed MIME types (txt, md, pdf, docx).
    </step>
    <step order="7" name="Frontend-only test (if spike = NO)">
      In Vite dev with feature flag forced ON (locally), capture the outgoing request in
      DevTools network tab. Confirm the payload includes `attachments[]` with the agreed
      schema. Backend will reject — that's expected and documented; the task is staged for
      Phase E.
    </step>
  </steps>

  <tools>
    <tool name="Read">Read spike memo + SprkChat.tsx send call site</tool>
    <tool name="Edit">Extend payload constructor + add clearAll call</tool>
    <tool name="Grep">Find the chat-message DTO type if needed for field-name confirmation</tool>
    <tool name="Bash">Run `npm test` + smoke in Vite dev against running BFF</tool>
  </tools>

  <outputs>
    <output type="code">src/client/shared/Spaarke.UI.Components/src/components/SprkChat/SprkChat.tsx</output>
    <output type="report">Task completion report stating (a) spike branch (YES / NO), (b) wiring lands active or staged behind flag, (c) end-to-end test result or staged-status note</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">`SprkChat.tsx` send handler includes an `attachments` field in the outbound payload when chips are present, using the exact field name + casing identified by spike 001.</criterion>
    <criterion testable="true">After successful send, `clearAll()` resets the hook state; chips disappear from the UI.</criterion>
    <criterion testable="true">After failed send, attachments state is NOT cleared; chips remain visible so user can retry.</criterion>
    <criterion testable="true">IF spike = YES: end-to-end test with 5 mixed-MIME files passes — AI reply references content from all 5 files.</criterion>
    <criterion testable="true">IF spike = NO: payload is constructed correctly per the agreed schema (verified in DevTools); feature flag default is OFF; task marked BLOCKED on Phase E.</criterion>
    <criterion testable="true">Single-LLM-call invariant preserved: exactly ONE backend call per send (verified in network tab).</criterion>
    <criterion testable="true">No `accessToken` props introduced; auth contract unchanged.</criterion>
    <criterion testable="true">`npm run build` succeeds; existing tests pass.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="end-to-end FR-07 acceptance (if spike = YES)">
      Cold load SpaarkeAi. Attach 5 .txt files with distinct content. Send "What's in each
      file?". Verify (a) one outbound POST to `/api/ai/chat/sessions/{sessionId}/messages`
      with `attachments` array of 5 items, (b) AI reply references content from all 5
      files, (c) chips clear after send completes, (d) no second LLM call triggered.
    </test>
    <test name="payload-staged verification (if spike = NO)">
      Force feature flag ON locally. Attach 2 .txt files. Send. Capture outbound request
      in DevTools. Verify payload schema matches the agreed Phase E DTO. Backend rejection
      is expected — document and move on.
    </test>
    <test name="error preserves attachments">
      Force a 500 response (via DevTools override). Send a message with 2 attachments.
      Verify (a) chips remain visible, (b) error telemetry fires, (c) user can retry.
    </test>
    <test name="single LLM call invariant (D-01)">
      Attach 3 files + send. Verify exactly ONE backend call to the chat-messages endpoint
      (no separate extraction call, no parallel preprocessing call).
    </test>
    <test name="dark-mode compliance (NFR-06, ADR-021)">
      Toggle dark mode. Attach files. Send. Verify chip clear animation + send UX use
      Fluent v9 tokens correctly. No hex leaks.
    </test>
  </ui-tests>

