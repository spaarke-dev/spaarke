  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Clicking the menu trigger opens a Fluent v9 dropdown with four sections separated by dividers: Open, Home, Switch Workspace, Edit current workspace.</criterion>
    <criterion testable="true">`×` close affordance is present on every non-Home tab in the Open section; absent / disabled on the Home entry.</criterion>
    <criterion testable="true">Selecting a tab in Open switches the active tab in WorkspacePane content area (via WorkspaceTabManager).</criterion>
    <criterion testable="true">Switch Workspace section lists all layouts from `useWorkspaceLayouts`; selecting one loads it as the new active layout.</criterion>
    <criterion testable="true">"+ New Workspace" launches `WorkspaceLayoutWizard` with the 6-template `templateFilter` prop passed (template list restricted accordingly).</criterion>
    <criterion testable="true">Source contains zero hex literals and zero `rgba(...)` literals; all colors via `tokens.*`.</criterion>
    <criterion testable="true">Menu trigger has an `aria-label`; full keyboard navigation works through all items including `×` controls.</criterion>
    <criterion testable="true">`npm run build` succeeds with zero TypeScript errors and zero new lint warnings.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="WorkspacePaneMenu Shows Four Sections With Dividers">
      <url>https://{org}.crm.dynamics.com/main.aspx?appid={app-id}&amp;pagetype=custom&amp;name=spaarke_spaarkeai</url>
      <steps>
        <step>Navigate to the SpaarkeAi code page</step>
        <step>Open the Workspace pane menu (click trigger in PaneHeader rightSlot)</step>
        <step>Verify four sections visible with dividers: Open, Home, Switch Workspace, Edit current workspace</step>
        <step>Verify Home entry has NO `×` close affordance; non-Home tabs DO show `×`</step>
        <step>Select a non-Home tab; verify it becomes the active tab in WorkspacePane content</step>
        <step>Click "+ New Workspace"; verify WorkspaceLayoutWizard opens with only 6 templates visible</step>
        <step>Check console for JavaScript errors</step>
      </steps>
      <expected>Menu renders four sections; dividers visible; Home non-closable; selection switches tabs; "+ New Workspace" launches wizard with 6-template filter. No console errors.</expected>
    </test>

    <test name="Dark Mode Compliance (ADR-021)">
      <steps>
        <step>Toggle dark mode in D365 settings</step>
        <step>Open WorkspacePaneMenu</step>
        <step>Verify menu surface, dividers, group headers, items, and `×` icons all adapt to dark theme</step>
        <step>Verify Wizard launched from "+ New Workspace" also renders correctly in dark mode</step>
      </steps>
      <expected>All colors use Fluent UI v9 semantic tokens per ADR-021. Dark mode renders correctly throughout.</expected>
    </test>

    <test name="Keyboard Navigation (NFR-05)">
      <steps>
        <step>Open WorkspacePaneMenu using keyboard (e.g., Tab to trigger, Enter to open)</step>
        <step>Use arrow keys to move between menu items</step>
        <step>Tab to `×` close on a non-Home tab; press Enter to close it</step>
        <step>Confirm focus visibility on every focusable item</step>
      </steps>
      <expected>Full keyboard navigation works; focus visibility is clear; `×` actions are keyboard-accessible.</expected>
    </test>
  </ui-tests>

  <execution>
    This task MUST be executed via the `task-execute` skill from `.claude/skills/task-execute/SKILL.md`.
