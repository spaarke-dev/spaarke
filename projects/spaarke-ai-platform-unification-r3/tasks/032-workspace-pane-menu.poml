    <tool name="Grep">Confirm zero hex/rgba literals; confirm zero accessToken snapshots</tool>
    <tool name="Bash">npm build + lint verification</tool>
  </tools>

  <outputs>
    <output type="code">src/solutions/SpaarkeAi/src/components/workspace/WorkspacePaneMenu.tsx (new)</output>
