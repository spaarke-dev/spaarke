<task id="042" project="spaarke-ai-platform-unification-r3">
  <metadata>
    <title>Register GetStartedCardsWidget + welcome-stage swap + wire widget_load events (FR-18, FR-19, FR-21)</title>
    <phase>Phase D â€” Context pane</phase>
