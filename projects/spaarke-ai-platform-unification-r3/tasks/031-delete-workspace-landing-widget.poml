    </files>
  </knowledge>

  <steps>
    <step order="1" name="Grep codebase for WorkspaceLandingWidget references">
      Run a project-wide grep for the symbol `WorkspaceLandingWidget` (including the `import`
      path `workspace/WorkspaceLandingWidget`). Capture every match — file path, line, context.
      Common offenders: `WorkspacePane.tsx`, any test fixtures, any barrel exports.
    </step>
    <step order="2" name="Remove imports / references">
      For each match found in step 1, remove the import statement and any JSX usage. If a JSX usage
      remained from before task 030, confirm that task 030 should already have replaced it with the
      `WorkspaceShell` embed — if not, that is a bug in 030's output; fix it here (delete the JSX
      element, since the Home tab now renders `WorkspaceShell`).
    </step>
    <step order="3" name="Delete WorkspaceLandingWidget.tsx">
      Once grep returns ZERO live references (besides the file itself), delete
      `src/solutions/SpaarkeAi/src/components/workspace/WorkspaceLandingWidget.tsx`.
    </step>
    <step order="4" name="Build verification">
      Run `npm run build` (or the project's standard build command) in the SpaarkeAi workspace.
      Confirm zero TypeScript errors, no orphan-import warnings, no "cannot find module" errors.
    </step>
    <step order="5" name="Test verification">
      Run any unit tests / snapshot tests for the SpaarkeAi solution. Confirm none reference the
      deleted file. If a test breaks because it imported `WorkspaceLandingWidget`, delete the
      obsolete test (it tested removed functionality).
    </step>
    <step order="6" name="Update TASK-INDEX and commit">
      Update `projects/spaarke-ai-platform-unification-r3/tasks/TASK-INDEX.md`: this task's status
      to ✅ completed. Commit changes per project conventions.
    </step>
  </steps>

  <tools>
    <tool name="Grep">Find all references to `WorkspaceLandingWidget` across the codebase</tool>
    <tool name="Edit">Remove imports / JSX usage from remaining files</tool>
    <tool name="Bash">Delete the file (`rm`) and run build verification</tool>
  </tools>

  <outputs>
    <output type="code">src/solutions/SpaarkeAi/src/components/workspace/WorkspaceLandingWidget.tsx (DELETED)</output>
    <output type="code">src/solutions/SpaarkeAi/src/components/workspace/WorkspacePane.tsx (modified if orphan imports remained)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">`WorkspaceLandingWidget.tsx` no longer exists in the repository (file deleted).</criterion>
    <criterion testable="true">Project-wide grep for `WorkspaceLandingWidget` returns zero matches (file no longer exists; no orphan imports).</criterion>
    <criterion testable="true">`npm run build` in the SpaarkeAi workspace succeeds with zero TypeScript errors and zero new lint warnings.</criterion>
    <criterion testable="true">Existing unit/snapshot tests for SpaarkeAi pass — any obsolete tests referencing the deleted widget are also removed.</criterion>
    <criterion testable="true">Standalone LegalWorkspace code page continues to function identically (FR-25, NFR-10) — confirmed by separate browser tab smoke check.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="No Orphan References After Deletion">
      <url>https://{org}.crm.dynamics.com/main.aspx?appid={app-id}&amp;pagetype=custom&amp;name=spaarke_spaarkeai</url>
      <steps>
        <step>Cold-load the SpaarkeAi code page in Power Apps host</step>
        <step>Verify Workspace pane renders correctly (Home tab populated with LegalWorkspace via task 030)</step>
        <step>Check browser DevTools console for any "module not found" / "undefined component" errors</step>
        <step>Verify no visual regression in the Workspace pane vs. task 030's output</step>
      </steps>
      <expected>Workspace pane renders without errors. Console is clean. No orphan import warnings.</expected>
    </test>

    <test name="Dark Mode Parity (ADR-021)">
      <steps>
        <step>Toggle dark mode in D365 settings</step>
        <step>Verify Workspace pane renders correctly in dark mode (Home tab via WorkspaceShell)</step>
        <step>Confirm no regression vs task 030's dark-mode baseline</step>
      </steps>
      <expected>Workspace pane dark mode behavior unchanged from task 030. No regressions.</expected>
    </test>
  </ui-tests>

  <execution>
