<task id="031" project="spaarke-ai-platform-unification-r3">
  <metadata>
    <title>Delete WorkspaceLandingWidget and clean up orphan imports</title>
    <phase>Phase C — Workspace Pane</phase>
    <status>not-started</status>
    <estimated-hours>1</estimated-hours>
    <dependencies>030</dependencies>
    <blocks>none</blocks>
    <tags>react, frontend, refactoring, ui-cleanup</tags>
    <rigor-hint>STANDARD</rigor-hint>
    <rigor-reason>Deletion + import cleanup. No new code; STANDARD rigor sufficient. Verifies clean build and no orphan references after task 030 moved Home-tab logic into WorkspacePane via WorkspaceShell embed.</rigor-reason>
    <parallel-group>C</parallel-group>
    <parallel-safe>false</parallel-safe>
    <parallel-reason>Paired with task 030 — Home tab logic moves into 030, then this task removes the now-unused widget. May touch `WorkspacePane.tsx` imports.</parallel-reason>
