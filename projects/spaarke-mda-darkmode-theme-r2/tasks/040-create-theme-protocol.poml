<task id="040" project="spaarke-mda-darkmode-theme-r2">
  <metadata>
    <title>Create theme consistency protocol document</title>
    <phase>5</phase>
    <tags>documentation, constraints</tags>
    <estimate>1h</estimate>
    <dependencies>001</dependencies>
    <parallel-safe>true</parallel-safe>
    <parallel-group>E</parallel-group>
