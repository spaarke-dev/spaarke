<task id="015" project="ai-analysis-workspace-sprkchat-integration">
  <metadata>
    <title>Remove web resources from Dataverse solution definition</title>
    <phase>2</phase>
    <stream>dataverse</stream>
    <tags>dataverse, cleanup</tags>
    <estimate>1h</estimate>
    <rigor>STANDARD</rigor>
    <parallel-group>F</parallel-group>
    <parallel-safe>true</parallel-safe>
    <dependencies>009</dependencies>
  </metadata>

  <prompt>
    <goal>Remove three web resources from the Dataverse solution: sprk_SprkChatPane, sprk_openSprkChatPane, and sprk_SidePaneManager.</goal>
    <context>These web resources were for the separate SprkChatPane Code Page and its launcher. They need to be removed from the solution definition so they don't deploy.</context>
    <constraints>
      - MUST remove sprk_SprkChatPane web resource reference
      - MUST remove sprk_openSprkChatPane web resource reference
      - MUST remove sprk_SidePaneManager web resource reference
      - MUST NOT remove sprk_AnalysisWorkspace (that's the one we keep)
    </constraints>
  </prompt>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-006-pcf-over-webresources.md</file>
    </files>
  </knowledge>

  <steps>
    <step>Find Dataverse solution definition files containing web resource references</step>
    <step>Remove sprk_SprkChatPane, sprk_openSprkChatPane, sprk_SidePaneManager entries</step>
    <step>Verify sprk_AnalysisWorkspace remains in solution</step>
    <step>Verify solution structure is valid</step>
  </steps>

  <outputs>
    <output>Modified: Dataverse solution definition (3 web resources removed)</output>
  </outputs>

  <acceptance-criteria>
    <criterion>Three web resources removed from solution</criterion>
    <criterion>sprk_AnalysisWorkspace still in solution</criterion>
    <criterion>Solution definition valid</criterion>
  </acceptance-criteria>
</task>
