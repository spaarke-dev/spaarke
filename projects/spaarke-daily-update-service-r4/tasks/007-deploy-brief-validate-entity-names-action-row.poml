      <file>projects/spaarke-daily-update-service-r4/spec.md</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="spec MUST">MUST follow `jps-action-create` skill; MUST validate via `jps-validate` before deployment.</constraint>
