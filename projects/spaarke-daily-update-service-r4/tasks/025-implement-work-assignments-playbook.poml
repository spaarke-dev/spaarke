      <file>projects/spaarke-daily-update-service-r4/CLAUDE.md</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-034">Membership resolution via ActionType 52 LookupUserMembership.</constraint>
    <constraint source="ADR-013">Playbook composes JPS primitives only.</constraint>
    <constraint source="ADR-037">Multinode output composition.</constraint>
    <constraint source="CLAUDE.md §11">Component Justification block REQUIRED: existing=stub PB-022, extension=Yes (functional promotion), cost-of-doing-nothing=users get zero work-assignment notifications.</constraint>
    <constraint source="project">24h time window relative to playbook execution time (UTC). Repo JSON = source-of-truth.</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>projects/spaarke-daily-update-service-r4/CLAUDE.md</file>
