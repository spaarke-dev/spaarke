<task id="005" project="spaarke-daily-update-service-r4">
  <metadata>
    <title>Deploy SYS-LOOKUP-MEMBERSHIP sprk_analysisaction row (ActionType 52)</title>
    <phase>1: W0 JPS — Action rows + EntityNameValidator (PR 1)</phase>
    <status>not-started</status>
    <estimated-hours>2</estimated-hours>
    <dependencies>001</dependencies>
    <blocks>011</blocks>
