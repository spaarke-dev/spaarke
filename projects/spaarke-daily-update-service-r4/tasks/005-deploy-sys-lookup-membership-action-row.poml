    <patterns>
      <pattern name="jps-action-create" location=".claude/skills/jps-action-create/SKILL.md">Author + validate + deploy sprk_analysisaction row via MCP upsert.</pattern>
    </patterns>
  </knowledge>

  <steps>
    <step order="1">Load all knowledge files. Read spec.md FR-1 (lines 109-110) + AC-1.</step>
    <step order="2">Invoke the `jps-action-create` skill to scaffold the SYS-LOOKUP-MEMBERSHIP Action JSON.</step>
    <step order="3">Read `LookupUserMembershipNodeExecutor.cs` to extract the canonical input schema (entityType, roles, identityTypes, includeRelated, limit) and output schema.</step>
    <step order="4">Author the JSON source at `projects/spaarke-daily-update-service/notes/playbooks/actions/sys-lookup-membership.action.json` with: sprk_executoractiontype 52, sprk_actioncode "SYS-LOOKUP-MEMBERSHIP", sprk_systemprompt with input schema, sprk_outputschemajson, statecode Active.</step>
    <step order="5">Run `jps-validate` against the JSON — fix any errors.</step>
    <step order="6">Check spaarkedev1 for an existing row via `mcp__dataverse__read_query` filtered to sprk_executoractiontype = 52 (idempotency check).</step>
    <step order="7">If exists → `mcp__dataverse__update_record` with the canonical fields; if not → `mcp__dataverse__create_record`.</step>
    <step order="8">Verify via `mcp__dataverse__read_query` SELECT … FROM sprk_analysisaction WHERE sprk_executoractiontype = 52 — returns exactly 1 row matching the canonical JSON.</step>
    <step order="9">Update TASK-INDEX.md: change this task's status to ✅.</step>
    <step order="10">If deviations from plan, document in projects/spaarke-daily-update-service-r4/notes/.</step>
  </steps>

  <tools>
    <tool name="mcp-dataverse">read_query / create_record / update_record for sprk_analysisaction upsert</tool>
  </tools>

  <outputs>
    <output type="data">spaarkedev1: sprk_analysisaction row with sprk_executoractiontype = 52, code SYS-LOOKUP-MEMBERSHIP, Active</output>
    <output type="source">projects/spaarke-daily-update-service/notes/playbooks/actions/sys-lookup-membership.action.json</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">mcp__dataverse__read_query SELECT WHERE sprk_executoractiontype = 52 returns exactly 1 row.</criterion>
    <criterion testable="true">Row has sprk_actioncode = "SYS-LOOKUP-MEMBERSHIP" and statecode = Active.</criterion>
    <criterion testable="true">JPS-validate passes against the canonical JSON source file.</criterion>
    <criterion testable="true">Canonical JSON committed at projects/spaarke-daily-update-service/notes/playbooks/actions/sys-lookup-membership.action.json.</criterion>
  </acceptance-criteria>

