<task id="047" project="spaarke-daily-update-service-r4">
  <metadata>
    <title>Link click → Xrm.Navigation.navigateTo modal + 403 fallback toast (FR-19)</title>
    <phase>5: W2 Consumer — UX redesign + preferences + link (PR 5)</phase>
