    <files>
      <file>scripts/Deploy-EventDetailSidePane.ps1</file>
      <file>.claude/adr/ADR-026-full-page-custom-page-standard.md</file>
    </files>
  </knowledge>
  <steps>
    <step order="1">Read Deploy-EventDetailSidePane.ps1 to understand the deployment pattern</step>
    <step order="2">Create scripts/Deploy-SmartTodo.ps1 following the same pattern, targeting src/solutions/SmartTodo and sprk_smarttodo web resource</step>
    <step order="3">Verify script runs npm run build in the correct directory</step>
    <step order="4">Verify script base64-encodes dist/index.html and uploads to Dataverse</step>
