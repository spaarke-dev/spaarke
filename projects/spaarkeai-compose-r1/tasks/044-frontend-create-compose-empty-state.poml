      <file>docs/architecture/LEGALWORKSPACE-EMBEDDED-MODE-CONTRACT.md</file>
      <file>src/solutions/SpaarkeAi/src/components/conversation/ConversationPane.tsx</file>
      <file>src/solutions/SpaarkeAi/src/utils/launch-resolver.ts</file>
      <file>src/solutions/SpaarkeAi/src/components/shell/ThreePaneShell.tsx</file>
      <file>src/client/shared/Spaarke.AI.Widgets/src/widgets/workspace/CalendarWorkspaceWidget</file>
    </files>
  </knowledge>

  <steps>
    <step order="0" name="Context check + load knowledge">Verify context &lt; 70%. Load FR-18 + CLAUDE.md Decisions Made.</step>
    <step order="1" name="Scaffold empty state">Create `src/solutions/SpaarkeAi/src/components/compose/ComposeEmptyState.tsx`. Use Fluent v9 primitives (`Card`, `Button`, semantic tokens).</step>
    <step order="2" name="Wire Browse action">Browse button dispatches a `compose:browse-requested` PaneEventBus event (contract from Task 041). Receiver = stub in R1.</step>
    <step order="3" name="Wire Search action">Search button dispatches a `compose:search-requested` PaneEventBus event (contract from Task 041). Receiver = stub in R1.</step>
    <step order="4" name="Accessibility">ARIA roles + keyboard navigation between the two buttons.</step>
    <step order="5" name="Build + ui-tests">`npm run build`, then `pwsh ./scripts/Build-AllClientComponents.ps1`. Run ui-tests below.</step>
    <step order="6" name="Update TASK-INDEX">TASK-INDEX.md: task 044 → ✅. Reset `current-task.md`.</step>
  </steps>

  <ui-tests>
    <test name="Component Renders">Empty state renders centered with Browse + Search buttons; zero console errors; both buttons keyboard-reachable.</test>
    <test name="Dark Mode Compliance (ADR-021)">Renders correctly in dark theme via Fluent v9 semantic tokens.</test>
    <test name="Action Dispatch">Click Browse — assert PaneEventBus emits `compose:browse-requested`; click Search — assert it emits `compose:search-requested`.</test>
  </ui-tests>

  <tools>
    <tool name="npm">Build TypeScript</tool>
    <tool name="pwsh">Run Build-AllClientComponents.ps1</tool>
  </tools>

  <outputs>
    <output type="code">src/solutions/SpaarkeAi/src/components/compose/ComposeEmptyState.tsx</output>
    <output type="docs">projects/spaarkeai-compose-r1/tasks/TASK-INDEX.md (status update)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Empty state renders Browse + Search buttons.</criterion>
    <criterion testable="true">Browse + Search both dispatch the correctly-shaped PaneEventBus events from Task 041 contracts.</criterion>
    <criterion testable="true">`npm run build` + `Build-AllClientComponents.ps1` succeed.</criterion>
    <criterion testable="true">ui-tests green: Component Renders, Dark Mode Compliance, Action Dispatch.</criterion>
    <criterion testable="true">TASK-INDEX.md status for task 044 is ✅.</criterion>
  </acceptance-criteria>

