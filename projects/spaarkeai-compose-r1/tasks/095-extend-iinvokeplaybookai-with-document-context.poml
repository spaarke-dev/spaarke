  </inputs>

  <constraints>
    <constraint source="adr-013">CRUD code MUST NOT inject AI internals (IOpenAiClient / IPlaybookOrchestrationService). The facade is the seam. Extending it is fine; bypassing it is not.</constraint>
    <constraint source="claudemd-6.5">Path B ADR amendment MUST land alongside or before the dependent code — task 102 files the amendment</constraint>
    <constraint source="testing">New overload requires test coverage per §10 #6</constraint>
  </constraints>

