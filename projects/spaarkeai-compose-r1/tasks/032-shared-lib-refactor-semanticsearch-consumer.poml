    <constraint source="project">MUST remove the local SemanticSearch hook file (no stub re-export remaining at end of this task)</constraint>
    <constraint source="project">MUST find ALL SemanticSearch consumers of useDocumentActions (not just SearchCommandBar) via grep before refactoring</constraint>
    <constraint source="project">MUST verify SemanticSearch builds clean and existing tests pass after refactor (gated explicitly in task 033)</constraint>
  </constraints>

  <knowledge>
    <topic>import-path refactor</topic>
    <files>
      <file>projects/spaarkeai-compose-r1/spec.md</file>
