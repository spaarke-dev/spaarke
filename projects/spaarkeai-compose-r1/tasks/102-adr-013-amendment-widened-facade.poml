    <file purpose="defer-issues">projects/spaarkeai-compose-r1/notes/defer-issues.md</file>
  </inputs>

  <constraints>
    <constraint source="CLAUDE.md-6.5">Path B amendment MUST land alongside dependent code (tasks 095, 096, 097) — no silent violation window</constraint>
