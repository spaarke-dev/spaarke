    <output type="docs">projects/spaarkeai-compose-r1/tasks/TASK-INDEX.md (status update)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">`AddComposeModule()` registers the three Compose services as Scoped, unconditionally.</criterion>
    <criterion testable="true">`Program.cs` calls `AddComposeModule()` and `MapComposeEndpoints()` without any feature-flag conditional.</criterion>
    <criterion testable="true">Host boots without DI-resolution errors; unauthenticated `/api/compose/*` returns 401.</criterion>
    <criterion testable="true">Static scan confirms no AI-internal types injected into Compose service constructors.</criterion>
    <criterion testable="true">BFF builds clean; publish-size delta ≤+0.3 MB; no new HIGH CVE.</criterion>
    <criterion testable="true">TASK-INDEX.md status for task 025 is ✅.</criterion>
  </acceptance-criteria>

