    </files>
  </knowledge>

  <steps>
    <step order="0" name="Context check + load launch-resolver">Verify context &lt; 70%. Load `launch-resolver.ts` + ConversationPane invocation site.</step>
    <step order="1" name="Add resolver entry">Extend `launch-resolver.ts` with a `compose-editor` target that resolves to the modal shell mounting `ComposeWorkspace` (Task 042) with the document context.</step>
    <step order="2" name="Add ribbon button definition">Add an "Open in Compose" command-bar button on the `sprk_document` form (ribbon XML or model-driven command bar — match existing Spaarke ribbon pattern). Button invokes the launch-resolver `compose-editor` entry with the current record's id + drive-item id.</step>
    <step order="3" name="Full-screen toggle">Confirm the modal shell's existing full-screen toggle works with `ComposeWorkspace` mounted (no extra work expected; verify via ui-test).</step>
    <step order="4" name="Pass document context">Ensure the modal forwards `sprk_documentid` + drive-item id to `ComposeWorkspace` props so `ComposeEditor` can load the DOCX.</step>
    <step order="5" name="Build + ui-tests">`npm run build`, then `pwsh ./scripts/Build-AllClientComponents.ps1`. Run ui-tests below.</step>
    <step order="6" name="Update TASK-INDEX">TASK-INDEX.md: task 046 → ✅. Reset `current-task.md`.</step>
  </steps>

  <ui-tests>
    <test name="Component Renders">Trigger the launch-resolver with `target=compose-editor` and a test document id; verify the modal opens with `ComposeWorkspace` mounted; zero console errors.</test>
    <test name="Dark Mode Compliance (ADR-021)">Modal + full-screen toggle render correctly in dark theme via Fluent v9 semantic tokens.</test>
    <test name="Full-Screen Toggle">Click the full-screen toggle in the modal header — verify the modal expands; click again — verify it collapses.</test>
    <test name="Document Context Forwarding">Confirm the `sprk_documentid` + drive-item id reach `ComposeWorkspace` props (assert via test harness or React DevTools snapshot).</test>
  </ui-tests>

  <tools>
    <tool name="npm">Build TypeScript</tool>
    <tool name="pwsh">Run Build-AllClientComponents.ps1</tool>
  </tools>

  <outputs>
    <output type="code">src/solutions/SpaarkeAi/src/utils/launch-resolver.ts (new `compose-editor` entry)</output>
    <output type="config">src/solutions/SpaarkeAi/ribbon or command-bar definition for `sprk_document` "Open in Compose"</output>
    <output type="docs">projects/spaarkeai-compose-r1/tasks/TASK-INDEX.md (status update)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">"Open in Compose" command-bar button exists on `sprk_document` form.</criterion>
    <criterion testable="true">Clicking the button opens the SpaarkeAi modal with `ComposeWorkspace` mounted.</criterion>
    <criterion testable="true">Full-screen toggle works in the modal.</criterion>
    <criterion testable="true">Document context (`sprk_documentid` + drive-item id) reaches `ComposeWorkspace`.</criterion>
    <criterion testable="true">`npm run build` + `Build-AllClientComponents.ps1` succeed.</criterion>
    <criterion testable="true">ui-tests green: Component Renders, Dark Mode Compliance, Full-Screen Toggle, Document Context Forwarding.</criterion>
    <criterion testable="true">TASK-INDEX.md status for task 046 is ✅.</criterion>
  </acceptance-criteria>

