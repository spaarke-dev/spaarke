<?xml version="1.0" encoding="UTF-8"?>
<task id="040" project="spaarkeai-compose-r1">
  <metadata>
    <title>Frontend — Register `compose-editor` section type in SECTION_REGISTRY</title>
    <phase>Phase 4: Frontend — SpaarkeAi Compose Surface</phase>
    <status>not-started</status>
    <estimated-hours>4</estimated-hours>
    <tags>frontend, react, typescript, fluent-ui, widget</tags>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Task tags include 'fluent-ui' (UI implementation per ADR-021)</rigor-reason>
    <parallel-group>F</parallel-group>
    <parallel-safe>true</parallel-safe>
    <parallel-reason>Independent registry edit; serialized only by section-registry file uniqueness — safe to run in parallel group F with 041, 044.</parallel-reason>
    <dependencies>001,002,003,004</dependencies>
    <blocks>042,045</blocks>
  </metadata>

  <prompt>
    Register a new `compose-editor` section type in the SpaarkeAi `SECTION_REGISTRY` so the Compose workspace layout can mount the TipTap editor shell as a workspace section. This is the foundational registry entry that allows the layout-driven shell to render the Compose surface. The actual `ComposeWorkspace.tsx` is built in Task 042; here we only wire the registry entry (id, displayName, factory pointer, default-config shape) following the precedent set by the Calendar workspace widget (Pattern D).
  </prompt>

  <role>
    Senior React/TypeScript developer with deep familiarity with the SpaarkeAi workspace layout system (`SECTION_REGISTRY`), Calendar workspace widget precedent (Pattern D), and Fluent UI v9 conventions.
  </role>

  <goal>
    `SECTION_REGISTRY` contains a `compose-editor` entry (matching the Phase 1 `sprk_workspacelayout.sprk_definitionjson` reference) that lazy-loads `ComposeWorkspace` once Task 042 lands. Build green; ui-test green; dark mode renders.
  </goal>

  <context>
    <background>
      FR-02 requires the `compose-editor` section type to be registered so the Compose layout (Phase 1, Task 010) can mount it. Pattern D (Calendar) is the canonical precedent — same lib, thin LW shim, dual-use registry entry. The registry entry is the smallest additive UI change that unblocks Tasks 042 + 045.
    </background>
  </context>

  <constraints>
    <constraint source="ADR-021">Section UI MUST use Fluent UI v9 semantic tokens; MUST honor dark mode via `useThemeContext`.</constraint>
    <constraint source="ADR-028">Spaarke Auth v2 — section consumes client SSO context via `@spaarke/auth`; do NOT re-acquire tokens.</constraint>
    <constraint source="project">REUSE existing `SECTION_REGISTRY` extension pattern (Calendar precedent); NO new registry abstraction.</constraint>
    <constraint source="project">No custom DOCX-feature integration outside TipTap OOB — the registry entry only references the OOB-only Compose shell.</constraint>
  </constraints>

  <justification>
    <existing>`SECTION_REGISTRY` already exists in the SpaarkeAi shell (mounts Calendar, Conversation, Context, etc.). This task ADDS one entry. Verified via grep `SECTION_REGISTRY` in `src/solutions/SpaarkeAi/src/components/shell/`.</existing>
    <extension>Yes — extends an existing registry by one row; no new abstraction created. The section TYPE (`compose-editor`) is new, but the registry mechanism is unchanged.</extension>
    <cost-of-doing-nothing>FR-02 fails — the Compose layout (Phase 1) references an unregistered section type, so opening Compose renders nothing (silent layout mount failure). Tasks 042 + 045 cannot ship without this entry.</cost-of-doing-nothing>
  </justification>

  <knowledge>
    <files>
      <file>projects/spaarkeai-compose-r1/spec.md</file>
      <file>projects/spaarkeai-compose-r1/plan.md</file>
      <file>projects/spaarkeai-compose-r1/CLAUDE.md</file>
      <file>docs/architecture/SPAARKEAI-WORKSPACE-ARCHITECTURE.md</file>
      <file>docs/architecture/SPAARKEAI-DASHBOARD-AND-WIDGET-MODEL.md</file>
      <file>docs/architecture/SPAARKEAI-COMPONENT-MODEL.md</file>
      <file>docs/guides/BUILD-A-NEW-WORKSPACE-WIDGET.md</file>
      <file>docs/architecture/LEGALWORKSPACE-EMBEDDED-MODE-CONTRACT.md</file>
      <file>src/solutions/SpaarkeAi/src/components/conversation/ConversationPane.tsx</file>
      <file>src/solutions/SpaarkeAi/src/utils/launch-resolver.ts</file>
      <file>src/solutions/SpaarkeAi/src/components/shell/ThreePaneShell.tsx</file>
      <file>src/client/shared/Spaarke.AI.Widgets/src/widgets/workspace/CalendarWorkspaceWidget</file>
    </files>
  </knowledge>

  <steps>
    <step order="0" name="Context check + load knowledge">Verify context &lt; 70%. Load spec.md FR-02, plan.md Phase 4, BUILD-A-NEW-WORKSPACE-WIDGET.md Pattern D, and the Calendar widget directory.</step>
    <step order="1" name="Locate SECTION_REGISTRY">Grep `SECTION_REGISTRY` in `src/solutions/SpaarkeAi/src/`. Read the existing registrations (Conversation, Context, Calendar) to match style.</step>
    <step order="2" name="Author registry entry">Add a `compose-editor` registration with id, displayName ("Compose"), and a lazy-load pointer (`React.lazy(() =&gt; import('./compose/ComposeWorkspace'))`). Until Task 042 lands, point at a placeholder fallback (`ComposeWorkspacePlaceholder`) that renders an empty Fluent v9 `Skeleton` so the build stays green.</step>
    <step order="3" name="Verify layout reference">Open the Phase 1 workspace-layout row (Task 010 output) and confirm its `definitionjson` references `"sectionType": "compose-editor"`. If it does not yet exist, add a comment in the registry pointing at the expected layout row.</step>
    <step order="4" name="Build">Run `npm run build` in the SpaarkeAi solution; confirm no TS errors.</step>
    <step order="5" name="Run shared client build">Run `pwsh ./scripts/Build-AllClientComponents.ps1` to verify the registry change does not break dependent solutions.</step>
    <step order="6" name="UI test execution">Run the ui-tests defined below; capture screenshots if rendering surfaces in `notes/ui-tests/`.</step>
    <step order="7" name="Update TASK-INDEX">Update `projects/spaarkeai-compose-r1/tasks/TASK-INDEX.md`: change task 040 status to ✅. Reset `current-task.md` to next pending task.</step>
  </steps>

  <ui-tests>
    <test name="Component Renders">Mount the SpaarkeAi shell with the Compose workspace layout id; verify the `compose-editor` section renders (placeholder Skeleton OK at this stage); zero console errors; zero React warnings.</test>
    <test name="Dark Mode Compliance (ADR-021)">Toggle to dark theme via `useThemeContext`; verify the section background, borders, and text resolve via Fluent v9 semantic tokens (`colorNeutralBackground1`, `colorNeutralForeground1`) — NO hard-coded hex values.</test>
    <test name="Registry Resolution">Programmatically resolve `SECTION_REGISTRY.get('compose-editor')` — returns a non-null factory; calling it returns a React element (placeholder until Task 042).</test>
  </ui-tests>

  <tools>
    <tool name="npm">Build TypeScript</tool>
    <tool name="pwsh">Run Build-AllClientComponents.ps1</tool>
  </tools>

  <outputs>
    <output type="code">src/solutions/SpaarkeAi/src/components/shell/SECTION_REGISTRY.* (registry edit)</output>
    <output type="code">src/solutions/SpaarkeAi/src/components/compose/ComposeWorkspacePlaceholder.tsx (temporary)</output>
    <output type="docs">projects/spaarkeai-compose-r1/tasks/TASK-INDEX.md (status update)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">`SECTION_REGISTRY.get('compose-editor')` returns a non-null factory.</criterion>
    <criterion testable="true">`npm run build` succeeds with no TS errors.</criterion>
    <criterion testable="true">`Build-AllClientComponents.ps1` succeeds (green).</criterion>
    <criterion testable="true">ui-tests green: Component Renders, Dark Mode Compliance, Registry Resolution.</criterion>
    <criterion testable="true">Dark mode renders correctly using Fluent v9 semantic tokens.</criterion>
    <criterion testable="true">TASK-INDEX.md status for task 040 is ✅.</criterion>
  </acceptance-criteria>

  <execution>
    <skill>.claude/skills/task-execute/SKILL.md</skill>
  </execution>
</task>
