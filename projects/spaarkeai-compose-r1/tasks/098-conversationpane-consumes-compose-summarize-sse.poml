  <metadata>
    <title>ConversationPane: handle compose_summarize_request events + fetch SSE + progressive render</title>
    <status>completed</status>
    <estimated-effort>2.5 hours</estimated-effort>
    <tags>frontend, spaarkeai, conversation-pane, sse, pane-event-bus, ai-response-surface</tags>
