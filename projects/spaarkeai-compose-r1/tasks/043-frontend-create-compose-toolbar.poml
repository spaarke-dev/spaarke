    </files>
  </knowledge>

  <steps>
    <step order="0" name="Context check + load knowledge">Verify context &lt; 70%. Load FR-12, SemanticSearch's current toolbar for reference UX.</step>
    <step order="1" name="Scaffold toolbar">Create `src/solutions/SpaarkeAi/src/components/compose/ComposeToolbar.tsx`. Use Fluent v9 `Toolbar` primitive.</step>
    <step order="2" name="Wire shared-lib hook">Import + call `useDocumentActions` from `@spaarke/document-operations`. Render Open-in-Word-Web + Open-in-Word-Desktop buttons bound to the hook's action handlers.</step>
    <step order="3" name="Dispatch-action surface">Add a `compose-summarize` button stub that fires a PaneEventBus event (receiver = Assistant pane stub in R1 per FR-20). Phase 6 wires the actual BFF call.</step>
    <step order="4" name="Accessibility + tooltips">Add Fluent v9 `Tooltip` + ARIA labels for each button.</step>
    <step order="5" name="Build + ui-tests">`npm run build`, then `pwsh ./scripts/Build-AllClientComponents.ps1`. Run ui-tests below.</step>
    <step order="6" name="Update TASK-INDEX">TASK-INDEX.md: task 043 → ✅. Reset `current-task.md`.</step>
  </steps>

  <ui-tests>
    <test name="Component Renders">Toolbar renders three buttons; zero console errors; ARIA labels present.</test>
    <test name="Dark Mode Compliance (ADR-021)">Toolbar renders correctly in dark theme via Fluent v9 semantic tokens.</test>
    <test name="Open-in-Word-Web Click">Click Open-in-Word-Web — verify `useDocumentActions` hook is called with expected document id; mock the hook and assert the call.</test>
    <test name="Compose-Summarize Dispatch">Click compose-summarize — verify PaneEventBus emits the dispatch event with the correct contract shape from Task 041.</test>
  </ui-tests>

  <tools>
    <tool name="npm">Build TypeScript</tool>
    <tool name="pwsh">Run Build-AllClientComponents.ps1</tool>
  </tools>

  <outputs>
    <output type="code">src/solutions/SpaarkeAi/src/components/compose/ComposeToolbar.tsx</output>
    <output type="docs">projects/spaarkeai-compose-r1/tasks/TASK-INDEX.md (status update)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Toolbar renders Open-in-Word-Web + Open-in-Word-Desktop + compose-summarize buttons.</criterion>
    <criterion testable="true">Open-in-Word buttons invoke `useDocumentActions` from `@spaarke/document-operations`.</criterion>
    <criterion testable="true">Compose-summarize button emits PaneEventBus event with correct contract shape.</criterion>
    <criterion testable="true">`npm run build` + `Build-AllClientComponents.ps1` succeed.</criterion>
    <criterion testable="true">ui-tests green: Component Renders, Dark Mode Compliance, Open-in-Word-Web Click, Compose-Summarize Dispatch.</criterion>
