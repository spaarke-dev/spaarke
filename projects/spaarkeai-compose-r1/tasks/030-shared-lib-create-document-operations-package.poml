<task id="030" project="spaarkeai-compose-r1">
  <metadata>
    <title>Scaffold src/client/shared/Spaarke.DocumentOperations/ package</title>
    <status>completed</status>
    <estimated-effort>0.5 day</estimated-effort>
    <tags>frontend, typescript, refactoring, shared-lib</tags>
    <rigor-hint>FULL</rigor-hint>
