    <output type="docs">projects/spaarkeai-compose-r1/tasks/TASK-INDEX.md</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Same user opening same document in second tab sees conflict dialog with FR-16 verbatim button labels</criterion>
    <criterion testable="true">"Go to that session" focuses the original tab (BroadcastChannel verified)</criterion>
    <criterion testable="true">"Force-close other session and open here" releases prior lock + grants new check-out to current tab</criterion>
    <criterion testable="true">Original tab receives force-close notification + unmounts editor</criterion>
    <criterion testable="true">No banned test patterns introduced (ADR-038)</criterion>
  </acceptance-criteria>

