  <constraints>
    <constraint source="FR-24">`docs/procedures/testing-and-code-quality.md` (or the code review checklist within it) gains one line: "Verify test-update obligation per `.claude/constraints/bff-extensions.md`."</constraint>
    <constraint source="design.md §5.5">Anti-drift via code review + PR template + constraint cross-reference; NO CI script</constraint>
    <constraint source="NFR-01">No production code changes (`docs/` is documentation, not `src/`)</constraint>
