    <file purpose="project-claude">projects/sdap-bff.api-test-suite-repair/CLAUDE.md</file>
  </inputs>

  <constraints>
    <constraint source="NFR-01">No `src/`, `power-platform/`, `infra/`, `scripts/` changes</constraint>
    <constraint source="NFR-02">Each fixture diff &lt;50% line replacement (additive dict + optional 1-LOC inheritance change are both well-below)</constraint>
    <constraint source="NFR-09">`repair-not-rewrite: true` in metadata</constraint>
    <constraint source="§4.5">Do NOT edit `CustomWebAppFactory.cs` OR `IntegrationTestFixture.cs` (both sealed; previous waves' work)</constraint>
    <constraint source="§4.7">Sibling-coord risk applies if any sibling project actively edits these fixtures; assume no conflict and proceed (no evidence of in-flight work)</constraint>
