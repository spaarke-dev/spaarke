<task id="043" project="sdap-bff.api-test-suite-repair">
  <metadata>
    <title>P23.H4 — Email association tests (~863 LOC) — COORD with x-email-communication-solution-r2</title>
    <status>not-started</status>
    <estimated-effort>3-5 hours</estimated-effort>
    <assigned>AI agent</assigned>
    <tags>phase-2-3, high-tier, p23-h, bff-api, testing, email, communications-coord</tags>
    <parallel-group>23-H</parallel-group>
    <parallel-safe>true</parallel-safe>
