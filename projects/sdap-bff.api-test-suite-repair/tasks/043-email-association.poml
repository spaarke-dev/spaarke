  <relevant-files>
    <file>tests/unit/Sprk.Bff.Api.Tests/Services/Email/EmailAssociation*.cs</file>
    <file>tests/unit/Sprk.Bff.Api.Tests/Services/Email/EmailAssociation/*.cs</file>
  </relevant-files>

  <steps>
    <step order="1">Post sync note to x-email-communication-solution-r2 owner — confirm no Email association code changes are in-flight on their side this iteration.</step>
    <step order="2">List Email association test files in scope. From Phase 0 baseline TRX, identify failing tests.</step>
    <step order="3">For each file: compute pre-edit line count; read failing tests + production code.</step>
    <step order="4">If any planned file edit would exceed 50% of file lines → HALT, file `escalations/rewrite-request-T-043-{FileName}.md`, await owner approval.</step>
    <step order="5">Classify each failure: `test-stale` vs `production-bug`.</step>
    <step order="6">Apply traits per §6.2; file ledger entries as needed.</step>
    <step order="7">After each file: `dotnet test --filter "FullyQualifiedName~Email.EmailAssociation"` verify outcome.</step>
    <step order="8">Update `current-task.md` with disposition + coordination outcome.</step>
    <step order="9">Verify `git status` shows NO production changes.</step>
  </steps>

  <tools>
    <tool name="dotnet">test</tool>
    <tool name="git">status</tool>
  </tools>

  <outputs>
