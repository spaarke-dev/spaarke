    <tags>deploy, dataverse</tags>
    <estimate>1-2 hours</estimate>
    <priority>high</priority>
    <dependencies>031</dependencies>
    <status>pending</status>
  </metadata>

  <prompt>
    <goal>Import the DocumentUploadWizard web resource and updated ribbon commands into Dataverse. Publish all customizations.</goal>
