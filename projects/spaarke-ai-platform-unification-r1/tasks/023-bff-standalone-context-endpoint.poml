    </files>
    <patterns>
      <pattern name="AnalysisChatContextResolver pattern" location="src/server/api/Sprk.Bff.Api/Services/Ai/Chat/AnalysisChatContextResolver.cs">
        Mirror this class for StandaloneChatContextProvider: same constructor shape, same method signature (ResolveAsync or equivalent), same exception types. Read before implementing.
      </pattern>
      <pattern name="Endpoint group registration" location="src/server/api/Sprk.Bff.Api/Api/Ai/AiToolEndpoints.cs">
        Pattern for MapGroup, AddEndpointFilter, route definition, and ProblemDetails returns. Mirror this for StandaloneChatContextEndpoints.cs.
      </pattern>
      <pattern name="Redis cache key + TTL" location="src/server/api/Sprk.Bff.Api/Services/Caching/RedisCacheService.cs">
        Cache key format and TTL setting. Use the same service/interface already registered in DI.
      </pattern>
      <pattern name="OBO auth filter" location="src/server/api/Sprk.Bff.Api/Infrastructure/Auth/OboAuthEndpointFilter.cs">
        Read to understand how tenantId is extracted from claims and how the filter is applied to a MapGroup.
      </pattern>
