<task id="AIPU-061" project="spaarke-ai-platform-unification-r1">
  <metadata>
    <title>AgentServiceNodeExecutor — INodeExecutor implementation for ActionType 60</title>
    <status>completed</status>
    <phase>2</phase>
    <wave>6</wave>
    <estimated-effort>3 hours</estimated-effort>
    <tags>bff-api, api, ai-foundry</tags>
