<task id="WKSP-062" project="spaarke-workspace-user-configuration-r1">
  <metadata>
    <title>Deploy updated BFF API with workspace layout endpoints</title>
    <phase>7</phase>
    <tags>deploy, bff-api</tags>
    <estimated-effort>1h</estimated-effort>
    <rigor-level>MINIMAL</rigor-level>
    <dependencies>023</dependencies>
    <parallel-group>F</parallel-group>
    <parallel-safe>true</parallel-safe>
  </metadata>
  <prompt>
    <role>Senior developer implementing workspace personalization</role>
    <goal>Deploy the updated BFF API containing the new workspace layout endpoints to the Azure App Service dev environment.</goal>
    <context>
      The BFF API (Sprk.Bff.Api) has been updated with workspace layout CRUD endpoints and the
      sections catalog endpoint. These changes need to be deployed to the dev Azure App Service
      (spe-api-dev-67e2xz) using the existing Deploy-BffApi.ps1 script.
    </context>
    <constraints>
      - MUST use scripts/Deploy-BffApi.ps1 for deployment
      - MUST verify the API builds successfully before deploying (dotnet build)
      - MUST verify health check passes after deployment (GET /healthz)
      - MUST verify workspace endpoints respond (GET /api/workspace/layouts returns 200)
    </constraints>
  </prompt>
  <knowledge>
    <files>
      <file>.claude/skills/bff-deploy/SKILL.md</file>
    </files>
  </knowledge>
  <relevant-files>
    <file>src/server/api/Sprk.Bff.Api/</file>
    <file>scripts/Deploy-BffApi.ps1</file>
  </relevant-files>
  <steps>
    <step id="1">Run dotnet build on Sprk.Bff.Api to verify the project compiles without errors.</step>
    <step id="2">Run Deploy-BffApi.ps1 to deploy the API to the dev App Service.</step>
    <step id="3">Verify the health check endpoint responds: GET https://spe-api-dev-67e2xz.azurewebsites.net/healthz.</step>
    <step id="4">Verify workspace layout endpoints respond: GET /api/workspace/layouts returns 200 (may return empty array for new user).</step>
  </steps>
  <acceptance-criteria>
    <criterion>BFF API deploys successfully to dev App Service without errors</criterion>
    <criterion>Health check endpoint returns 200 after deployment</criterion>
    <criterion>GET /api/workspace/layouts endpoint responds with 200</criterion>
  </acceptance-criteria>
</task>
