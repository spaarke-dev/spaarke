<task id="071" project="sdap-secure-project-module">
  <metadata>
    <title>E2E Test — External User Invitation &amp; Onboarding</title>
    <phase>7: Testing, Deployment &amp; Wrap-Up</phase>
    <status>not-started</status>
    <estimated-hours>4</estimated-hours>
    <dependencies>062</dependencies>
    <blocks>075</blocks>
    <tags>testing, e2e-test</tags>
    <rigor-hint>STANDARD</rigor-hint>
    <rigor-reason>Testing task — E2E verification of invitation flow</rigor-reason>
    <parallel-group>H</parallel-group>
    <parallel-safe>true</parallel-safe>
  </metadata>
  <prompt>Test the full invitation and onboarding flow end-to-end: invite user via email → email sent → user redeems invitation → Entra External ID authentication → web role assigned → SPA access granted with correct project visibility.</prompt>
  <role>You are a QA engineer writing end-to-end tests for the external user invitation and onboarding flow.</role>
  <goal>Verified that the complete invitation-to-access flow works correctly, from invitation to authenticated SPA access.</goal>
  <context>
    <background>The invitation flow is how new external users are onboarded. This E2E test verifies the complete chain from sending an invitation to the user having authenticated SPA access with correct project visibility.</background>
    <relevant-files>
      <file>tests/e2e/ (create test files)</file>
    </relevant-files>
  </context>
  <constraints>
    <constraint source="testing">Test against dev environment</constraint>
  </constraints>
  <knowledge>
    <files>
      <file>.claude/constraints/testing.md</file>
    </files>
  </knowledge>
  <steps>
    <step order="1">Create E2E test for invitation and onboarding flow</step>
    <step order="2">Test: Send invitation via BFF API (POST /api/external-access/invite)</step>
    <step order="3">Verify: adx_invitation record created with correct web role</step>
    <step order="4">Verify: Email sent (check sprk_communication records)</step>
    <step order="5">Test: Simulate invitation redemption (or use test endpoint)</step>
    <step order="6">Verify: Contact linked to Entra External ID identity</step>
    <step order="7">Verify: Web role assigned to Contact</step>
    <step order="8">Verify: SPA shows correct project in workspace home after login</step>
  </steps>
  <acceptance-criteria>
    <criterion>Full invitation-to-access flow works end-to-end</criterion>
    <criterion>Invitation email sent</criterion>
    <criterion>Web role assigned after redemption</criterion>
    <criterion>SPA access granted with correct project visibility</criterion>
  </acceptance-criteria>
</task>
