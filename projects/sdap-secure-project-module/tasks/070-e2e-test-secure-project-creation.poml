  </constraints>
  <knowledge>
    <files>
      <file>.claude/constraints/testing.md</file>
    </files>
  </knowledge>
  <steps>
    <step order="1">Create E2E test for secure project creation flow</step>
    <step order="2">Test: Create project with secure toggle ON via wizard</step>
    <step order="3">Verify: child BU created with correct name (SP-{ProjectRef})</step>
    <step order="4">Verify: SPE container provisioned and accessible</step>
    <step order="5">Verify: External Access Account created and owned by BU</step>
    <step order="6">Verify: project record has sprk_issecure=true, sprk_securitybuid, sprk_externalaccountid populated</step>
    <step order="7">Clean up test data after verification</step>
  </steps>
  <acceptance-criteria>
    <criterion>Secure project creation works end-to-end</criterion>
    <criterion>All infrastructure (BU, container, Account) provisioned correctly</criterion>
    <criterion>All references stored on project record</criterion>
