  <steps>
    <step order="1">Deploy final BFF API to Azure App Service</step>
    <step order="2">Verify BFF API health check and external access endpoints</step>
    <step order="3">Deploy final Dataverse solution (SpaarkeCore with all Phase 1 changes)</step>
    <step order="4">Verify Dataverse tables, fields, views, and subgrids</step>
