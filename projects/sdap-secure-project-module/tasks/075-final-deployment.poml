    <step order="7">Run full unit test suite: dotnet test</step>
    <step order="8">Run integration tests</step>
    <step order="9">Run Test-SdapBffApi.ps1 for endpoint validation</step>
    <step order="10">Perform manual smoke test: create secure project → invite user → login as external user → verify workspace</step>
  </steps>
  <acceptance-criteria>
