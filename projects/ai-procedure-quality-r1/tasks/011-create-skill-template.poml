<task id="011" project="ai-procedure-quality-r1">
  <metadata>
    <title>Create .claude/skills/_template/SKILL.md canonical scaffold</title>
    <phase>1</phase>
    <stream>infrastructure</stream>
    <tags>template, skills, scaffold</tags>
    <estimate>30min</estimate>
    <rigor>FULL</rigor>
    <parallel-group>1-A</parallel-group>
    <parallel-safe>false</parallel-safe>
    <dependencies>none</dependencies>
    <writes-to>.claude/skills/_template/</writes-to>
  </metadata>

  <prompt>
    <goal>Create a canonical skill template that new skills can clone and existing skills can be measured against during Phase 2a audit.</goal>
    <context>The 2026-05-14 issues revealed that skills drift in shape over time. A canonical template plus an audit that measures against it keeps the family of skills coherent.</context>
    <constraints>
      - parallel-safe: false — main session only
      - Template must enforce the 7 best practices from spec.md (description-as-trigger, body <200 lines, goal-oriented, Gotchas section, no overlap, no deterministic rules, current references)
      - Template MUST include `exemplar:` frontmatter field as opt-in (either a path OR `none-too-volatile` with rationale)
      - Template MUST include `Last Reviewed: YYYY-MM-DD` stamp
    </constraints>
  </prompt>

  <knowledge>
    <files>
      <file>projects/ai-procedure-quality-r1/design.md</file>
      <file>projects/ai-procedure-quality-r1/spec.md</file>
      <file>.claude/skills/INDEX.md</file>
      <file>.claude/skills/dataverse-deploy/SKILL.md</file>
    </files>
  </knowledge>

  <steps>
    <step>Read 2-3 existing skills as reference (pick well-structured ones)</step>
    <step>Draft .claude/skills/_template/SKILL.md with sections: Description (trigger-leading), When to Use, What to Achieve (goal-oriented), Acceptance Criteria, Reference Exemplar (opt-in), Gotchas, References, Last Reviewed</step>
    <step>Frontmatter fields: name, description, tags, techStack, appliesTo, alwaysApply, exemplar, last-reviewed</step>
    <step>Body must be under 200 lines</step>
    <step>Add a one-paragraph comment at the top explaining how to use the template ("Copy this folder to .claude/skills/your-skill/, fill in placeholders, delete this comment")</step>
    <step>Optionally create .claude/skills/_template/examples/ and .claude/skills/_template/references/ as empty directories with .gitkeep showing the canonical subdirectory structure for skills that need to split content</step>
  </steps>

  <outputs>
    <output>.claude/skills/_template/SKILL.md</output>
    <output>.claude/skills/_template/examples/.gitkeep (optional)</output>
    <output>.claude/skills/_template/references/.gitkeep (optional)</output>
  </outputs>

  <acceptance-criteria>
    <criterion>Template exists, under 200 lines</criterion>
    <criterion>All 7 best-practice sections are present</criterion>
    <criterion>exemplar: field is opt-in with clear instruction</criterion>
    <criterion>Last Reviewed: stamp is present</criterion>
  </acceptance-criteria>
</task>
