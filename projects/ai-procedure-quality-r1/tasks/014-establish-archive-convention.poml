<task id="014" project="ai-procedure-quality-r1">
  <metadata>
    <title>Establish .claude/archive/ convention</title>
    <phase>1</phase>
    <stream>infrastructure</stream>
    <tags>archive, infrastructure, convention</tags>
    <estimate>15min</estimate>
    <rigor>STANDARD</rigor>
    <parallel-group>1-A</parallel-group>
    <parallel-safe>false</parallel-safe>
    <dependencies>none</dependencies>
    <writes-to>.claude/archive/</writes-to>
  </metadata>

  <prompt>
    <goal>Create the .claude/archive/ directory and document the archive-before-delete convention used throughout this project and going forward.</goal>
    <context>Per NF-1 in spec.md: every removal is an archive operation, not a delete. .claude/archive/YYYY-MM-DD/<original-path> preserves anything retired. This task establishes the directory and convention so subsequent tasks (Phase 2b, 3b) have a known place to put archived content.</context>
    <constraints>
      - parallel-safe: false — main session only
      - Include a README.md in .claude/archive/ explaining the convention
      - .gitkeep in 2026-05-14/ subdirectory so the date-organized structure is committable from day one
    </constraints>
  </prompt>

  <knowledge>
    <files>
      <file>projects/ai-procedure-quality-r1/spec.md</file>
    </files>
  </knowledge>

  <steps>
    <step>Create .claude/archive/ directory</step>
    <step>Create .claude/archive/README.md with: purpose, convention (YYYY-MM-DD/original-path format), retention policy (keep indefinitely; git is the actual archive), how to restore (git mv back)</step>
    <step>Create .claude/archive/2026-05-14/ subdirectory (this project's archive date)</step>
    <step>Add .claude/archive/2026-05-14/.gitkeep so directory is committable empty</step>
    <step>Document the convention in .claude/CHANGELOG.md under "Added" for this project's release</step>
  </steps>

  <outputs>
    <output>.claude/archive/README.md</output>
    <output>.claude/archive/2026-05-14/.gitkeep</output>
  </outputs>

  <acceptance-criteria>
    <criterion>Directory structure exists</criterion>
    <criterion>README explains convention clearly</criterion>
    <criterion>Convention is referenced by CHANGELOG entry for this project</criterion>
  </acceptance-criteria>
</task>
