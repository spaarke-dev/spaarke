<task id="082" project="ai-procedure-quality-r1">
  <metadata>
    <title>Schedule monthly audit run</title>
    <phase>5</phase>
    <stream>cadence</stream>
    <tags>schedule, audit, automation</tags>
    <estimate>30min</estimate>
    <rigor>STANDARD</rigor>
    <parallel-safe>true</parallel-safe>
    <dependencies>081</dependencies>
    <writes-to>scripts/quality/, .github/workflows/</writes-to>
  </metadata>

  <prompt>
    <goal>Automate monthly run of Run-ProcedureQualityAudit.ps1. Per resolved decision #1: monthly, 1st of month (or first business day).</goal>
    <context>Options: GHA scheduled workflow OR Claude Code /schedule remote agent. Pick GHA — it's the established mechanism and doesn't require Claude Code subscription state.</context>
  </prompt>

  <steps>
    <step>Create .github/workflows/monthly-procedure-quality.yml</step>
    <step>Trigger: schedule (cron: '0 9 1 * *' — 09:00 UTC on the 1st of every month) + workflow_dispatch for ad-hoc runs</step>
    <step>Job: checkout, run Run-ProcedureQualityAudit.ps1, commit the report to a `chore/quality-audit-<date>` branch, open a PR for review</step>
    <step>PR opens against master; tags maintainers (notification routing per task 073)</step>
    <step>All action references SHA-pinned</step>
    <step>Test by manually running via workflow_dispatch</step>
  </steps>

  <outputs>
    <output>.github/workflows/monthly-procedure-quality.yml</output>
  </outputs>

  <acceptance-criteria>
    <criterion>Scheduled trigger configured</criterion>
    <criterion>workflow_dispatch works for manual runs</criterion>
    <criterion>Auto-PR creation works</criterion>
    <criterion>First manual run produces a real report</criterion>
  </acceptance-criteria>
</task>
