  <ui-tests>
    <test name="3 new action buttons render in order">
      <steps>
        <step>Render `DailyBriefingApp` with a fixture containing 1 unread notification</step>
        <step>Query all per-item buttons</step>
        <step>Verify order: Check, Remove, Keep, Add to To Do</step>
      </steps>
      <expected>4 buttons render; first 3 have the specified Fluent v9 icons</expected>
    </test>

    <test name="Check action invokes markChecked handler">
      <steps>
        <step>Render with a notification item</step>
        <step>Click the Check button</step>
        <step>Verify `markChecked` hook handler called with item id</step>
        <step>Verify optimistic UI update applied</step>
      </steps>
      <expected>Handler invoked; toast shown; item rendered as read</expected>
    </test>

    <test name="Dark mode visual compliance per ADR-021">
      <steps>
        <step>Toggle FluentProvider theme to `webDarkTheme`</step>
        <step>Render widget</step>
        <step>Inspect button icon colors vs background contrast</step>
      </steps>
      <expected>Icons + backgrounds use semantic tokens; contrast ratio meets WCAG AA per ADR-021</expected>
    </test>

    <test name="Existing Add to To Do button regression-free">
      <steps>
        <step>Render with a notification item that has `regardingId`</step>
        <step>Click the existing "Add to To Do" button</step>
        <step>Verify `useInlineTodoCreate` flow still executes</step>
      </steps>
      <expected>4th button still functional; ADR-024 `TODO_REGARDING_CATALOG` resolution preserved</expected>
    </test>
  </ui-tests>

