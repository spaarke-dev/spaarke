<task id="060" project="ai-spaarke-insights-engine-r1">
  <metadata>
    <title>D-P14 — predict-matter-cost synthesis playbook (end-to-end)</title>
    <status>not-started</status>
    <wave>7</wave>
    <estimated-effort>1 day</estimated-effort>
    <tags>playbook-authoring, synthesis, predict-matter-cost, zone-a, evidence-sufficiency</tags>
    <dependencies>020, 021, 022, 023, 041</dependencies>
    <parallel-safe>true</parallel-safe>
    <rigor>FULL</rigor>
    <d-p>D-P14</d-p>
  </metadata>

  <prompt>
    Author the `predict-matter-cost` Insights-mode playbook (the Phase 1 synthesis question per D-54 questions-as-playbooks). Composes Live Facts + Observations + Precedents via new D-P12 node executors. Evidence-sufficiency rule (`comparableMatters.min: 12`) routes to `DeclineToFindNode` on insufficient; otherwise synthesizes Inference and `ReturnInsightArtifactNode` serializes. Per [SPEC.md §3.4.3 worked example](../SPEC.md) and [SPEC-phase-1-minimum.md §6](../SPEC-phase-1-minimum.md).
  </prompt>

  <role>Playbook author + senior .NET developer familiar with Insights-mode metadata, node composition, evidence-sufficiency contracts.</role>

  <goal>
    `predict-matter-cost@v1` published in Dataverse playbook entity with full Insights-mode metadata (tier=inference, evidence rule, insufficient-evidence template, cache TTL, parameter schema). Node graph composes: LiveFactNode (current matter facts) → IndexRetrieveNode×2 (cohort outcomes + applicable Precedents) → EvidenceSufficiencyNode → [if sufficient] AiAnalysisNodeExecutor (synthesis) → GroundingVerifyNode → ReturnInsightArtifactNode; [if insufficient] DeclineToFindNode → ReturnInsightArtifactNode. Invoked via `IInsightsAi.AnswerQuestionAsync`.
  </goal>

  <inputs>
    <file purpose="spec">projects/ai-spaarke-insights-engine-r1/SPEC.md (§3.1 D-P14, §3.4.3 synthesis query worked example)</file>
    <file purpose="rationale">projects/ai-spaarke-insights-engine-r1/SPEC-phase-1-minimum.md (§6 synthesis path)</file>
    <file purpose="claude">projects/ai-spaarke-insights-engine-r1/CLAUDE.md</file>
  </inputs>

  <constraints>
    <constraint source="D-54">Implemented as Spaarke playbook (NOT custom orchestration code)</constraint>
    <constraint source="D-06">Evidence-sufficiency rule MANDATORY; routes to DeclineToFindNode on insufficient</constraint>
    <constraint source="D-47">GroundingVerifyNode MANDATORY after synthesis before ReturnInsightArtifactNode</constraint>
    <constraint source="D-A23">ReturnInsightArtifactNode's EvidenceGuard.Validate prevents empty-evidence Inference</constraint>
    <constraint source="D-P13">Playbook execution cached via InsightsPlaybookExecutionCache (default TTL 5 min)</constraint>
  </constraints>

  <knowledge>
    <topic>playbook-authoring, synthesis-orchestration, evidence-sufficiency, predict-matter-cost</topic>
    <files>
      <file>docs/adr/ADR-013-ai-architecture.md</file>
      <file>docs/adr/ADR-009-redis-first-caching.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Read SPEC §3.4.3 + SPEC-phase-1-minimum.md §6">Confirm node graph + acceptance behavior</step>
    <step order="2" name="Author Insights-mode metadata">tier=inference; evidence rule `{comparableMatters: {min: 12}}`; insufficient-evidence template per D-49; parameter schema `{matterId, optionalConstraints?}`; cache TTL 300s</step>
    <step order="3" name="Author node graph">Per goal section — composes LiveFactNode + IndexRetrieveNode×2 + EvidenceSufficiencyNode + (conditional branch via ConditionNodeExecutor) + AiAnalysisNodeExecutor + GroundingVerifyNode + DeclineToFindNode + ReturnInsightArtifactNode</step>
    <step order="4" name="Author synthesis prompt">predict-matter-cost-synthesis@v1 — composes cohort Observations + Precedents + Live Facts into Inference with cited evidence; verbatim quote rule applies to citations</step>
    <step order="5" name="Publish playbook">Via existing playbook publish flow; Insights-mode discoverable by IInsightsAi.AnswerQuestionAsync</step>
    <step order="6" name="End-to-end integration test">Mock data scenarios: (a) 15 comparable matters → Inference returned with 12+ evidence refs; (b) 5 comparable matters → DeclineResponse with MinimumEvidenceNeeded field populated; (c) synthetic bad citation → GroundingVerifyNode strips it</step>
    <step order="7" name="Quality gates">code-review + adr-check</step>
  </steps>

  <tools>
    <tool name="dotnet">Build and test</tool>
    <tool name="dataverse">Playbook publish</tool>
  </tools>

  <outputs>
    <output type="playbook">Dataverse playbook "predict-matter-cost@v1" published as Insights-mode</output>
    <output type="prompt">src/server/api/Sprk.Bff.Api/Services/Ai/Insights/Prompts/predict-matter-cost-synthesis.v1.txt</output>
    <output type="config">src/server/api/Sprk.Bff.Api/Services/Ai/Insights/Playbooks/predict-matter-cost.playbook.json</output>
    <output type="test">tests/integration/Services/Ai/Insights/PredictMatterCostPlaybookTests.cs</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Playbook publishes successfully as Insights-mode</criterion>
    <criterion testable="true">Sufficient-evidence test: 15 mock comparable matters → Inference returned with 12+ evidence refs in evidence[]</criterion>
    <criterion testable="true">Insufficient-evidence test: 5 mock comparable matters → DeclineResponse with MinimumEvidenceNeeded ≥ 7 (gap analysis)</criterion>
    <criterion testable="true">GroundingVerifyNode strips one synthetic fabricated citation from Inference output</criterion>
    <criterion testable="true">Precedent citation: if applicable Confirmed Precedent exists, it's cited in Inference evidence[] as precedent://... ref</criterion>
    <criterion testable="true">D-P13 cache hit on second identical invocation (verified via App Insights cache_hit event)</criterion>
  </acceptance-criteria>
</task>
