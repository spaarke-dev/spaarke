{
  "$schema": "https://spaarke.com/schemas/playbook-definition/v1",
  "playbook": {
    "id": "NP-004",
    "name": "New Emails on Matters",
    "description": "Notifies users when new emails have been received on their assigned matters since the last check. Queries email activity records linked to matters where the user is a team member, filtered by the configurable timeWindow parameter.",
    "sprk_playbooktype": 2,
    "isPublic": true,
    "isSystemPlaybook": true,
    "sprk_configjson": {
      "schedule": {
        "frequency": "daily",
        "time": "06:00"
      },
      "category": "new-emails",
      "channelLabel": "New Emails",
      "channelIcon": "mail",
      "parameters": {
        "timeWindow": {
          "type": "duration",
          "default": "24h",
          "options": ["12h", "24h", "48h", "7d"],
          "label": "Time window",
          "description": "How far back to look for new emails"
        }
      }
    },
    "scopes": {
      "actions": [],
      "skills": [],
      "knowledge": [],
      "tools": []
    }
  },
  "nodes": [
    {
      "name": "Start",
      "nodeType": "Control",
      "actionType": null,
      "canvasType": "start",
      "outputVariable": "start",
      "positionX": 100,
      "positionY": 200,
      "dependsOn": [],
      "configJson": {
        "scope": "user-matters",
        "resolveUserId": true,
        "description": "Scoped to the current user's assigned matters"
      }
    },
    {
      "name": "Query New Emails",
      "nodeType": "Workflow",
      "actionType": 22,
      "canvasType": "updateRecord",
      "outputVariable": "newEmails",
      "positionX": 350,
      "positionY": 200,
      "dependsOn": ["Start"],
      "configJson": {
        "__actionType": 22,
        "queryMode": true,
        "entityLogicalName": "email",
        "fetchXml": "<fetch top='50'><entity name='email'><attribute name='subject'/><attribute name='sender'/><attribute name='createdon'/><attribute name='regardingobjectid'/><attribute name='activityid'/><filter type='and'><condition attribute='directioncode' operator='eq' value='0'/><condition attribute='createdon' operator='ge' value='{{sinceTimestamp}}'/></filter><link-entity name='sprk_matter' from='sprk_matterid' to='regardingobjectid' link-type='inner'><attribute name='sprk_name'/></link-entity><order attribute='createdon' descending='true'/></entity></fetch>",
        "parameters": {
          "sinceTimestamp": "{{timeWindow}}"
        },
        "description": "Retrieve inbound emails linked to user's matters received within the configured time window"
      }
    },
    {
      "name": "Has New Emails?",
      "nodeType": "Control",
      "actionType": 30,
      "canvasType": "condition",
      "outputVariable": "hasNewEmails",
      "positionX": 600,
      "positionY": 200,
      "dependsOn": ["Query New Emails"],
      "configJson": {
        "__actionType": 30,
        "conditionJson": "{{newEmails.output.count}} > 0",
        "description": "Check if any new emails were found"
      }
    },
    {
      "name": "Create Notification",
      "nodeType": "Workflow",
      "actionType": 50,
      "canvasType": "createNotification",
      "outputVariable": "notification",
      "positionX": 900,
      "positionY": 150,
      "dependsOn": ["Has New Emails?"],
      "configJson": {
        "__actionType": 50,
        "title": "You have {{newEmails.output.count}} new email(s) on your matters",
        "body": "{{#each newEmails.output.items}}From {{sender}}: {{subject}} ({{regardingMatterName}})\n{{/each}}",
        "category": "new-emails",
        "priority": 100000000,
        "actionUrl": "/main.aspx?pagetype=entitylist&etn=email&viewtype=1039",
        "recipientId": "{{run.userId}}",
        "regardingType": "email",
        "iterateItems": true,
        "itemNotification": {
          "title": "New email on {{item.regardingMatterName}}",
          "body": "From {{item.sender}}: {{item.subject}}",
          "category": "new-emails",
          "priority": 100000000,
          "actionUrl": "/main.aspx?pagetype=entityrecord&etn=email&id={{item.activityid}}",
          "recipientId": "{{run.userId}}",
          "regardingId": "{{item.activityid}}",
          "regardingType": "email"
        },
        "deduplication": {
          "enabled": true,
          "key": "new-emails:{{run.userId}}:{{item.activityid}}"
        }
      }
    }
  ],
  "edges": [
    { "source": "Start", "target": "Query New Emails" },
    { "source": "Query New Emails", "target": "Has New Emails?" },
    { "source": "Has New Emails?", "target": "Create Notification", "condition": "true" }
  ]
}
