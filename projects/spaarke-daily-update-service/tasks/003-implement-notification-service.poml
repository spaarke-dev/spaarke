  <prompt>
    Implement NotificationService as a shared BFF singleton for creating appnotification records inline from BFF endpoints. This service provides a simple CreateNotificationAsync method that existing endpoints will call after operations like document upload, analysis complete, etc.
  </prompt>

  <role>
    SPAARKE platform developer. Expert in ASP.NET Core services and Dataverse Web API integration.
  </role>

  <goal>
    NotificationService.cs exists as a singleton service with CreateNotificationAsync method that creates appnotification records via Dataverse Web API. Supports title, body, category, priority, actionUrl, regardingId, and optional AI metadata.
  </goal>

  <context>
    <background>
      Inline notifications are triggered by BFF endpoint operations (upload, analysis, email). NotificationService centralizes this creation logic so each endpoint just calls CreateNotificationAsync.
    </background>
    <relevant-files>
      <file>src/server/api/Sprk.Bff.Api/Services/</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-010">Register as singleton concrete — no interface unless seam needed</constraint>
    <constraint source="ADR-001">Must be within BFF runtime</constraint>
    <constraint source="project">MUST use Dataverse Web API for appnotification creation</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-010-di-minimalism.md</file>
      <file>.claude/constraints/api.md</file>
      <file>.claude/patterns/api/service-registration.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Review existing service patterns in Services/ directory</step>
    <step order="2">Create NotificationService.cs in Services/</step>
    <step order="3">Implement CreateNotificationAsync(userId, title, body, category, priority, actionUrl, regardingId, aiMetadata?)</step>
    <step order="4">Use DataverseWebApiService (or HttpClient) to POST to appnotification entity</step>
    <step order="5">Include proper error handling and logging</step>
    <step order="6">Run dotnet build to verify compilation</step>
    <step order="7">Update TASK-INDEX.md: change this task's status to ✅ completed</step>
  </steps>

  <tools>
    <tool name="dotnet">Build and test .NET projects</tool>
  </tools>

  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/NotificationService.cs</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">NotificationService.cs exists with CreateNotificationAsync method</criterion>
    <criterion testable="true">Creates appnotification with all required fields</criterion>
    <criterion testable="true">dotnet build succeeds</criterion>
  </acceptance-criteria>

