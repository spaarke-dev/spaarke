  <role>
    SPAARKE platform developer. Expert in xUnit testing and mocking patterns.
  </role>

  <goal>
    Unit tests cover: executor creates notification, executor skips duplicate, service creates appnotification, error handling. All tests pass.
  </goal>

  <context>
