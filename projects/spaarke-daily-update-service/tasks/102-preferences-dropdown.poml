      <file>.claude/adr/ADR-012-shared-components.md</file>
    </files>
  </knowledge>
  <steps>
    <step order="1">Create PreferencesDropdown.tsx with Fluent Popover + PopoverTrigger + PopoverSurface.</step>
    <step order="2">Add Settings20Regular gear icon as trigger button.</step>
    <step order="3">Port channel toggles from PreferencesPanel (Switch components).</step>
    <step order="4">Port parameter dropdowns (Dropdown components).</step>
    <step order="5">Port auto-popup toggle.</step>
    <step order="6">Wire onUpdatePreferences for immediate persistence.</step>
    <step order="7">Style with Fluent v9 tokens, ~280px width.</step>
    <step order="8">Build to verify.</step>
  </steps>
  <outputs>
    <output type="code">PreferencesDropdown.tsx in DailyBriefing/src/components/</output>
  </outputs>
  <acceptance-criteria>
    <criterion testable="true">Gear icon opens popover with all preference controls.</criterion>
    <criterion testable="true">All preferences editable: channel toggles, due window, recency, AI threshold, auto-popup.</criterion>
    <criterion testable="true">Changes persist immediately via onUpdatePreferences callback.</criterion>
    <criterion testable="true">Popover dismisses on outside click.</criterion>
    <criterion testable="true">Dark mode works correctly.</criterion>
    <criterion testable="true">Build succeeds with no errors.</criterion>
  </acceptance-criteria>
