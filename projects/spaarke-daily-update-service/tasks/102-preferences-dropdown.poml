  <prompt>Create PreferencesDropdown.tsx to replace the bottom PreferencesPanel. Uses Fluent Popover anchored to a gear icon (Settings20Regular) in the header toolbar. Popover width ~280px, right-aligned. Contains: channel toggle switches (all channels except system), due window dropdown (1,2,3,5,7 days), recency dropdown (12h,24h,48h,7d), AI threshold dropdown (60,75,85,95%), auto-popup toggle. Changes persist immediately via onUpdatePreferences callback. Same DailyDigestPreferences type as current PreferencesPanel.</prompt>
  <role>SPAARKE platform developer.</role>
  <goal>Gear icon opens preferences dropdown popover — replaces collapsible bottom panel</goal>
  <context>
    <relevant-files>
      <file>src/solutions/DailyBriefing/src/components/PreferencesPanel.tsx</file>
      <file>src/solutions/DailyBriefing/src/types/notifications.ts</file>
    </relevant-files>
  </context>
  <knowledge>
