  <steps>
    <step order="1">Update App.tsx imports: add new components, remove old.</step>
    <step order="2">Replace useAiBriefing with useBriefingNarration.</step>
    <step order="3">Update render: DigestHeader (with PreferencesDropdown) then TldrSection then ActivityNotesSection then CaughtUpFooter.</step>
    <step order="4">Wire useInlineTodoCreate hook.</step>
    <step order="5">Wire dismiss handler for notification mark-as-read.</step>
    <step order="6">Wire record link navigation (Xrm.Navigation.navigateTo).</step>
    <step order="7">Update DigestHeader: remove markAllRead, add gear icon.</step>
    <step order="8">Delete old files: AiBriefing.tsx, NarrativeSummary.tsx, ChannelCard.tsx, NotificationItem.tsx, ChannelErrorState.tsx, PreferencesPanel.tsx.</step>
    <step order="9">Build to verify.</step>
    <step order="10">Update TASK-INDEX.md.</step>
  </steps>
  <outputs>
    <output type="code">Updated App.tsx with narrative layout</output>
    <output type="code">Updated DigestHeader with PreferencesDropdown</output>
    <output type="code">Deleted old component files</output>
  </outputs>
  <acceptance-criteria>
    <criterion testable="true">Briefing renders narrative layout: TldrSection at top, ActivityNotesSection in middle, CaughtUpFooter at bottom.</criterion>
