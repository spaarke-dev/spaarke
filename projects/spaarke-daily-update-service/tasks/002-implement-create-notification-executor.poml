  <prompt>
    Implement CreateNotificationNodeExecutor following the existing CreateTaskNodeExecutor pattern. The executor creates appnotification records via Dataverse Web API with idempotency check — if unread notification exists for same user + regarding record + category, skip creation.
  </prompt>

  <role>
    SPAARKE platform developer. Expert in playbook engine node executors and Dataverse Web API.
  </role>

  <goal>
    CreateNotificationNodeExecutor.cs exists, implements INodeExecutor for ActionType.CreateNotification (50), creates appnotification records with title, body, category, priority, action URL, regarding record, and AI metadata. Idempotency check prevents duplicates.
  </goal>

  <context>
    <background>
      The playbook engine executes nodes by routing ActionType to INodeExecutor implementations. We need a new executor that creates Dataverse appnotification records.
    </background>
    <relevant-files>
      <file>src/server/api/Sprk.Bff.Api/Services/Ai/Nodes/CreateTaskNodeExecutor.cs</file>
      <file>src/server/api/Sprk.Bff.Api/Services/Ai/Nodes/INodeExecutor.cs</file>
      <file>src/server/api/Sprk.Bff.Api/Services/Ai/Nodes/NodeExecutorRegistry.cs</file>
      <file>src/server/api/Sprk.Bff.Api/Services/Ai/NodeExecutionContext.cs</file>
    </relevant-files>
  </context>

  <constraints>
    <constraint source="ADR-001">Must be within BFF runtime</constraint>
    <constraint source="ADR-010">Register as concrete, not interface</constraint>
    <constraint source="project">MUST implement idempotency — query before create</constraint>
    <constraint source="project">MUST use Dataverse Web API for appnotification creation</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-001-minimal-api.md</file>
      <file>.claude/adr/ADR-010-di-minimalism.md</file>
