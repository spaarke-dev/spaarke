    </files>
    <patterns>
      <pattern name="Node executor pattern" location="src/server/api/Sprk.Bff.Api/Services/Ai/Nodes/CreateTaskNodeExecutor.cs">
        Follow this exact pattern for implementing INodeExecutor
      </pattern>
    </patterns>
  </knowledge>

  <steps>
    <step order="1">Read CreateTaskNodeExecutor.cs to understand the INodeExecutor pattern</step>
    <step order="2">Read NodeExecutionContext.cs to understand context available during execution</step>
    <step order="3">Create CreateNotificationNodeExecutor.cs in Services/Ai/Nodes/</step>
    <step order="4">Implement ActionType property returning CreateNotification (50)</step>
    <step order="5">Implement ExecuteAsync: extract title, body, category, priority, actionUrl, regardingId from node config</step>
    <step order="6">Add idempotency check: query appnotification for unread + same user + same regarding + same category</step>
    <step order="7">If no duplicate found, create appnotification via Dataverse Web API</step>
    <step order="8">Return NodeOutput with success/skip status</step>
    <step order="9">Run dotnet build to verify compilation</step>
    <step order="10">Update TASK-INDEX.md: change this task's status to ✅ completed</step>
  </steps>

  <tools>
    <tool name="dotnet">Build and test .NET projects</tool>
  </tools>

  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Ai/Nodes/CreateNotificationNodeExecutor.cs</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">CreateNotificationNodeExecutor implements INodeExecutor</criterion>
    <criterion testable="true">ActionType returns CreateNotification (50)</criterion>
    <criterion testable="true">Idempotency check queries for existing unread notification before creating</criterion>
