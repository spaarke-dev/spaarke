    <output type="code">src/solutions/DailyBriefing/src/types/notifications.ts</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Queries appnotification via Xrm.WebApi</criterion>
    <criterion testable="true">Groups notifications by category</criterion>
