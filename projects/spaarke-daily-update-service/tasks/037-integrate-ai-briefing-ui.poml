  <prompt>
    Integrate the AI briefing summary into the Daily Digest Code Page. Fetch from POST /api/ai/daily-briefing/summarize, render at top of digest with priority action items. Show loading state and graceful fallback if AI is unavailable.
  </prompt>

  <role>SPAARKE platform developer.</role>

  <goal>AI briefing renders at top of digest with 3-4 sentence narrative and priority action items. Graceful fallback when AI unavailable.</goal>

  <context>
    <relevant-files>
      <file>src/solutions/DailyBriefing/src/</file>
    </relevant-files>
  </context>

  <constraints>
