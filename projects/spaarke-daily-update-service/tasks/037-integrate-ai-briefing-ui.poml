    <constraint source="ADR-021">Fluent v9 tokens for styling</constraint>
  </constraints>

  <knowledge>
    <files>
      <file>.claude/adr/ADR-021-fluent-design-system.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1">Create AiBriefing.tsx component</step>
    <step order="2">Fetch summary from BFF endpoint via authenticated call</step>
    <step order="3">Render briefing text and priority action items</step>
    <step order="4">Add loading skeleton state</step>
    <step order="5">Add fallback when AI unavailable (show template-based summary only)</step>
    <step order="6">Label AI content with "AI Insight" indicator</step>
    <step order="7">Wire into App.tsx above channel cards</step>
    <step order="8">Update TASK-INDEX.md: change this task's status to ✅ completed</step>
