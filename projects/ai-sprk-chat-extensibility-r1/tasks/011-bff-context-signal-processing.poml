<task id="CHAT-011" project="SprkChat Analysis Workspace Command Center">
  <metadata>
    <title>BFF context signal processing in system prompt and routing</title>
    <status>not-started</status>
    <phase>1</phase>
    <estimated-effort>4 hours</estimated-effort>
    <tags>bff-api, ai, context-enrichment</tags>
    <parallel-group>none</parallel-group>
    <parallel-safe>true</parallel-safe>
    <dependencies>CHAT-010</dependencies>
  </metadata>

  <prompt>
    Enhance the BFF to receive and process client-side context signals (FR-05, FR-10).
    PlaybookChatContextProvider must incorporate context signals into the system prompt
    and tool selection. The AI model should use these signals for improved routing accuracy.
  </prompt>

  <role>Senior .NET developer familiar with BFF Minimal API and AI chat pipeline.</role>

  <goal>
    BFF ChatEndpoints receive enriched payload with context signals, and PlaybookChatContextProvider
    incorporates them into the system prompt for improved AI routing accuracy.
  </goal>

  <inputs>
    <file purpose="target">src/server/api/Sprk.Bff.Api/Api/Ai/ChatEndpoints.cs</file>
    <file purpose="target">src/server/api/Sprk.Bff.Api/Services/Ai/Chat/PlaybookChatContextProvider.cs</file>
    <file purpose="reference">src/server/api/Sprk.Bff.Api/Services/Ai/Chat/SprkChatAgent.cs</file>
    <file purpose="spec">projects/ai-sprk-chat-extensibility-r1/spec.md</file>
  </inputs>

  <constraints>
    <constraint source="ADR-001">Minimal API patterns</constraint>
    <constraint source="ADR-008">Endpoint filters for authorization</constraint>
    <constraint source="ADR-013">Flow ChatHostContext through pipeline; AI extends BFF</constraint>
    <constraint source="FR-10">Natural language routing uses enriched context signals</constraint>
  </constraints>

  <knowledge>
    <topic>bff-ai-pipeline, context-routing</topic>
    <files>
      <file>.claude/adr/ADR-001-minimal-api.md</file>
      <file>.claude/adr/ADR-013-ai-architecture.md</file>
      <file>.claude/patterns/api/endpoint-definition.md</file>
      <file>.claude/constraints/ai.md</file>
      <file>.claude/constraints/api.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Read ChatEndpoints">Understand current message payload structure and how messages flow to AI.</step>
    <step order="2" name="Read PlaybookChatContextProvider">Understand how system prompt is built and tools are registered.</step>
    <step order="3" name="Add ContextSignals DTO">Create C# DTO matching the client IContextSignals type. Add to chat message request model.</step>
    <step order="4" name="Enhance system prompt">Modify PlaybookChatContextProvider to include context signals in system prompt (editor selection, document type, conversation phase).</step>
    <step order="5" name="Enhance tool selection">Use available_actions from context to prioritize relevant tools in the AI model's tool list.</step>
    <step order="6" name="Write unit tests">Test system prompt generation with and without context signals.</step>
  </steps>

  <tools>
    <tool name="dotnet">Build and test .NET</tool>
    <tool name="git">Version control</tool>
  </tools>

  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/Api/Ai/ChatEndpoints.cs (modified)</output>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Ai/Chat/PlaybookChatContextProvider.cs (modified)</output>
    <output type="code">New ContextSignals DTO class</output>
    <output type="test">Unit tests for context signal processing</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">BFF accepts context signals in chat message payload</criterion>
    <criterion testable="true">System prompt includes context signal information when present</criterion>
    <criterion testable="true">AI routing accuracy improves with context signals (manual verification)</criterion>
    <criterion testable="true">dotnet build succeeds; unit tests pass</criterion>
  </acceptance-criteria>
</task>
