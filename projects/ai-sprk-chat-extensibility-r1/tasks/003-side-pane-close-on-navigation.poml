<task id="CHAT-003" project="SprkChat Analysis Workspace Command Center">
  <metadata>
    <title>Implement side pane close on navigation away from Analysis</title>
    <status>not-started</status>
    <phase>0</phase>
    <estimated-effort>3 hours</estimated-effort>
    <tags>code-page, side-pane, lifecycle</tags>
    <parallel-group>B</parallel-group>
    <parallel-safe>true</parallel-safe>
    <dependencies>none</dependencies>
  </metadata>

  <prompt>
    When user navigates away from an Analysis record (to Corporate Workspace, matter form, etc.),
    the sprkchat-analysis side pane MUST be explicitly closed. Implement dual mechanism:
    1. Primary: useEffect cleanup in AnalysisWorkspace/App.tsx calls Xrm.App.sidePanes.getPane('sprkchat-analysis')?.close()
    2. Fallback: contextService.ts poll detects entityType change away from sprk_analysisoutput → triggers pane close.
    This is FR-03.
  </prompt>

  <role>
    Frontend developer experienced with Dataverse side pane APIs and React lifecycle.
  </role>

  <goal>
    Navigating from Analysis Workspace to any other page (Corporate Workspace, matter form, etc.)
    automatically closes the SprkChat side pane with no orphaned panes remaining.
  </goal>

  <inputs>
    <file purpose="target">src/client/code-pages/AnalysisWorkspace/src/App.tsx</file>
    <file purpose="target">src/client/code-pages/SprkChatPane/src/services/contextService.ts</file>
    <file purpose="reference">src/client/code-pages/SprkChatPane/launcher/openSprkChatPane.ts</file>
    <file purpose="spec">projects/ai-sprk-chat-extensibility-r1/spec.md</file>
  </inputs>

  <constraints>
    <constraint source="ADR-006">Code Page pattern — React 18+, bundled</constraint>
    <constraint source="NFR-04">Close must execute within 2-second poll interval</constraint>
    <constraint source="FR-03">Dual mechanism: useEffect cleanup + contextService poll fallback</constraint>
  </constraints>

  <knowledge>
    <topic>side-pane-lifecycle, code-pages</topic>
    <files>
      <file>.claude/adr/ADR-006-pcf-over-webresources.md</file>
      <file>.claude/constraints/webresource.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Read AnalysisWorkspace App.tsx">
      Understand current component structure and identify where useEffect cleanup should go.
    </step>
    <step order="2" name="Read contextService.ts">
      Understand the existing 2-second poll mechanism and entityType detection.
    </step>
    <step order="3" name="Add useEffect cleanup to AnalysisWorkspace">
      In AnalysisWorkspace/App.tsx, add useEffect cleanup that calls
      Xrm.App.sidePanes.getPane('sprkchat-analysis')?.close() on unmount.
    </step>
    <step order="4" name="Add fallback close to contextService">
      In contextService.ts, detect when entityType changes away from sprk_analysisoutput
      and trigger pane close via Xrm.App.sidePanes API.
    </step>
    <step order="5" name="Test dual mechanism">
      Verify both mechanisms work: useEffect fires on component unmount, and poll detects
      entity change as fallback.
    </step>
  </steps>

  <tools>
    <tool name="npm">Build TypeScript</tool>
    <tool name="git">Version control</tool>
  </tools>

  <outputs>
    <output type="code">src/client/code-pages/AnalysisWorkspace/src/App.tsx (modified)</output>
    <output type="code">src/client/code-pages/SprkChatPane/src/services/contextService.ts (modified)</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Navigating from Analysis to Corporate Workspace closes SprkChat pane</criterion>
    <criterion testable="true">No orphaned SprkChat pane after navigation</criterion>
    <criterion testable="true">Both useEffect cleanup and poll fallback work independently</criterion>
  </acceptance-criteria>
</task>
