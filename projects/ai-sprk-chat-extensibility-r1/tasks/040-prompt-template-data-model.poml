<task id="CHAT-040" project="SprkChat Analysis Workspace Command Center">
  <metadata>
    <title>Prompt template data model and Dataverse configuration</title>
    <status>not-started</status>
    <phase>4</phase>
    <estimated-effort>4 hours</estimated-effort>
    <tags>bff-api, dataverse, configuration</tags>
    <parallel-group>F</parallel-group>
    <parallel-safe>true</parallel-safe>
    <dependencies>Phase 3 complete</dependencies>
  </metadata>

  <prompt>
    Design and implement the data model for parameterized prompt templates (FR-16).
    Templates stored in Dataverse (extending playbook configuration) with fill-in-the-blank
    parameters. BFF endpoints to CRUD templates and resolve parameters.
  </prompt>

  <role>Full-stack developer with Dataverse data modeling and BFF API expertise.</role>

  <goal>
    Prompt templates stored in Dataverse with parameter definitions, accessible via BFF
    endpoints. Admin can create new templates; they appear in SprkChat within 5 minutes.
  </goal>

  <inputs>
    <file purpose="reference">src/server/api/Sprk.Bff.Api/Api/Ai/PlaybookEndpoints.cs</file>
    <file purpose="reference">src/server/api/Sprk.Bff.Api/Services/Ai/Chat/PlaybookChatContextProvider.cs</file>
    <file purpose="spec">projects/ai-sprk-chat-extensibility-r1/spec.md</file>
  </inputs>

  <constraints>
    <constraint source="ADR-001">Minimal API patterns</constraint>
    <constraint source="ADR-008">Endpoint filters for authorization</constraint>
    <constraint source="FR-16">Templates with fill-in parameters; available within 5 minutes of creation</constraint>
  </constraints>

  <knowledge>
    <topic>prompt-templates, dataverse-config, playbook-extensions</topic>
    <files>
      <file>.claude/adr/ADR-001-minimal-api.md</file>
      <file>.claude/adr/ADR-013-ai-architecture.md</file>
      <file>.claude/patterns/api/endpoint-definition.md</file>
      <file>.claude/constraints/data.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Design data model">
      Define template structure: name, description, prompt text with {parameter} placeholders,
      parameter definitions (name, type, required, description).
      Decide: extend playbook entity or new related table.
    </step>
    <step order="2" name="Create BFF template endpoints">
      GET /api/ai/templates — List available templates (with caching, 5-min TTL).
      GET /api/ai/templates/{id} — Get template with parameter definitions.
    </step>
    <step order="3" name="Create template resolution service">
      Service that takes template + parameter values → resolved prompt string.
    </step>
    <step order="4" name="Integrate with chat pipeline">
      When user selects template and fills parameters, resolved prompt sent as chat message.
    </step>
    <step order="5" name="Write tests">Test template CRUD, parameter resolution, caching.</step>
  </steps>

  <tools>
    <tool name="dotnet">Build and test</tool>
    <tool name="git">Version control</tool>
  </tools>

  <outputs>
    <output type="code">BFF template endpoints and service</output>
    <output type="code">Template data model</output>
    <output type="test">Template service tests</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Templates stored in Dataverse with parameter definitions</criterion>
    <criterion testable="true">BFF endpoints return available templates</criterion>
    <criterion testable="true">Template resolution correctly fills parameters</criterion>
    <criterion testable="true">New templates appear within 5 minutes (caching TTL)</criterion>
  </acceptance-criteria>
</task>
