<task id="CHAT-030" project="SprkChat Analysis Workspace Command Center">
  <metadata>
    <title>Enhance PlanPreviewCard with edit/cancel for compound actions</title>
    <status>not-started</status>
    <phase>3</phase>
    <estimated-effort>4 hours</estimated-effort>
    <tags>fluent-ui, code-page, component</tags>
    <parallel-group>E</parallel-group>
    <parallel-safe>true</parallel-safe>
    <dependencies>CHAT-016</dependencies>
  </metadata>

  <prompt>
    Enhance the existing PlanPreviewCard component (FR-12) to support compound action plan
    preview. Any action requiring 2+ tool calls MUST show a numbered step plan before executing.
    User actions: [Proceed], [Edit plan], [Cancel]. "Edit plan" allows conversational modification.
    Data-modifying or email-sending actions always require plan preview.
  </prompt>

  <role>Senior React/Fluent UI v9 developer.</role>

  <goal>
    PlanPreviewCard supports Proceed, Edit plan, and Cancel actions. Edit plan enables
    conversational modification of the plan before execution.
  </goal>

  <inputs>
    <file purpose="target">src/client/shared/Spaarke.UI.Components/src/components/SprkChat/PlanPreviewCard.tsx</file>
    <file purpose="reference">src/client/shared/Spaarke.UI.Components/src/components/SprkChat/types.ts</file>
    <file purpose="spec">projects/ai-sprk-chat-extensibility-r1/spec.md</file>
  </inputs>

  <constraints>
    <constraint source="ADR-012">Callback-based props</constraint>
    <constraint source="ADR-021">Fluent v9; dark mode</constraint>
    <constraint source="FR-12">Data-modifying/email actions MUST show plan regardless of step count</constraint>
  </constraints>

  <knowledge>
    <topic>plan-preview, compound-actions</topic>
    <files>
      <file>.claude/adr/ADR-012-shared-components.md</file>
      <file>.claude/adr/ADR-021-fluent-design-system.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Read existing PlanPreviewCard">Understand current props, rendering, and action handling.</step>
    <step order="2" name="Add Edit plan action">
      Add "Edit plan" button alongside Proceed and Cancel. Edit switches to conversational
      mode where user can say "skip step 2" or "also include the deadline".
    </step>
    <step order="3" name="Implement plan editing state">
      Track plan editing state. Show editable plan with user modification capability.
      AI re-generates plan based on user's edits.
    </step>
    <step order="4" name="Add mandatory preview logic">
      Accept a `requiresPreview` prop. When true, plan preview is shown even for single-step
      actions (used for data-modifying and email actions).
    </step>
    <step order="5" name="Write tests">Test all three actions, plan editing, and mandatory preview.</step>
  </steps>

  <tools>
    <tool name="npm">Build and test</tool>
    <tool name="git">Version control</tool>
  </tools>

  <outputs>
    <output type="code">src/client/shared/Spaarke.UI.Components/src/components/SprkChat/PlanPreviewCard.tsx (modified)</output>
    <output type="test">Enhanced PlanPreviewCard tests</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">Proceed, Edit plan, and Cancel buttons rendered</criterion>
    <criterion testable="true">Edit plan enables conversational plan modification</criterion>
    <criterion testable="true">requiresPreview=true forces preview even for 1-step actions</criterion>
    <criterion testable="true">Dark mode renders correctly</criterion>
  </acceptance-criteria>
</task>
