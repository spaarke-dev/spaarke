<task id="CHAT-043" project="SprkChat Analysis Workspace Command Center">
  <metadata>
    <title>Phase 4 integration tests for templates and playbook library</title>
    <status>not-started</status>
    <phase>4</phase>
    <estimated-effort>3 hours</estimated-effort>
    <tags>testing, integration-test</tags>
    <parallel-group>none</parallel-group>
    <parallel-safe>true</parallel-safe>
    <dependencies>CHAT-040, CHAT-041, CHAT-042</dependencies>
  </metadata>

  <prompt>
    Write integration tests for Phase 4: template selection → parameter fill → execute,
    playbook library browse → search → activate, and end-to-end template-to-response flow.
  </prompt>

  <role>Test engineer.</role>

  <goal>
    Comprehensive integration tests for all Phase 4 features.
  </goal>

  <inputs>
    <file purpose="reference">All Phase 4 task outputs</file>
    <file purpose="spec">projects/ai-sprk-chat-extensibility-r1/spec.md</file>
  </inputs>

  <constraints>
    <constraint source="testing">80% coverage on new code</constraint>
  </constraints>

  <knowledge>
    <topic>integration-testing</topic>
    <files>
      <file>.claude/constraints/testing.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Test template flow">Select template → fill params → send → verify response.</step>
    <step order="2" name="Test playbook browser">Open /playbooks → search → activate → verify switch.</step>
    <step order="3" name="Test caching">Verify new templates appear within 5 minutes.</step>
    <step order="4" name="Run full test suite">Verify no regressions.</step>
  </steps>

  <tools>
    <tool name="npm">Run Jest tests</tool>
    <tool name="dotnet">Run .NET tests</tool>
    <tool name="git">Version control</tool>
  </tools>

  <outputs>
    <output type="test">Phase 4 integration test files</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">All Phase 4 integration tests pass</criterion>
    <criterion testable="true">All existing tests still pass</criterion>
  </acceptance-criteria>
</task>
