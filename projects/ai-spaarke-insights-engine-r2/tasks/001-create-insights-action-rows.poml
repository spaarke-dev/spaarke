    <file purpose="jps-skill-conventions">.claude/skills/jps-action-create/SKILL.md + .claude/skills/jps-playbook-design/SKILL.md</file>
  </inputs>

  <constraints>
    <constraint source="owner-direction-2026-06-02">JPS authoring MUST follow jps-action-create + jps-playbook-design conventions; no inline JPS authoring by task-execute</constraint>
    <constraint source="D-01 §3 Q1">Determine: is sprk_actiontype (int) directly writeable, or is the value derived from sprk_actiontypeid lookup?</constraint>
    <constraint source="D-01 §3 Q2">Determine: what is the lookup target entity for sprk_actiontypeid? What is its row schema (logical name, fields, how the ActionType integer is encoded)?</constraint>
    <constraint source="D-01 §3 Q3">Determine: what prevents the Make Playbook Designer UI from clobbering sprk_configjson when an Insights playbook is opened post-deploy?</constraint>
  </constraints>

  <knowledge>
