<task id="034" project="ai-spaarke-insights-engine-r2">
  <metadata>
    <title>D5 — Multi-entity subject schemes + per-entity ILiveFactResolver (matter, project, invoice)</title>
    <status>completed</status>
    <wave>D</wave>
    <estimated-effort>2d</estimated-effort>
    <tags>multi-entity, ILiveFactResolver, subject-parser, di, zone-a, bff-api</tags>
    <dependencies>015, 023</dependencies>
