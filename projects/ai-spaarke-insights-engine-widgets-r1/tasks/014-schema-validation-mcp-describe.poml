    <step order="2" name="Web API list with all attributes selected">GET ?$select=all-9-fields — verify seed row</step>
    <step order="3" name="MCP search by topicname">Verify alternate-key query works</step>
    <step order="4" name="Form check">Open Main form in Power Apps; render verified</step>
    <step order="5" name="Author validation report">Pass/fail per check</step>
  </steps>

  <outputs>
