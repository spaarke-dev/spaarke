<task id="014" project="ai-spaarke-insights-engine-widgets-r1">
  <metadata>
    <title>Schema validation via MCP describe + Web API query</title>
    <status>not-started</status>
    <estimated-effort>0.5h</estimated-effort>
    <phase>1</phase>
    <tags>dataverse, validation, mcp</tags>
    <dependencies>013</dependencies>
    <parallel-safe>true</parallel-safe>
    <rigor>MINIMAL</rigor>
  </metadata>

  <prompt>
    Final Phase 1 gate: verify entity + form + seed row all coherent via MCP describe + Web API. Produce a one-page validation report — Phase 2 cannot start until this passes.
  </prompt>

  <role>Schema QA.</role>

  <goal>
    `notes/handoffs/phase-1-validation.md` recording: entity exists, 9 fields confirmed, alternate key enforced, 1 seed row present, forms open in Power Apps. Phase 2 unblocked.
  </goal>

  <inputs>
