<task id="025" project="ai-spaarke-insights-engine-widgets-r1">
  <metadata>
    <title>Document envelope schema for downstream consumers</title>
    <status>not-started</status>
    <estimated-effort>2h</estimated-effort>
    <phase>2</phase>
    <tags>docs, schema, downstream</tags>
    <dependencies>022</dependencies>
