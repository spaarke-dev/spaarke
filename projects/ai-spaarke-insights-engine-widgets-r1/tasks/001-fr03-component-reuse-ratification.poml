    <file purpose="destination-package">src/client/shared/Spaarke.AI.Widgets/package.json (v0.1.0 verification)</file>
  </inputs>

  <constraints>
    <constraint source="spec-FR-03">Must produce notes file + DR-001 decision record at named paths</constraint>
    <constraint source="root-CLAUDE.md §3">Cannot modify `.claude/` paths from a sub-agent context</constraint>
    <constraint source="Q-U3">Feedback affordance deferred to r2+; do NOT reference `FeedbackButtons` as a reuse candidate</constraint>
    <constraint source="Q-U1">Ban `@v1`/`@vN` identifier-suffix vernacular anywhere</constraint>
  </constraints>

  <knowledge>
    <topic>fluent-v9-widget-composition, popover+dialog pattern, spaarke-ai-widgets package</topic>
    <files>
