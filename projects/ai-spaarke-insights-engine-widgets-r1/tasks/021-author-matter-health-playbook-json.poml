  <prompt>
    Author `matter-health-single.playbook.json` following the shape of `predict-matter-cost.playbook.json` and the conventions of `universal-ingest.playbook.json`. Use only existing node executors per FR-11. Wire the Task 020 synthesis prompt by actionCode FK. Apply `jps-playbook-design` skill workflow.
  </prompt>

  <role>JPS playbook architect.</role>

  <goal>
    `src/server/api/Sprk.Bff.Api/Services/Ai/Insights/Playbooks/matter-health-single.playbook.json` — valid playbook JSON that loads in `PlaybookExecutionEngine`, references the Task 020 action code, persists output via UpdateRecord (Task 022 configures that node).
  </goal>

  <inputs>
    <file purpose="reference-playbook">src/server/api/Sprk.Bff.Api/Services/Ai/Insights/Playbooks/predict-matter-cost.playbook.json</file>
    <file purpose="reference-playbook">src/server/api/Sprk.Bff.Api/Services/Ai/Insights/Playbooks/universal-ingest.playbook.json</file>
    <file purpose="spec">projects/ai-spaarke-insights-engine-widgets-r1/spec.md (FR-10, FR-11)</file>
    <file purpose="design">projects/ai-spaarke-insights-engine-widgets-r1/design.md</file>
  </inputs>

  <constraints>
    <constraint source="spec-FR-11">Use ONLY existing node executor types: QueryDataverse, IndexRetrieve (or LiveFact), EvidenceSufficiency, AiAnalysis, GroundingVerify, UpdateRecord, ReturnInsightArtifact, DeclineToFind</constraint>
    <constraint source="Q-U1">Playbook name = bare `matter-health-single`. NO `@v1` suffix anywhere — not in name, not in identifiers, not in any field.</constraint>
    <constraint source="audit-DR-003">No new BFF facade — playbook invoked via existing IInsightsAi.AnswerQuestionAsync</constraint>
  </constraints>

  <knowledge>
    <topic>jps playbook, node executors, ActionType enum, PlaybookExecutionEngine</topic>
    <files>
      <file>.claude/skills/jps-playbook-design/SKILL.md</file>
