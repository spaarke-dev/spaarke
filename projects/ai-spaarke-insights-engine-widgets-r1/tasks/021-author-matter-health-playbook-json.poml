      <file>src/server/api/Sprk.Bff.Api/Services/Ai/Insights/Playbooks/universal-ingest.playbook.json</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="Invoke jps-playbook-design skill">Per its workflow</step>
    <step order="2" name="Compose top-level playbook metadata">name=`matter-health-single`, hostentity=`sprk_matter`, scopes</step>
    <step order="3" name="Compose nodes[]">QueryDataverse → IndexRetrieve → EvidenceSufficiency → (branch) AiAnalysis(actionCode=matter-health-synthesis) → GroundingVerify → UpdateRecord → ReturnInsightArtifact; with DeclineToFind branch</step>
    <step order="4" name="Wire DeclineToFind">When EvidenceSufficiency fails</step>
    <step order="5" name="Validate JSON against schema">jps-validate skill</step>
    <step order="6" name="Save playbook file">canonical Playbooks/ directory</step>
  </steps>

  <outputs>
    <output type="code">src/server/api/Sprk.Bff.Api/Services/Ai/Insights/Playbooks/matter-health-single.playbook.json</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">jps-validate skill passes</criterion>
    <criterion testable="true">No `@v` substring anywhere in file</criterion>
    <criterion testable="true">All referenced actionCodes resolve to existing sprk_analysisaction rows</criterion>
    <criterion testable="true">All referenced executor types exist in ActionType enum</criterion>
    <criterion testable="true">DeclineToFind branch covers EvidenceSufficiency failure path</criterion>
