<task id="080" project="ai-spaarke-insights-engine-widgets-r1">
  <metadata>
    <title>Production-ready deploy (BFF + Dataverse solution)</title>
    <status>not-started</status>
    <estimated-effort>3h</estimated-effort>
    <phase>7</phase>
    <tags>deploy, bff-deploy, dataverse-deploy, deploy</tags>
    <dependencies>067</dependencies>
    <parallel-safe>true</parallel-safe>
    <rigor>FULL</rigor>
  </metadata>

  <prompt>
    Production deploy:
    - BFF: telemetry registration + cache TTL plumbing via `bff-deploy` skill. Verify NFR-01 publish-size ceiling ≤60 MB and delta &lt;5 MB vs baseline.
    - Dataverse solution: package containing `sprk_aitopicregistry` entity + 1 seed row + Matter form patch + web resources. Deploy via `dataverse-deploy`.
    - Playbook + action row: production Dataverse via `Deploy-Playbook.ps1` + sprk_analysisaction row promotion.
  </prompt>

  <role>Production deployment engineer.</role>

  <goal>
    All r1 components live in production. Smoke test on production Matter passes.
  </goal>

  <inputs>
    <file purpose="bff">Tasks 050, 051, 052 outputs</file>
    <file purpose="dataverse">Tasks 010-014, 020-025, 040-043 outputs</file>
  </inputs>

  <constraints>
    <constraint source="NFR-01">Publish size ≤60 MB; delta &lt;5 MB</constraint>
    <constraint source="bff-extensions">Verify publish-size per task — report absolute + delta in notes</constraint>
  </constraints>

  <knowledge>
    <topic>bff-deploy, dataverse-deploy, production promotion</topic>
    <files>
      <file>.claude/skills/bff-deploy/SKILL.md</file>
      <file>.claude/skills/dataverse-deploy/SKILL.md</file>
      <file>.claude/constraints/bff-extensions.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="1" name="dotnet publish baseline">Measure compressed publish size; compare to Task 005 baseline</step>
    <step order="2" name="bff-deploy skill">Deploy BFF</step>
    <step order="3" name="Package Dataverse solution">Managed solution for prod</step>
    <step order="4" name="Promote sprk_aitopicregistry entity">Via solution import</step>
    <step order="5" name="Deploy playbook + action row">Production Dataverse</step>
    <step order="6" name="Deploy Matter form patch + web resources">Via solution</step>
    <step order="7" name="Production smoke test">Open prod Matter; verify card renders + envelope persists</step>
    <step order="8" name="Document deploy">notes/handoffs/production-deploy.md</step>
  </steps>

  <outputs>
    <output type="deployment">All r1 components in production</output>
    <output type="notes">projects/ai-spaarke-insights-engine-widgets-r1/notes/handoffs/production-deploy.md</output>
  </outputs>

  <acceptance-criteria>
    <criterion testable="true">BFF publish size ≤60 MB compressed</criterion>
    <criterion testable="true">Delta vs Task 005 baseline &lt;5 MB</criterion>
    <criterion testable="true">Production smoke test passes</criterion>
    <criterion testable="true">No HIGH-severity CVE introduced (dotnet list package --vulnerable)</criterion>
  </acceptance-criteria>
</task>
