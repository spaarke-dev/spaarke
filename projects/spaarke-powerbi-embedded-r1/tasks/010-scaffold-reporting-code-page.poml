<task id="010" project="spaarke-powerbi-embedded-r1">
  <metadata>
    <title>Scaffold sprk_reporting Code Page</title>
    <phase>2</phase>
    <stream>frontend</stream>
    <tags>frontend, code-page</tags>
    <estimate>3h</estimate>
    <rigor>FULL</rigor>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Creates new Code Page project from scratch — multiple config files, build pipeline, auth bootstrap, and React shell. Modifies .ts/.tsx files with 6+ steps.</rigor-reason>
    <parallel-group>B</parallel-group>
    <parallel-safe>true</parallel-safe>
    <dependencies>none</dependencies>
  </metadata>

  <prompt>
    <role>Frontend engineer building a new Vite + React 19 Code Page for Power BI Embedded reporting.</role>
    <goal>Create the src/solutions/Reporting/ project from scratch, following the EventsPage canonical reference. The project must include package.json, vite.config.ts, tsconfig.json, index.html, src/main.tsx with auth bootstrap, and src/App.tsx with a shell layout (header + report area).</goal>
    <context>
      This is the Reporting module's Code Page — a full-page Dataverse web resource that embeds Power BI reports.
      The EventsPage (src/solutions/EventsPage/) is the canonical reference for Vite + React 19 + single-file Code Pages.
      The auth bootstrap pattern uses @spaarke/auth: resolveRuntimeConfig → setRuntimeConfig → ensureAuthInitialized → render.
      The build must produce a single index.html file via vite-plugin-singlefile.
    </context>
    <constraints>
      - MUST use React 19 with createRoot (Code Page, not PCF) per ADR-006
      - MUST use Vite + vite-plugin-singlefile per ADR-026
      - MUST use Fluent UI v9 (@fluentui/react-components) exclusively per ADR-021
      - MUST wrap root in FluentProvider with theme detection (light/dark)
      - MUST use @spaarke/auth bootstrap pattern per .claude/patterns/auth/spaarke-auth-initialization.md
      - MUST include powerbi-client-react 2.0.2 as dependency
      - MUST include @spaarke/ui-components as dependency per ADR-012
      - MUST use resolveSharedLibDeps aliases in vite.config.ts
      - MUST NOT hard-code colors — use Fluent design tokens per ADR-021
      - MUST NOT use module-level constants that call runtime config getters
    </constraints>
  </prompt>

  <knowledge>
    <files>
      <file>src/solutions/EventsPage/package.json</file>
      <file>src/solutions/EventsPage/vite.config.ts</file>
      <file>src/solutions/EventsPage/tsconfig.json</file>
      <file>src/solutions/EventsPage/index.html</file>
      <file>src/solutions/EventsPage/src/main.tsx</file>
      <file>src/solutions/EventsPage/src/App.tsx</file>
      <file>.claude/adr/ADR-006-pcf-over-webresources.md</file>
      <file>.claude/adr/ADR-021-fluent-design-system.md</file>
      <file>.claude/adr/ADR-026-full-page-custom-page-standard.md</file>
      <file>.claude/patterns/auth/spaarke-auth-initialization.md</file>
      <file>.claude/patterns/webresource/full-page-custom-page.md</file>
    </files>
    <adrs>
      <adr>.claude/adr/ADR-006-pcf-over-webresources.md</adr>
      <adr>.claude/adr/ADR-012-shared-components.md</adr>
      <adr>.claude/adr/ADR-021-fluent-design-system.md</adr>
      <adr>.claude/adr/ADR-026-full-page-custom-page-standard.md</adr>
    </adrs>
  </knowledge>

  <steps>
    <step>Read EventsPage package.json, vite.config.ts, tsconfig.json, index.html, src/main.tsx, and src/App.tsx as canonical reference</step>
    <step>Create src/solutions/Reporting/package.json with React 19, @fluentui/react-components, powerbi-client-react 2.0.2, @spaarke/ui-components, @spaarke/auth, vite, vite-plugin-singlefile, and TypeScript dev dependencies</step>
    <step>Create src/solutions/Reporting/vite.config.ts with viteSingleFile plugin, resolveSharedLibDeps aliases, and appropriate build config</step>
    <step>Create src/solutions/Reporting/tsconfig.json matching EventsPage configuration</step>
    <step>Create src/solutions/Reporting/index.html with root div and script entry point</step>
    <step>Create src/solutions/Reporting/src/main.tsx with createRoot, FluentProvider, theme detection (light/dark), and @spaarke/auth bootstrap (resolveRuntimeConfig → setRuntimeConfig → ensureAuthInitialized → render)</step>
    <step>Create src/solutions/Reporting/src/App.tsx with shell layout: header area (title, dropdown placeholder, toolbar placeholder) and report area (placeholder for ReportViewer)</step>
    <step>Run npm install in src/solutions/Reporting/ to verify dependencies resolve</step>
    <step>Run npm run build in src/solutions/Reporting/ to verify single-file output</step>
  </steps>

  <outputs>
    <output>New file: src/solutions/Reporting/package.json</output>
    <output>New file: src/solutions/Reporting/vite.config.ts</output>
    <output>New file: src/solutions/Reporting/tsconfig.json</output>
    <output>New file: src/solutions/Reporting/index.html</output>
    <output>New file: src/solutions/Reporting/src/main.tsx</output>
    <output>New file: src/solutions/Reporting/src/App.tsx</output>
    <output>Successful build producing dist/index.html as single file</output>
  </outputs>

  <acceptance-criteria>
    <criterion>src/solutions/Reporting/ project exists with all config files</criterion>
    <criterion>package.json includes React 19, Fluent v9, powerbi-client-react 2.0.2, @spaarke/auth, @spaarke/ui-components</criterion>
    <criterion>vite.config.ts uses viteSingleFile and resolveSharedLibDeps</criterion>
    <criterion>main.tsx uses createRoot with FluentProvider and auth bootstrap pattern</criterion>
    <criterion>App.tsx renders a shell with header and report area placeholders</criterion>
    <criterion>npm run build produces a single dist/index.html file</criterion>
    <criterion>No hard-coded colors — Fluent design tokens only</criterion>
  </acceptance-criteria>
</task>
