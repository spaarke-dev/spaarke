<task id="066" project="spaarke-ai-platform-unification-r6">
  <metadata>
    <title>D-C-19 — Selective recall via embedding similarity (vectorize at write, retrieve by similarity)</title>
    <status>pending</status>
    <estimated-effort>1 day</estimated-effort>
    <phase>Phase C — Cross-Conversation Memory (Pillar 7)</phase>
