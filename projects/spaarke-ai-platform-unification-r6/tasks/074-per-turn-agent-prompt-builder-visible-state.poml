    <constraint source="spec NFR-10">Total 8K budget preserved.</constraint>
    <constraint source="project R6 Pillar 9 binding">Filter rule: `tab.visibleToAssistant === true` AND widget has `getVisibleState`. Both required.</constraint>
  </constraints>

