    <file purpose="workspace-svc">src/server/api/Sprk.Bff.Api/Services/Workspace/IWorkspaceStateService.cs</file>
  </inputs>

  <constraints>
    <constraint source="ADR-010">Existing module registration; ZERO new Program.cs lines.</constraint>
