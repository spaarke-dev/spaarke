    <file purpose="existing-context">src/server/api/Sprk.Bff.Api/Services/Ai/ToolExecutionContext.cs</file>
    <file purpose="handler-interface">src/server/api/Sprk.Bff.Api/Services/Ai/IToolHandler.cs</file>
    <file purpose="bff-claude">src/server/api/Sprk.Bff.Api/CLAUDE.md</file>
  </inputs>

  <constraints>
    <constraint source="ADR-010">No new top-level Program.cs lines.</constraint>
    <constraint source="ADR-013">Refactor purely internal to `Services/Ai/`; no facade-boundary change.</constraint>
    <constraint source="ADR-015">No user message content logged in context fields; `ChatInvocationContext` exposes only IDs + scoped state.</constraint>
    <constraint source="ADR-029">Verify BFF publish-size delta; ≤+5 MB R6 budget.</constraint>
    <constraint source="spec FR-09">Both contexts inherit a shared base; handlers receive the appropriate type; existing handlers remain functional.</constraint>
    <constraint source="NFR-08">All 11 production node executors preserved — `ToolExecutionContext` semantics for playbook nodes MUST be unchanged.</constraint>
  </constraints>

  <knowledge>
    <topic>bff-api/handler-context</topic>
    <files>
      <file>.claude/patterns/api/service-registration.md</file>
