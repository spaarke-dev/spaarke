  <steps>
    <step order="0" name="Context Check + Rigor Declaration">
      Output: "🔒 RIGOR LEVEL: FULL — handler context refactor + downstream blocker + NFR-08 preservation".
    </step>
    <step order="1" name="Review Progress">
      Verify 006 ✅. Update `current-task.md`.
    </step>
    <step order="2" name="Gather Resources">
      Read inputs + knowledge. Capture baseline publish size.
    </step>
    <step order="3" name="Inspect Existing Context Type">
      Open `ToolExecutionContext.cs`; enumerate fields. Identify which are playbook-specific (nodeContext, playbookId, action) vs which are shared (tenantId, requestId, cancellation token).
    </step>
    <step order="4" name="Author Base Type">
      Add `ToolInvocationContextBase` containing the shared fields. Preserve names for source compatibility.
    </step>
    <step order="5" name="Refactor `ToolExecutionContext`">
      Make it derive from `ToolInvocationContextBase`; retain playbook-specific fields. Existing handlers + node-executor pipeline see the same `ToolExecutionContext` type with same fields.
    </step>
    <step order="6" name="Add `ChatInvocationContext`">
      New type deriving from base; adds `ChatSessionId`, `ConversationHistory` reference (handle only, not content per ADR-015), LLM-parameter-passing fields.
    </step>
    <step order="7" name="Build + Test">
      `dotnet build src/server/api/Sprk.Bff.Api/` → 0 errors. `dotnet test` → all existing tests green; existing handlers compile unchanged.
    </step>
    <step order="8" name="Add Unit Tests">
      Unit tests: base + derived types serialize correctly; field set per type matches expected.
    </step>
    <step order="9" name="Verify Publish Size + Acceptance Criteria">
      `dotnet publish -c Release` → measure delta vs baseline; report ≤+5 MB R6 budget. Walk each criterion below.
    </step>
    <step order="9.5" name="Quality Gates (FULL rigor)">
      Run `code-review` + `adr-check` against changed files. Verify ADR-010 / ADR-013 / ADR-015 / ADR-029 + NFR-08 + FR-09 compliance. Both gates MUST pass.
    </step>
    <step order="10" name="Document + Complete">
      Update task POML status complete. TASK-INDEX 009 ✅. Reset `current-task.md`. Report.
    </step>
  </steps>

  <tools>
    <tool name="dotnet">build, test, publish</tool>
    <tool name="git">stage + commit changes</tool>
    <tool name="code-review">Quality gate Step 9.5</tool>
    <tool name="adr-check">ADR compliance gate Step 9.5</tool>
  </tools>

