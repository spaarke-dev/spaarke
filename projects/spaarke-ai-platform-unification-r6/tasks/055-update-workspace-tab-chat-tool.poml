  </inputs>

  <constraints>
    <constraint source="ADR-010">Register via auto-discovery in existing module; ZERO new Program.cs lines.</constraint>
    <constraint source="ADR-013">BFF-internal tool; consumes `IWorkspaceStateService` directly.</constraint>
    <constraint source="ADR-015">Telemetry emits tool name + decision (`applied` | `refused_stale_read`) + timestamp ONLY. NEVER the `changes` body. Deterministic IDs OK.</constraint>
    <constraint source="ADR-029">Publish-size delta verified.</constraint>
    <constraint source="ADR-030">Publish `workspace.tab_edited` on existing `workspace` channel. Additive event type only.</constraint>
    <constraint source="spec FR-35">Modifies existing tab; registered as `sprk_analysistool` row.</constraint>
    <constraint source="spec FR-40">Conflict resolution per Q8 â€” USER WINS. Agent checks timestamp; refuses on stale write with re-read prompt. No OT/CRDT.</constraint>
    <constraint source="project Q8 binding">Refusal message is a structured response the LLM can re-act on. Format: `{ status: "stale_read", currentTimestamp, message: "Tab edited by user since your last read; please re-read before re-attempting." }`.</constraint>
  </constraints>

