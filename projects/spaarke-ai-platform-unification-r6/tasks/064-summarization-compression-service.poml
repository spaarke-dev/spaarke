    <file purpose="ai-arch">docs/architecture/AI-ARCHITECTURE.md</file>
    <file purpose="chat-arch">docs/architecture/chat-architecture.md</file>
    <file purpose="ctx-provider">src/server/api/Sprk.Bff.Api/Services/Ai/Chat/PlaybookChatContextProvider.cs</file>
  </inputs>

  <constraints>
    <constraint source="ADR-010">Register in existing module (`AnalysisServicesModule`).</constraint>
    <constraint source="ADR-013">BFF-side AI service; CRUD-side consumers via facade pattern (not applicable here — internal to chat).</constraint>
    <constraint source="ADR-014">Persistence uses Cosmos `sessions` container per existing write-through pattern; per-tenant isolation enforced.</constraint>
    <constraint source="ADR-015">Compression summary is stored content; treat per existing chat history data-governance contract (Cosmos `sessions` already governed).</constraint>
    <constraint source="ADR-029">Publish-size delta verified; expect &lt;1 MB.</constraint>
    <constraint source="spec FR-41">Sliding-window compression; replace oldest M turns with summary; appends `[Conversation summary: ...]` at history top.</constraint>
    <constraint source="spec NFR-10">8K system prompt budget preserved; summary caps at ~500 tokens.</constraint>
    <constraint source="project R6 Pillar 7">Pillar 7 infrastructure for memory composition; consumed by task 067 hierarchical composition.</constraint>
  </constraints>

