  <ui-tests>
    <test name="Object-Typed Field Renders as Labeled Key-Value Blocks (fixes R5 entities bug)">
      <url>https://{org}.crm.dynamics.com/main.aspx?appid={app-id}&amp;pagetype=custom&amp;name=spaarke-ai-workspace</url>
      <steps>
        <step>Open SpaarkeAi workspace shell against a test matter</step>
        <step>Trigger `summarize-document-for-workspace@v1` against a test document that produces an `entities` field</step>
        <step>Wait for `streaming_complete` event</step>
        <step>Inspect rendered output for the `entities` field</step>
        <step>Verify rendered DOM shows labeled sections (e.g., "Organizations" label + content; "Persons" label + content)</step>
        <step>Verify nested arrays inside `entities` render as bulleted lists (reusing task 040's path)</step>
        <step>Verify NO raw JSON object literal (e.g., `{\"organizations\":[`) appears in visible text</step>
        <step>Check browser console — no JavaScript errors</step>
      </steps>
      <expected>`entities` field renders as labeled key-value blocks with nested bulleted lists; no raw JSON visible; no console errors</expected>
    </test>

    <test name="Array-Rendering Regression (task 040 still works)">
      <steps>
        <step>Trigger the same workspace summarization</step>
        <step>Verify `tldr` field STILL renders as bulleted list (task 040 case)</step>
        <step>Confirm refactor did not break array dispatch</step>
      </steps>
      <expected>`tldr` bulleted list rendering preserved after refactor</expected>
    </test>

    <test name="Dark Mode Compliance (ADR-021)">
      <steps>
        <step>Toggle dark mode in D365 settings</step>
        <step>Reload the workspace shell</step>
        <step>Trigger workspace summarization producing `entities` output</step>
        <step>Verify labeled-block text color, label color, and section borders all adapt to dark theme via Fluent UI v9 tokens</step>
        <step>Verify nested bulleted list (from task 040) also adapts</step>
        <step>Toggle back to light mode; verify reverse adaptation</step>
      </steps>
      <expected>All colors adapt via Fluent UI v9 semantic tokens; no hard-coded values</expected>
    </test>

    <test name="Depth Guard Fallback">
      <steps>
        <step>Inject a test outputSchema with nested object-of-object (depth ≥ 2)</step>
        <step>Trigger streaming with matching payload</step>
        <step>Verify widget falls back to compact JSON.stringify for the depth-≥-2 value</step>
        <step>Verify NO infinite recursion / crash</step>
      </steps>
      <expected>Depth-≥-2 object falls back to compact JSON with TODO marker; widget remains stable</expected>
    </test>
  </ui-tests>

