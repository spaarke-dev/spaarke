  </knowledge>

  <steps>
    <step order="0" name="Context Check + Rigor Declaration">
      Output: "🔒 RIGOR LEVEL: FULL — chat-agent build-path modification + NFR-10 token budget".
    </step>
    <step order="1" name="Review Progress">
      Verify 021 ✅. Update `current-task.md`.
    </step>
    <step order="2" name="Gather Resources">
      Read inputs + knowledge. Capture baseline publish size.
    </step>
    <step order="3" name="Implement Dynamic Description">
      Extend `SprkChatAgentFactory.ResolveTools()` (or a helper). After building the `invoke_playbook` AIFunction, fetch tenant-accessible playbooks via existing playbook visibility service. Format description: "Available playbooks: 1. {name} - {desc}, 2. {name} - {desc}, ...". Truncate / page if exceeding token budget allotment.
    </step>
    <step order="4" name="Implement Caching">
      Cache description per `tenantId` (Redis key `chat:invoke_playbook_desc:{tenantId}`); short TTL (5 min). Invalidate on playbook CRUD via existing cache invalidation pattern.
    </step>
    <step order="5" name="Add Unit Tests">
      Tests: empty list → "no playbooks available"; small list → full description; long list → truncated within budget; tenant isolation (tenant A's description ≠ tenant B's).
    </step>
    <step order="6" name="Build + Verify Publish Size + Acceptance Criteria">
      `dotnet build` → 0 errors. `dotnet publish -c Release` → delta. Walk each criterion.
    </step>
    <step order="9.5" name="Quality Gates (FULL rigor)">
      Run `code-review` + `adr-check`. Verify ADR-010 / ADR-013 / ADR-014 / ADR-015 / ADR-029 + NFR-10 / NFR-14 + FR-23 compliance. Both gates MUST pass.
    </step>
    <step order="10" name="Document + Complete">
      Update task POML status complete. TASK-INDEX 022 ✅. Reset `current-task.md`. Report.
    </step>
  </steps>

  <tools>
    <tool name="dotnet">build, test, publish</tool>
    <tool name="git">stage + commit</tool>
    <tool name="code-review">Quality gate Step 9.5</tool>
    <tool name="adr-check">ADR compliance gate Step 9.5</tool>
  </tools>

