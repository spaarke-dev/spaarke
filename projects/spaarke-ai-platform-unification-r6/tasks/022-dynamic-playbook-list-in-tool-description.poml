    <criterion testable="true">Description includes name + description of each accessible playbook (FR-23).</criterion>
    <criterion testable="true">Description respects NFR-10 token budget (truncation or paging if needed).</criterion>
    <criterion testable="true">Cache keyed per `tenantId` per ADR-014.</criterion>
    <criterion testable="true">Tenant isolation verified; cross-tenant playbooks not visible (NFR-14).</criterion>
    <criterion testable="true">Telemetry payload ADR-015-compliant; no playbook content logged.</criterion>
    <criterion testable="true">BFF publish-size delta reported; ≤+5 MB R6 budget.</criterion>
