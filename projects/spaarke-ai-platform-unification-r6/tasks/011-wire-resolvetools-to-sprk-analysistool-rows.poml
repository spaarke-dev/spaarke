  <acceptance-criteria>
    <criterion testable="true">`ResolveTools()` queries `sprk_analysistool` filtered by tenant + `AvailableInContexts ∋ Chat`.</criterion>
    <criterion testable="true">Adapter wraps each row + `IToolHandler` impl; returns `AIFunction[]`.</criterion>
    <criterion testable="true">Cache key includes `tenantId` (ADR-014).</criterion>
    <criterion testable="true">Fallback to hardcoded list when query returns 0 tools — preserves NFR-11 backward-compat during migration window.</criterion>
    <criterion testable="true">NO new feature flag introduced (ADR-018).</criterion>
    <criterion testable="true">Conversational-primacy test: even with 0 tools, agent responds conversationally (NFR-01).</criterion>
    <criterion testable="true">Safety pipeline middleware chain unchanged (NFR-13).</criterion>
    <criterion testable="true">No user message content in telemetry (ADR-015).</criterion>
    <criterion testable="true">BFF publish-size delta reported; ≤+5 MB R6 budget.</criterion>
    <criterion testable="true">`code-review` + `adr-check` quality gates pass.</criterion>
  </acceptance-criteria>
