  </inputs>

  <constraints>
    <constraint source="spec FR-48">CommandRouter parses user input into `Intent { command, references[], rawText }`. Runs before agent invocation.</constraint>
    <constraint source="spec NFR-11">Natural language requests still work alongside slashes. When no slash detected, parser returns `command: null` and existing `CapabilityRouter` path handles the message unchanged.</constraint>
    <constraint source="spec NFR-01">Conversational primacy — parser MUST NOT interrupt the LLM's conversational ability. It only classifies; it does not block.</constraint>
    <constraint source="ADR-029">BFF publish-size delta = 0 MB for this task (frontend-only).</constraint>
    <constraint source="ADR-030">PaneEventBus channels stay at 4. This task does NOT add a 5th channel; parser is a pure module, not an event emitter at this stage.</constraint>
    <constraint source="project Pillar 8">Q6 vocabulary closed at 6 hard + 4 soft + 3 reference types. Do NOT extend.</constraint>
  </constraints>

  <knowledge>
    <topic>frontend/command-router-parser</topic>
    <files>
      <file>.claude/patterns/ui/fluent-v9-component-authoring.md</file>
