  <constraints>
    <constraint source="spec NFR-07">Pre-fill regressions MUST show ZERO diff in per-field wizard output values vs BEFORE baselines from tasks 034 + 035. If ANY diff — escalate.</constraint>
    <constraint source="project">Integration test SCENARIOS run against Spaarke Dev (or a designated test environment) using deterministic test documents (so before/after diffs are exact).</constraint>
    <constraint source="project">Evidence MUST include: screenshots of rendered output; relevant server logs (no user message text per ADR-015); before/after pre-fill diffs.</constraint>
    <constraint source="ADR-015">AI data governance — no user message text in evidence logs; redact if any test document contains sensitive content.</constraint>
    <constraint source="ADR-029">BFF publish-size — this task is test-only; no BFF code change; publish-size delta = 0 MB; confirm in evidence notes.</constraint>
  </constraints>

