<task id="052" project="spaarke-ai-platform-unification-r6">
  <metadata>
    <title>D-C-03 — `GET /api/workspace/state` BFF endpoint (tenant + session scoped)</title>
    <status>pending</status>
    <estimated-effort>4 hours</estimated-effort>
    <phase>Phase C — Tri-directional Workspace (Pillar 6a)</phase>
    <wave>C-G1 (sequential)</wave>
    <parallel-safe>false</parallel-safe>
    <dependencies>051 (WorkspaceStateService)</dependencies>
    <tags>bff-api, endpoints, ai, workspace</tags>
    <rigor-level>FULL</rigor-level>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>New endpoint; auth filter + rate limit + per-tenant scoping; consumed by frontend workspace shell + Pillar 9 visibility builder.</rigor-reason>
    <parallel-group>C-G1</parallel-group>
  </metadata>

  <prompt>
    Add `GET /api/workspace/state` endpoint that returns current open tabs + active tab +
    user selection state for a tenant + session. Endpoint MUST respect Pillar 9's
    `getAgentVisibleState()` filter when called from the agent prompt builder (task 074),
    but the raw endpoint returns the FULL state — the prompt builder applies the filter
    per-tab. Per ADR-008 endpoint filter pattern for authorization. Per ADR-016 inherits
    `ai-context` rate limit policy. Register in `WorkspaceStateEndpoints.cs` (new file
    in `src/server/api/Sprk.Bff.Api/Api/Workspace/`); wire from existing endpoint
    registration in `Program.cs` via the established module pattern (per ADR-010 — module
    file registers the endpoint; ZERO new lines in `Program.cs` beyond the existing
    module call).
  </prompt>

  <role>
    Senior BFF API engineer with familiarity with Minimal API endpoint definition,
    Spaarke endpoint filter authorization, and rate-limit policy registration.
  </role>

  <goal>
    `GET /api/workspace/state?sessionId={sessionId}` returns `WorkspaceStateResponse`
    containing `tabs: WorkspaceTab[]`, `activeTabId: string?`, `userSelection: object?`.
    Returns 401 if unauthenticated, 403 if tenant mismatch, 429 if rate-limited, 200 on
    success. Empty session returns `{ tabs: [], activeTabId: null, userSelection: null }`.
  </goal>

  <inputs>
    <file purpose="project-spec">projects/spaarke-ai-platform-unification-r6/spec.md</file>
    <file purpose="project-plan">projects/spaarke-ai-platform-unification-r6/plan.md</file>
    <file purpose="project-claude">projects/spaarke-ai-platform-unification-r6/CLAUDE.md</file>
    <file purpose="root-claude">CLAUDE.md</file>
    <file purpose="bff-extensions">.claude/constraints/bff-extensions.md</file>
    <file purpose="scope-endpoints">src/server/api/Sprk.Bff.Api/Api/Ai/ScopeEndpoints.cs</file>
    <file purpose="workspace-svc">src/server/api/Sprk.Bff.Api/Services/Workspace/IWorkspaceStateService.cs</file>
  </inputs>

  <constraints>
    <constraint source="ADR-008">Endpoint filter for authorization (tenant resolution, claims check). Apply existing `ai-context` filter pattern.</constraint>
    <constraint source="ADR-010">Module pattern; ZERO new Program.cs lines beyond existing module call.</constraint>
    <constraint source="ADR-013">Workspace state plumbing in BFF (not separate microservice); service consumed via interface.</constraint>
    <constraint source="ADR-014">Per-tenant cache key isolation enforced by service.</constraint>
    <constraint source="ADR-016">`ai-context` rate limit policy applied.</constraint>
    <constraint source="ADR-029">Publish-size delta verified.</constraint>
    <constraint source="spec FR-33">Endpoint MUST be tenant-scoped + session-scoped + honor per-widget `getAgentVisibleState()` when consumed by prompt builder (filter logic lives in prompt builder per task 074, NOT in endpoint).</constraint>
    <constraint source="project R6">Use canonical `WorkspaceTab` interface from task 050; do NOT redefine the shape.</constraint>
  </constraints>

