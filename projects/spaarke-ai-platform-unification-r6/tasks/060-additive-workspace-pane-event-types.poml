  </inputs>

  <constraints>
    <constraint source="ADR-012">Shared lib `@spaarke/ai-widgets`; Fluent v9 conventions.</constraint>
    <constraint source="ADR-015">User selection text is user-visible-by-design (per FR-38 + Pillar 9 visibility contract) — NOT a telemetry event. Telemetry separately must NOT log selection text.</constraint>
    <constraint source="ADR-030">4 channels closed; additive types only on existing `workspace` channel; no 5th channel.</constraint>
    <constraint source="spec FR-38">Additive `workspace.*` event types on existing channel.</constraint>
    <constraint source="project R6 Pillar 6c">Reverse-flow events let workspace inform assistant + context pane of state changes.</constraint>
  </constraints>

