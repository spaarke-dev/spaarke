  </inputs>

  <constraints>
    <constraint source="spec FR-50">Soft slashes set strong intent signal; route to agent; agent may ask clarifying questions if intent is incomplete.</constraint>
    <constraint source="spec Phase D exit criterion 3">Soft slashes route via agent with prioritized intent; verifiable by tracing a `/summarize` invocation through CapabilityRouter to the SUM-CHAT playbook.</constraint>
    <constraint source="spec NFR-01">Conversational primacy preserved — soft slashes augment routing, agent remains conversational.</constraint>
    <constraint source="spec NFR-11">Backward compat — natural language ("summarize this") still works; soft slash is the explicit shortcut.</constraint>
    <constraint source="ADR-013">No new public-contract surface in `Services/Ai/PublicContracts/`. Soft slashes use existing Pillar 3 `IInvokePlaybookAi` facade transparently.</constraint>
    <constraint source="ADR-015">Telemetry: command name + decision + timestamp only; no user message text.</constraint>
    <constraint source="ADR-029">BFF publish-size delta = 0 MB.</constraint>
    <constraint source="project Pillar 8">Q6 vocabulary closed at exactly 4 soft slashes — do NOT add new ones.</constraint>
  </constraints>

