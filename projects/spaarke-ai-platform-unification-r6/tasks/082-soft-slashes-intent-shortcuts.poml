  <ui-tests>
    <test name="Soft Slash Routes via Agent">
      <url>https://{org}.crm.dynamics.com/main.aspx?appid={app-id}&amp;pagetype=control&amp;controlName=spaarke_SpaarkeAi</url>
      <steps>
        <step>Open conversation pane</step>
        <step>Type `/summarize` and submit</step>
        <step>Observe agent invokes summarize playbook (Pillar 3 invoke_playbook tool fires)</step>
        <step>Verify Context pane shows execution trace from playbook engine</step>
      </steps>
      <expected>Agent recognizes soft slash; routes to SUM-CHAT playbook; trace visible in Context pane</expected>
    </test>
    <test name="Conversational Primacy After Soft Slash (NFR-01)">
      <steps>
        <step>After a `/summarize` invocation completes</step>
        <step>Type a follow-up: "make it shorter"</step>
        <step>Verify agent responds conversationally (no tool call needed)</step>
      </steps>
      <expected>Refinement message received; agent stays conversational</expected>
    </test>
    <test name="Dark Mode Compliance (ADR-021)">
      <steps>
        <step>Toggle dark mode</step>
        <step>Trigger `/summarize` and observe response rendering</step>
      </steps>
      <expected>Response surfaces use Fluent v9 semantic tokens; no hardcoded colors</expected>
    </test>
