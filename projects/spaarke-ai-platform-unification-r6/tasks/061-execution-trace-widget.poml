    <file purpose="dashboard-widget-model">docs/architecture/SPAARKEAI-DASHBOARD-AND-WIDGET-MODEL.md</file>
    <file purpose="event-types">src/client/shared/Spaarke.AI.Widgets/src/events/PaneEventTypes.ts</file>
  </inputs>

  <constraints>
    <constraint source="ADR-012">Built in `@spaarke/ai-widgets` shared lib; Fluent v9 conventions.</constraint>
    <constraint source="ADR-015 BINDING">Renders typed fields from event payload only. NEVER attempts to render free-form content. NEVER includes a "show user message" affordance. Widget is observability, not transcript replay.</constraint>
    <constraint source="ADR-021">Light + dark mode parity verified per dark-mode audit.</constraint>
    <constraint source="ADR-030">Subscribes to existing `context` channel; no new channel.</constraint>
    <constraint source="spec FR-36">Widget registered with `ContextWidgetRegistry`; subscribes to `context.*` events; renders ordered timeline.</constraint>
    <constraint source="project R6 Pillar 6c">Widget is the Claude-Code-like surface. Visual model: ordered timeline grouped by event type with collapsible filters.</constraint>
  </constraints>

