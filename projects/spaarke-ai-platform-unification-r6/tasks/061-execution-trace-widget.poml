<task id="061" project="spaarke-ai-platform-unification-r6">
  <metadata>
    <title>D-C-14 — `ExecutionTraceWidget.tsx` (Claude-Code-like Context-pane widget)</title>
    <status>pending</status>
    <estimated-effort>1.5 days</estimated-effort>
    <phase>Phase C — Tri-directional Workspace (Pillar 6c)</phase>
    <wave>C-G2 (parallel after 6a)</wave>
