  <constraints>
    <constraint source="ADR-010">No new top-level Program.cs lines; handler registrations inside existing module.</constraint>
    <constraint source="ADR-013">Handlers are AI-internal; no CRUD-side facade exposure.</constraint>
    <constraint source="ADR-014">Tenant-isolation on tool execution; cache keys include `tenantId`.</constraint>
    <constraint source="ADR-015">Every migrated handler MUST emit only tool name + decision + timestamp telemetry; NEVER user message content.</constraint>
    <constraint source="ADR-018">No new feature flags. Rollback gate uses existing flag established in task 011 if any.</constraint>
    <constraint source="ADR-027">Dataverse seed rows use unmanaged solution conventions.</constraint>
    <constraint source="ADR-029">Verify BFF publish-size delta; net negative expected (deleted hardcoded classes). ≤+5 MB R6 total budget per NFR-02.</constraint>
    <constraint source="spec NFR-01">Conversational primacy preserved — chat agent responds conversationally after migration.</constraint>
    <constraint source="spec NFR-04">ZERO Microsoft Agent Framework references introduced.</constraint>
    <constraint source="spec NFR-11">Backward compatibility — existing tools' user-visible behavior unchanged post-migration.</constraint>
    <constraint source="spec NFR-13">Safety pipeline middleware chain (PromptShield + Groundedness + Citations + Privilege + Cross-matter) MUST continue to wrap every tool invocation.</constraint>
    <constraint source="spec FR-12">All 10 named tools migrated; existing classes deleted OR feature-gated for rollback.</constraint>
    <constraint source="bff-extensions.md F (test obligation)">Every modified service MUST have updated unit tests. 60+ regression tests required (10 tools × 6 paths).</constraint>
    <constraint source="project plan R1">Comprehensive regression test + rollback plan + staging validation gate REQUIRED before merge.</constraint>
  </constraints>

