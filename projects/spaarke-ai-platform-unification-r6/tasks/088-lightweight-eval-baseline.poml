    <patterns>
      <pattern name="Transcript file shape" location="projects/spaarke-ai-platform-unification-r6/notes/eval-baseline/{persona}-{playbook}.md (new)">
        Markdown sections: Title, Persona, Playbook, User Messages, Expected Response Shape, Actual Response Snapshot. Front-matter optional (YAML for future programmatic parsing).
      </pattern>
    </patterns>
  </knowledge>

  <steps>
    <step order="0" name="Context Check + Rigor Declaration">
      Check context. Output: "🔒 RIGOR LEVEL: MINIMAL — Lightweight eval baseline per Q10; documentation-only".
    </step>
    <step order="1" name="Review Progress">
      Read TASK-INDEX.md; confirm 088 status is 🔲, dep 087 is ✅. Update `current-task.md`.
    </step>
    <step order="2" name="Gather Resources">
      Read task-087-vertical-slice-evidence.md (vertical-slice snapshot data). Read spec Q10 to confirm scope. Identify the 4 migrated actions from Pillar 5 (summarize-chat, summarize-workspace, matter-prefill, project-prefill).
    </step>
    <step order="3" name="Author 4+ Transcripts">
      Create `projects/spaarke-ai-platform-unification-r6/notes/eval-baseline/` directory. Author 4 transcripts:
      - `sys-default-summarize-chat.md` (from vertical-slice snapshot)
      - `sys-default-summarize-workspace.md`
      - `sys-default-matter-prefill.md` (NFR-07 binding evidence)
      - `sys-default-project-prefill.md` (NFR-07 binding evidence)
      Each follows the standard shape. Use SYNTHETIC user messages where actual would expose PII per ADR-015.
    </step>
    <step order="4" name="Cite Q10 in Each File">
      Each transcript MUST include a front-line note: "Captured per R6 Q10 (lightweight eval baseline; full harness deferred R7). Reference file for future eval harness consumption."
    </step>
    <step order="5" name="Verify Acceptance Criteria">
      Walk through every &lt;acceptance-criterion&gt; below.
    </step>
    <step order="6" name="Document + Complete">
      Update task POML status. Update TASK-INDEX.md: 088 🔲 → ✅. Reset `current-task.md`. Report completion + downstream unblock (089).
    </step>
  </steps>

  <tools>
