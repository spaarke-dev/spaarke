    <file purpose="vertical-slice-evidence">projects/spaarke-ai-platform-unification-r6/notes/task-087-vertical-slice-evidence.md</file>
  </inputs>

  <constraints>
    <constraint source="spec Q10 (Owner Clarifications)">R6 ships lightweight eval baseline (markdown transcripts per persona + playbook); full harness deferred to R7.</constraint>
    <constraint source="ADR-015">Transcripts MUST NOT include any sensitive user message text beyond what's captured in the vertical-slice scenario. Synthesize generic user messages where actual messages would expose PII.</constraint>
    <constraint source="ADR-029">BFF publish-size delta = 0 MB (docs-only task).</constraint>
  </constraints>

  <knowledge>
    <topic>docs/eval-baseline</topic>
    <files>
