    <constraint source="ADR-013">No facade-boundary change; refactor is purely internal to `Services/Ai/`.</constraint>
    <constraint source="ADR-029">Verify BFF publish-size delta; near-zero expected (rename only); ≤+5 MB R6 budget.</constraint>
    <constraint source="spec FR-06">Type alias preserved for source compatibility; existing handlers (`GenericAnalysisHandler`, `DocumentClassifierHandler`, `SummaryHandler`, `SemanticSearchToolHandler`) continue to work unchanged.</constraint>
  </constraints>

