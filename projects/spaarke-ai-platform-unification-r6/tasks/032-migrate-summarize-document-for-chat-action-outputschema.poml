    <constraint source="project">Migration script MUST be idempotent (guard with GET before PATCH) and committed to `scripts/`.</constraint>
    <constraint source="project">outputSchema MUST be a syntactically valid JSON Schema document (validate against draft-07 or compatible meta-schema in script).</constraint>
  </constraints>

