    <patterns>
      <pattern name="Action row PATCH via Web API" location=".claude/patterns/dataverse/web-api-client.md">
        Pattern: query action row by alternate key (`sprk_actioncode = 'summarize-document-for-chat@v1'`);
        GET current `sprk_outputschemajson` value; if null, PATCH with the new schema; if
        non-null AND matches expected schema, skip; if non-null AND mismatches, fail
        with conflict message (manual intervention required).
      </pattern>
      <pattern name="JPS output contract inspection" location="docs/guides/JPS-AUTHORING-GUIDE.md">
        The existing `$choices`-constrained output for SUM-CHAT@v1 enumerates the JSON
        fields the action emits. Walk through the action's JPS source (likely in
        `infra/dataverse/` or seeded data) to extract the exact field types. Build a JSON
        Schema describing those fields.
      </pattern>
    </patterns>
