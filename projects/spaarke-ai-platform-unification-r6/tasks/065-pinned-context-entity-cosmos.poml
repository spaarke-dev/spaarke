  <acceptance-criteria>
    <criterion testable="true">`PinnedContextItem` entity with required fields; `pinType` enum constrained to 3 values.</criterion>
    <criterion testable="true">Service supports Get/Create/Update/Delete with per-tenant + per-user partition key.</criterion>
    <criterion testable="true">Unit tests for tenant isolation + each CRUD method.</criterion>
