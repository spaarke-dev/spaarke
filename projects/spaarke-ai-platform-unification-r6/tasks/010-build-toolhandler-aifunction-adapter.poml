      <file>.claude/adr/ADR-013-ai-architecture.md</file>
      <file>.claude/adr/ADR-015-ai-data-governance.md</file>
      <file>.claude/adr/ADR-029-bff-publish-hygiene.md</file>
      <file>.claude/constraints/bff-extensions.md</file>
      <file>docs/architecture/AI-ARCHITECTURE.md</file>
      <file>docs/architecture/chat-architecture.md</file>
      <file>src/server/api/Sprk.Bff.Api/CLAUDE.md</file>
