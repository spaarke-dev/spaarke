  </inputs>

  <constraints>
    <constraint source="ADR-010">Register in existing module.</constraint>
    <constraint source="ADR-013">BFF-side AI service.</constraint>
    <constraint source="ADR-029">Publish-size delta verified.</constraint>
    <constraint source="spec FR-44">Hierarchical composition: recent verbatim + compressed mid + retrieved old.</constraint>
    <constraint source="spec NFR-10">8K total budget; pinned never dropped.</constraint>
  </constraints>

  <knowledge>
    <topic>bff/ai-memory-composition</topic>
    <files>
      <file>docs/architecture/AI-ARCHITECTURE.md</file>
      <file>.claude/adr/ADR-013-ai-architecture.md</file>
      <file>.claude/adr/ADR-029-bff-publish-hygiene.md</file>
    </files>
  </knowledge>

  <steps>
    <step order="0" name="Context Check + Rigor Declaration">"🔒 RIGOR LEVEL: FULL — Composition orchestrator; budget enforcement critical."</step>
    <step order="1" name="Review Progress">Read TASK-INDEX; confirm 064/065/066 complete.</step>
    <step order="2" name="Gather Resources">Read primitives + budget tracking patterns.</step>
    <step order="3" name="Author Composition Service">`IMemoryCompositionService` + impl. Constructor injects compression + pinned + recall services.</step>
    <step order="4" name="Implement Layering">Recent (last 10) + compressed (10-50) + retrieved (50+ by similarity) + pinned. Tag each layer in output.</step>
    <step order="5" name="Implement Budget Enforcement">Drop priority order; pinned never dropped.</step>
    <step order="6" name="Register in Module">Per ADR-010.</step>
    <step order="7" name="Tests">Unit tests for each layer + budget enforcement + pinned-always-present.</step>
    <step order="8" name="Publish-Size + CVE">dotnet publish + vulnerable check.</step>
    <step order="9.5" name="Quality Gates (FULL)">code-review + adr-check.</step>
    <step order="10" name="Document + Complete">TASK-INDEX 067 ✅.</step>
  </steps>

  <tools>
