<task id="023" project="spaarke-ai-platform-unification-r6">
  <metadata>
    <title>D-A-15 Remove `InvokeSummarizePlaybookTool` + `InvokeInsightsQueryTool` Specialized Bridges (Pillar 3)</title>
    <phase>Phase A — Data-driven Foundation</phase>
    <status>not-started</status>
    <estimated-effort>4 hours</estimated-effort>
