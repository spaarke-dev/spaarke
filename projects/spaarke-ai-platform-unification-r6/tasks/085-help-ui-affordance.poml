  <acceptance-criteria>
    <criterion testable="true">`HelpAffordance.tsx` exists and renders a Fluent v9 button with help icon + tooltip.</criterion>
    <criterion testable="true">Clicking opens the same `CommandHelpPanel` drawer as `/help` (task 081 reuse confirmed).</criterion>
