    <patterns>
      <pattern name="Fluent v9 icon button in input bar" location=".claude/patterns/ui/fluent-v9-component-authoring.md">
        Use `&lt;Button appearance="subtle" icon={&lt;Help24Regular /&gt;} aria-label="Show available commands (/help)" /&gt;`. Tooltip via Fluent v9 `Tooltip`. Semantic tokens for colors.
      </pattern>
      <pattern name="Reuse CommandHelpPanel drawer" location="src/solutions/SpaarkeAi/src/components/conversation/CommandHelpPanel.tsx (from task 081)">
        Trigger same drawer via shared `useCommandHelpPanel()` hook or via HardSlashExecutor.executeHardSlash({command: 'help'}).
      </pattern>
    </patterns>
  </knowledge>

  <steps>
    <step order="0" name="Context Check + Rigor Declaration">
      Check context. Output: "🔒 RIGOR LEVEL: STANDARD — UI affordance built on existing drawer from task 081; ADR-021 dark-mode check required".
    </step>
    <step order="1" name="Review Progress">
      Read TASK-INDEX.md; confirm 085 status is 🔲, dep 081 is ✅. Update `current-task.md`.
    </step>
    <step order="2" name="Gather Resources">
      Read CommandHelpPanel.tsx (task 081 output). Read Fluent v9 patterns. Identify the chat input bar location in ConversationPane.tsx.
    </step>
    <step order="3" name="Author HelpAffordance">
      Create `src/solutions/SpaarkeAi/src/components/conversation/HelpAffordance.tsx`. Fluent v9 Button + Tooltip. Click handler opens the same drawer as `/help`. Accessibility: `aria-label`, keyboard focus, screen-reader text.
    </step>
    <step order="4" name="Wire into ConversationPane">
      Add `&lt;HelpAffordance /&gt;` to the chat input bar in `ConversationPane.tsx`. Positioned beside the send button.
    </step>
    <step order="5" name="Build + Visual Verification">
      Run build. Visually verify the affordance is discoverable (icon visible, tooltip clear). Verify clicking opens the drawer with command list.
    </step>
    <step order="6" name="Verify Acceptance Criteria">
      Walk through every &lt;acceptance-criterion&gt; below.
    </step>
    <step order="7" name="Document + Complete">
      Update task POML status. Update TASK-INDEX.md: 085 🔲 → ✅. Reset `current-task.md`. Report completion + downstream unblock (087).
    </step>
  </steps>

