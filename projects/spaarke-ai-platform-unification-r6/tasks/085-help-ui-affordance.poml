  <ui-tests>
    <test name="Help Affordance Visible + Functional">
      <url>https://{org}.crm.dynamics.com/main.aspx?appid={app-id}&amp;pagetype=control&amp;controlName=spaarke_SpaarkeAi</url>
      <steps>
        <step>Open conversation pane</step>
        <step>Verify help icon button visible in chat input bar</step>
        <step>Hover; verify tooltip shows "Show available commands (/help)"</step>
        <step>Click; verify CommandHelpPanel drawer opens with command list</step>
        <step>Verify drawer shows all 6 hard slashes + 4 soft slashes</step>
      </steps>
      <expected>Affordance discoverable; drawer opens; commands listed</expected>
    </test>
    <test name="Dark Mode Compliance (ADR-021)">
      <steps>
        <step>Toggle dark mode in D365 settings</step>
        <step>Verify help affordance icon adapts (no white background in dark mode)</step>
        <step>Verify tooltip text + drawer background use semantic tokens</step>
        <step>Verify icons use currentColor</step>
      </steps>
      <expected>All colors use Fluent v9 semantic tokens per ADR-021</expected>
    </test>
    <test name="Accessibility">
      <steps>
        <step>Tab-navigate to the help affordance</step>
        <step>Verify focus ring visible</step>
        <step>Press Enter; verify drawer opens</step>
        <step>Verify screen-reader announces aria-label</step>
      </steps>
      <expected>Keyboard + screen-reader accessible</expected>
    </test>
  </ui-tests>
</task>
