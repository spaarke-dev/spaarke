    <file purpose="workspace-architecture">docs/architecture/SPAARKEAI-WORKSPACE-ARCHITECTURE.md</file>
  </inputs>

  <constraints>
    <constraint source="spec FR-51">References resolve at parse time + included in agent prompt as known entities. 3 reference types: `#scope`, `@&lt;entity&gt;`, `#&lt;filename&gt;`.</constraint>
    <constraint source="spec Phase D exit criterion 4">Verifiable: `@matter` resolves to matter record; `#contract.docx` resolves to session file; resolved entities appear in agent prompt.</constraint>
    <constraint source="spec NFR-01">Resolver never blocks the conversation. Unresolved refs degrade with `resolved: false`.</constraint>
    <constraint source="ADR-013">Use existing PublicContracts facades (scope endpoints, polymorphic resolvers); no new facade added.</constraint>
    <constraint source="ADR-014">Cache resolutions per session with `tenantId` in keys (use existing Redis pattern if BFF cache; or in-memory frontend cache).</constraint>
    <constraint source="ADR-029">BFF publish-size delta = 0 MB.</constraint>
    <constraint source="project Pillar 8">Q6 reference types closed at exactly 3 — do NOT extend.</constraint>
  </constraints>

  <knowledge>
