    </files>
    <patterns>
      <pattern name="ResolvedReference shape" location="src/solutions/SpaarkeAi/src/components/conversation/ReferenceResolver.ts (new)">
        Export `ResolvedReference { type: 'scope' | 'entity' | 'file'; rawToken: string; canonicalId: string | null; displayName: string; metadata: unknown; resolved: boolean }`. Async `resolveAll(refs: Reference[], ctx): Promise&lt;ResolvedReference[]&gt;`.
      </pattern>
      <pattern name="Session-files registry" location="task 050s output (Pillar 6a workspace state)">
        File-name references first check open workspace tabs (in-memory state); fall back to session-files Azure Search index via BFF endpoint. Use cached `WorkspaceState` from Pillar 6a.
      </pattern>
    </patterns>
  </knowledge>

  <steps>
    <step order="0" name="Context Check + Rigor Declaration">
      Check context usage. Output: "🔒 RIGOR LEVEL: FULL — Reference resolution surfaces to agent prompt; FR-51 + Phase D exit 4 binding".
    </step>
    <step order="1" name="Review Progress">
      Read TASK-INDEX.md; confirm 083 status is 🔲, dep 080 is ✅. Update `current-task.md`.
    </step>
    <step order="2" name="Gather Resources">
      Read scope-architecture.md + polymorphic-resolver.md pattern + WORKSPACE-ARCHITECTURE.md. Identify the BFF endpoints to use for each resolver type (scope endpoint, polymorphic entity endpoint, session-files endpoint from Pillar 6a).
    </step>
    <step order="3" name="Author ReferenceResolver">
      Create `src/solutions/SpaarkeAi/src/components/conversation/ReferenceResolver.ts`. Implement `resolveAll(refs, ctx)`. Per-type resolvers: scope (uses scope endpoint), entity (uses polymorphic-resolver), file (checks open tabs first, then session-files endpoint).
    </step>
    <step order="4" name="Caching">
      Implement per-session in-memory cache keyed by `tenantId:sessionId:rawToken`. Cache TTL matches session lifecycle. Invalidate on `/clear` (task 081 signals via PaneEventBus existing channel).
    </step>
    <step order="5" name="Graceful Degradation">
      Unresolved references return `{ resolved: false, rawToken, displayName: rawToken }`. Conversation never blocks. Agent prompt receives unresolved tokens so the agent can ask for clarification.
    </step>
    <step order="6" name="Wire into ConversationPane Send Path">
      In `ConversationPane.tsx`, when `intent.references.length > 0`, await `ReferenceResolver.resolveAll(intent.references, ctx)` before sending. Attach `resolvedReferences` to message payload metadata.
    </step>
    <step order="7" name="Tests">
      Cover: each reference type resolves correctly; cache hits don't re-fetch; cache invalidation on `/clear`; unresolved refs degrade gracefully; mixed resolved + unresolved in one message.
    </step>
    <step order="8" name="Verify Acceptance Criteria">
      Walk through every &lt;acceptance-criterion&gt; below.
    </step>
    <step order="9.5" name="Quality Gates (FULL rigor)">
      Run `code-review` + `adr-check`. Verify ADR-013 (uses existing facades), ADR-014 (tenantId in cache keys), ADR-029 (size 0 MB), NFR-01 (never blocks). Both gates MUST pass.
    </step>
    <step order="10" name="Document + Complete">
      Update task POML status. Update TASK-INDEX.md: 083 🔲 → ✅. Reset `current-task.md`. Report completion + downstream unblock (084).
    </step>
  </steps>

  <tools>
