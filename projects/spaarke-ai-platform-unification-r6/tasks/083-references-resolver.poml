  <acceptance-criteria>
    <criterion testable="true">`ReferenceResolver.ts` resolves all 3 reference types (`#scope`, `@&lt;entity&gt;`, `#&lt;filename&gt;`).</criterion>
    <criterion testable="true">`@matter` resolves to a matter record with canonical ID + display name (Phase D exit criterion 4).</criterion>
    <criterion testable="true">`#contract.docx` resolves to a session file (or open workspace tab) with canonical ID (Phase D exit criterion 4).</criterion>
    <criterion testable="true">Resolved references appear in chat message payload metadata; verifiable in BFF prompt construction (Phase D exit criterion 4).</criterion>
    <criterion testable="true">Cache hits avoid redundant resolution; cache keys include `tenantId` per ADR-014.</criterion>
    <criterion testable="true">Unresolved references degrade gracefully with `resolved: false` flag; conversation never blocks.</criterion>
    <criterion testable="true">Mixed resolved + unresolved references in one message work correctly.</criterion>
    <criterion testable="true">BFF publish-size delta = 0 MB (frontend-only task).</criterion>
    <criterion testable="true">`code-review` + `adr-check` quality gates pass at Step 9.5.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="Entity Reference Resolves">
      <url>https://{org}.crm.dynamics.com/main.aspx?appid={app-id}&amp;pagetype=control&amp;controlName=spaarke_SpaarkeAi</url>
      <steps>
        <step>Open conversation pane in active matter context</step>
        <step>Type "tell me about @matter" and submit</step>
        <step>Verify reference resolves to current matter; agent prompt includes matter ID + name</step>
        <step>Verify agent response references the specific matter</step>
      </steps>
      <expected>`@matter` resolves to canonical matter record; response is matter-specific</expected>
    </test>
    <test name="File Reference Resolves">
      <steps>
        <step>Upload a session file (e.g., contract.pdf)</step>
        <step>Type "summarize #contract.pdf" (composition with soft slash)</step>
        <step>Verify file reference resolves to session file ID</step>
        <step>Verify summarize playbook receives the resolved file as input</step>
      </steps>
      <expected>File reference resolves; playbook receives canonical file ID</expected>
    </test>
    <test name="Dark Mode Compliance (ADR-021)">
      <steps>
        <step>Toggle dark mode</step>
        <step>Type a message with `@matter` reference; verify any UI affordance (autocomplete dropdown if present) adapts to dark mode</step>
      </steps>
      <expected>Reference affordances use Fluent v9 semantic tokens; no hardcoded colors</expected>
    </test>
  </ui-tests>
