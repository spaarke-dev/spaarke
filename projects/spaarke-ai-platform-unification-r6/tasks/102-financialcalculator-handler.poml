<task id="102" project="spaarke-ai-platform-unification-r6">
  <metadata>
    <title>D-H-02 `FinancialCalculatorHandler` (FR-18, Wave 1 — Pure Deterministic)</title>
    <phase>Parallel — 8 Typed Tool Handlers</phase>
    <status>not-started</status>
