  </outputs>

  <acceptance-criteria>
    <criterion testable="true">`GET /api/ai/scopes/personas` route maps and returns 200 with empty list when no personas exist.</criterion>
    <criterion testable="true">Endpoint applies the same authorization filter as other scope endpoints (ADR-008 verified by adr-check).</criterion>
    <criterion testable="true">Endpoint applies `ai-context` rate-limit policy (ADR-016 verified).</criterion>
    <criterion testable="true">Registration occurs inside existing module pattern per ADR-010 — ZERO new top-level Program.cs lines.</criterion>
    <criterion testable="true">No injection of AI internals; only `IScopeResolverService` consumed per ADR-013 facade boundary.</criterion>
    <criterion testable="true">Unit test covers endpoint mapping + filter application + pagination.</criterion>
    <criterion testable="true">BFF publish-size delta reported in task notes; ≤+5 MB R6 total budget verified.</criterion>
    <criterion testable="true">`code-review` + `adr-check` quality gates pass at Step 9.5.</criterion>
  </acceptance-criteria>
</task>
