  <acceptance-criteria>
    <criterion testable="true">`InvokePlaybookHandler` implements `IToolHandler`; injects `IInvokePlaybookAi` facade only (no `IPlaybookOrchestrationService` direct injection per ADR-013).</criterion>
    <criterion testable="true">`sprk_analysistool` row seeded with name "invoke_playbook", AvailableInContexts=Chat, valid JsonSchema.</criterion>
    <criterion testable="true">Handler validates playbookId against tenant-accessible `sprk_analysisplaybook` rows.</criterion>
    <criterion testable="true">Handler validates parameters against playbook's parameter schema.</criterion>
    <criterion testable="true">Tenant isolation enforced; cross-tenant id rejected.</criterion>
    <criterion testable="true">Telemetry payload ADR-015-compliant; no user message content.</criterion>
    <criterion testable="true">Handler registered inside existing module per ADR-010.</criterion>
    <criterion testable="true">BFF publish-size delta reported; ≤+5 MB R6 budget.</criterion>
    <criterion testable="true">`code-review` + `adr-check` quality gates pass.</criterion>
  </acceptance-criteria>
</task>
