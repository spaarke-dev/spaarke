  </outputs>

  <acceptance-criteria>
    <criterion testable="true">All 6 hard slashes (`/clear`, `/new-session`, `/help`, `/export`, `/save-to-matter`, `/pin`) implemented in HardSlashExecutor.ts.</criterion>
    <criterion testable="true">Each hard slash executes in &lt;100ms p99 (verified via `performance.now()` brackets in tests).</criterion>
    <criterion testable="true">Zero Azure OpenAI requests made when a hard slash is invoked (verified via fetch mock instrumentation; phase D exit criterion 2 met).</criterion>
    <criterion testable="true">`/help` opens a Fluent v9 panel listing all available commands; semantic tokens used per ADR-021 (dark-mode safe).</criterion>
    <criterion testable="true">`/save-to-matter [matterId]` + `/pin` reuse existing Pillar 6 endpoints (no new BFF surface; confirmed via code review).</criterion>
    <criterion testable="true">Telemetry per ADR-015 — command name + decision + timestamp only; no user message text logged.</criterion>
    <criterion testable="true">NFR-11 backward compat: non-slash input continues unchanged through CapabilityRouter.</criterion>
    <criterion testable="true">BFF publish-size delta = 0 MB (no .cs files modified).</criterion>
    <criterion testable="true">`code-review` + `adr-check` quality gates pass at Step 9.5.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test name="Hard Slashes Execute Without LLM">
      <url>https://{org}.crm.dynamics.com/main.aspx?appid={app-id}&amp;pagetype=control&amp;controlName=spaarke_SpaarkeAi</url>
      <steps>
        <step>Open conversation pane in active session</step>
        <step>Type `/clear` and submit; observe conversation history cleared instantly</step>
        <step>Type `/help` and submit; observe help drawer opens with command list</step>
        <step>Type `/new-session`; observe new session ID</step>
        <step>Verify Network tab shows no chat-completion request for any hard slash</step>
      </steps>
      <expected>All hard slashes execute instantly; no Azure OpenAI requests; help drawer accessible</expected>
    </test>
    <test name="Dark Mode Compliance (ADR-021)">
      <steps>
        <step>Toggle dark mode in D365 settings</step>
        <step>Type `/help`; verify help drawer adapts (no white background in dark mode)</step>
        <step>Verify text + icons use Fluent semantic tokens</step>
      </steps>
      <expected>Help drawer uses Fluent v9 semantic tokens per ADR-021; no hardcoded colors</expected>
    </test>
    <test name="`/save-to-matter` Persists via Existing Endpoint">
      <steps>
        <step>Open a workspace tab</step>
        <step>Type `/save-to-matter 00000000-0000-0000-0000-000000000001` and submit</step>
        <step>Observe Network tab call to existing Pillar 6 pin endpoint</step>
        <step>Reload session; verify tab persists attached to matter</step>
      </steps>
      <expected>Save persists via existing endpoint; reload confirms attachment</expected>
    </test>
  </ui-tests>
</task>
