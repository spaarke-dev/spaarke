  <constraints>
    <constraint source="ADR-010">No new top-level Program.cs lines; orchestrator already registered inside existing module.</constraint>
    <constraint source="ADR-013">Orchestrator is AI-internal; no facade-boundary change.</constraint>
    <constraint source="ADR-015">No user message content in telemetry; engine emits playbook + node + action IDs + decisions + timestamps only.</constraint>
    <constraint source="ADR-018">No new feature flags.</constraint>
    <constraint source="ADR-029">Verify BFF publish-size delta; ≤+5 MB R6 budget per NFR-02.</constraint>
    <constraint source="spec NFR-08">11 production node executors UNMODIFIED — engine path uses existing executors.</constraint>
    <constraint source="spec NFR-13">Safety pipeline middleware chain (PromptShield + Groundedness + Citations + Privilege + Cross-matter) MUST continue to wrap the chat /summarize call.</constraint>
    <constraint source="spec FR-26">Existing functionality preserved: session-files filter + Structured Outputs mode + streaming JSON delta. FK chain traversed; NO `sprk_actioncode` alternate-key lookup remains in chat path.</constraint>
    <constraint source="project CLAUDE.md MUST NOT">MUST NOT load action by alternate key in chat /summarize path after this task lands.</constraint>
  </constraints>

