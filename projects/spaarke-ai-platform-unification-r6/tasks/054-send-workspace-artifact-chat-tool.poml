    <file purpose="tool-handler-iface">src/server/api/Sprk.Bff.Api/Services/Ai/IAnalysisToolHandler.cs</file>
  </inputs>

  <constraints>
    <constraint source="ADR-010">Register in existing module per DI minimalism; auto-discovery via `IToolHandler` registry collection injection. ZERO new Program.cs lines.</constraint>
    <constraint source="ADR-013">Tool is BFF-side; consumes `WorkspaceStateService` directly (BFF-internal); does NOT cross facade boundary inappropriately.</constraint>
    <constraint source="ADR-015">Telemetry emits tool name + decision + timestamp ONLY. NEVER the artifact `content` body. Deterministic IDs (tabId, sessionId, matterId) acceptable.</constraint>
    <constraint source="ADR-029">Verify publish-size delta; expect &lt;1 MB; total R6 budget ≤+5 MB.</constraint>
    <constraint source="ADR-030">Publish `workspace.tab_created` on existing `workspace` channel; NO new channel. Additive event types only.</constraint>
    <constraint source="spec FR-35">Tool creates new tab; registered as `sprk_analysistool` row with `AvailableInContexts ∋ "Chat"`.</constraint>
    <constraint source="project R6 Pillar 6b">Tool builds on Phase A Pillar 2 infrastructure (`IToolHandler`, `ToolHandlerToAIFunctionAdapter`). Must use those primitives, NOT hardcode a parallel chat-tool class.</constraint>
  </constraints>

