  </tools>

  <ui-tests>
    <test name="Array-Typed Field Renders as Bulleted List (fixes R5 TL;DR bug)">
      <url>https://{org}.crm.dynamics.com/main.aspx?appid={app-id}&amp;pagetype=custom&amp;name=spaarke-ai-workspace</url>
      <steps>
        <step>Open SpaarkeAi workspace shell against a test matter</step>
        <step>Trigger `summarize-document-for-workspace@v1` against a test document via the workspace path</step>
        <step>Wait for `streaming_complete` event to fire</step>
        <step>Inspect the rendered output for the `tldr` field</step>
        <step>Verify rendered DOM uses semantic `<ul>` with multiple `<li>` children</step>
        <step>Verify NO raw streaming JSON token fragments (e.g., `[\"first`) appear in the visible text</step>
        <step>Check browser console for JavaScript errors — none expected</step>
      </steps>
      <expected>`tldr` field renders as a Fluent v9 bulleted list with one `<li>` per array element; no raw JSON visible; no console errors</expected>
    </test>

    <test name="Dark Mode Compliance (ADR-021)">
      <steps>
        <step>Toggle dark mode in D365 settings</step>
        <step>Reload the workspace shell</step>
        <step>Trigger the same workspace summarization</step>
        <step>Verify bulleted-list text color adapts to dark theme (uses `tokens.colorNeutralForeground1`)</step>
        <step>Verify list-item bullet markers adapt</step>
        <step>Verify spacing tokens (`tokens.spacingHorizontalM`) are unaffected by theme</step>
        <step>Toggle back to light mode; verify reverse adaptation</step>
      </steps>
      <expected>All colors adapt via Fluent UI v9 semantic tokens; no hard-coded white-in-dark or black-in-light</expected>
    </test>

    <test name="Backward Compatibility (Actions Without outputSchema)">
      <steps>
        <step>Open SpaarkeAi workspace shell</step>
        <step>Trigger an action whose row has NULL `sprk_outputschemajson` (e.g., a not-yet-migrated action)</step>
        <step>Wait for streaming_complete</step>
        <step>Verify widget renders accumulated text as a string (current behavior)</step>
        <step>Check console — no errors expected (legacy path still works)</step>
      </steps>
      <expected>Widget falls back to string rendering when outputSchema is absent; no regression on non-migrated actions</expected>
    </test>

    <test name="Streaming In-Progress Indicator">
      <steps>
        <step>Trigger workspace summarization</step>
        <step>Observe widget DURING streaming (before streaming_complete fires)</step>
        <step>Verify an "in-progress" / "loading" indicator is visible</step>
        <step>Verify rendered list does NOT appear until streaming_complete</step>
      </steps>
      <expected>Streaming indicator visible until streaming_complete; rendered list appears atomically after parse</expected>
    </test>
  </ui-tests>

