  </outputs>

  <acceptance-criteria>
    <criterion testable="true">"Send to Workspace" button visible on chat assistant messages; click creates tab with `visibleToAssistant: false`.</criterion>
    <criterion testable="true">"Add to Assistant" toggle visible on user-created tabs; toggle flips `visibleToAssistant`.</criterion>
    <criterion testable="true">"Pin to Matter" affordance pins tab + promotes to Cosmos durable.</criterion>
    <criterion testable="true">Reload session: pinned tabs reappear; non-pinned cleared after TTL.</criterion>
    <criterion testable="true">Dark-mode parity verified per ADR-021.</criterion>
    <criterion testable="true">All affordances emit appropriate `workspace.*` events on existing channel (no 5th channel).</criterion>
    <criterion testable="true">Fluent v9 conventions followed per ADR-012.</criterion>
    <criterion testable="true">code-review + adr-check pass.</criterion>
  </acceptance-criteria>

  <ui-tests>
    <test>Render SendToWorkspaceButton in light + dark themes; verify ADR-021 token usage.</test>
    <test>Click SendToWorkspaceButton; verify tab appears in workspace strip with `visibleToAssistant: false`.</test>
    <test>Toggle AddToAssistant on a tab; verify `visibleToAssistant` flips; verify event emitted.</test>
    <test>Click PinToMatter; reload page; verify tab persists.</test>
  </ui-tests>
</task>
