  <ui-tests>
    <test>Render PinnedMemoryListWidget with 6 mock items (2 of each pinType); verify grouping.</test>
    <test>Filter by pinType; verify only matching items shown.</test>
    <test>Search by title; verify case-insensitive matching.</test>
    <test>Open PinnedMemoryEditDialog; create new item; verify it appears in list + Cosmos persisted.</test>
    <test>Edit existing item; verify update persists.</test>
    <test>Delete item; verify confirmation shown + item removed.</test>
    <test>Render in dark mode; verify ADR-021 token usage.</test>
    <test>Provenance badge correctly distinguishes chat-created vs UI-created items.</test>
  </ui-tests>
