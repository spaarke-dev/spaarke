    <file purpose="pinned-context-svc">src/server/api/Sprk.Bff.Api/Services/Ai/Memory/IPinnedContextService.cs</file>
  </inputs>

  <constraints>
    <constraint source="ADR-008">Endpoint pair (GET/POST/PUT/DELETE) wired with auth filter + ai-context rate limit.</constraint>
    <constraint source="ADR-010">BFF endpoints registered in existing module.</constraint>
    <constraint source="ADR-012">Components in shared lib; Fluent v9 conventions.</constraint>
    <constraint source="ADR-013">UI consumes BFF endpoints via standard HTTP; BFF endpoints route through service contract.</constraint>
    <constraint source="ADR-021">Light + dark mode parity verified per dark-mode audit.</constraint>
    <constraint source="ADR-029">Publish-size delta verified.</constraint>
    <constraint source="ADR-030">UI emits events on existing channels only; no new channel.</constraint>
    <constraint source="spec FR-47 (expanded per Q7)">R6 ships full Pinned Memory CRUD + visualization (NOT R7-deferred).</constraint>
    <constraint source="project Q7 SCOPE EXPANSION binding">Task adds 1-2 weeks to Phase C calendar. Re-defer to R7 only if Phase B slipped >5 days per plan.md risk R4.</constraint>
  </constraints>

