<task id="056" project="spaarke-ai-platform-unification-r6">
  <metadata>
    <title>D-C-07 — `close_workspace_tab` chat tool</title>
    <status>completed</status>
    <estimated-effort>3 hours</estimated-effort>
    <phase>Phase C — Tri-directional Workspace (Pillar 6b)</phase>
    <wave>C-G2 (parallel after 6a)</wave>
    <parallel-safe>true</parallel-safe>
    <dependencies>053 (workspace state wired into factory)</dependencies>
    <tags>bff-api, ai, chat, workspace, tool-handler</tags>
    <rigor-level>FULL</rigor-level>
    <rigor-hint>FULL</rigor-hint>
    <rigor-reason>Destructive operation (closes a tab); must respect user pin state + emit governance-compliant telemetry.</rigor-reason>
    <parallel-group>C-G2</parallel-group>
  </metadata>

  <prompt>
    Build the `close_workspace_tab(tabId)` chat tool as an `IToolHandler`. On invocation:
    fetches tab; if `isPinned: true`, REFUSES with a polite response ("pinned tab; user
    must unpin first"); if not pinned, calls `WorkspaceStateService.CloseTabAsync` (which
    removes from Redis hot tier but does NOT delete Cosmos durable rows for previously
    pinned data — durable state preserved per spec FR-32). Emits `workspace.tab_closed`
    event with deterministic IDs only. Register as `sprk_analysistool` row with
    `AvailableInContexts = "Chat"`. ADR-015 binding: telemetry emits tool name + decision
    (`closed` | `refused_pinned`) + timestamp + tabId only.
  </prompt>

  <role>
    Senior BFF engineer familiar with the workspace state model + tool handler pattern.
  </role>

  <goal>
    `close_workspace_tab` tool installed; respects pin state; emits event; telemetry
    governance-compliant.
  </goal>

  <inputs>
    <file purpose="project-spec">projects/spaarke-ai-platform-unification-r6/spec.md</file>
    <file purpose="project-plan">projects/spaarke-ai-platform-unification-r6/plan.md</file>
    <file purpose="project-claude">projects/spaarke-ai-platform-unification-r6/CLAUDE.md</file>
    <file purpose="root-claude">CLAUDE.md</file>
    <file purpose="workspace-svc">src/server/api/Sprk.Bff.Api/Services/Workspace/IWorkspaceStateService.cs</file>
  </inputs>

  <constraints>
    <constraint source="ADR-010">Auto-discovery in existing module; ZERO new Program.cs lines.</constraint>
    <constraint source="ADR-013">BFF-internal tool.</constraint>
    <constraint source="ADR-015">Tool name + decision + timestamp + tabId only in telemetry. NEVER tab content.</constraint>
    <constraint source="ADR-029">Publish-size delta verified.</constraint>
    <constraint source="ADR-030">Publish `workspace.tab_closed` on existing `workspace` channel; additive event only.</constraint>
    <constraint source="spec FR-35">Tool closes tab; registered as `sprk_analysistool` row.</constraint>
    <constraint source="project R6 Pillar 6b">Pinned tabs refused; user explicitly unpins first.</constraint>
  </constraints>

  <knowledge>
    <topic>bff/ai-chat-tools</topic>
    <files>
      <file>.claude/adr/ADR-010-di-minimalism.md</file>
