    </files>
  </knowledge>

  <steps>
    <step order="0" name="Context Check + Rigor Declaration">"🔒 RIGOR LEVEL: FULL — Destructive workspace operation; pin guard critical."</step>
    <step order="1" name="Review Progress">Read TASK-INDEX.</step>
    <step order="2" name="Gather Resources">WorkspaceStateService.CloseTabAsync semantics.</step>
    <step order="3" name="Author Handler">Create `CloseWorkspaceTabHandler.cs`.</step>
    <step order="4" name="Implement Pin Guard">Fetch tab; if pinned, return refusal response without mutation.</step>
    <step order="5" name="Implement Close">Call CloseTabAsync; emit `workspace.tab_closed` event.</step>
    <step order="6" name="Seed Dataverse Row">`sprk_analysistool` row.</step>
    <step order="7" name="Tests">Pin guard test; close path test; ADR-015 audit (no tab content in telemetry).</step>
    <step order="8" name="Publish-Size">dotnet publish + measure.</step>
    <step order="9.5" name="Quality Gates (FULL)">code-review + adr-check.</step>
    <step order="10" name="Document + Complete">TASK-INDEX 056 ✅.</step>
  </steps>

