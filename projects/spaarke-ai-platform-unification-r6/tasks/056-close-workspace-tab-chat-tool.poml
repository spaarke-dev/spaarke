  <acceptance-criteria>
    <criterion testable="true">Pinned tab close refused with structured response (no mutation).</criterion>
    <criterion testable="true">Unpinned tab close removes from Redis + emits `workspace.tab_closed`.</criterion>
    <criterion testable="true">Cosmos durable rows preserved for previously pinned data.</criterion>
