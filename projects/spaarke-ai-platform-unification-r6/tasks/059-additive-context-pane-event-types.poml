    <constraint source="ADR-030">4 channels closed (workspace / context / conversation / safety); additive event types only; no 5th channel.</constraint>
    <constraint source="ADR-012">Shared lib `@spaarke/ai-widgets`; Fluent v9 conventions.</constraint>
