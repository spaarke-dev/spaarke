{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spaarke.com/insights/schemas/outcome-extraction/v1.json",
  "title": "OutcomeExtractionResponse",
  "description": "Strict shape of the JSON returned by the outcome-extraction@v1 prompt (SPEC-phase-1-minimum.md §3.4). Used by OutcomeExtractionResponseValidator to reject malformed LLM output before downstream D-P9 / D-P10 gates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "outcomeCategory",
    "settlementAmount",
    "settlementCurrency",
    "outcomeDate",
    "matterDurationDays",
    "keyTerms",
    "evidence",
    "confidence"
  ],
  "properties": {
    "outcomeCategory": {
      "type": ["string", "null"],
      "enum": [
        "favorable_to_client",
        "unfavorable_to_client",
        "neutral",
        "mixed",
        "unclear",
        null
      ]
    },
    "settlementAmount": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "settlementCurrency": {
      "type": ["string", "null"],
      "pattern": "^[A-Z]{3}$"
    },
    "outcomeDate": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "matterDurationDays": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "keyTerms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["term", "description"],
        "properties": {
          "term": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcomeCategory", "settlementAmount", "outcomeDate", "matterDurationDays"],
      "properties": {
        "outcomeCategory": { "type": ["string", "null"] },
        "settlementAmount": { "type": ["string", "null"] },
        "outcomeDate": { "type": ["string", "null"] },
        "matterDurationDays": { "type": ["string", "null"] }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcomeCategory", "settlementAmount", "outcomeDate", "matterDurationDays"],
      "properties": {
        "outcomeCategory": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "settlementAmount": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "outcomeDate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "matterDurationDays": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "explanations": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
