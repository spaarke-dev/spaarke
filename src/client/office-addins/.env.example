# Office Add-in Configuration
# Copy this file to .env and update ALL values before building.
# All four variables below are REQUIRED — the build will fail if any are missing.

# Azure AD App Registration for Office Add-in
ADDIN_CLIENT_ID=your-addin-client-id-here

# Spaarke Tenant
TENANT_ID=your-tenant-id-here

# BFF API Configuration
BFF_API_CLIENT_ID=your-bff-api-client-id-here
BFF_API_BASE_URL=https://your-bff-api-url-here

# Optional: Fallback redirect URI for Dialog API auth (when NAA is not supported)
# FALLBACK_REDIRECT_URI=https://your-addin-url/auth-callback.html
