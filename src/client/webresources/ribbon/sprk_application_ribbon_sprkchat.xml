<!--
  Application Ribbon: Global "SprkChat" Button

  Adds a visible "SprkChat" button to the global command bar across all pages.
  Reuses openSprkChatPane.js which has singleton pane management.

  The enable rule also triggers auto-init of the side pane as a side-effect,
  providing a backup loading mechanism for OOB forms.

  Web Resource: sprk_/scripts/openSprkChatPane.js
  Namespace: Spaarke.SprkChat

  Version: 1.0.0
-->
<RibbonDiffXml>
  <CustomActions>

    <!-- ================================================================== -->
    <!-- Global "SprkChat" Button — visible in command bar on all pages      -->
    <!-- ================================================================== -->
    <CustomAction Id="sprk.Global.SprkChat.OpenButton.CustomAction"
                  Location="Mscrm.GlobalTab.MainTab.Actions.Controls._children"
                  Sequence="500">
      <CommandUIDefinition>
        <Button Id="sprk.Global.SprkChat.OpenButton"
                Command="sprk.Global.SprkChat.Open.Command"
                LabelText="$LocLabels:sprk.SprkChat.Button.Label"
                Alt="$LocLabels:sprk.SprkChat.Button.Alt"
                ToolTipTitle="$LocLabels:sprk.SprkChat.Button.Label"
                ToolTipDescription="$LocLabels:sprk.SprkChat.Button.Tooltip"
                TemplateAlias="o1"
                Image16by16="/_imgs/ribbon/Chat_16.png"
                Image32by32="/_imgs/ribbon/Chat_32.png"
                ModernImage="Chat" />
      </CommandUIDefinition>
    </CustomAction>

  </CustomActions>

  <CommandDefinitions>

    <!-- ================================================================== -->
    <!-- Command: Open SprkChat pane (or focus if already open)              -->
    <!-- ================================================================== -->
    <CommandDefinition Id="sprk.Global.SprkChat.Open.Command">
      <EnableRules>
        <EnableRule Id="sprk.Global.SprkChat.Open.EnableRule" />
      </EnableRules>
      <DisplayRules />
      <Actions>
        <JavaScriptFunction Library="$webresource:sprk_openSprkChatPane"
                           FunctionName="Spaarke.SprkChat.openPane">
          <CrmParameter Value="PrimaryControl" />
        </JavaScriptFunction>
      </Actions>
    </CommandDefinition>

  </CommandDefinitions>

  <RuleDefinitions>
    <EnableRules>

      <!-- Enable Rule: Available when sidePanes API exists.                -->
      <!-- Side-effect: triggers autoInitSidePane() on first evaluation,    -->
      <!-- which registers SprkChat in the side pane launcher.              -->
      <EnableRule Id="sprk.Global.SprkChat.Open.EnableRule">
        <CustomRule Library="$webresource:sprk_openSprkChatPane"
                   FunctionName="Spaarke.SprkChat.enable"
                   Default="true">
        </CustomRule>
      </EnableRule>

    </EnableRules>
  </RuleDefinitions>

  <LocLabels>
    <LocLabel Id="sprk.SprkChat.Button.Label">
      <Titles>
        <Title languagecode="1033" description="SprkChat" />
      </Titles>
    </LocLabel>
    <LocLabel Id="sprk.SprkChat.Button.Alt">
      <Titles>
        <Title languagecode="1033" description="Open SprkChat AI assistant" />
      </Titles>
    </LocLabel>
    <LocLabel Id="sprk.SprkChat.Button.Tooltip">
      <Titles>
        <Title languagecode="1033" description="Open or bring SprkChat AI assistant to focus. If SprkChat is not visible, it will be registered and opened." />
      </Titles>
    </LocLabel>
  </LocLabels>
</RibbonDiffXml>
