<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="Spaarke.Controls" constructor="DocumentRelationshipViewer" version="1.0.33"
           display-name-key="Document Relationship Viewer"
           description-key="Validate bound documentId is GUID — fallback to entity record ID (v1.0.33)"
           control-type="virtual">

    <external-service-usage enabled="true">
      <!-- Domain resolved at runtime from Dataverse environment variable sprk_BffApiBaseUrl -->
      <domain>*.azurewebsites.net</domain>
      <domain>login.microsoftonline.com</domain>
    </external-service-usage>

    <!-- Input: Document ID to find relationships for -->
    <property name="documentId" display-name-key="Document ID" description-key="The GUID of the source document"
              of-type="SingleLine.Text" usage="bound" required="true" />

    <!-- Input: Tenant ID - resolved from Dataverse env var sprk_TenantId at runtime if not set -->
    <property name="tenantId" display-name-key="Tenant ID" description-key="Tenant identifier (resolved from sprk_TenantId env var if empty)"
              of-type="SingleLine.Text" usage="input" required="false" />

    <!-- Input: Client Application ID - resolved from Dataverse env var sprk_MsalClientId at runtime -->
    <property name="clientAppId" display-name-key="Client App ID" description-key="Azure AD Client App ID (resolved from sprk_MsalClientId env var)"
              of-type="SingleLine.Text" usage="input" required="false" />

    <!-- Input: BFF Application ID - resolved from Dataverse env var sprk_BffApiAppId at runtime -->
    <property name="bffAppId" display-name-key="BFF App ID" description-key="BFF App ID for OAuth scope (resolved from sprk_BffApiAppId env var)"
              of-type="SingleLine.Text" usage="input" required="false" />

    <!-- Input: API Base URL - resolved from Dataverse env var sprk_BffApiBaseUrl at runtime if not set -->
    <property name="apiBaseUrl" display-name-key="API Base URL" description-key="BFF API base URL (resolved from sprk_BffApiBaseUrl env var if empty)"
              of-type="SingleLine.Text" usage="input" required="false" />

    <!-- Output: Selected document ID when user clicks a node -->
    <property name="selectedDocumentId" display-name-key="Selected Document" description-key="The document selected by the user"
              of-type="SingleLine.Text" usage="output" />

    <resources>
      <code path="index.ts" order="1"/>
      <!-- Platform-provided libraries (not bundled) -->
      <platform-library name="React" version="16.14.0" />
      <platform-library name="Fluent" version="9.46.2" />
    </resources>

    <feature-usage>
      <uses-feature name="WebAPI" required="true" />
      <uses-feature name="Utility" required="true" />
    </feature-usage>
  </control>
</manifest>
