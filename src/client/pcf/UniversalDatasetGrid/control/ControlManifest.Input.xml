<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="Spaarke.UI.Components"
           constructor="UniversalDatasetGrid"
           version="2.3.1"
           display-name-key="Universal Dataset Grid"
           description-key="Virtual PCF: React/Fluent externalized via platform-library; auth init in React useEffect (v2.3.1)"
           control-type="virtual">

    <external-service-usage enabled="false" />

    <!-- Dataset -->
    <data-set name="dataset" display-name-key="Dataset" />

    <!-- Optional: Configuration JSON -->
    <property name="configJson"
              display-name-key="Configuration JSON"
              description-key="JSON configuration for grid behavior, commands, and SDAP integration"
              of-type="Multiple"
              usage="input"
              required="false" />

    <!-- Calendar Filter JSON (Task 010) -->
    <property name="calendarFilter"
              display-name-key="Calendar Filter"
              description-key="JSON filter from EventCalendarFilter with type (single, range, or clear), date, start, and end properties"
              of-type="SingleLine.Text"
              usage="input"
              required="false" />

    <!-- Selected Event Date (Task 012 - Bi-directional sync) -->
    <property name="selectedEventDate"
              display-name-key="Selected Event Date"
              description-key="ISO date string of the selected row due date. Emitted on row click. Used for calendar highlighting."
              of-type="SingleLine.Text"
              usage="output" />

    <resources>
      <code path="index.ts" order="1" />
      <css path="styles.css" order="2" />
      <platform-library name="React" version="16.14.0" />
      <platform-library name="Fluent" version="9.46.2" />
    </resources>

    <feature-usage>
      <uses-feature name="WebAPI" required="true" />
    </feature-usage>
  </control>
</manifest>
