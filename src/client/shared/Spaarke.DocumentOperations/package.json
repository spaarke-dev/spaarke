{
  "name": "@spaarke/document-operations",
  "version": "0.1.0",
  "description": "Spaarke shared document-operations library — cross-surface hooks for Open-in-Word web/desktop, download, delete, email-link, and send-to-index. Consumed by SemanticSearch and Compose (FR-13 of spaarkeai-compose-r1). React 19, NOT PCF-safe.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "keywords": [
    "spaarke",
    "react",
    "typescript",
    "document-operations",
    "open-in-word",
    "bff-client"
  ],
  "author": "Spaarke Engineering Team",
  "license": "UNLICENSED",
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@spaarke/auth": "file:../Spaarke.Auth"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ts-jest": "^29.4.4",
    "typescript": "^5.3.3"
  }
}
