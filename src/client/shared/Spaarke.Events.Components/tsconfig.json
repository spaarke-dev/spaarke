{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react",
    // Task 114: hoisted source had 7 pre-existing type errors that
    // EventsPage's Vite/esbuild build never enforced. Minimal type-bridge
    // casts (annotated with "Task 114 note") were applied so `strict: true`
    // can pass cleanly. Pre-existing runtime semantics unchanged.
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": ["src"]
}
