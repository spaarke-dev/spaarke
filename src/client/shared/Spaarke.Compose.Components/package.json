    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@fluentui/react-components": "^9.66.10",
    "@fluentui/react-icons": "^2.0.300",
    "eslint": "^9.17.0",
    "jest": "^30.2.0",
