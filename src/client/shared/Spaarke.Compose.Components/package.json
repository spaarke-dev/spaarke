{
  "name": "@spaarke/compose-components",
  "version": "0.2.0",
  "description": "Spaarke shared compose-components library — TipTap-based ComposeWorkspace + ComposeEditor + ComposeToolbar widgets for the spaarkeai-compose-r1 drafting workspace. Mounted by LegalWorkspace section shim (composeEditor.registration.ts) Pattern D / Calendar precedent. React 19, NOT PCF-safe.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "keywords": [
    "spaarke",
    "react",
    "typescript",
    "compose",
    "tiptap",
    "docx",
    "editor"
  ],
  "author": "Spaarke Engineering Team",
  "license": "UNLICENSED",
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@fluentui/react-components": "^9.0.0",
    "@fluentui/react-icons": "^2.0.0"
  },
  "dependencies": {
    "@spaarke/auth": "file:../Spaarke.Auth",
    "@spaarke/document-operations": "file:../Spaarke.DocumentOperations",
    "@spaarke/ai-widgets": "file:../Spaarke.AI.Widgets",
    "@tiptap/core": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "@tiptap/extension-underline": "^2.10.3",
    "@tiptap/extension-link": "^2.10.3",
    "@tiptap/extension-image": "^2.10.3",
    "@tiptap/extension-table": "^2.10.3",
    "@tiptap/extension-table-row": "^2.10.3",
    "@tiptap/extension-table-header": "^2.10.3",
    "@tiptap/extension-table-cell": "^2.10.3",
    "@tiptap/extension-task-list": "^2.10.3",
    "@tiptap/extension-task-item": "^2.10.3",
    "@tiptap/extension-character-count": "^2.10.3",
    "@tiptap/extension-text-align": "^2.10.3",
    "mammoth": "^1.8.0",
    "docx": "^9.0.3"
