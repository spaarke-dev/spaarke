    "@fluentui/react-icons": "^2.0.0",
    "@spaarke/auth": "^2.0.0",
    "@spaarke/ui-components": "*",
    "react": "^16.14.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.14.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@fluentui/react-components": "^9.46.2",
