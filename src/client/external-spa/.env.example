# Copy this file to .env.local and fill in the values for your local environment.
# .env.local is gitignored — never commit real secrets.

# BFF API base URL (Spaarke backend)
VITE_BFF_API_URL=https://spe-api-dev-67e2xz.azurewebsites.net

# Azure AD tenant ID for the Spaarke Azure AD tenant (B2B guest authentication)
VITE_MSAL_TENANT_ID=<spaarke-azure-ad-tenant-id>

# App registration client ID for the external SPA (registered in the Spaarke tenant)
VITE_MSAL_CLIENT_ID=<external-spa-app-registration-client-id>

# BFF API scope for token acquisition (api://{bff-app-registration-id}/user_impersonation)
VITE_BFF_API_SCOPE=api://<bff-app-registration-id>/user_impersonation
