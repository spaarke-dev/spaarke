# Copy this file to .env.local and fill in the values for your local environment.
# .env.local is gitignored — never commit real secrets.
#
# For local development, .env.development provides dev defaults.
# For production, CI/CD token substitution populates .env.production.

# BFF API base URL (Spaarke backend)
VITE_BFF_API_URL=https://your-bff-api.azurewebsites.net

# MSAL / Entra B2B authentication
# SPA app registration (spaarke-external-access-SPA) client ID
VITE_MSAL_CLIENT_ID=your-spa-client-id
# Main Spaarke workforce tenant ID
VITE_MSAL_TENANT_ID=your-tenant-id
# BFF API scope (SDAP-BFF-SPE-API / user_impersonation)
VITE_MSAL_BFF_SCOPE=api://your-bff-app-id/user_impersonation
