{
  "name": "spaarke-ai",
  "version": "0.1.0",
  "private": true,
  "description": "SpaarkeAi standalone Code Page — three-pane AI workspace hosted as web resource sprk_spaarkeai",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "node ../../../scripts/tsc-surface-gate.mjs",
    "build": "node ../../../scripts/tsc-surface-gate.mjs && vite build && node --input-type=module -e \"import{renameSync}from'fs';renameSync('dist/index.html','dist/spaarkeai.html');\"",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "jest"
  },
