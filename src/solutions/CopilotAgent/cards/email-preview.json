{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "📧 Draft Email",
      "weight": "Bolder",
      "size": "Medium"
    },
    {
      "type": "FactSet",
      "facts": [
        { "title": "To", "value": "${recipientEmail} (${recipientRole})" },
        { "title": "Subject", "value": "${subject}" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "${body}",
      "wrap": true,
      "spacing": "Medium",
      "size": "Small"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "📤 Send",
      "data": { "action": "send_email", "communicationId": "${communicationId}" }
    },
    {
      "type": "Action.Submit",
      "title": "✏️ Edit Draft",
      "data": { "action": "edit_email", "communicationId": "${communicationId}" }
    },
    {
      "type": "Action.Submit",
      "title": "✕ Cancel",
      "data": { "action": "cancel_email", "communicationId": "${communicationId}" }
    }
  ]
}
