{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Something went wrong",
      "weight": "Bolder",
      "size": "Medium",
      "color": "Attention"
    },
    {
      "type": "TextBlock",
      "text": "${errorMessage}",
      "wrap": true,
      "size": "Small"
    },
    {
      "type": "TextBlock",
      "text": "Correlation ID: ${correlationId}",
      "isSubtle": true,
      "size": "Small",
      "spacing": "Medium"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Try Again",
      "data": { "action": "retry", "originalAction": "${originalAction}" }
    }
  ]
}
