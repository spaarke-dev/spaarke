{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "${matterName}",
      "weight": "Bolder",
      "size": "Medium"
    },
    {
      "type": "FactSet",
      "facts": [
        { "title": "Status", "value": "${status}" },
        { "title": "Type", "value": "${matterType}" },
        { "title": "Open Tasks", "value": "${openTaskCount}" },
        { "title": "Documents", "value": "${documentCount}" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Summary",
      "weight": "Bolder",
      "spacing": "Medium"
    },
    {
      "type": "TextBlock",
      "text": "${summary}",
      "wrap": true,
      "size": "Small"
    },
    {
      "type": "TextBlock",
      "text": "Recent Activity",
      "weight": "Bolder",
      "spacing": "Medium"
    },
    {
      "type": "Container",
      "$data": "${recentActivity}",
      "items": [
        {
          "type": "TextBlock",
          "text": "• ${description} (${date})",
          "wrap": true,
          "size": "Small"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "View Documents",
      "data": { "action": "list_matter_documents", "matterId": "${matterId}" }
    },
    {
      "type": "Action.Submit",
      "title": "View Tasks",
      "data": { "action": "list_matter_tasks", "matterId": "${matterId}" }
    }
  ]
}
