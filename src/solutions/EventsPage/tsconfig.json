{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@spaarke/events-components": ["../../client/shared/Spaarke.Events.Components/src/index.ts"],
      "@spaarke/events-components/*": ["../../client/shared/Spaarke.Events.Components/src/*"],
      "@spaarke/ui-components": ["../../client/shared/Spaarke.UI.Components/src/index.ts"],
      "@spaarke/ui-components/*": ["../../client/shared/Spaarke.UI.Components/src/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
