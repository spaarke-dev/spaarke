                          ],
                          "prefixMatch": [
                            "test-documents/"
                          ]
                        },
                        "actions": {
                          "baseBlob": {
                            "delete": {
                              "daysAfterCreationGreaterThan": 1
                            }
                          }
                        }
                      }
