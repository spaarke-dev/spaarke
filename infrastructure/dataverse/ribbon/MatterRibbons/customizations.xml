          <LocLabel Id="sprk.Wizard.FindSimilar.Label">
            <Titles>
              <Title languagecode="1033" description="Find Similar" />
            </Titles>
          </LocLabel>
          <LocLabel Id="sprk.Wizard.FindSimilar.ToolTipTitle">
