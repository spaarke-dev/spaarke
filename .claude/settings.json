{
  "$schema": "https://code.claude.com/schemas/settings.json",
  "model": "opus",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "command": "bash scripts/quality/post-edit-lint.sh"
      }
    ],
    "TaskCompleted": [
      {
        "command": "bash scripts/quality/task-quality-gate.sh"
      }
    ]
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Skill(*)",
      "Task(*)",
      "Bash",
      "Read(//c/code_files/spaarke-wt-ai-document-relationship-visuals/src/client/shared/Spaarke.UI.Components/**)",
      "Bash(xargs -I {} basename {})",
      "Read(//c/code_files/spaarke-wt-sdap-file-upload-document-r2/**)",
      "Bash(npm ls d3-force)"
    ]
  }
}
